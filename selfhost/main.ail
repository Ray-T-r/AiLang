// selfhost/main.ail — the AiLang bootstrap compiler, written in AiLang.  (v2)
//
// The whole pipeline, self-hosted:
//   .ail source  →  lex  →  parse (recursive AST)  →  C codegen  →  clang  →  binary
//
// Usage:
//   ailangc compile selfhost/main.ail -o /tmp/ailc0     # build the bootstrap compiler
//   /tmp/ailc0 <input.ail> <output-binary>              # compile an .ail to native code
//
// v2 source subset:
//   - `fn name(p1, p2, ...) { stmts }`     function declarations (all i64)
//   - `rt <expr>`                          return
//   - `name := <expr>`                     integer variable binding
//   - `if <expr> <stmt>`  /  `if <expr> { stmts }`   conditional (no else yet)
//   - `lp <expr> { stmts }`                while-loop
//   - `println(<expr>)`                    print an integer
//   - calls `name(args)`, identifiers, int literals
//   - operators: + - * /  and  < > <= >= == !=  with precedence
//   - top-level statements form an implicit main()
//
// Enough to compile a recursive fib(). The AST uses an `en Stmt` + `[Stmt]`
// bodies + a `Func` struct holding `[Stmt]` — the nested-aggregate data model
// that recursive ADTs + arrays-of-aggregates make expressible.

// ===== token kinds + Token ==================================================
fn TK_EOF() -> i64    { 0 }
fn TK_INT() -> i64    { 1 }
fn TK_IDENT() -> i64  { 2 }
fn TK_PLUS() -> i64   { 3 }
fn TK_MINUS() -> i64  { 4 }
fn TK_STAR() -> i64   { 5 }
fn TK_SLASH() -> i64  { 6 }
fn TK_LPAREN() -> i64 { 7 }
fn TK_RPAREN() -> i64 { 8 }
fn TK_LBRACE() -> i64 { 9 }
fn TK_RBRACE() -> i64 { 10 }
fn TK_COMMA() -> i64  { 11 }
fn TK_WALRUS() -> i64 { 12 }   // :=
fn TK_LT() -> i64     { 13 }   // <
fn TK_GT() -> i64     { 14 }   // >
fn TK_LE() -> i64     { 15 }   // <=
fn TK_GE() -> i64     { 16 }   // >=
fn TK_EQ() -> i64     { 17 }   // ==
fn TK_NE() -> i64     { 18 }   // !=
fn TK_ASSIGN() -> i64 { 19 }   // =
fn TK_AND() -> i64    { 20 }   // &&
fn TK_OR() -> i64     { 21 }   // ||
fn TK_NOT() -> i64    { 22 }   // !
fn TK_STR() -> i64    { 23 }   // "string literal" (text = inner content)
fn TK_PERCENT() -> i64 { 24 }  // %
fn TK_DOT() -> i64    { 25 }   // .
fn TK_SEMI() -> i64   { 26 }   // ;
fn TK_COLON() -> i64  { 27 }   // :
fn TK_LBRACK() -> i64 { 28 }   // [
fn TK_RBRACK() -> i64 { 29 }   // ]
fn TK_AMP() -> i64    { 30 }   // &  (address-of)
fn TK_QUEST() -> i64  { 32 }   // ?  (try / error propagation)
fn TK_FLOAT() -> i64  { 33 }   // 3.14  (f64 literal)
fn TK_DOTDOT() -> i64 { 34 }   // ..  (range, as in `lp i in lo..hi`)
fn TK_LTLT() -> i64   { 35 }   // <<  (shift left)
fn TK_GTGT() -> i64   { 36 }   // >>  (shift right)
fn TK_CARET() -> i64  { 37 }   // ^   (bitwise xor)
fn TK_PIPE() -> i64   { 38 }   // |   (bitwise or; `||` is TK_OR)
fn TK_PIPEGT() -> i64 { 39 }   // |>  (pipe-forward)
fn TK_CHAR() -> i64   { 40 }   // 'a' (char literal → i64 code)
fn TK_CONCAT() -> i64 { 41 }   // ++  (string concat)
fn TK_QQ() -> i64     { 42 }   // ??  (nil-coalesce; `?` is TK_QUEST)
fn TK_ERR() -> i64    { 31 }

st Token { kind: i64; text: str; pos: i64 }

fn is_digit(c:i64) -> bool { c >= 48 && c <= 57 }
fn is_alpha(c:i64) -> bool {
  (c >= 97 && c <= 122) || (c >= 65 && c <= 90) || c == 95
}
fn is_space(c:i64) -> bool { c == 32 || c == 9 || c == 10 || c == 13 }

// ===== lexer ================================================================
fn lex(src:str) -> [Token] {
  mu toks:[Token] := []
  mu i := 0
  lp i < len(src) {
    c := src[i]
    if is_space(c) { i += 1; ct }

    // line comment `// ...`
    if c == 47 && i + 1 < len(src) && src[i + 1] == 47 {
      lp i < len(src) { if src[i] == 10 { br } i += 1 }
      ct
    }

    // block comment `/* ... */`  (42 = '*'); unterminated runs to EOF
    if c == 47 && i + 1 < len(src) && src[i + 1] == 42 {
      i += 2
      lp i + 1 < len(src) { if src[i] == 42 && src[i + 1] == 47 { br } i += 1 }
      i += 2
      ct
    }

    // string literal "..."  — text is the inner content with escapes kept raw
    // (a `\` escapes the next byte, so `\"` stays inside the string).
    if c == 34 {                 // opening "
      mu j := i + 1
      lp j < len(src) {
        d := src[j]
        if d == 92 { j += 2; ct }   // backslash: skip the escaped byte
        if d == 34 { br }           // closing "
        j += 1
      }
      toks = push(toks, Token(TK_STR(), substring(src, i + 1, j), i))
      i = j + 1                   // past closing "
      ct
    }

    // char literal '…' — text is the inner content; parser decodes to an i64 code
    if c == 39 {                 // opening '
      mu j := i + 1
      lp j < len(src) {
        d := src[j]
        if d == 92 { j += 2; ct }   // backslash: skip the escaped byte
        if d == 39 { br }           // closing '
        j += 1
      }
      toks = push(toks, Token(TK_CHAR(), substring(src, i + 1, j), i))
      i = j + 1
      ct
    }

    // two-char operators
    if c == 58 && i + 1 < len(src) && src[i + 1] == 61 {   // :=
      toks = push(toks, Token(TK_WALRUS(), ":=", i)); i += 2; ct
    }
    if c == 60 && i + 1 < len(src) && src[i + 1] == 61 {   // <=
      toks = push(toks, Token(TK_LE(), "<=", i)); i += 2; ct
    }
    if c == 62 && i + 1 < len(src) && src[i + 1] == 61 {   // >=
      toks = push(toks, Token(TK_GE(), ">=", i)); i += 2; ct
    }
    if c == 61 && i + 1 < len(src) && src[i + 1] == 61 {   // ==
      toks = push(toks, Token(TK_EQ(), "==", i)); i += 2; ct
    }
    if c == 33 && i + 1 < len(src) && src[i + 1] == 61 {   // !=
      toks = push(toks, Token(TK_NE(), "!=", i)); i += 2; ct
    }
    if c == 38 && i + 1 < len(src) && src[i + 1] == 38 {   // &&
      toks = push(toks, Token(TK_AND(), "&&", i)); i += 2; ct
    }
    if c == 124 && i + 1 < len(src) && src[i + 1] == 124 { // ||
      toks = push(toks, Token(TK_OR(), "||", i)); i += 2; ct
    }
    if c == 46 && i + 1 < len(src) && src[i + 1] == 46 {   // ..  (range)
      toks = push(toks, Token(TK_DOTDOT(), "..", i)); i += 2; ct
    }
    if c == 60 && i + 1 < len(src) && src[i + 1] == 60 {   // <<
      toks = push(toks, Token(TK_LTLT(), "<<", i)); i += 2; ct
    }
    if c == 62 && i + 1 < len(src) && src[i + 1] == 62 {   // >>
      toks = push(toks, Token(TK_GTGT(), ">>", i)); i += 2; ct
    }
    if c == 124 && i + 1 < len(src) && src[i + 1] == 62 {  // |>
      toks = push(toks, Token(TK_PIPEGT(), "|>", i)); i += 2; ct
    }
    if c == 43 && i + 1 < len(src) && src[i + 1] == 43 {   // ++
      toks = push(toks, Token(TK_CONCAT(), "++", i)); i += 2; ct
    }
    if c == 63 && i + 1 < len(src) && src[i + 1] == 63 {   // ??  (must precede bare `?`)
      toks = push(toks, Token(TK_QQ(), "??", i)); i += 2; ct
    }

    if is_digit(c) {
      mu j := i
      lp j < len(src) { if is_digit(src[j]) == false { br } j += 1 }
      // a '.' between digits is a decimal point → f64 literal (not field access)
      if j + 1 < len(src) && src[j] == 46 && is_digit(src[j + 1]) {
        j += 1                          // consume '.'
        lp j < len(src) { if is_digit(src[j]) == false { br } j += 1 }
        toks = push(toks, Token(TK_FLOAT(), substring(src, i, j), i)); i = j; ct
      }
      // typed-int suffix like `0_i64`/`42_i32` — a usage hint; str_to_int reads
      // the leading digits and ignores the rest, so just absorb it into the token.
      if j < len(src) && src[j] == 95 {   // '_'
        j += 1
        lp j < len(src) { dd := src[j]; if is_alpha(dd) == false && is_digit(dd) == false { br } j += 1 }
      }
      toks = push(toks, Token(TK_INT(), substring(src, i, j), i)); i = j; ct
    }

    if is_alpha(c) {
      mu j := i
      lp j < len(src) {
        d := src[j]
        if is_alpha(d) == false && is_digit(d) == false { br }
        j += 1
      }
      toks = push(toks, Token(TK_IDENT(), substring(src, i, j), i)); i = j; ct
    }

    // single-char tokens
    k := TK_ERR()
    if c == 43 { k = TK_PLUS() }
    if c == 45 { k = TK_MINUS() }
    if c == 42 { k = TK_STAR() }
    if c == 47 { k = TK_SLASH() }
    if c == 37 { k = TK_PERCENT() }
    if c == 46 { k = TK_DOT() }          // .
    if c == 59 { k = TK_SEMI() }         // ;
    if c == 58 { k = TK_COLON() }        // : (the `:=` two-char case ran earlier)
    if c == 91 { k = TK_LBRACK() }       // [
    if c == 93 { k = TK_RBRACK() }       // ]
    if c == 40 { k = TK_LPAREN() }
    if c == 41 { k = TK_RPAREN() }
    if c == 123 { k = TK_LBRACE() }
    if c == 125 { k = TK_RBRACE() }
    if c == 44 { k = TK_COMMA() }
    if c == 60 { k = TK_LT() }
    if c == 62 { k = TK_GT() }
    if c == 61 { k = TK_ASSIGN() }       // bare `=` (the `==`/`:=` cases ran earlier)
    if c == 33 { k = TK_NOT() }          // bare `!` (the `!=` case ran earlier)
    if c == 38 { k = TK_AMP() }          // bare `&` (the `&&` case ran earlier)
    if c == 94 { k = TK_CARET() }        // ^
    if c == 124 { k = TK_PIPE() }        // bare `|` (the `||`/`|>` cases ran earlier)
    if c == 63 { k = TK_QUEST() }        // ?  (error propagation)
    toks = push(toks, Token(k, substring(src, i, i + 1), i)); i += 1
  }
  toks = push(toks, Token(TK_EOF(), "", i))
  toks
}

// ===== AST ==================================================================
// Operator tags (small ints) used by both codegen and precedence.
fn OP_ADD() -> i64 { 1 }
fn OP_SUB() -> i64 { 2 }
fn OP_MUL() -> i64 { 3 }
fn OP_DIV() -> i64 { 4 }
fn OP_MOD() -> i64 { 14 }
fn OP_LT() -> i64  { 5 }
fn OP_GT() -> i64  { 6 }
fn OP_LE() -> i64  { 7 }
fn OP_GE() -> i64  { 8 }
fn OP_EQ() -> i64  { 9 }
fn OP_NE() -> i64  { 10 }
fn OP_AND() -> i64 { 11 }
fn OP_OR() -> i64  { 12 }
fn OP_NOT() -> i64 { 13 }   // unary
fn OP_SHL() -> i64  { 15 }   // <<
fn OP_SHR() -> i64  { 16 }   // >>
fn OP_BAND() -> i64 { 17 }   // &  (infix bitwise and)
fn OP_BXOR() -> i64 { 18 }   // ^
fn OP_BOR() -> i64  { 19 }   // |
fn OP_CAT() -> i64  { 20 }   // ++ (string concat)
fn OP_QQ() -> i64   { 21 }   // ?? (nil-coalesce / map get-or-default)

en Expr {
  Num(v:i64),
  Flt(s:str),                    // f64 literal — kept as text, emitted verbatim
  Str(s:str),                    // string literal (inner content, escapes raw)
  Var(name:str),
  Bin(op:i64, l:Expr, r:Expr),
  Unary(op:i64, e:Expr),
  Call(fname:str, args:[Expr]),
  Field(obj:Expr, fname:str),    // obj.fname  — struct field access
  Index(obj:Expr, idx:Expr),     // obj[idx]   — array indexing
  Array(elems:[Expr], ety:str),  // [a, b, …]  — array literal (ety = annotated elem type, "" if inferred)
  MapLit(mty:str, keys:[Expr], vals:[Expr]),   // {} or {k:v, …}; mty = annotation ("" if bare)
  Addr(e:Expr),                  // &x         — address-of
  // mt scrut { Variant(b…) => body; … } — arms as parallel arrays (avoids a
  // `MArm` struct that would hold `Expr` by value and close a by-value cycle
  // `Expr→MArm→Expr`; `[Expr]` bodies are heap-backed, breaking it). `vbinds[i]`
  // is the i-th arm's ";"-joined binding names ("" for none).
  Match(scrut:Expr, vnames:[str], vbinds:[str], bodies:[Expr]),
  IfE(cond:Expr, then:Expr, els:Expr),   // if c { e } el { e } as an expression
  Try(e:Expr),                           // e?  — propagate err to the enclosing fn
  Lambda(params:[str], ptypes:[str], body:Expr, lamid:i64),   // fn(a:T,b) expr — HOF arg (inlined) OR first-class closure value (lifted); ptypes parallel to params ("i64" if unannotated); lamid = parse-time token pos, names the lifted __lam_<id>/__env_<id>
  Tuple(elems:[Expr]),                   // (a, b, …) — tuple literal, for multi-return
  BlockE(body:[Stmt]),                   // { s1; s2; …; tail } as a value — last stmt's expr is the value
  Bad,
}

// A user struct: `st Name { f1:T1; f2:T2 }`. Field names and their type names
// are kept in parallel arrays (a struct has no nested aggregate yet, so [str]
// suffices). Type names are "i64" / "str" / another struct name.
st StructDef { name:str; fnames:[str]; ftypes:[str] }

// A user enum `en Name { V0, V1(f:T,…), … }`. For each variant we keep its name
// and its field types as parallel arrays (`vnames[i]` ↔ `vftypes[i]` where the
// latter is a ";"-joined list of field type names, "" for a unit variant). The
// field *names* aren't needed (match binds positionally), only the count+types.
st EnumDef { name:str; vnames:[str]; vftypes:[str] }

en Stmt {
  SDecl(name:str, e:Expr),       // name := expr  (or  mu name := expr)  — declares
  SDestructure(names:[str], e:Expr),  // a, b := expr — destructure a tuple ("_" slot ignores)
  SAssign(name:str, e:Expr),     // name = expr   — reassigns an existing binding
  SIdxAssign(obj:Expr, idx:Expr, e:Expr),  // obj[idx] = expr
  SFieldAssign(obj:Expr, fname:str, e:Expr), // obj.field = expr
  SReturn(e:Expr),               // rt expr
  SPrint(e:Expr),                // println(expr)
  SIf(cond:Expr, body:[Stmt], else_b:[Stmt]),   // if cond {body} [el {else_b}]
  SLoop(cond:Expr, body:[Stmt]),                // lp cond { body }
  SLoopIn(vnm:str, coll:Expr, body:[Stmt]),     // lp x in coll { body }
  SLoopKV(kn:str, vn:str, coll:Expr, body:[Stmt]),  // lp (k, v) in map { body }
  SLoopRange(vnm:str, lo:Expr, hi:Expr, body:[Stmt]),  // lp i in lo..hi { body }
  SBreak,                        // br  — break out of the enclosing loop
  SContinue,                     // ct  — continue the enclosing loop
  SExpr(e:Expr),                 // bare expression statement
}

st Func { name:str; params:[str]; ptypes:[str]; ret:str; lib:str; tparams:[str]; body:[Stmt] }

// ===== parser state =========================================================
st P { toks: [Token]; pos: i64; src: str }
st Binds { names:[str]; vals:[Expr] }   // match-arm bindings: name → matched scrutinee component
fn cur(p:*P) -> Token { p.toks[p.pos] }
fn ckind(p:*P) -> i64 { p.toks[p.pos].kind }
fn ctext(p:*P) -> str { p.toks[p.pos].text }
fn adv(p:*P) { p.pos = p.pos + 1 }
// ----- diagnostics: report a source-located error with a caret, then exit ----
fn tok_name(k:i64) -> str {
  if k == TK_RPAREN() rt "')'"
  if k == TK_RBRACE() rt "'}'"
  if k == TK_RBRACK() rt "']'"
  if k == TK_LPAREN() rt "'('"
  if k == TK_LBRACE() rt "'{'"
  if k == TK_COLON() rt "':'"
  if k == TK_COMMA() rt "','"
  if k == TK_WALRUS() rt "':='"
  if k == TK_ASSIGN() rt "'='"
  if k == TK_GT() rt "'>'"
  "the expected token"
}
fn report_at(src:str, pos:i64, msg:str) {
  mu line := 1
  mu lstart := 0
  mu i := 0
  lp i < pos && i < len(src) {
    if src[i] == 10 { line = line + 1; lstart = i + 1 }
    i += 1
  }
  mu lend := lstart
  lp lend < len(src) { if src[lend] == 10 { br } lend += 1 }
  println("error " + int_to_str(line) + ":" + int_to_str(pos - lstart + 1) + ": " + msg)
  println("  " + substring(src, lstart, lend))
  mu caret := "  "
  mu k := lstart
  lp k < pos { caret = caret + " "; k += 1 }
  println(caret + "^")
  exit(1)
}
fn eat(p:*P, k:i64) {
  if ckind(p) == k { adv(p) }
  el { report_at(p.src, p.toks[p.pos].pos, "expected " + tok_name(k) + ", got '" + ctext(p) + "'") }
}

// ----- expressions ----------------------------------------------------------
// Precedence, loosest → tightest:
//   or  <  and  <  cmp  <  add  <  mul  <  unary(!)  <  factor
fn cmp_op(k:i64) -> i64 {
  if k == TK_LT() rt OP_LT()
  if k == TK_GT() rt OP_GT()
  if k == TK_LE() rt OP_LE()
  if k == TK_GE() rt OP_GE()
  if k == TK_EQ() rt OP_EQ()
  if k == TK_NE() rt OP_NE()
  0
}

fn parse_expr(p:*P) -> Expr { parse_coalesce(p) }

// `a ?? b` — nil-coalesce, the loosest binary level. For a map index
// `m[k] ?? d` it yields m[k] when key k is present, else the default d
// (see gen_qq). Left-assoc; a single `??` is all the subset needs.
fn parse_coalesce(p:*P) -> Expr {
  mu left := parse_pipe(p)
  lp ckind(p) == TK_QQ() { adv(p); left = Bin(OP_QQ(), left, parse_pipe(p)) }
  left
}

// `a |> f` / `a |> f(b)` → f(a) / f(a, b): pipe the lhs in as the first argument.
fn prepend_arg(x:Expr, xs:[Expr]) -> [Expr] {
  mu out:[Expr] := [x]
  mu i := 0
  lp i < len(xs) { out = push(out, xs[i]); i += 1 }
  out
}
fn pipe_call(lhs:Expr, rhs:Expr) -> Expr {
  mt rhs {
    Var(n)             => Call(n, [lhs]);
    Call(f, a)         => Call(f, prepend_arg(lhs, a));
    Tuple(tes)         => rhs;
    BlockE(bb)         => rhs;
    Num(v)             => rhs;
    Flt(fs)            => rhs;
    Str(s)             => rhs;
    Bin(o,x,y)         => rhs;
    Unary(o,x)         => rhs;
    Field(o,f)         => rhs;
    Index(o,ix)        => rhs;
    Array(es,et)       => rhs;
    MapLit(ml,mks,mvs) => rhs;
    Addr(x)            => rhs;
    Match(sc,vn,vb,bd) => rhs;
    IfE(c,t,el2)       => rhs;
    Try(e2)            => rhs;
    Lambda(ps,pts,b,id)    => rhs;
    Bad                => rhs;
  }
}
fn parse_pipe(p:*P) -> Expr {
  mu left := parse_or(p)
  lp ckind(p) == TK_PIPEGT() { adv(p); left = pipe_call(left, parse_or(p)) }
  left
}

fn parse_or(p:*P) -> Expr {
  mu left := parse_and(p)
  lp ckind(p) == TK_OR() { adv(p); left = Bin(OP_OR(), left, parse_and(p)) }
  left
}

fn parse_and(p:*P) -> Expr {
  mu left := parse_bitor(p)
  lp ckind(p) == TK_AND() { adv(p); left = Bin(OP_AND(), left, parse_bitor(p)) }
  left
}
// Bitwise levels (C precedence: | looser than ^ looser than &, all above cmp).
// Infix `&` lives here; prefix address-of `&` is consumed by parse_unary when it
// starts an operand, so the two never collide.
fn parse_bitor(p:*P) -> Expr {
  mu left := parse_bitxor(p)
  lp ckind(p) == TK_PIPE() { adv(p); left = Bin(OP_BOR(), left, parse_bitxor(p)) }
  left
}
fn parse_bitxor(p:*P) -> Expr {
  mu left := parse_bitand(p)
  lp ckind(p) == TK_CARET() { adv(p); left = Bin(OP_BXOR(), left, parse_bitand(p)) }
  left
}
fn parse_bitand(p:*P) -> Expr {
  mu left := parse_cmp(p)
  lp ckind(p) == TK_AMP() { adv(p); left = Bin(OP_BAND(), left, parse_cmp(p)) }
  left
}

fn parse_cmp(p:*P) -> Expr {
  mu left := parse_shift(p)
  o := cmp_op(ckind(p))
  if o != 0 {
    adv(p)
    left = Bin(o, left, parse_shift(p))
  }
  left
}
fn parse_shift(p:*P) -> Expr {
  mu left := parse_add(p)
  lp true {
    k := ckind(p)
    if k == TK_LTLT() { adv(p); left = Bin(OP_SHL(), left, parse_add(p)) }
    el if k == TK_GTGT() { adv(p); left = Bin(OP_SHR(), left, parse_add(p)) }
    el { br }
  }
  left
}

fn parse_add(p:*P) -> Expr {
  mu left := parse_mul(p)
  lp true {
    k := ckind(p)
    if k == TK_PLUS() { adv(p); left = Bin(OP_ADD(), left, parse_mul(p)) }
    el if k == TK_MINUS() { adv(p); left = Bin(OP_SUB(), left, parse_mul(p)) }
    el if k == TK_CONCAT() { adv(p); left = Bin(OP_CAT(), left, parse_mul(p)) }
    el { br }
  }
  left
}

fn parse_mul(p:*P) -> Expr {
  mu left := parse_unary(p)
  lp true {
    k := ckind(p)
    if k == TK_STAR() { adv(p); left = Bin(OP_MUL(), left, parse_unary(p)) }
    el if k == TK_SLASH() { adv(p); left = Bin(OP_DIV(), left, parse_unary(p)) }
    el if k == TK_PERCENT() { adv(p); left = Bin(OP_MOD(), left, parse_unary(p)) }
    el { br }
  }
  left
}

fn parse_unary(p:*P) -> Expr {
  if ckind(p) == TK_NOT() { adv(p); rt Unary(OP_NOT(), parse_unary(p)) }
  if ckind(p) == TK_MINUS() { adv(p); rt Bin(OP_SUB(), Num(0), parse_unary(p)) }
  if ckind(p) == TK_AMP() { adv(p); rt Addr(parse_unary(p)) }
  parse_factor(p)
}

// factor := primary ('.' IDENT ('(' args ')')? | '[' index ']')*
// `.field`/`[index]` postfixes chain left to right; `.name(args)` is a UFCS
// method call that desugars at parse time to `name(receiver, args)` — the `(`
// disambiguates it from a plain field access, so no struct-registry lookup is
// needed. Bare `.cstr` is the one property-form sugar (str passthrough).
fn parse_factor(p:*P) -> Expr {
  mu e := parse_primary(p)
  lp ckind(p) == TK_DOT() || ckind(p) == TK_LBRACK() {
    if ckind(p) == TK_DOT() {
      adv(p)                            // .
      fname := ctext(p)
      adv(p)                            // field / method name
      if ckind(p) == TK_LPAREN() {      // UFCS method call: `e.f(args)` → `f(e, args)`
        adv(p)                          // (
        mu margs:[Expr] := [e]          // receiver becomes the first argument
        lp ckind(p) != TK_RPAREN() && ckind(p) != TK_EOF() {
          margs = push(margs, parse_expr(p))
          if ckind(p) == TK_COMMA() { adv(p) }
        }
        eat(p, TK_RPAREN())             // )
        e = Call(fname, margs)
      } el if fname == "cstr" {         // bare `.cstr` property → `cstr(e)`
        e = Call("cstr", [e])
      } el {
        e = Field(e, fname)
      }
    } el {
      adv(p)                            // [
      idx := parse_expr(p)
      eat(p, TK_RBRACK())               // ]
      e = Index(e, idx)
    }
  }
  // `e?` — error propagation (postfix, binds tighter than binary operators).
  if ckind(p) == TK_QUEST() { adv(p); rt Try(e) }
  e
}

// Parse `{ expr }` — a brace-wrapped single expression (an `if`-expression
// branch). The subset's value-position branches are always one expression.
fn parse_brace_expr(p:*P) -> Expr {
  eat(p, TK_LBRACE())
  e := parse_expr(p)
  eat(p, TK_RBRACE())
  e
}

// Does a string literal's content contain a `${` interpolation hole?
fn str_has_interp(s:str) -> bool {
  mu i := 0
  lp i + 1 < len(s) {
    if s[i] == 36 && s[i + 1] == 123 { rt true }   // '$' '{'
    i += 1
  }
  false
}

// Desugar an interpolated string `"a${e}b"` into a `+`-chain of literal chunks
// and `to_str(e)` holes: `"a" + to_str(e) + "b"`. Each hole's source is lexed +
// parsed as a fresh expression; `to_str` stringifies (str → itself, i64 → i2s).
fn parse_interp(s:str) -> Expr {
  mu parts:[Expr] := []
  mu i := 0
  mu start := 0
  lp i < len(s) {
    if i + 1 < len(s) && s[i] == 36 && s[i + 1] == 123 {   // ${
      if i > start { parts = push(parts, Str(substring(s, start, i))) }
      mu depth := 1
      mu j := i + 2
      lp j < len(s) {
        d := s[j]
        if d == 123 { depth += 1 }
        if d == 125 { depth = depth - 1; if depth == 0 { br } }
        j += 1
      }
      esrc := substring(s, i + 2, j)
      etoks := lex(esrc)
      mu ep := P(etoks, 0, esrc)
      mu hole:[Expr] := []
      hole = push(hole, parse_expr(&ep))
      if ckind(&ep) == TK_EOF() {
        parts = push(parts, Call("to_str", hole))        // a clean single expr → stringify
      } el {
        // leftover tokens → not an expression; keep it literal. Build the prefix
        // as "$"+"{" so this very source line doesn't self-interpolate.
        parts = push(parts, Str("$" + "{" + esrc + "}"))
      }
      i = j + 1
      start = i
    } el {
      i += 1
    }
  }
  if len(s) > start { parts = push(parts, Str(substring(s, start, len(s)))) }
  if len(parts) == 0 rt Str("")
  mu r := parts[0]
  mu k := 1
  lp k < len(parts) { r = Bin(OP_ADD(), r, parts[k]); k += 1 }
  r
}

// Decode a char-literal's inner text to its i64 code: 'A'→65, '\n'→10, etc.
fn char_code(s:str) -> i64 {
  if len(s) == 0 rt 0
  if s[0] == 92 {                  // backslash escape
    if len(s) < 2 rt 92
    c := s[1]
    if c == 110 rt 10              // \n
    if c == 116 rt 9               // \t
    if c == 114 rt 13              // \r
    if c == 48 rt 0                // \0
    if c == 92 rt 92               // \\
    if c == 39 rt 39               // \'
    rt c
  }
  s[0]
}
// ----- match desugar: literal/wildcard/tuple patterns → an `if`/`el` chain.
// No Match AST / gen_match change — `mt x { 0=>a; _=>b }` becomes `if x==0 {a}
// el {b}`, and `mt (e0,e1) { (p0,p1)=>… }` ANDs each component equality. Variant
// patterns keep the existing Match path. Tuple scrutinee components are re-
// evaluated per arm (fine for pure exprs, which is all the examples use).
fn is_bad(e:Expr) -> bool {
  mt e {
    Bad                => true;
    Tuple(tes)         => false;
    BlockE(bb)         => false;
    Num(v)             => false;
    Flt(fs)            => false;
    Str(s)             => false;
    Var(n)             => false;
    Bin(o,a,b)         => false;
    Unary(o,x)         => false;
    Call(f,a)          => false;
    Field(o,f)         => false;
    Index(o,ix)        => false;
    Array(es,et)       => false;
    MapLit(ml,mks,mvs) => false;
    Addr(x)            => false;
    Match(sc,vn,vb,bd) => false;
    IfE(c,t,el2)       => false;
    Try(e2)            => false;
    Lambda(ps,pts,b,id)    => false;
  }
}
// Substitute Var(nm) → repl throughout an expression — used to bind a match
// pattern variable to its scrutinee component (`(0, x) => …x…` rewrites x).
fn is_lower_ident(s:str) -> bool {
  if len(s) == 0 rt false
  c := s[0]
  c >= 97 && c <= 122
}
fn subst_var_hit(n:str, nm:str, repl:Expr, orig:Expr) -> Expr {
  if n == nm rt repl
  orig
}
fn subst_args(es:[Expr], nm:str, repl:Expr) -> [Expr] {
  mu out:[Expr] := []
  mu i := 0
  lp i < len(es) { out = push(out, subst_var(es[i], nm, repl)); i += 1 }
  out
}
fn subst_var(e:Expr, nm:str, repl:Expr) -> Expr {
  mt e {
    Var(n)             => subst_var_hit(n, nm, repl, e);
    Tuple(tes)         => Tuple(subst_args(tes,nm,repl));
    BlockE(bb)         => e;
    Bin(o,a,b)         => Bin(o, subst_var(a,nm,repl), subst_var(b,nm,repl));
    Unary(o,x)         => Unary(o, subst_var(x,nm,repl));
    Call(f,ar)         => Call(f, subst_args(ar,nm,repl));
    Field(o,f)         => Field(subst_var(o,nm,repl), f);
    Index(o,ix)        => Index(subst_var(o,nm,repl), subst_var(ix,nm,repl));
    Array(es,et)       => Array(subst_args(es,nm,repl), et);
    MapLit(ml,ks,vs)   => MapLit(ml, subst_args(ks,nm,repl), subst_args(vs,nm,repl));
    Addr(x)            => Addr(subst_var(x,nm,repl));
    Match(sc,vn,vb,bd) => Match(subst_var(sc,nm,repl), vn, vb, subst_args(bd,nm,repl));
    IfE(c,t,el2)       => IfE(subst_var(c,nm,repl), subst_var(t,nm,repl), subst_var(el2,nm,repl));
    Try(x)             => Try(subst_var(x,nm,repl));
    Lambda(ps,pts,b,id)    => Lambda(ps, pts, subst_var(b,nm,repl), id);
    Num(v)             => e;
    Flt(fs)            => e;
    Str(s)             => e;
    Bad                => e;
  }
}
fn parse_arm_cond(p:*P, scruts:[Expr], is_tuple:bool, bnd:*Binds) -> Expr {
  if is_tuple {
    if ckind(p) == TK_LPAREN() {
      adv(p)
      mu cond := Bad
      mu j := 0
      lp ckind(p) != TK_RPAREN() && ckind(p) != TK_EOF() {
        if ckind(p) == TK_IDENT() && ctext(p) == "_" { adv(p) }
        el if ckind(p) == TK_IDENT() && is_lower_ident(ctext(p)) && ctext(p) != "true" && ctext(p) != "false" {
          // a lowercase ident → binding: no condition, bind it to this component
          if j < len(scruts) { bnd.names = push(bnd.names, ctext(p)); bnd.vals = push(bnd.vals, scruts[j]) }
          adv(p)
        }
        el {
          if j >= len(scruts) { report_at(p.src, p.toks[p.pos].pos, "match arm has more components than the tuple scrutinee") }
          c := Bin(OP_EQ(), scruts[j], parse_primary(p))
          if is_bad(cond) { cond = c } el { cond = Bin(OP_AND(), cond, c) }
        }
        j += 1
        if ckind(p) == TK_COMMA() { adv(p) }
      }
      eat(p, TK_RPAREN())
      if j < len(scruts) { report_at(p.src, p.toks[p.pos].pos, "match arm has fewer components than the tuple scrutinee") }
      rt cond                       // Bad ⇒ all components `_` (catch-all)
    }
    if ckind(p) == TK_IDENT() && ctext(p) == "_" { adv(p) }   // bare `_` catch-all
    rt Bad
  }
  if ckind(p) == TK_IDENT() && ctext(p) == "_" { adv(p); rt Bad }   // scalar wildcard
  Bin(OP_EQ(), scruts[0], parse_primary(p))                          // scalar literal
}
fn build_if_chain(conds:[Expr], bodies:[Expr]) -> Expr {
  mu acc := Bad                     // no-arm-matched fallthrough
  mu i := len(conds) - 1
  lp i >= 0 {
    if is_bad(conds[i]) { acc = bodies[i] }              // catch-all → trailing else
    el { acc = IfE(conds[i], bodies[i], acc) }
    i = i - 1
  }
  acc
}
fn parse_match_desugar(p:*P, scruts:[Expr], is_tuple:bool) -> Expr {
  mu conds:[Expr] := []
  mu bodies:[Expr] := []
  lp ckind(p) != TK_RBRACE() && ckind(p) != TK_EOF() {
    mu bnd := Binds(empty_strs(), no_exprs())
    cond := parse_arm_cond(p, scruts, is_tuple, &bnd)
    if ckind(p) == TK_ASSIGN() { adv(p) }   // `=>`
    if ckind(p) == TK_GT() { adv(p) }
    conds = push(conds, cond)
    mu body := parse_expr(p)
    mu bi := 0                              // bind each pattern var → its scrutinee component
    lp bi < len(bnd.names) { body = subst_var(body, bnd.names[bi], bnd.vals[bi]); bi += 1 }
    bodies = push(bodies, body)
    if ckind(p) == TK_SEMI() { adv(p) }     // arm separator
  }
  eat(p, TK_RBRACE())
  build_if_chain(conds, bodies)
}
// Field names of struct `name`, in DECLARED order, by scanning the token stream
// for `st name { … }`. Returns [] when `name` isn't a declared struct — which is
// how a brace literal `Name{…}` is told apart from a loop body like `xs {…}`.
// Brace-depth tracked so a map-typed field (`m: {str:str}`) doesn't leak its
// inner `:`-names as fields.
fn struct_field_names(toks:[Token], name:str) -> [str] {
  mu out:[str] := []
  mu i := 0
  lp i < len(toks) {
    if toks[i].kind == TK_IDENT() && toks[i].text == "st" && i + 2 < len(toks) && toks[i + 1].text == name {
      mu depth := 1
      mu j := i + 3                       // past `st Name {`
      lp depth > 0 && j < len(toks) && toks[j].kind != TK_EOF() {
        kk := toks[j].kind
        if kk == TK_LBRACE() { depth += 1 }
        el if kk == TK_RBRACE() { depth = depth - 1 }   // bootstrap has no `-=`
        el if depth == 1 && kk == TK_IDENT() && j + 1 < len(toks) && toks[j + 1].kind == TK_COLON() {
          out = push(out, toks[j].text)
        }
        j += 1
      }
      rt out
    }
    i += 1
  }
  out
}
// Disambiguate a `{` in expression position: a BLOCK `{ a:=3; b:=4; a*b }` vs a
// MAP literal `{}` / `{k:v,…}`. Scan to the matching `}` (depth-tracked over all
// bracket kinds); at depth 1 a `:=` or `;` means block, a `:` means map. An empty
// `{}` is a map; a brace with tokens but no `:`/`;`/`:=` (a bare tail expr) is a block.
fn brace_is_block(p:*P) -> bool {
  mu i := p.pos + 1
  mu depth := 1
  mu saw := false
  lp i < len(p.toks) {
    kk := p.toks[i].kind
    if kk == TK_RBRACE() && depth == 1 { br }     // matching close
    saw = true
    if kk == TK_LBRACE() || kk == TK_LBRACK() || kk == TK_LPAREN() { depth += 1 }
    el if kk == TK_RBRACE() || kk == TK_RBRACK() || kk == TK_RPAREN() { depth = depth - 1 }
    el if depth == 1 {
      if kk == TK_WALRUS() rt true               // a decl ⇒ block
      if kk == TK_SEMI() rt true                 // a separator ⇒ block
      if kk == TK_COLON() rt false               // a k:v pair ⇒ map
    }
    i = i + 1
  }
  saw                                            // bare expr ⇒ block; empty {} ⇒ map
}
fn parse_primary(p:*P) -> Expr {
  k := ckind(p)
  if k == TK_INT() {
    v := str_to_int(ctext(p)); adv(p); rt Num(v)
  }
  if k == TK_FLOAT() {
    s := ctext(p); adv(p); rt Flt(s)
  }
  if k == TK_CHAR() {
    c := char_code(ctext(p)); adv(p); rt Num(c)
  }
  if k == TK_STR() {
    s := ctext(p); adv(p)
    if str_has_interp(s) { rt parse_interp(s) }
    rt Str(s)
  }
  // `fn(a, b) expr` — a lambda. As a map/filter/reduce arg it's inlined (params
  // typed from the array elem); elsewhere it's a first-class closure value lifted
  // to `__lam_<id>` (params default i64). `id` = the `fn` token's position — a
  // stable unique tag (one P parses the whole file, so positions don't collide).
  if k == TK_IDENT() && ctext(p) == "fn" {
    id := p.pos                         // tag from the `fn` token, before adv
    adv(p)                              // fn
    eat(p, TK_LPAREN())
    mu params:[str] := []
    mu ptypes:[str] := []
    lp ckind(p) != TK_RPAREN() && ckind(p) != TK_EOF() {
      if ckind(p) == TK_IDENT() {
        params = push(params, ctext(p)); adv(p)
        if ckind(p) == TK_COLON() { adv(p); ptypes = push(ptypes, parse_type(p)) }   // `: Type`
        el { ptypes = push(ptypes, "i64") }                  // unannotated param → i64
      } el if ckind(p) == TK_COMMA() {
        adv(p)
      } el {
        adv(p)                                                // defensive: a stray token must never spin this loop
      }
    }
    eat(p, TK_RPAREN())
    rt Lambda(params, ptypes, parse_expr(p), id)
  }
  // `mt scrut { Variant(b…) => body; … }` — match expression
  if k == TK_IDENT() && ctext(p) == "mt" {
    adv(p)                              // mt
    mu scruts:[Expr] := []
    mu is_tuple := false
    if ckind(p) == TK_LPAREN() {        // `mt (e0, e1, …)` — tuple scrutinee
      adv(p)
      scruts = push(scruts, parse_expr(p))
      lp ckind(p) == TK_COMMA() { adv(p); scruts = push(scruts, parse_expr(p)); is_tuple = true }
      eat(p, TK_RPAREN())
    } el {
      scruts = push(scruts, parse_expr(p))
    }
    eat(p, TK_LBRACE())
    // literal / wildcard / tuple patterns → desugar to an if-chain (no Match AST);
    // capitalized Variant patterns stay on the existing Match path below.
    fk := ckind(p)
    if is_tuple || fk == TK_INT() || fk == TK_STR() || fk == TK_CHAR() || (fk == TK_IDENT() && ctext(p) == "_") {
      rt parse_match_desugar(p, scruts, is_tuple)
    }
    scrut := scruts[0]
    mu vnames:[str] := []
    mu vbinds:[str] := []
    mu bodies:[Expr] := []
    lp ckind(p) != TK_RBRACE() && ckind(p) != TK_EOF() {
      vname := ctext(p); adv(p)         // Variant name
      mu binds:str := ""                 // ";"-joined binding names
      if ckind(p) == TK_LPAREN() {
        adv(p)
        lp ckind(p) != TK_RPAREN() && ckind(p) != TK_EOF() {
          if len(binds) > 0 { binds = binds + ";" }
          binds = binds + ctext(p); adv(p)
          if ckind(p) == TK_COMMA() { adv(p) }
        }
        eat(p, TK_RPAREN())
      }
      // `=>`  is lexed as `=` then `>` (no fat-arrow token)
      if ckind(p) == TK_ASSIGN() { adv(p) }
      if ckind(p) == TK_GT() { adv(p) }
      body := parse_expr(p)
      vnames = push(vnames, vname)
      vbinds = push(vbinds, binds)
      bodies = push(bodies, body)
      if ckind(p) == TK_SEMI() { adv(p) }   // arm separator
    }
    eat(p, TK_RBRACE())
    rt Match(scrut, vnames, vbinds, bodies)
  }
  // `if cond { e } el { e }` as an expression (branches are single expressions
  // in the subset). Distinct from the statement `if` handled in parse_stmt.
  if k == TK_IDENT() && ctext(p) == "if" {
    adv(p)
    cond := parse_expr(p)
    then_e := parse_brace_expr(p)
    mu els := Bad
    if ckind(p) == TK_IDENT() && ctext(p) == "el" {
      adv(p)
      if ckind(p) == TK_IDENT() && ctext(p) == "if" {
        els = parse_primary(p)        // `el if …` → nested if-expression (chain)
      } el {
        els = parse_brace_expr(p)
      }
    }
    rt IfE(cond, then_e, els)
  }
  // array literal `[a, b, …]` (or empty `[]`)
  if k == TK_LBRACK() {
    adv(p)
    mu elems:[Expr] := []
    lp ckind(p) != TK_RBRACK() && ckind(p) != TK_EOF() {
      elems = push(elems, parse_expr(p))
      if ckind(p) == TK_COMMA() { adv(p) }
    }
    eat(p, TK_RBRACK())
    rt Array(elems, "")
  }
  // block expression `{ s1; s2; …; tail }` — distinguished from a map literal
  // by a `:=`/`;` (or a bare tail expr) inside the braces.
  if k == TK_LBRACE() && brace_is_block(p) {
    rt BlockE(parse_block(p))
  }
  // map literal `{}` or `{k: v, k: v, …}` (mirrors the array-literal loop)
  if k == TK_LBRACE() {
    adv(p)
    mu mkeys:[Expr] := []
    mu mvals:[Expr] := []
    lp ckind(p) != TK_RBRACE() && ckind(p) != TK_EOF() {
      mkeys = push(mkeys, parse_expr(p))
      eat(p, TK_COLON())
      mvals = push(mvals, parse_expr(p))
      if ckind(p) == TK_COMMA() { adv(p) }
    }
    eat(p, TK_RBRACE())
    rt MapLit("", mkeys, mvals)
  }
  if k == TK_IDENT() {
    name := ctext(p)
    // bool literals lower to C ints (true→1, false→0)
    // bool literals → a bool-typed node (a trivial comparison): direct use prints
    // 1/0 (expr_is_cmp), but a variable typed from it prints true/false — exactly
    // ailangc's _Generic behavior. Value is still 1/0.
    if name == "true"  { adv(p); rt Bin(OP_EQ(), Num(1), Num(1)) }
    if name == "false" { adv(p); rt Bin(OP_NE(), Num(1), Num(1)) }
    adv(p)
    if ckind(p) == TK_LPAREN() {        // a call / struct ctor: name(args)
      adv(p)
      mu args:[Expr] := []
      lp ckind(p) != TK_RPAREN() && ckind(p) != TK_EOF() {
        args = push(args, parse_expr(p))
        if ckind(p) == TK_COMMA() { adv(p) }
      }
      eat(p, TK_RPAREN())
      rt Call(name, args)
    }
    if ckind(p) == TK_LBRACE() {        // brace struct literal: Name { f: v, … }
      order := struct_field_names(p.toks, name)
      if len(order) > 0 {               // a DECLARED struct (not a loop body `xs {…}`)
        adv(p)                          // {
        mu fnames:[str] := []
        mu fvals:[Expr] := []
        lp ckind(p) != TK_RBRACE() && ckind(p) != TK_EOF() {
          fnames = push(fnames, ctext(p)); adv(p)   // field name
          eat(p, TK_COLON())
          fvals = push(fvals, parse_expr(p))
          if ckind(p) == TK_COMMA() { adv(p) }
        }
        eat(p, TK_RBRACE())
        // splice named values into declared field order → positional ctor,
        // reusing the existing `Call`→`mk_Name` lowering. Order-independent.
        mu cargs:[Expr] := []
        mu oi := 0
        lp oi < len(order) {
          mu fi := 0
          lp fi < len(fnames) { if fnames[fi] == order[oi] { cargs = push(cargs, fvals[fi]) } fi += 1 }
          oi += 1
        }
        rt Call(name, cargs)
      }
    }
    rt Var(name)
  }
  if k == TK_LPAREN() {
    adv(p)
    inner := parse_expr(p)
    // `(a, b, …)` — a tuple literal (multi-return). A lone `(e)` stays a
    // grouped expression (collapses to the inner expr, as before).
    if ckind(p) == TK_COMMA() {
      mu elems:[Expr] := [inner]
      lp ckind(p) == TK_COMMA() {
        adv(p)
        if ckind(p) == TK_RPAREN() { br }   // tolerate a trailing comma
        elems = push(elems, parse_expr(p))
      }
      eat(p, TK_RPAREN())
      rt Tuple(elems)
    }
    eat(p, TK_RPAREN())
    rt inner
  }
  // Unrecognized token: consume it so callers always make progress (a
  // non-advancing Bad here would spin a parse loop into an unbounded push).
  report_at(p.src, p.toks[p.pos].pos, "unexpected token '" + ctext(p) + "' in expression")
  adv(p)
  Bad
}

// ----- statements -----------------------------------------------------------
// Parse a `{ stmts }` block, or a single statement, into a [Stmt].
fn parse_block(p:*P) -> [Stmt] {
  mu body:[Stmt] := []
  if ckind(p) == TK_LBRACE() {
    adv(p)
    lp ckind(p) != TK_RBRACE() && ckind(p) != TK_EOF() {
      if ckind(p) == TK_SEMI() { adv(p); ct }   // skip `;` separators (one-liners)
      body = push(body, parse_stmt(p))
    }
    eat(p, TK_RBRACE())
  } el {
    body = push(body, parse_stmt(p))
  }
  body
}

// Lookahead: does a statement start a tuple destructure `IDENT (, IDENT)+ :=`?
// (the `+` — at least one comma — keeps a plain `name :=` on the SDecl path.)
fn is_destructure_ahead(p:*P) -> bool {
  if ckind(p) != TK_IDENT() { rt false }
  mu i := p.pos + 1
  if i >= len(p.toks) || p.toks[i].kind != TK_COMMA() { rt false }
  lp i < len(p.toks) && p.toks[i].kind == TK_COMMA() {
    i = i + 1
    if i >= len(p.toks) || p.toks[i].kind != TK_IDENT() { rt false }
    i = i + 1
  }
  i < len(p.toks) && p.toks[i].kind == TK_WALRUS()
}
// Parse `a, b, … := expr`. A name of "_" marks an ignored slot.
fn parse_destructure(p:*P) -> Stmt {
  mu names:[str] := []
  lp ckind(p) == TK_IDENT() {
    names = push(names, ctext(p))
    adv(p)
    if ckind(p) == TK_COMMA() { adv(p) } el { br }
  }
  eat(p, TK_WALRUS())               // :=
  SDestructure(names, parse_expr(p))
}

fn parse_stmt(p:*P) -> Stmt {
  k := ckind(p)
  t := ctext(p)

  if k == TK_IDENT() && t == "rt" {
    adv(p)
    rt SReturn(parse_expr(p))
  }
  if k == TK_IDENT() && t == "br" { adv(p); rt SBreak }
  if k == TK_IDENT() && t == "ct" { adv(p); rt SContinue }
  if k == TK_IDENT() && t == "if" {
    adv(p)
    cond := parse_expr(p)
    body := parse_block(p)
    // optional `el { … }`  or  `el if … { … }` (the latter nests as a single
    // SIf inside the else-branch, which is just another [Stmt]).
    mu else_b:[Stmt] := []
    if ckind(p) == TK_IDENT() && ctext(p) == "el" {
      adv(p)
      if ckind(p) == TK_IDENT() && ctext(p) == "if" {
        else_b = push(else_b, parse_stmt(p))   // re-enter: parses the `if …`
      } el {
        else_b = parse_block(p)
      }
    }
    rt SIf(cond, body, else_b)
  }
  if k == TK_IDENT() && t == "lp" {
    adv(p)
    // `lp (k, v) in map { … }` — iterate map entries (key + value).
    if ckind(p) == TK_LPAREN() {
      adv(p)                         // (
      kn := ctext(p); adv(p)         // k
      eat(p, TK_COMMA())
      vn := ctext(p); adv(p)         // v
      eat(p, TK_RPAREN())
      if ckind(p) == TK_IDENT() && ctext(p) == "in" { adv(p) }   // in
      coll := parse_expr(p)
      rt SLoopKV(kn, vn, coll, parse_block(p))
    }
    // `lp x in coll { … }` — iterate; vs `lp cond { … }` — while.
    if ckind(p) == TK_IDENT() && p.toks[p.pos + 1].kind == TK_IDENT() && p.toks[p.pos + 1].text == "in" {
      vnm := ctext(p); adv(p)       // x
      adv(p)                         // in
      coll := parse_expr(p)
      // `lp i in lo..hi { … }` — counting range (parse_expr stops at `..`).
      if ckind(p) == TK_DOTDOT() {
        adv(p)                       // ..
        mu incl := false
        if ckind(p) == TK_ASSIGN() { adv(p); incl = true }   // ..=  (inclusive)
        mu hi := parse_expr(p)
        if incl { hi = Bin(OP_ADD(), hi, Num(1)) }           // lo..=hi  ≡  lo..(hi+1)
        rt SLoopRange(vnm, coll, hi, parse_block(p))
      }
      rt SLoopIn(vnm, coll, parse_block(p))
    }
    cond := parse_expr(p)
    rt SLoop(cond, parse_block(p))
  }
  if k == TK_IDENT() && t == "println" {
    adv(p)
    eat(p, TK_LPAREN())
    e := parse_expr(p)
    eat(p, TK_RPAREN())
    rt SPrint(e)
  }
  // `mu name [:Type] := expr` — mutable declaration. The annotation pins an
  // empty array literal's element type (`mu xs:[Token] := []`).
  if k == TK_IDENT() && t == "mu" {
    adv(p)
    if is_destructure_ahead(p) { rt parse_destructure(p) }   // mu a, b := …
    name := ctext(p)
    adv(p)                          // name
    mu ann := ""
    if ckind(p) == TK_COLON() { adv(p); ann = parse_type(p) }
    eat(p, TK_WALRUS())             // :=
    rt SDecl(name, parse_decl_rhs(p, ann))
  }
  // `a, b := expr` — tuple destructure (must precede the single-name `name :=`).
  if is_destructure_ahead(p) { rt parse_destructure(p) }
  // `name : Type = expr` — typed immutable binding (the non-`mu` analogue of the
  // `mu name : Type := …` form above). The annotation pins an empty array/map
  // literal's element type, e.g. `m : {str:i64} = {}`. Accepts `=` or `:=` after
  // the type so both `name : T = e` and `name : T := e` bind.
  if k == TK_IDENT() && p.toks[p.pos + 1].kind == TK_COLON() {
    name := t
    adv(p)                          // name
    adv(p)                          // :
    ann := parse_type(p)
    if ckind(p) == TK_WALRUS() { adv(p) } el { eat(p, TK_ASSIGN()) }   // := or =
    rt SDecl(name, parse_decl_rhs(p, ann))
  }
  // `name := expr` — new binding
  if k == TK_IDENT() && p.toks[p.pos + 1].kind == TK_WALRUS() {
    name := t
    adv(p); adv(p)                  // name :=
    rt SDecl(name, parse_expr(p))
  }
  // `name = expr` — reassignment
  if k == TK_IDENT() && p.toks[p.pos + 1].kind == TK_ASSIGN() {
    name := t
    adv(p); adv(p)                  // name =
    rt SAssign(name, parse_expr(p))
  }
  // `name += expr` — compound add-assign (lexed `+` then `=`); desugar to
  // `name = name + expr`. The only compound op the subset needs.
  if k == TK_IDENT() && p.toks[p.pos + 1].kind == TK_PLUS() && p.toks[p.pos + 2].kind == TK_ASSIGN() {
    name := t
    adv(p); adv(p); adv(p)          // name + =
    rt SAssign(name, Bin(OP_ADD(), Var(name), parse_expr(p)))
  }
  // `obj[idx] = expr` or `obj.field = expr` — l-value assignment. A statement
  // starting `IDENT [` or `IDENT .` parses a factor first; if `=` follows, it's
  // an l-value assignment (dispatched by the factor's shape), else a bare expr.
  // An `IDENT.`/`IDENT[` only takes the l-value-assignment path when a lookahead
  // confirms it ends at `=`/`+=`. Otherwise it begins a bare expression (e.g. a
  // braceless fn body `p.x * p.x + …`) which must parse in FULL — parsing just the
  // factor here dropped the rest and mis-reported the next operator.
  if k == TK_IDENT() && (p.toks[p.pos + 1].kind == TK_LBRACK() || p.toks[p.pos + 1].kind == TK_DOT()) {
    if is_lvalue_assign(p) {
      lhs := parse_factor(p)          // the l-value chain (stops before `=`/`+`)
      if ckind(p) == TK_ASSIGN() {
        adv(p)
        rt mk_lvalue_assign(lhs, parse_expr(p))
      }
      adv(p); adv(p)                  // `+` `=` — compound add-assign `lhs += expr`
      rt mk_lvalue_assign(lhs, Bin(OP_ADD(), lhs, parse_expr(p)))
    }
  }
  // bare expression statement
  SExpr(parse_expr(p))
}

// Lookahead (no token consumption): does the upcoming `IDENT(.field|[idx])…`
// chain end at an assignment operator (`=` or `+=`)? If not, that `IDENT.`/
// `IDENT[` opens a bare expression (e.g. `p.x * p.x`) that must parse in full.
fn is_lvalue_assign(p:*P) -> bool {
  mu i := p.pos + 1                   // past the head IDENT
  lp i < len(p.toks) {
    kk := p.toks[i].kind
    if kk == TK_DOT() && i + 1 < len(p.toks) && p.toks[i + 1].kind == TK_IDENT() {
      i = i + 2
    } el if kk == TK_LBRACK() {
      mu d := 1
      i = i + 1
      lp i < len(p.toks) && d > 0 {
        ik := p.toks[i].kind
        if ik == TK_LBRACK() { d = d + 1 }
        el if ik == TK_RBRACK() { d = d - 1 }
        i = i + 1
      }
    } el {
      br
    }
  }
  if i >= len(p.toks) rt false
  if p.toks[i].kind == TK_ASSIGN() rt true
  if p.toks[i].kind == TK_PLUS() && i + 1 < len(p.toks) && p.toks[i + 1].kind == TK_ASSIGN() rt true
  false
}
// Build the right assignment statement from an l-value: `obj[idx]` → SIdxAssign,
// `obj.field` → SFieldAssign; anything else degrades to a bare expr statement
// (match arms can't hold `rt`, so this dispatch lives in a helper).
fn mk_lvalue_assign(lhs:Expr, rhs:Expr) -> Stmt {
  mt lhs {
    Index(obj, idx)  => SIdxAssign(obj, idx, rhs);
    Field(obj, fnm)  => SFieldAssign(obj, fnm, rhs);
    Tuple(tes)       => SExpr(lhs);
    BlockE(bb)       => SExpr(lhs);
    Num(v)           => SExpr(lhs);
    Flt(fs)          => SExpr(lhs);
    Str(s)           => SExpr(lhs);
    Var(n)           => SExpr(lhs);
    Bin(o,a,b)       => SExpr(lhs);
    Unary(o,x)       => SExpr(lhs);
    Call(f,a)        => SExpr(lhs);
    Array(es,et)     => SExpr(lhs);
    MapLit(mlt,mks,mvs) => SExpr(lhs);
    Addr(x)          => SExpr(lhs);
    Match(sc,vn,vb,bd) => SExpr(lhs);
    IfE(c,t,el2)     => SExpr(lhs);
    Try(e2)          => SExpr(lhs);
    Lambda(ps,pts,b,id)  => SExpr(lhs);
    Bad              => SExpr(lhs);
  }
}

// Parse a decl's RHS, stamping an annotation's type onto an empty aggregate
// literal so codegen knows `mu xs:[Token] := []` is `[Token]` and
// `mu m:{str:str} := {}` is that map type, not a bare `[]`/`{}`.
fn parse_decl_rhs(p:*P, ann:str) -> Expr {
  e := parse_expr(p)
  if is_array_ann(ann) { rt stamp_array_ann(e, elem_of_ann(ann)) }
  if is_map_ann(ann) { rt stamp_map_ann(e, ann) }
  e
}

// If `e` is an empty array literal, re-stamp it with element type `ety`.
fn stamp_array_ann(e:Expr, ety:str) -> Expr {
  mt e {
    Array(elems, old) => stamp_if_empty(elems, old, ety);
    Tuple(tes)        => e;
    BlockE(bb)        => e;
    Num(v)            => e;
    Flt(fs)           => e;
    Str(s)            => e;
    Var(n)            => e;
    Bin(o,a,b)        => e;
    Unary(o,x)        => e;
    Call(f,a)         => e;
    Field(o,f)        => e;
    Index(o,i)        => e;
    MapLit(mlt,mks,mvs) => e;
    Addr(x)           => e;
    Match(sc,vn,vb,bd) => e;
    IfE(c,t,el2)      => e;
    Try(e2)           => e;
    Lambda(ps,pts,b,id)   => e;
    Bad               => e;
  }
}

// If `e` is an empty map literal, re-stamp it with map type `mty`.
fn stamp_map_ann(e:Expr, mty:str) -> Expr {
  mt e {
    MapLit(old,mks,mvs) => MapLit(mty, mks, mvs);
    Tuple(tes)        => e;
    BlockE(bb)        => e;
    Array(elems, old) => e;
    Addr(x)           => e;
    Match(sc,vn,vb,bd) => e;
    Num(v)            => e;
    Flt(fs)           => e;
    Str(s)            => e;
    Var(n)            => e;
    Bin(o,a,b)        => e;
    Unary(o,x)        => e;
    Call(f,a)         => e;
    Field(o,f)        => e;
    Index(o,i)        => e;
    IfE(c,t,el2)      => e;
    Try(e2)           => e;
    Lambda(ps,pts,b,id)   => e;
    Bad               => e;
  }
}

fn stamp_if_empty(elems:[Expr], old:str, ety:str) -> Expr {
  if len(elems) == 0 { rt Array(elems, ety) }
  Array(elems, old)
}

// ----- top-level: structs, functions, main statements ----------------------
// `st Name { f1:T1; f2:T2 }` — collect parallel field-name/field-type arrays.
fn parse_struct(p:*P) -> StructDef {
  adv(p)                            // `st`
  name := ctext(p); adv(p)          // Name
  eat(p, TK_LBRACE())
  mu fnames:[str] := []
  mu ftypes:[str] := []
  lp ckind(p) != TK_RBRACE() && ckind(p) != TK_EOF() {
    if ckind(p) == TK_IDENT() {
      fnames = push(fnames, ctext(p)); adv(p)   // field name
      eat(p, TK_COLON())                         // :
      ftypes = push(ftypes, parse_type(p))       // type name
    } el {
      adv(p)                                     // skip ; or stray
    }
  }
  eat(p, TK_RBRACE())
  StructDef(name, fnames, ftypes)
}

// `en Name { V0, V1(f:T, …), … }` — collect variant names + ";"-joined field
// type lists (parallel arrays). A field whose type is the enclosing enum itself
// is recorded as "@self" so codegen boxes it (heap pointer) to break the cycle.
fn parse_enum(p:*P) -> EnumDef {
  adv(p)                            // `en`
  name := ctext(p); adv(p)          // Name
  eat(p, TK_LBRACE())
  mu vnames:[str] := []
  mu vftypes:[str] := []
  lp ckind(p) != TK_RBRACE() && ckind(p) != TK_EOF() {
    if ckind(p) == TK_IDENT() {
      vn := ctext(p); adv(p)        // Variant name
      mu fts := ""
      if ckind(p) == TK_LPAREN() {
        adv(p)
        mu first := true
        lp ckind(p) != TK_RPAREN() && ckind(p) != TK_EOF() {
          // each field is `fname : Type`; we keep only the type
          if ckind(p) == TK_IDENT() { adv(p) }   // field name
          eat(p, TK_COLON())
          ft := parse_type(p)
          if ft == name { ft = "@self" }         // self-reference → box it
          if first { fts = ft } el { fts = fts + ";" + ft }
          first = false
          if ckind(p) == TK_COMMA() { adv(p) }
        }
        eat(p, TK_RPAREN())
      }
      vnames = push(vnames, vn)
      vftypes = push(vftypes, fts)
      if ckind(p) == TK_COMMA() { adv(p) }
    } el {
      adv(p)
    }
  }
  eat(p, TK_RBRACE())
  EnumDef(name, vnames, vftypes)
}

// ----- boxed enum fields (recursion-cycle breaking) -------------------------
// A variant field is boxed (stored as a heap pointer) when storing it by value
// would close a struct cycle: a self-reference ("@self") OR a bare field typed
// as ANOTHER enum ("@box:<Enum>"). `is_boxed_ft` tests either; `boxed_enum`
// returns the pointee enum name (the container for @self).
fn is_boxed_ft(ft:str) -> bool {
  if ft == "@self" rt true
  len(ft) >= 5 && substring(ft, 0, 5) == "@box:"
}
fn boxed_enum(ft:str, selfname:str) -> str {
  if ft == "@self" rt selfname
  substring(ft, 5, len(ft))                 // strip "@box:"
}
fn is_enum_name(enums:[EnumDef], nm:str) -> bool {
  mu i := 0
  lp i < len(enums) { if enums[i].name == nm rt true   i += 1 }
  false
}
fn is_struct_name(structs:[StructDef], nm:str) -> bool {
  mu i := 0
  lp i < len(structs) { if structs[i].name == nm rt true   i += 1 }
  false
}
fn is_prim_name(nm:str) -> bool {
  nm == "i64" || nm == "i32" || nm == "u32" || nm == "f64" || nm == "bool" || nm == "str" || nm == "bytes" || nm == "i8" || nm == "i16" || nm == "u8" || nm == "u16" || nm == "u64" || nm == "f32" || nm == "void"
}
// Mark a bare unknown name (not a primitive, has no type prefix, and isn't a
// declared struct/enum) as a C header type "@c:<name>" so it spells raw.
fn mark_ctype(ty:str, structs:[StructDef], enums:[EnumDef]) -> str {
  if len(ty) == 0 rt ty
  c := ty[0]
  // a type prefix ([ { * ! @ ( ) means it's already a known shape
  if c == 91 || c == 123 || c == 42 || c == 33 || c == 64 || c == 40 rt ty
  if is_prim_name(ty) rt ty
  if is_struct_name(structs, ty) rt ty
  if is_enum_name(enums, ty) rt ty
  "@c:" + ty
}
// Post-pass: once all user structs/enums are known, mark each extern's return
// type that names a C-header type (e.g. `ex fn div(...) -> div_t`). The return
// flows into the call's value type, so the `r := div(...)` local spells `div_t`
// (not `s_div_t`). Params left as-is (header-type params are rare).
fn mark_extern_ctypes(externs:[Func], structs:[StructDef], enums:[EnumDef]) -> [Func] {
  mu out:[Func] := []
  mu i := 0
  lp i < len(externs) {
    f := externs[i]
    nr := mark_ctype(f.ret, structs, enums)
    out = push(out, Func(f.name, f.params, f.ptypes, nr, f.lib, f.tparams, f.body))
    i += 1
  }
  out
}
// Post-pass (after ALL enums are known, so forward refs resolve): mark every
// bare field typed as a different enum "@box:<Enum>" so two enums can reference
// each other (mutual recursion). Self-refs are already "@self"; arrays `[Enum]`
// stay by-name (they're heap-backed `arr_<Enum>`), so only bare enum fields box.
fn box_cross_enums(enums:[EnumDef]) -> [EnumDef] {
  mu out:[EnumDef] := []
  mu i := 0
  lp i < len(enums) {
    ed := enums[i]
    mu newvft:[str] := []
    mu vi := 0
    lp vi < len(ed.vftypes) {
      raw := ed.vftypes[vi]
      if len(raw) == 0 {
        newvft = push(newvft, "")           // unit variant — no fields
      } el {
        fts := split_semi(raw)
        mu nf := ""
        mu fi := 0
        lp fi < len(fts) {
          ft := fts[fi]
          if ft != "@self" && is_enum_name(enums, ft) { ft = "@box:" + ft }
          if fi == 0 { nf = ft } el { nf = nf + ";" + ft }
          fi += 1
        }
        newvft = push(newvft, nf)
      }
      vi += 1
    }
    out = push(out, EnumDef(ed.name, ed.vnames, newvft))
    i += 1
  }
  out
}

// A type name: `i64`/`str`/StructName, an array `[T]`, a map `{K:V}`, or a
// pointer `*T`. Returned as a literal string ("[i64]", "{str:str}", "*P", …) —
// a leading '[' / '{' / '*' tells codegen which kind it is.
fn parse_type(p:*P) -> str {
  if ckind(p) == TK_NOT() {           // `!T` — a result type (ok T | err str)
    adv(p)                            // !
    rt "!" + parse_type(p)
  }
  if ckind(p) == TK_STAR() {
    adv(p)                            // *
    rt "*" + parse_type(p)
  }
  if ckind(p) == TK_LBRACK() {
    adv(p)                            // [
    inner := parse_type(p)
    eat(p, TK_RBRACK())               // ]
    rt "[" + inner + "]"
  }
  if ckind(p) == TK_LBRACE() {
    adv(p)                            // {
    kt := parse_type(p)               // key type
    eat(p, TK_COLON())                // :
    vt := parse_type(p)               // value type
    eat(p, TK_RBRACE())               // }
    rt "{" + kt + ":" + vt + "}"
  }
  // `(T1, T2, …)` — a tuple type (multi-return). Encoded "(T1;T2;…)". A single
  // `(T)` with no comma collapses to the inner type.
  if ckind(p) == TK_LPAREN() {
    adv(p)                            // (
    mu inner := "("
    mu n := 0
    lp ckind(p) != TK_RPAREN() && ckind(p) != TK_EOF() {
      if n > 0 { inner = inner + ";" }
      inner = inner + parse_type(p)
      n += 1
      if ckind(p) == TK_COMMA() { adv(p) }
    }
    eat(p, TK_RPAREN())               // )
    if n == 1 { rt substring(inner, 1, len(inner)) }   // (T) → T
    rt inner + ")"
  }
  // `fn(T,...) -> R` — a function/closure type. Encoded compactly as
  // "@fn(<pty>,...)<ret>" (e.g. "@fn()i64", "@fn(i64)i64"); `cty` maps it to
  // closure_t. Must precede the bare-IDENT branch so `fn` isn't read as a type
  // name. (main.ail has no fn-type annotations, so this is dead when self-hosting.)
  if ckind(p) == TK_IDENT() && ctext(p) == "fn" {
    adv(p)                            // fn
    eat(p, TK_LPAREN())               // (
    mu sig := "@fn("
    mu first := true
    lp ckind(p) != TK_RPAREN() && ckind(p) != TK_EOF() {
      if first == false { sig = sig + "," }
      sig = sig + parse_type(p)
      first = false
      if ckind(p) == TK_COMMA() { adv(p) }
    }
    eat(p, TK_RPAREN())               // )
    mu ret := "i64"
    if ckind(p) == TK_MINUS() { adv(p) }                     // (no `->` token)
    if ckind(p) == TK_GT() { adv(p); ret = parse_type(p) }   // > RetType
    rt sig + ")" + ret
  }
  if ckind(p) == TK_IDENT() {
    t := ctext(p); adv(p); rt t
  }
  "i64"
}

// Type-name helpers: an array type name starts with '[', a map type name with
// '{'. `elem_of_ann("[i64]")` → "i64"; `arr_suffix("i64")` → "i64" (a struct
// keeps its name) — used to build the monomorphic C `arr_<suffix>` helper names.
fn is_array_ann(ty:str) -> bool { len(ty) > 0 && ty[0] == 91 }   // '['
fn elem_of_ann(ty:str) -> str { substring(ty, 1, len(ty) - 1) }   // strip [ ]
fn is_map_ann(ty:str) -> bool { len(ty) > 0 && ty[0] == 123 }    // '{'
fn is_ptr_ann(ty:str) -> bool { len(ty) > 0 && ty[0] == 42 }     // '*'
fn deref_ann(ty:str) -> str { substring(ty, 1, len(ty)) }         // strip leading '*'
fn is_result_ann(ty:str) -> bool { len(ty) > 0 && ty[0] == 33 }  // '!' — `!T`
fn result_inner(ty:str) -> str { substring(ty, 1, len(ty)) }      // strip leading '!'
// Function/closure type "@fn(<pty>,...)<ret>": `is_fn_ann` tests the "@fn"
// prefix; `fn_ret_of` returns the return type (everything after the ')');
// `fn_type_of` builds the annotation for a lambda of `np` i64 params → `ret`.
fn is_fn_ann(ty:str) -> bool { len(ty) >= 3 && ty[0] == 64 && ty[1] == 102 && ty[2] == 110 }  // "@fn"
fn fn_ret_of(sig:str) -> str {
  mu i := 0
  lp i < len(sig) { if sig[i] == 41 { rt substring(sig, i + 1, len(sig)) }   i += 1 }   // after ')'
  "i64"
}
fn fn_type_of(np:i64, ret:str) -> str {
  mu s := "@fn("
  mu k := 0
  lp k < np { if k > 0 { s = s + "," }   s = s + "i64"; k += 1 }
  s + ")" + ret
}
// A lambda's closure type "@fn(<pts>)<ret>": seed the params with their declared
// types first so the body's return type infers correctly (`fn(name:str) greeting
// + name` returns str, not i64). Mirrors register_lam's seeding.
fn lambda_type(sy:*Syms, ps:[str], pts:[str], b:Expr) -> str {
  mu i := 0
  lp i < len(ps) { if i < len(pts) { set_ty(sy, ps[i], pts[i]) }   i += 1 }
  fn_type_of_pts(pts, type_of_expr(sy, b))
}
// Like fn_type_of but with the real (possibly annotated) param types.
fn fn_type_of_pts(pts:[str], ret:str) -> str {
  mu s := "@fn("
  mu k := 0
  lp k < len(pts) { if k > 0 { s = s + "," }   s = s + pts[k]; k += 1 }
  s + ")" + ret
}
// The param type list of a closure type "@fn(<pts>)<ret>". Splits on a top-level
// ',' (depth-tracked over nested parens). MVP: simple param types (str/i64/…).
fn fn_params_of(sig:str) -> [str] {
  mu out:[str] := []
  mu i := 4                                  // skip "@fn("
  mu depth := 0
  mu cur := ""
  lp i < len(sig) {
    c := sig[i]
    if c == 40 { depth += 1; cur = cur + "(" }                        // '('
    el if c == 41 { if depth == 0 { br }   depth = depth - 1; cur = cur + ")" }   // ')'
    el if c == 44 && depth == 0 { out = push(out, cur); cur = "" }    // ',' separator
    el { cur = cur + substring(sig, i, i + 1) }
    i += 1
  }
  if len(cur) > 0 { out = push(out, cur) }
  out
}
// The pointee type of `ty` if it's a pointer, else `ty` unchanged. Used so
// `p.field` / `p[i]` on a `*T` looks through to T's fields/elements.
fn under_ptr(ty:str) -> str { if is_ptr_ann(ty) { deref_ann(ty) } el { ty } }

// Tuple type "(T1;T2;…)": paren-prefixed, ';'-joined element type names — a new
// prefix distinct from '[' '{' '*' '!' '@' and idents. Used for multi-return.
// MVP: elements are flat (no nested tuples), so a flat ';' split is exact.
fn is_tuple_ann(ty:str) -> bool { len(ty) >= 2 && ty[0] == 40 }   // '('
fn tuple_elems(ty:str) -> [str] {
  mu out:[str] := []
  mu cur := ""
  mu i := 1
  lp i < len(ty) - 1 {                 // between the outer '(' and ')'
    if ty[i] == 59 {                    // ';' — element separator
      out = push(out, cur)
      cur = ""
    } el {
      cur = cur + substring(ty, i, i + 1)
    }
    i += 1
  }
  out = push(out, cur)
  out
}
// The C struct suffix for a tuple shape: arr_suffix of each element, joined by
// '_' (e.g. "(i64;i64)" → "i64_i64", "(str;i64)" → "str_i64").
fn tuple_suffix(ty:str) -> str {
  es := tuple_elems(ty)
  mu s := ""
  mu i := 0
  lp i < len(es) {
    if i > 0 { s = s + "_" }
    s = s + arr_suffix(es[i])
    i += 1
  }
  s
}

fn parse_func(p:*P) -> Func {
  adv(p)                            // `fn`
  name := ctext(p); adv(p)          // name
  // optional generic type params `<T, U>` (lexed `<` … `>`)
  mu tparams:[str] := []
  if ckind(p) == TK_LT() {
    adv(p)
    lp ckind(p) != TK_GT() && ckind(p) != TK_EOF() {
      if ckind(p) == TK_IDENT() { tparams = push(tparams, ctext(p)); adv(p) }
      if ckind(p) == TK_COMMA() { adv(p) }
    }
    eat(p, TK_GT())
  }
  eat(p, TK_LPAREN())
  mu pnames:[str] := []
  mu ptypes:[str] := []
  lp ckind(p) != TK_RPAREN() && ckind(p) != TK_EOF() {
    if ckind(p) == TK_IDENT() && ctext(p) == "mu" { adv(p) }   // optional `mu` — C params are mutable anyway
    if ckind(p) == TK_IDENT() {
      pnames = push(pnames, ctext(p)); adv(p)    // param name
      if ckind(p) == TK_COLON() {
        adv(p)
        ptypes = push(ptypes, parse_type(p))     // : Type
      } el {
        ptypes = push(ptypes, "i64")             // unannotated → i64
      }
    }
    if ckind(p) == TK_COMMA() { adv(p) }
  }
  eat(p, TK_RPAREN())
  // optional `-> RetType`. We keep it: an explicit annotation is authoritative
  // (needed for fns whose body is a tail `mt`/`if` expression with no `rt`, which
  // body-inference would otherwise read as void). "" when absent → inferred.
  mu ret := ""
  if ckind(p) == TK_MINUS() { adv(p) }            // (no `->` token; '-' then '>')
  if ckind(p) == TK_GT() { adv(p); ret = parse_type(p) }
  Func(name, pnames, ptypes, ret, "", tparams, parse_block(p))
}

// `ex [\"lib\"] fn name(params) -> ret` — an external (C/libc) function, no body.
// Parsed into a bodiless Func; codegen emits a thin `f_<name>` wrapper that calls
// the real C symbol, so the normal `f_`-prefixed call path reaches it unchanged.
// An optional `\"lib\"` before `fn` links `-llib` (recorded in the `lib` field).
fn parse_extern(p:*P) -> Func {
  adv(p)                            // `ex`
  mu lib := ""
  if ckind(p) == TK_STR() { lib = ctext(p); adv(p) }   // ex "lib" fn …
  adv(p)                            // `fn`
  name := ctext(p); adv(p)          // name
  eat(p, TK_LPAREN())
  mu pnames:[str] := []
  mu ptypes:[str] := []
  lp ckind(p) != TK_RPAREN() && ckind(p) != TK_EOF() {
    if ckind(p) == TK_DOTDOT() {         // `...` variadic marker (lexed as `..` + `.`)
      adv(p)                             // ..
      if ckind(p) == TK_DOT() { adv(p) } // the trailing .
      pnames = push(pnames, "...")
      ptypes = push(ptypes, "...")       // sentinel: gen_extern emits a macro alias
    } el {
      if ckind(p) == TK_IDENT() && ctext(p) == "mu" { adv(p) }   // optional `mu`
      if ckind(p) == TK_IDENT() {
        pnames = push(pnames, ctext(p)); adv(p)
        if ckind(p) == TK_COLON() {
          adv(p)
          ptypes = push(ptypes, parse_type(p))
        } el {
          ptypes = push(ptypes, "i64")
        }
      }
    }
    if ckind(p) == TK_COMMA() { adv(p) }
  }
  eat(p, TK_RPAREN())
  mu ret := ""
  if ckind(p) == TK_MINUS() { adv(p) }
  if ckind(p) == TK_GT() { adv(p); ret = parse_type(p) }
  mu nobody:[Stmt] := []
  mu notp:[str] := []
  Func(name, pnames, ptypes, ret, lib, notp, nobody)
}

// Emit a wrapper `static <ret> f_<name>(<params>){ return (<ret>)<name>(args); }`
// for an extern. The return type follows the declaration (`str`→`const char*`,
// `i64`/`i32`/`bool`→`int64_t`); a void extern (empty ret) drops the `return`.
// C type for an extern PROTOTYPE — narrow (libc-matching) types, unlike `cty`
// which widens i32/u32→int64_t for the wrapper. So `extern double sqrt(double);`
// / `extern int rand(void);` match libc exactly (compatible with <stdlib.h> etc).
fn cty_proto(ty:str) -> str {
  if is_c_type_ann(ty) rt c_type_name(ty)        // header type → raw
  if ty == "i32" rt "int"
  if ty == "u32" rt "unsigned int"
  if ty == "f64" rt "double"
  if ty == "i64" rt "int64_t"
  if ty == "bool" rt "int"
  if ty == "str" rt "const char*"
  if ty == "bytes" rt "ailang_bytes"
  if is_ptr_ann(ty) rt cty_proto(deref_ann(ty)) + "*"
  ty                       // a header-defined C type (e.g. div_t) — emit it raw,
}                          // NOT s_-prefixed: an extern signature is C, not AiLang.
fn gen_extern(f:Func) -> str {
  // Variadic extern (`ex fn printf(fmt, ...)`): a fixed-arity `f_<name>` wrapper
  // can't forward C varargs, so don't emit one — alias the `f_<name>` call name
  // straight to the real symbol with a macro and rely on the system header
  // (<stdio.h> is always included) for the prototype. Matches ailangc, which
  // likewise skips its own prototype for the printf family and binds the header.
  if len(f.ptypes) > 0 && f.ptypes[len(f.ptypes) - 1] == "..." {
    rt "#undef " + f.name + "\n#define f_" + f.name + " " + f.name + "\n"
  }
  rty := cty_ret(f.ret)
  // Always declare the real symbol (C99 needs it for libc fns with no header).
  // `#undef` first drops any function-like macro a cinc'd header defines for this
  // name (e.g. <ctype.h>'s toupper) so the decl + calls bind to the real symbol;
  // it's a no-op otherwise. A prototype that merely duplicates a header's own
  // declaration is a compatible redeclaration, so emitting it unconditionally is
  // safe — and cty_proto spells header types raw, so it won't clash.
  mu out := "#undef " + f.name + "\n"
  pr := if len(f.ret) == 0 { "void" } el { cty_proto(f.ret) }
  out = out + "extern " + pr + " " + f.name + "("
  mu pi := 0
  lp pi < len(f.params) {
    if pi > 0 { out = out + ", " }
    out = out + cty_proto(f.ptypes[pi])
    pi += 1
  }
  if len(f.params) == 0 { out = out + "void" }
  out = out + ");\n"
  out = out + "static " + rty + " f_" + f.name + "("
  mu i := 0
  lp i < len(f.params) {
    if i > 0 { out = out + ", " }
    out = out + cty(f.ptypes[i]) + " a" + int_to_str(i)
    i += 1
  }
  if len(f.params) == 0 { out = out + "void" }
  out = out + "){ "
  if len(f.ret) > 0 { out = out + "return (" + rty + ")" }
  out = out + f.name + "("
  mu j := 0
  lp j < len(f.params) {
    if j > 0 { out = out + ", " }
    out = out + "a" + int_to_str(j)
    j += 1
  }
  out + "); }\n"
}

// ===== codegen ==============================================================
fn op_c(op:i64) -> str {
  if op == OP_ADD() rt " + "
  if op == OP_SUB() rt " - "
  if op == OP_MUL() rt " * "
  if op == OP_DIV() rt " / "
  if op == OP_MOD() rt " % "
  if op == OP_LT() rt " < "
  if op == OP_GT() rt " > "
  if op == OP_LE() rt " <= "
  if op == OP_GE() rt " >= "
  if op == OP_EQ() rt " == "
  if op == OP_NE() rt " != "
  if op == OP_AND() rt " && "
  if op == OP_OR() rt " || "
  if op == OP_SHL() rt " << "
  if op == OP_SHR() rt " >> "
  if op == OP_BAND() rt " & "
  if op == OP_BXOR() rt " ^ "
  if op == OP_BOR() rt " | "
  " ? "
}

// ===== type tracking =========================================================
// Codegen tracks a *type name* per binding — "i64", "str", or a struct name.
// `vty` maps varname → type; `fld` maps "Struct.field" → field's type; `ctors`
// records struct names → 1 so a `Name(...)` call is recognized as a constructor;
// `frets` maps user fn name → its return type (so `p := mk()` types `p`). All in
// one `Syms` threaded by pointer (AiLang fns return a single value). `has(vty,n)`
// also means "already declared" → declare-once for `:=`/`mu` vs `=`.
st Syms {
  vty: {str:str}      // varname → "i64" / "str" / StructName / "*T" / "[T]" / "{K:V}" / EnumName
  fld: {str:str}      // "Struct.field" → field type
  ctors: {str:str}    // StructName → "1"
  frets: {str:str}    // fn name → return type name
  evar: {str:str}     // VariantName → EnumName (so a `Variant(args)` call is recognized)
  vft: {str:str}      // VariantName → ";"-joined field type names ("" for a unit variant)
  gfns: [Func]        // generic functions (tparams non-empty) — inlined at call sites
  lams: [Func]        // lifted first-class lambdas (name=<lamid>, ptypes all i64, ret=body type, body=[SReturn(b)]); ordered registry driving deterministic env/__lam emission. Captures ride evar["@lamcaps.<id>"]/["@lamcapt.<id>"].
}

fn ty_of(sy:*Syms, name:str) -> str {
  if has(sy.vty, name) rt sy.vty[name]
  if is_variant(sy, name) rt sy.evar[name]    // a bare nullary variant → its enum
  "i64"
}
fn declared(sy:*Syms, name:str) -> bool { has(sy.vty, name) }
fn set_ty(sy:*Syms, name:str, ty:str) { sy.vty[name] = ty }
fn is_ctor(sy:*Syms, name:str) -> bool { has(sy.ctors, name) }
fn is_variant(sy:*Syms, name:str) -> bool { has(sy.evar, name) }

// Field key joins a struct + field name into the `fld` map key.
fn fkey(sname:str, fname:str) -> str { sname + "." + fname }

// The C suffix for an element type, used in the monomorphic `arr_<suffix>`
// helpers. i64/str keep their name; a struct keeps its name (matches its
// typedef's `s_<name>` only after `cty`, so we use the bare name for the
// suffix). Array-of-array would nest; not needed yet.
fn arr_suffix(ety:str) -> str { if ety == "bool" { "i64" } el { ety } }   // bool reuses the i64 array/result runtime

// The C type spelling for a bootstrap type name.
// A C header type (from `cinc` + `ex fn`, e.g. `div_t`) is encoded "@c:<name>"
// so it spells RAW in C (no `s_` prefix — it isn't an AiLang struct). Marked on
// extern signatures by `mark_extern_ctypes` once all user structs/enums are known.
fn is_c_type_ann(ty:str) -> bool { len(ty) >= 3 && ty[0] == 64 && ty[1] == 99 && ty[2] == 58 }  // "@c:"
fn c_type_name(ty:str) -> str { substring(ty, 3, len(ty)) }

fn cty(ty:str) -> str {
  if is_c_type_ann(ty) rt c_type_name(ty)        // header type → raw, before the s_ fallback
  if ty == "i64" rt "int64_t"
  if ty == "bool" rt "int64_t"     // AiLang bool is a truthy int (true→1/false→0)
  if ty == "i32" rt "int64_t"      // libc-int extern returns widen to i64
  if ty == "u32" rt "uint32_t"     // unsigned 32-bit (e.g. srand)
  if ty == "f64" rt "double"
  if ty == "bytes" rt "ailang_bytes"
  if ty == "str" rt "const char*"
  if is_array_ann(ty) rt "arr_" + arr_suffix(elem_of_ann(ty))   // [T] → arr_T
  if is_map_ann(ty) rt map_cty(ty)                               // {K:V} → map_<suffix>
  if is_ptr_ann(ty) rt cty(deref_ann(ty)) + "*"                  // *T → <cty(T)>*
  if is_result_ann(ty) rt "res_" + arr_suffix(result_inner(ty)) // !T → res_T
  if is_fn_ann(ty) rt "closure_t"                               // fn(...)->R → closure_t
  if is_tuple_ann(ty) rt "tup_" + tuple_suffix(ty)              // (T1;T2) → tup_T1_T2
  "s_" + ty               // a struct → its typedef name
}

// Map type-name helpers for `{K:V}`. The C runtime type is `map_<ksuf>_<vsuf>`
// (map_str_str / map_str_i64 / map_i64_i64 / map_i64_str …) where each suffix is
// arr_suffix(type-name). `map_ktype`/`map_vtype` split out K / V.
fn map_vtype(ty:str) -> str {
  // ty is "{K:V}" — return the part after the ':' up to the closing '}'.
  mu i := 1
  lp i < len(ty) { if ty[i] == 58 { br } i += 1 }   // find ':'
  substring(ty, i + 1, len(ty) - 1)
}
fn map_ktype(ty:str) -> str {
  // ty is "{K:V}" — return K (after '{' up to ':').
  mu i := 1
  lp i < len(ty) { if ty[i] == 58 { br } i += 1 }   // find ':'
  substring(ty, 1, i)
}
fn map_cty(ty:str) -> str {
  map_nm(map_ktype(ty), map_vtype(ty))    // same name builder the runtime emits
}

// ----- static type of an expression (the type name it produces) -------------
fn type_of_expr(sy:*Syms, e:Expr) -> str {
  mt e {
    Num(v)           => "i64";
    Flt(fs)          => "f64";
    Str(s)           => "str";
    Var(name)        => ty_of(sy, name);
    Bin(op,l,r)      => bin_type(sy, op, l, r);
    Unary(op,x)      => "i64";
    Call(fname,args) => call_type_a(sy, fname, args);
    Field(obj,fnm)   => field_type(sy, obj, fnm);
    Index(obj,idx)   => index_type(sy, obj);
    Array(elems,ety) => array_type_of(sy, elems, ety);
    MapLit(mty,mks,mvs) => maplit_type(sy, mty, mks, mvs);
    Addr(x)          => "*" + type_of_expr(sy, x);
    Match(sc,vn,vb,bd) => match_type(sy, bd);
    IfE(c,t,el2)     => type_of_expr(sy, t);
    Try(e)           => result_inner(type_of_expr(sy, e));
    Lambda(ps,pts,b,id)  => lambda_type(sy, ps, pts, b);
    Tuple(elems)     => tuple_type_of(sy, elems);
    BlockE(body)     => block_type(sy, body);
    Bad              => "i64";
  }
}

// A match's type = its first arm's body type. (The subset's matches are
// homogeneous; codegen would clash at C level if not.)
fn match_type(sy:*Syms, bodies:[Expr]) -> str {
  if len(bodies) > 0 rt type_of_expr(sy, bodies[0])
  "i64"
}

// Type produced by `obj[idx]`: an array's element type, a map's value type, or
// a string's byte (i64).
fn index_type(sy:*Syms, obj:Expr) -> str {
  t := type_of_expr(sy, obj)
  if is_array_ann(t) rt elem_of_ann(t)
  if is_map_ann(t) rt map_vtype(t)
  "i64"                     // string byte, or unknown
}

// The array type "[T]" produced by a literal: from the annotation if present,
// else inferred from the first element.
fn array_type_of(sy:*Syms, elems:[Expr], ety:str) -> str {
  if len(ety) > 0 { rt "[" + ety + "]" }
  if len(elems) > 0 { rt "[" + type_of_expr(sy, elems[0]) + "]" }
  "[i64]"
}

// The map type produced by a `{}` literal: its annotation, or default {str:str}.
fn map_lit_type(mty:str) -> str {
  if len(mty) > 0 rt mty
  "{str:str}"
}

fn bin_type(sy:*Syms, op:i64, l:Expr, r:Expr) -> str {
  if op == OP_CAT() rt "str"        // `++` always concatenates strings
  if op == OP_QQ() rt type_of_expr(sy, l)   // `m[k] ?? d` → the map's value type
  // `+` on two strings is concat → str.
  if op == OP_ADD() && type_of_expr(sy, l) == "str" && type_of_expr(sy, r) == "str" {
    rt "str"
  }
  // arithmetic with an f64 operand is f64 (comparisons/logic stay i64-bool).
  if op == OP_ADD() || op == OP_SUB() || op == OP_MUL() || op == OP_DIV() {
    if type_of_expr(sy, l) == "f64" || type_of_expr(sy, r) == "f64" { rt "f64" }
  }
  if op >= OP_LT() && op <= OP_OR() rt "bool"   // 5..12: < > <= >= == != && || → bool
  "i64"
}

// TLS / Postgres native builtins all lower to `fname(args)` (the C helper shares
// the name, no polymorphism), so they share one dispatch arm + grouped type rules
// instead of ~26 identical per-builtin arms.
fn is_native_call(fname:str) -> bool {
  if fname == "tls_server_ctx" || fname == "tls_client_ctx" || fname == "tls_free_ctx" || fname == "tls_accept" || fname == "tls_connect_fd" || fname == "tls_send" || fname == "tls_send_str" || fname == "tls_recv" || fname == "tls_close" || fname == "tls_error" || fname == "sha1" rt true
  if fname == "pg_connect" || fname == "pg_status" || fname == "pg_error" || fname == "pg_close" || fname == "pg_exec" || fname == "pg_ok" || fname == "pg_result_error" || fname == "pg_clear" || fname == "pg_nrows" || fname == "pg_ncols" || fname == "pg_value" || fname == "pg_isnull" || fname == "pg_col_name" || fname == "pg_affected" || fname == "pg_escape" rt true
  false
}

fn call_type_a(sy:*Syms, fname:str, args:[Expr]) -> str {
  // A generic call's type: its return type with the type param substituted.
  if is_generic(sy, fname) {
    f := find_gfn(sy, fname)
    gt := generic_T(sy, f, args)
    if is_tparam(f, f.ret) rt gt
    rt f.ret
  }
  // HOFs: map → [body-type] (param typed from the array elem first); filter →
  // same array type; reduce → the accumulator/init type.
  if fname == "map" && len(args) == 2 {
    et := elem_of_ann(type_of_expr(sy, args[0]))
    ps := lam_params(args[1])
    set_ty(sy, ps[0], et)
    rt "[" + type_of_expr(sy, lam_body(args[1])) + "]"
  }
  if fname == "filter" && len(args) == 2 { rt type_of_expr(sy, args[0]) }
  if fname == "reduce" && len(args) == 3 { rt type_of_expr(sy, args[1]) }
  if fname == "to_str" rt "str"
  if fname == "cstr" rt "str"                          // str passthrough (`s.cstr`)
  if fname == "print" || fname == "println" rt "i64"   // printf-returns-int (expression form)
  if fname == "int_to_str" rt "str"
  if fname == "str_to_int" rt "i64"
  if fname == "float_to_str" rt "str"
  if fname == "str_to_float" rt "f64"
  if fname == "substring" rt "str"
  if fname == "read_file" rt "str"
  if fname == "write_file" rt "bool"   // success flag — ailangc prints true/false
  if fname == "str_to_bytes" rt "bytes"
  if fname == "bytes_to_str" rt "str"
  if fname == "bytes_at" rt "i64"
  if fname == "bytes_slice" rt "bytes"
  if fname == "read_file_bytes" rt "bytes"
  if fname == "write_file_bytes" rt "i64"
  if fname == "args" rt "[str]"
  if fname == "len" rt "i64"
  // `!T` result helpers: ok(x):!Tx; err_<T>(m):!T; unwrap(r):T; is_*/err_msg.
  if fname == "ok" && len(args) > 0 { rt "!" + type_of_expr(sy, args[0]) }
  if fname == "err" && len(args) > 0 { rt "!" + ty_of(sy, "@ret") }   // generic err → enclosing !T
  if fname == "unwrap" && len(args) > 0 { rt result_inner(type_of_expr(sy, args[0])) }
  if fname == "is_ok" || fname == "is_err" rt "bool"
  if fname == "err_msg" rt "str"
  if len(fname) > 4 && substring(fname, 0, 4) == "err_" rt "!" + substring(fname, 4, len(fname))
  if fname == "keys" && len(args) > 0 rt "[" + map_ktype(type_of_expr(sy, args[0])) + "]"
  if fname == "values" && len(args) > 0 { rt "[" + map_vtype(type_of_expr(sy, args[0])) + "]" }
  // push/slice/reverse/sort return the same array type as their first arg.
  if (fname == "push" || fname == "slice" || fname == "reverse" || fname == "sort") && len(args) > 0 {
    rt type_of_expr(sy, args[0])
  }
  // Phase 1 builtins: predicates/indices → i64; string transforms → str.
  if fname == "starts_with" || fname == "ends_with" || fname == "contains" || fname == "str_to_bool" || fname == "has" rt "bool"
  if fname == "index_of" || fname == "ord" || fname == "sign" || fname == "clamp" rt "i64"
  if fname == "to_upper" || fname == "to_lower" || fname == "trim" || fname == "replace" || fname == "repeat" || fname == "pad_left" || fname == "pad_right" || fname == "chr" || fname == "read_line" || fname == "get_env" || fname == "format" || fname == "join" rt "str"
  if fname == "split" rt "[str]"
  // Phase 2 native builtins: time / sockets / process / regex.
  if fname == "now_ms" || fname == "now_us" || fname == "mono_ms" || fname == "sleep_ms" rt "i64"
  if fname == "time_iso" rt "str"
  if fname == "tcp_listen" || fname == "tcp_accept" || fname == "tcp_connect" || fname == "sock_send" || fname == "sock_send_str" || fname == "sock_close" rt "i64"
  if fname == "sock_recv" rt "bytes"
  if fname == "proc_fork" || fname == "proc_getpid" || fname == "proc_no_zombies" || fname == "proc_reap" rt "i64"
  if fname == "regex_match" rt "bool"
  if fname == "regex_find" rt "str"
  if fname == "abs" && len(args) > 0 rt type_of_expr(sy, args[0])   // i64 or f64
  if fname == "abs_i64" rt "i64"
  if fname == "abs_f64" rt "f64"
  if fname == "pop" && len(args) > 0 rt type_of_expr(sy, args[0])   // same array type
  // Phase 3 TLS/PG return types (grouped); everything else native → i64.
  if fname == "tls_error" || fname == "pg_error" || fname == "pg_result_error" || fname == "pg_value" || fname == "pg_col_name" || fname == "pg_escape" rt "str"
  if fname == "tls_recv" || fname == "sha1" rt "bytes"
  if fname == "pg_ok" || fname == "pg_isnull" rt "bool"
  if is_native_call(fname) rt "i64"        // handles / counts / status (incl. void→i64)
  if is_ctor(sy, fname) rt fname           // a struct ctor produces that struct
  if is_variant(sy, fname) rt sy.evar[fname]   // a variant ctor produces its enum
  // a closure-typed local called as `f(...)` yields its fn-type's return type
  if has(sy.vty, fname) && is_fn_ann(sy.vty[fname]) rt fn_ret_of(sy.vty[fname])
  if has(sy.frets, fname) rt sy.frets[fname]
  "i64"
}

fn field_type(sy:*Syms, obj:Expr, fname:str) -> str {
  sty := under_ptr(type_of_expr(sy, obj))      // look through a *T
  k := fkey(sty, fname)
  if has(sy.fld, k) rt sy.fld[k]
  "i64"
}

fn expr_is_str(e:Expr, sy:*Syms) -> bool { type_of_expr(sy, e) == "str" }

// ===== expression codegen ====================================================
fn gen_args(sy:*Syms, args:[Expr]) -> str {
  mu out := ""
  mu i := 0
  lp i < len(args) {
    if i > 0 { out = out + ", " }
    out = out + gen_expr(sy, args[i])
    i += 1
  }
  out
}

// Re-quote a string literal's inner content as a C string literal (escapes were
// kept raw by the lexer, so the content is already C-safe; just wrap in quotes).
fn gen_str(s:str) -> str { "\"" + s + "\"" }

// A bare identifier: a nullary enum variant (`Bad`, `SBreak`) constructs via
// `mkv_<name>()`; anything else is a local/param `v_<name>`.
fn gen_var(sy:*Syms, name:str) -> str {
  if is_variant(sy, name) rt "mkv_" + name + "()"
  "v_" + name
}

fn gen_expr(sy:*Syms, e:Expr) -> str {
  mt e {
    Num(v)           => int_to_str(v);
    Flt(fs)          => fs;
    Str(s)           => gen_str(s);
    Var(name)        => gen_var(sy, name);
    Bin(op,l,r)      => gen_bin(sy, op, l, r);
    Unary(op,x)      => "(!" + gen_expr(sy, x) + ")";
    Call(fname,args) => gen_call(sy, fname, args);
    Field(obj,fnm)   => gen_field(sy, obj, fnm);
    Index(obj,idx)   => gen_index(sy, obj, idx);
    Array(elems,ety) => gen_array(sy, elems, ety);
    MapLit(mty,mks,mvs) => gen_maplit(sy, mty, mks, mvs);
    Addr(x)          => "(&" + gen_expr(sy, x) + ")";
    Match(sc,vn,vb,bd) => gen_match(sy, sc, vn, vb, bd);
    IfE(c,t,el2)     => gen_ife(sy, c, t, el2);
    Try(e)           => gen_try(sy, e);
    Lambda(ps,pts,b,id)  => gen_lambda(sy, id);
    Tuple(elems)     => gen_tuple_lit(sy, elems);
    BlockE(body)     => gen_block_e(sy, body);
    Bad              => "0";
  }
}

// `if c { t } el { e }` as a value → a GNU statement-expression, like gen_match.
// The result type is the then-branch's (branches are homogeneous in the subset).
fn gen_ife(sy:*Syms, c:Expr, t:Expr, el2:Expr) -> str {
  rty := type_of_expr(sy, t)
  "({ " + cty(rty) + " __r; if (" + gen_expr(sy, c) + ") { __r = " + gen_expr(sy, t) + "; } else { __r = " + gen_expr(sy, el2) + "; } __r; })"
}

// `e?` → evaluate the result; on err, re-wrap into the *enclosing* fn's result
// type (`@ret`, seeded per fn) and early-return; on ok, yield the unwrapped value.
fn gen_try(sy:*Syms, e:Expr) -> str {
  rcty := cty(type_of_expr(sy, e))          // res_<Te>
  fret := ty_of(sy, "@ret")                 // enclosing fn's ok type
  "({ " + rcty + " __t = " + gen_expr(sy, e) + "; if(__t.tag) return mk_err_" + arr_suffix(fret) + "(__t.err); __t.ok; })"
}

// `mt scrut { Variant(b…) => body; … }` → a GNU statement-expression:
//   ({ T __m; ScrutTy __s = <scrut>; if(__s.tag==K0){ binds…; __m=arm0; }
//      else if(…){…} __m; })
// Variant bindings read `__s.u.<Variant>.f<i>` (a recursive/self-ref field is
// stored boxed, so it's dereferenced). The scrutinee type drives tag indices.
fn gen_match(sy:*Syms, sc:Expr, vnames:[str], vbinds:[str], bodies:[Expr]) -> str {
  sty := type_of_expr(sy, sc)                 // the enum type name
  // Type arm-0's bindings before inferring the result type: the result type is
  // arm-0's body type, which may itself BE a binding (e.g. `Lambda(ps,b) => ps`,
  // where `ps:[str]`). Without this the `__m` decl would default to i64 and the
  // arm assignment `__m = <arr_str>` would be a C type error.
  if len(vnames) > 0 { bind_arm_types(sy, vnames[0], split_semi(vbinds[0])) }
  rty := match_type(sy, bodies)
  mu out := "({ " + cty(rty) + " __m; " + cty(sty) + " __s = " + gen_expr(sy, sc) + "; "
  mu i := 0
  lp i < len(vnames) {
    vname := vnames[i]
    binds := split_semi(vbinds[i])
    tag := variant_tag(sy, sty, vname)
    kw := if i == 0 { "if" } el { "else if" }
    out = out + kw + "(__s.tag==" + int_to_str(tag) + "){ "
    out = out + gen_arm_binds(sy, vname, binds)
    // type the binds so the body's gen_expr knows their types
    bind_arm_types(sy, vname, binds)
    out = out + "__m = " + gen_expr(sy, bodies[i]) + "; } "
    i += 1
  }
  out + "__m; })"
}

// Emit the C locals for an arm's variant bindings, reading from the union and
// dereferencing a boxed (self-recursive) field.
fn gen_arm_binds(sy:*Syms, vname:str, binds:[str]) -> str {
  ftypes := split_semi(sy.vft[vname])
  mu out := ""
  mu i := 0
  lp i < len(binds) {
    ft := if i < len(ftypes) { ftypes[i] } el { "i64" }
    src := "__s.u." + vname + ".f" + int_to_str(i)
    rhs := if is_boxed_ft(ft) { "*(" + src + ")" } el { src }
    cft := if is_boxed_ft(ft) { cty(boxed_enum(ft, sy.evar[vname])) } el { cty(ft) }
    out = out + cft + " v_" + binds[i] + " = " + rhs + "; "
    i += 1
  }
  out
}

// Set the arm bindings' types in `sy` so the arm body types correctly.
fn bind_arm_types(sy:*Syms, vname:str, binds:[str]) {
  ftypes := split_semi(sy.vft[vname])
  mu i := 0
  lp i < len(binds) {
    ft := if i < len(ftypes) { ftypes[i] } el { "i64" }
    rt2 := if is_boxed_ft(ft) { boxed_enum(ft, sy.evar[vname]) } el { ft }
    set_ty(sy, binds[i], rt2)
    i += 1
  }
}

// The 0-based tag index of `vname` within its enum, found via the variant order
// recorded at parse time (`evar["@order." + sty]` is a ";"-joined variant list).
// Stored in `evar` (not `vty`) because the per-fn var map is wiped each function
// while the enum registry must survive — see `compile_to_c`.
fn variant_tag(sy:*Syms, sty:str, vname:str) -> i64 {
  order := split_semi(sy.evar["@order." + sty])
  mu i := 0
  lp i < len(order) {
    if order[i] == vname rt i
    i += 1
  }
  0
}

// Split a ";"-joined string into its parts ([] for an empty string).
fn split_semi(s:str) -> [str] {
  mu out:[str] := []
  if len(s) == 0 rt out
  mu start := 0
  mu i := 0
  lp i < len(s) {
    if s[i] == 59 {                  // ';'
      out = push(out, substring(s, start, i))
      start = i + 1
    }
    i += 1
  }
  out = push(out, substring(s, start, len(s)))
  out
}

// `obj.field`: if obj is a pointer (`*T`), use `->`; else `.`.
fn gen_field(sy:*Syms, obj:Expr, fnm:str) -> str {
  if is_ptr_ann(type_of_expr(sy, obj)) {
    rt "(" + gen_expr(sy, obj) + ")->" + fnm
  }
  "(" + gen_expr(sy, obj) + ")." + fnm
}

// `xs[i]` → `arr_<T>_get(xs,i)`; `m[k]` → `map_<v>_get(m,k)`; `s[i]` on a string
// → the i-th byte. Dispatch by the container's static type.
fn gen_index(sy:*Syms, obj:Expr, idx:Expr) -> str {
  ot := type_of_expr(sy, obj)
  if is_array_ann(ot) {
    rt "arr_" + arr_suffix(elem_of_ann(ot)) + "_get(" + gen_expr(sy, obj) + ", " + gen_expr(sy, idx) + ")"
  }
  if is_map_ann(ot) {
    rt map_cty(ot) + "_get(" + gen_expr(sy, obj) + ", " + gen_expr(sy, idx) + ")"
  }
  if ot == "bytes" {
    rt "bytes_at(" + gen_expr(sy, obj) + ", " + gen_expr(sy, idx) + ")"
  }
  if ot == "str" {
    rt "((int64_t)(unsigned char)(" + gen_expr(sy, obj) + ")[" + gen_expr(sy, idx) + "])"
  }
  "0"
}

// An array literal builds a fresh array then pushes each element:
//   ({ arr_T a = arr_T_new(); a = arr_T_push(a, e0); …; a; })
fn gen_array(sy:*Syms, elems:[Expr], ety:str) -> str {
  at := array_type_of(sy, elems, ety)
  suf := arr_suffix(elem_of_ann(at))
  mu out := "({ arr_" + suf + " __a = arr_" + suf + "_new(); "
  mu i := 0
  lp i < len(elems) {
    out = out + "__a = arr_" + suf + "_push(__a, " + gen_expr(sy, elems[i]) + "); "
    i += 1
  }
  out + "__a; })"
}

// `{}` / `{k:v, …}` literal: (K,V) from the entries (or the annotation if empty),
// then a statement-expr that news the map and `_set`s each entry (like gen_array).
fn maplit_type(sy:*Syms, mty:str, keys:[Expr], vals:[Expr]) -> str {
  if len(keys) > 0 rt "{" + type_of_expr(sy, keys[0]) + ":" + type_of_expr(sy, vals[0]) + "}"
  map_lit_type(mty)
}
fn gen_maplit(sy:*Syms, mty:str, keys:[Expr], vals:[Expr]) -> str {
  mc := map_cty(maplit_type(sy, mty, keys, vals))
  if len(keys) == 0 rt mc + "_new()"
  mu out := "({ " + mc + " __ml = " + mc + "_new(); "
  mu i := 0
  lp i < len(keys) {
    out = out + mc + "_set(__ml, " + gen_expr(sy, keys[i]) + ", " + gen_expr(sy, vals[i]) + "); "
    i += 1
  }
  out + "__ml; })"
}

// ----- lambdas + higher-order builtins (map/filter/reduce) ------------------
// Lambdas are not first-class values here; they're INLINED into the loop a
// map/filter/reduce generates, so captured outer vars stay in scope for free
// (no env struct / fn pointer). `lam_params`/`lam_body` pull the parts out (the
// arg is always a Lambda by construction; the other arms are dead but the match
// must be total).
fn empty_strs() -> [str] { mu e:[str] := []; e }
fn no_exprs() -> [Expr] { mu e:[Expr] := []; e }   // typed empty [Expr] for ctor args
fn lam_params(e:Expr) -> [str] {
  mt e {
    Lambda(ps,pts,b,id)  => ps;
    Num(v)           => empty_strs();
    Flt(s)           => empty_strs();
    Str(s)           => empty_strs();
    Var(n)           => empty_strs();
    Bin(o,l,r)       => empty_strs();
    Unary(o,x)       => empty_strs();
    Call(f,a)        => empty_strs();
    Field(o,f)       => empty_strs();
    Index(o,i)       => empty_strs();
    Array(es,et)     => empty_strs();
    Tuple(tes)       => empty_strs();
    BlockE(bb)       => empty_strs();
    MapLit(m,mks,mvs) => empty_strs();
    Addr(x)          => empty_strs();
    Match(sc,vn,vb,bd) => empty_strs();
    IfE(c,t,el2)     => empty_strs();
    Try(x)           => empty_strs();
    Bad              => empty_strs();
  }
}
fn lam_body(e:Expr) -> Expr {
  mt e {
    Lambda(ps,pts,b,id)  => b;
    Tuple(tes)       => Bad;
    BlockE(bb)       => Bad;
    Num(v)           => Bad;
    Flt(s)           => Bad;
    Str(s)           => Bad;
    Var(n)           => Bad;
    Bin(o,l,r)       => Bad;
    Unary(o,x)       => Bad;
    Call(f,a)        => Bad;
    Field(o,f)       => Bad;
    Index(o,i)       => Bad;
    Array(es,et)     => Bad;
    MapLit(m,mks,mvs) => Bad;
    Addr(x)          => Bad;
    Match(sc,vn,vb,bd) => Bad;
    IfE(c,t,el2)     => Bad;
    Try(x)           => Bad;
    Bad              => Bad;
  }
}

// ----- closure capture analysis ---------------------------------------------
// `free_vars(b)` = the `Var` names appearing in a lambda body, deduped in
// first-seen order. The caller (`register_lam`) narrows these to actual captures
// (drop the lambda's own params + anything not a live enclosing local). MUST
// recurse every Expr arm — esp. Match arm bodies and a nested Lambda's body — or
// a capture is dropped and the lifted fn references an undeclared `v_<cap>`.
fn is_param(ps:[str], nm:str) -> bool {
  mu i := 0
  lp i < len(ps) { if ps[i] == nm rt true   i += 1 }
  false
}
fn fv_add(acc:[str], name:str) -> [str] {
  mu i := 0
  lp i < len(acc) { if acc[i] == name rt acc   i += 1 }   // already seen
  push(acc, name)
}
fn fv_args(args:[Expr], acc:[str]) -> [str] {
  mu a := acc
  mu i := 0
  lp i < len(args) { a = fv_walk(args[i], a); i += 1 }
  a
}
fn fv_walk(e:Expr, acc:[str]) -> [str] {
  mt e {
    Var(name)        => fv_add(acc, name);
    Num(v)           => acc;
    Flt(s)           => acc;
    Str(s)           => acc;
    MapLit(m,mks,mvs) => fv_args(mvs, fv_args(mks, acc));
    Bad              => acc;
    Bin(op,l,r)      => fv_walk(r, fv_walk(l, acc));
    Unary(op,x)      => fv_walk(x, acc);
    Call(fname,args) => fv_args(args, acc);            // fname is a fn, not a captured var
    Tuple(tes)       => fv_args(tes, acc);
    BlockE(bb)       => fv_body(bb, acc);                 // block-body lambda: walk its stmts
    Field(obj,fnm)   => fv_walk(obj, acc);
    Index(obj,idx)   => fv_walk(idx, fv_walk(obj, acc));
    Array(elems,ety) => fv_args(elems, acc);
    Addr(x)          => fv_walk(x, acc);
    Match(sc,vn,vb,bd) => fv_args(bd, fv_walk(sc, acc));   // scrutinee + every arm body
    IfE(c,t,el2)     => fv_walk(el2, fv_walk(t, fv_walk(c, acc)));
    Try(x)           => fv_walk(x, acc);
    Lambda(ps,pts,b,id)  => fv_walk(b, acc);                  // nested lambda body
  }
}
// Free vars inside a [Stmt] body — for a block-body lambda's capture analysis.
// Over-collects (block-local `:=`/loop vars included), but `register_lam`
// filters to actual enclosing locals, so bindings drop out harmlessly.
fn fv_body(body:[Stmt], acc:[str]) -> [str] {
  mu a := acc
  mu i := 0
  lp i < len(body) { a = fv_stmt(body[i], a); i += 1 }
  a
}
fn fv_stmt(s:Stmt, acc:[str]) -> [str] {
  mt s {
    SDecl(name,e)         => fv_walk(e, acc);
    SDestructure(names,e) => fv_walk(e, acc);
    SAssign(name,e)       => fv_walk(e, acc);
    SIdxAssign(o,ix,e)    => fv_walk(e, fv_walk(ix, fv_walk(o, acc)));
    SFieldAssign(o,f,e)   => fv_walk(e, fv_walk(o, acc));
    SReturn(e)            => fv_walk(e, acc);
    SPrint(e)             => fv_walk(e, acc);
    SExpr(e)              => fv_walk(e, acc);
    SIf(c,b,eb)           => fv_body(eb, fv_body(b, fv_walk(c, acc)));
    SLoop(c,b)            => fv_body(b, fv_walk(c, acc));
    SLoopIn(vnm,coll,b)   => fv_body(b, fv_walk(coll, acc));
    SLoopKV(kn,vn,coll,b) => fv_body(b, fv_walk(coll, acc));
    SLoopRange(v,lo,hi,b) => fv_body(b, fv_walk(hi, fv_walk(lo, acc)));
    SBreak                => acc;
    SContinue             => acc;
  }
}
fn free_vars(b:Expr) -> [str] { mu acc:[str] := []; fv_walk(b, acc) }

// map(arr, fn(x) e) → a fresh array of e applied to each element.
fn gen_map(sy:*Syms, arr:Expr, lam:Expr) -> str {
  at := type_of_expr(sy, arr)
  et := elem_of_ann(at)
  ps := lam_params(lam)
  set_ty(sy, ps[0], et)
  b := lam_body(lam)
  ut := type_of_expr(sy, b)
  usuf := arr_suffix(ut)
  tsuf := arr_suffix(et)
  mu o := "({ arr_" + usuf + " __hm = arr_" + usuf + "_new(); arr_" + tsuf + " __hs = " + gen_expr(sy, arr) + "; "
  o = o + "for(int64_t __hi=0; __hi<__hs.len; __hi++){ " + cty(et) + " v_" + ps[0] + " = __hs.data[__hi]; "
  o = o + "__hm = arr_" + usuf + "_push(__hm, " + gen_expr(sy, b) + "); } __hm; })"
  o
}

// filter(arr, fn(x) cond) → the elements where cond holds.
fn gen_filter(sy:*Syms, arr:Expr, lam:Expr) -> str {
  at := type_of_expr(sy, arr)
  et := elem_of_ann(at)
  ps := lam_params(lam)
  set_ty(sy, ps[0], et)
  b := lam_body(lam)
  tsuf := arr_suffix(et)
  mu o := "({ arr_" + tsuf + " __hm = arr_" + tsuf + "_new(); arr_" + tsuf + " __hs = " + gen_expr(sy, arr) + "; "
  o = o + "for(int64_t __hi=0; __hi<__hs.len; __hi++){ " + cty(et) + " v_" + ps[0] + " = __hs.data[__hi]; "
  o = o + "if(" + gen_expr(sy, b) + "){ __hm = arr_" + tsuf + "_push(__hm, v_" + ps[0] + "); } } __hm; })"
  o
}

// reduce(arr, init, fn(acc, x) e) → fold from init.
fn gen_reduce(sy:*Syms, arr:Expr, init:Expr, lam:Expr) -> str {
  at := type_of_expr(sy, arr)
  et := elem_of_ann(at)
  ut := type_of_expr(sy, init)
  ps := lam_params(lam)
  set_ty(sy, ps[0], ut)
  set_ty(sy, ps[1], et)
  b := lam_body(lam)
  tsuf := arr_suffix(et)
  mu o := "({ " + cty(ut) + " __ha = " + gen_expr(sy, init) + "; arr_" + tsuf + " __hs = " + gen_expr(sy, arr) + "; "
  o = o + "for(int64_t __hi=0; __hi<__hs.len; __hi++){ " + cty(ut) + " v_" + ps[0] + " = __ha; " + cty(et) + " v_" + ps[1] + " = __hs.data[__hi]; "
  o = o + "__ha = " + gen_expr(sy, b) + "; } __ha; })"
  o
}

// ----- generics (inlined, like lambdas) -------------------------------------
// A generic fn `id<T>(x:T) -> T` isn't a C function; each call inlines its body
// with params bound to the call's concrete types (so the body is only emitted
// for types it's used with). `is_generic` short-circuits when none exist.
fn is_generic(sy:*Syms, name:str) -> bool {
  if len(sy.gfns) == 0 rt false
  has(sy.evar, "@generic." + name)
}
fn is_tparam(f:Func, ty:str) -> bool {
  mu i := 0
  lp i < len(f.tparams) { if f.tparams[i] == ty rt true   i += 1 }
  false
}
fn is_array_tparam(f:Func, ty:str) -> bool {        // ty is `[T]` for a type param T?
  mu i := 0
  lp i < len(f.tparams) { if ty == "[" + f.tparams[i] + "]" rt true   i += 1 }
  false
}
fn subst_tparam(f:Func, ty:str, concrete:str) -> str {   // T→concrete, [T]→[concrete], else as-is
  mu i := 0
  lp i < len(f.tparams) {
    if ty == f.tparams[i] rt concrete
    if ty == "[" + f.tparams[i] + "]" rt "[" + concrete + "]"
    i += 1
  }
  ty
}
fn find_gfn(sy:*Syms, name:str) -> Func {
  mu i := 0
  lp i < len(sy.gfns) {
    if sy.gfns[i].name == name rt sy.gfns[i]
    i += 1
  }
  mu nob:[Stmt] := []
  mu noa:[str] := []
  Func("", noa, noa, "", "", noa, nob)
}
fn generic_T(sy:*Syms, f:Func, args:[Expr]) -> str {
  mu i := 0
  lp i < len(f.ptypes) {
    if i < len(args) {
      if is_tparam(f, f.ptypes[i]) rt type_of_expr(sy, args[i])                       // scalar `T` param
      if is_array_tparam(f, f.ptypes[i]) rt elem_of_ann(type_of_expr(sy, args[i]))    // `[T]` param → arg's elem type
    }
    i += 1
  }
  "i64"
}
fn inline_stmt_value(sy:*Syms, s:Stmt) -> str {
  mt s {
    SExpr(e)              => gen_expr(sy, e) + ";";
    SReturn(e)            => gen_expr(sy, e) + ";";
    SDestructure(names,e) => "0;";
    SDecl(name,e)         => "0;";
    SAssign(name,e)       => "0;";
    SIdxAssign(o,i,e)     => "0;";
    SFieldAssign(o,f,e)   => "0;";
    SPrint(e)             => "0;";
    SIf(c,b,eb)           => "0;";
    SLoop(c,b)            => "0;";
    SLoopIn(vnm,coll,b)   => "0;";
    SLoopKV(kn,vn,coll,b) => "0;";
    SLoopRange(v,lo,hi,b) => "0;";
    SBreak                => "0;";
    SContinue             => "0;";
  }
}
fn gen_generic_call(sy:*Syms, name:str, args:[Expr]) -> str {
  f := find_gfn(sy, name)
  gt := generic_T(sy, f, args)
  mu o := "({ "
  mu i := 0
  lp i < len(f.params) {
    pt := subst_tparam(f, f.ptypes[i], gt)   // substitutes both `T` and `[T]`
    set_ty(sy, f.params[i], pt)
    o = o + cty(pt) + " v_" + f.params[i] + " = " + gen_expr(sy, args[i]) + "; "
    i += 1
  }
  n := len(f.body)
  mu j := 0
  lp j < n - 1 { o = o + gen_stmt(sy, f.body[j], "") j += 1 }
  if n > 0 { o = o + inline_stmt_value(sy, f.body[n - 1]) }
  o + " })"
}

// ----- first-class closures -------------------------------------------------
// A `Lambda` used as a value emits a `closure_t {fn, env}` literal. Captures
// (names from evar["@lamcaps.<id>"]) are copied into a heap env; the RHS
// `v_<cap>` resolve in the enclosing scope where the literal appears.
fn gen_lambda(sy:*Syms, id:i64) -> str {
  idstr := int_to_str(id)
  caps := split_semi(sy.evar["@lamcaps." + idstr])
  if len(caps) == 0 {
    rt "((closure_t){ (void*)__lam_" + idstr + ", (void*)0 })"
  }
  mu out := "({ __env_" + idstr + "* __e = (__env_" + idstr + "*)GC_MALLOC(sizeof(__env_" + idstr + ")); "
  mu k := 0
  lp k < len(caps) { out = out + "__e->v_" + caps[k] + " = v_" + caps[k] + "; "; k += 1 }
  out + "((closure_t){ (void*)__lam_" + idstr + ", (void*)__e }); })"
}

// `f(a0, ...)` on a closure-typed local: call through the fn pointer with the
// env prepended. Cast spells the exact arity; args default to int64_t.
fn gen_closure_call(sy:*Syms, fname:str, ret:str, args:[Expr]) -> str {
  cv := gen_var(sy, fname)                     // "v_f"
  pts := fn_params_of(ty_of(sy, fname))        // the closure's declared param types
  mu cast := cty(ret) + " (*)(void*"
  mu k := 0
  lp k < len(args) {
    pt := if k < len(pts) { pts[k] } el { "i64" }
    cast = cast + ", " + cty(pt)
    k += 1
  }
  cast = cast + ")"
  mu out := "(((" + cast + ")(" + cv + ").fn)((" + cv + ").env"
  k = 0
  lp k < len(args) { out = out + ", " + gen_expr(sy, args[k]); k += 1 }
  out + "))"
}

// `to_str(x)` → i2s; struct ctor → mk_Name; `len`/`push` on an array → the
// monomorphic helper; any other call is a user fn → `f_<name>(args)`.
fn gen_call(sy:*Syms, fname:str, args:[Expr]) -> str {
  if is_generic(sy, fname) { rt gen_generic_call(sy, fname, args) }
  if fname == "map" && len(args) == 2 { rt gen_map(sy, args[0], args[1]) }
  if fname == "filter" && len(args) == 2 { rt gen_filter(sy, args[0], args[1]) }
  if fname == "reduce" && len(args) == 3 { rt gen_reduce(sy, args[0], args[1], args[2]) }
  if fname == "to_str" && len(args) == 1 {
    // Polymorphic stringify (drives string interpolation): str→itself, f64→%g,
    // bool→true/false, bytes→decode, else i64→i2s. Matches ailangc's _Generic.
    t := type_of_expr(sy, args[0])
    if t == "str" rt gen_expr(sy, args[0])
    if t == "f64" rt "f2s(" + gen_expr(sy, args[0]) + ")"
    if t == "bool" rt "((" + gen_expr(sy, args[0]) + ") ? \"true\" : \"false\")"
    if t == "bytes" rt "bytes_to_str(" + gen_expr(sy, args[0]) + ")"
    rt "i2s(" + gen_expr(sy, args[0]) + ")"
  }
  // `print(x)` — like println but no trailing newline (same type dispatch). Used
  // as an expression statement, so it returns the bare printf/print_bytes call.
  if fname == "print" && len(args) == 1 {
    t := type_of_expr(sy, args[0])
    if t == "str" rt "printf(\"%s\", " + gen_expr(sy, args[0]) + ")"
    if t == "f64" rt "printf(\"%g\", (double)(" + gen_expr(sy, args[0]) + "))"
    if t == "bool" rt "printf(\"%s\", (" + gen_expr(sy, args[0]) + ") ? \"true\" : \"false\")"
    if t == "bytes" rt "print_bytes(" + gen_expr(sy, args[0]) + ")"
    rt "printf(\"%lld\", (long long)(" + gen_expr(sy, args[0]) + "))"
  }
  // println as an EXPRESSION (e.g. a match/if arm body); the statement form is
  // SPrint. Same type dispatch as `print`, with a trailing newline.
  if fname == "println" && len(args) == 1 {
    t := type_of_expr(sy, args[0])
    if t == "str" rt "printf(\"%s\\n\", " + gen_expr(sy, args[0]) + ")"
    if t == "f64" rt "printf(\"%g\\n\", (double)(" + gen_expr(sy, args[0]) + "))"
    if t == "bool" rt "printf(\"%s\\n\", (" + gen_expr(sy, args[0]) + ") ? \"true\" : \"false\")"
    if t == "bytes" rt "(print_bytes(" + gen_expr(sy, args[0]) + "), putchar(10))"
    if is_map_ann(t) && is_scalar_ty(map_vtype(t)) rt "(" + map_cty(t) + "_print(" + gen_expr(sy, args[0]) + "), putchar(10))"
    rt "printf(\"%lld\\n\", (long long)(" + gen_expr(sy, args[0]) + "))"
  }
  if fname == "int_to_str" && len(args) == 1 {
    rt "i2s(" + gen_expr(sy, args[0]) + ")"
  }
  if fname == "str_to_int" && len(args) == 1 {
    rt "s2i(" + gen_expr(sy, args[0]) + ")"
  }
  if fname == "float_to_str" && len(args) == 1 {
    rt "f2s(" + gen_expr(sy, args[0]) + ")"
  }
  if fname == "str_to_float" && len(args) == 1 {
    rt "s2f(" + gen_expr(sy, args[0]) + ")"
  }
  // `cstr(s)` — str → C-string passthrough (AiLang str is already `const char*`),
  // so `s.cstr` lowers to a no-op. Matches ailangc's `cstr` builtin.
  if fname == "cstr" && len(args) == 1 {
    rt gen_expr(sy, args[0])
  }
  if fname == "substring" && len(args) == 3 {
    rt "substr(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ", " + gen_expr(sy, args[2]) + ")"
  }
  if fname == "read_file" && len(args) == 1 {
    rt "read_file_c(" + gen_expr(sy, args[0]) + ")"
  }
  if fname == "write_file" && len(args) == 2 {
    rt "write_file_c(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ")"
  }
  // bytes builtins map 1:1 onto same-named C prelude helpers.
  if fname == "str_to_bytes" && len(args) == 1 {
    rt "str_to_bytes(" + gen_expr(sy, args[0]) + ")"
  }
  if fname == "bytes_to_str" && len(args) == 1 {
    rt "bytes_to_str(" + gen_expr(sy, args[0]) + ")"
  }
  if fname == "bytes_at" && len(args) == 2 {
    rt "bytes_at(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ")"
  }
  if fname == "bytes_slice" && len(args) == 3 {
    rt "bytes_slice(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ", " + gen_expr(sy, args[2]) + ")"
  }
  if fname == "read_file_bytes" && len(args) == 1 {
    rt "read_file_bytes(" + gen_expr(sy, args[0]) + ")"
  }
  if fname == "write_file_bytes" && len(args) == 2 {
    rt "write_file_bytes(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ")"
  }
  if fname == "args" && len(args) == 0 {
    rt "ailang_args()"
  }
  if fname == "exit" && len(args) == 1 {
    rt "exit((int)(" + gen_expr(sy, args[0]) + "))"
  }
  // `!T` result helpers. `ok(x)` monomorphizes on x's type; `err_<T>(m)` on the
  // name suffix; inspectors read the {tag, ok, err} struct directly.
  if fname == "ok" && len(args) == 1 {
    rt "mk_ok_" + arr_suffix(type_of_expr(sy, args[0])) + "(" + gen_expr(sy, args[0]) + ")"
  }
  if fname == "err" && len(args) == 1 {     // generic err(m) → mk_err_<enclosing !T>
    rt "mk_err_" + arr_suffix(ty_of(sy, "@ret")) + "(" + gen_expr(sy, args[0]) + ")"
  }
  if fname == "unwrap" && len(args) == 1 {
    rt "(" + gen_expr(sy, args[0]) + ").ok"
  }
  if fname == "is_ok" && len(args) == 1 {
    rt "((" + gen_expr(sy, args[0]) + ").tag==0)"
  }
  if fname == "is_err" && len(args) == 1 {
    rt "((" + gen_expr(sy, args[0]) + ").tag!=0)"
  }
  if fname == "err_msg" && len(args) == 1 {
    rt "(" + gen_expr(sy, args[0]) + ").err"
  }
  if len(fname) > 4 && substring(fname, 0, 4) == "err_" && len(args) == 1 {
    rt "mk_err_" + substring(fname, 4, len(fname)) + "(" + gen_expr(sy, args[0]) + ")"
  }
  if fname == "len" && len(args) == 1 {
    t := type_of_expr(sy, args[0])
    if is_array_ann(t) {
      rt "arr_" + arr_suffix(elem_of_ann(t)) + "_len(" + gen_expr(sy, args[0]) + ")"
    }
    if t == "bytes" { rt "(" + gen_expr(sy, args[0]) + ").len" }
    if is_map_ann(t) { rt map_cty(t) + "_len(" + gen_expr(sy, args[0]) + ")" }
    rt "((int64_t)strlen(" + gen_expr(sy, args[0]) + "))"     // len of a string
  }
  if fname == "push" && len(args) == 2 {
    t := type_of_expr(sy, args[0])
    if is_array_ann(t) {
      suf := arr_suffix(elem_of_ann(t))
      rt "arr_" + suf + "_push(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ")"
    }
  }
  if fname == "has" && len(args) == 2 {
    t := type_of_expr(sy, args[0])
    if is_map_ann(t) {
      rt map_cty(t) + "_has(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ")"
    }
  }
  if fname == "slice" && len(args) == 3 {
    t := type_of_expr(sy, args[0])
    if is_array_ann(t) {
      rt "arr_" + arr_suffix(elem_of_ann(t)) + "_slice(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ", " + gen_expr(sy, args[2]) + ")"
    }
  }
  if fname == "reverse" && len(args) == 1 {
    t := type_of_expr(sy, args[0])
    if is_array_ann(t) {
      rt "arr_" + arr_suffix(elem_of_ann(t)) + "_reverse(" + gen_expr(sy, args[0]) + ")"
    }
  }
  if fname == "sort" && len(args) == 1 {
    t := type_of_expr(sy, args[0])
    if is_array_ann(t) {
      rt "arr_" + arr_suffix(elem_of_ann(t)) + "_sort(" + gen_expr(sy, args[0]) + ")"
    }
  }
  if (fname == "keys" || fname == "values") && len(args) == 1 {
    t := type_of_expr(sy, args[0])
    if is_map_ann(t) {
      rt map_cty(t) + "_" + fname + "(" + gen_expr(sy, args[0]) + ")"
    }
  }
  // ===== Phase 1 string / numeric / io builtins (codegen) =====
  if fname == "starts_with" && len(args) == 2 { rt "starts_with(" + gen_args(sy, args) + ")" }
  if fname == "ends_with" && len(args) == 2 { rt "ends_with(" + gen_args(sy, args) + ")" }
  if fname == "to_upper" && len(args) == 1 { rt "to_upper(" + gen_expr(sy, args[0]) + ")" }
  if fname == "to_lower" && len(args) == 1 { rt "to_lower(" + gen_expr(sy, args[0]) + ")" }
  if fname == "trim" && len(args) == 1 { rt "trim(" + gen_expr(sy, args[0]) + ")" }
  if fname == "replace" && len(args) == 3 { rt "str_replace(" + gen_args(sy, args) + ")" }
  if fname == "repeat" && len(args) == 2 { rt "repeat(" + gen_args(sy, args) + ")" }
  if fname == "pad_left" && len(args) == 3 { rt "pad_left(" + gen_args(sy, args) + ")" }
  if fname == "pad_right" && len(args) == 3 { rt "pad_right(" + gen_args(sy, args) + ")" }
  if fname == "chr" && len(args) == 1 { rt "chr(" + gen_expr(sy, args[0]) + ")" }
  if fname == "ord" && len(args) == 1 { rt "ord(" + gen_expr(sy, args[0]) + ")" }
  if fname == "str_to_bool" && len(args) == 1 { rt "str_to_bool(" + gen_expr(sy, args[0]) + ")" }
  if fname == "sign" && len(args) == 1 { rt "sign(" + gen_expr(sy, args[0]) + ")" }
  if fname == "clamp" && len(args) == 3 { rt "clamp(" + gen_args(sy, args) + ")" }
  if fname == "read_line" && len(args) == 0 { rt "read_line()" }
  if fname == "get_env" && len(args) == 1 { rt "get_env(" + gen_expr(sy, args[0]) + ")" }
  if fname == "split" && len(args) == 2 { rt "split(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ")" }
  // Phase 2 native builtins → same-named C helpers (gated into the prelude).
  if fname == "now_ms" && len(args) == 0 { rt "now_ms()" }
  if fname == "now_us" && len(args) == 0 { rt "now_us()" }
  if fname == "mono_ms" && len(args) == 0 { rt "mono_ms()" }
  if fname == "sleep_ms" && len(args) == 1 { rt "sleep_ms(" + gen_expr(sy, args[0]) + ")" }
  if fname == "time_iso" && len(args) == 1 { rt "time_iso(" + gen_expr(sy, args[0]) + ")" }
  if fname == "tcp_listen" && len(args) == 2 { rt "tcp_listen(" + gen_args(sy, args) + ")" }
  if fname == "tcp_accept" && len(args) == 1 { rt "tcp_accept(" + gen_args(sy, args) + ")" }
  if fname == "tcp_connect" && len(args) == 2 { rt "tcp_connect(" + gen_args(sy, args) + ")" }
  if fname == "sock_send" && len(args) == 2 { rt "sock_send(" + gen_args(sy, args) + ")" }
  if fname == "sock_send_str" && len(args) == 2 { rt "sock_send_str(" + gen_args(sy, args) + ")" }
  if fname == "sock_recv" && len(args) == 2 { rt "sock_recv(" + gen_args(sy, args) + ")" }
  if fname == "sock_close" && len(args) == 1 { rt "sock_close(" + gen_args(sy, args) + ")" }
  if fname == "proc_fork" && len(args) == 0 { rt "proc_fork()" }
  if fname == "proc_getpid" && len(args) == 0 { rt "proc_getpid()" }
  if fname == "proc_no_zombies" && len(args) == 0 { rt "proc_no_zombies()" }
  if fname == "proc_reap" && len(args) == 0 { rt "proc_reap()" }
  if fname == "regex_match" && len(args) == 2 { rt "regex_match(" + gen_args(sy, args) + ")" }
  if fname == "regex_find" && len(args) == 2 { rt "regex_find(" + gen_args(sy, args) + ")" }
  if fname == "format" && len(args) >= 1 { rt "format(" + gen_args(sy, args) + ")" }
  if fname == "abs" && len(args) == 1 {
    if type_of_expr(sy, args[0]) == "f64" { rt "abs_f64(" + gen_expr(sy, args[0]) + ")" }
    rt "abs_i64(" + gen_expr(sy, args[0]) + ")"
  }
  if fname == "abs_i64" && len(args) == 1 { rt "abs_i64(" + gen_expr(sy, args[0]) + ")" }
  if fname == "abs_f64" && len(args) == 1 { rt "abs_f64(" + gen_expr(sy, args[0]) + ")" }
  // contains / index_of: poly over string AND array (dispatch on arg[0]'s type).
  if fname == "contains" && len(args) == 2 {
    t := type_of_expr(sy, args[0])
    if is_array_ann(t) { rt "arr_" + arr_suffix(elem_of_ann(t)) + "_contains(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ")" }
    rt "str_contains(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ")"
  }
  if fname == "index_of" && len(args) == 2 {
    t := type_of_expr(sy, args[0])
    if is_array_ann(t) { rt "arr_" + arr_suffix(elem_of_ann(t)) + "_index_of(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ")" }
    rt "str_index_of(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ")"
  }
  if fname == "pop" && len(args) == 1 {
    t := type_of_expr(sy, args[0])
    if is_array_ann(t) { rt "arr_" + arr_suffix(elem_of_ann(t)) + "_pop(" + gen_expr(sy, args[0]) + ")" }
  }
  if fname == "join" && len(args) == 2 {
    t := type_of_expr(sy, args[0])
    if is_array_ann(t) { rt "arr_" + arr_suffix(elem_of_ann(t)) + "_join(" + gen_expr(sy, args[0]) + ", " + gen_expr(sy, args[1]) + ")" }
  }
  // Phase 3 TLS/PG native builtins → same-named C helper (gated into the prelude).
  if is_native_call(fname) { rt fname + "(" + gen_args(sy, args) + ")" }
  if is_ctor(sy, fname) {
    rt "mk_" + fname + "(" + gen_args(sy, args) + ")"
  }
  if is_variant(sy, fname) {
    rt "mkv_" + fname + "(" + gen_args(sy, args) + ")"   // variant constructor
  }
  // a closure-typed local called indirectly via its fn pointer (before the
  // user-fn `f_<name>` fallback, since a closure var shadows that path)
  if has(sy.vty, fname) && is_fn_ann(sy.vty[fname]) {
    rt gen_closure_call(sy, fname, fn_ret_of(sy.vty[fname]), args)
  }
  "f_" + fname + "(" + gen_args(sy, args) + ")"
}

// A `+` whose operands are strings lowers to a runtime `scat(a, b)` call;
// any other binary op is plain C infix. (Matches real AiLang: no int→str
// auto-coercion — int operands must be wrapped in `to_str` first.)
// `m[k] ?? d` — map get-or-default: read m[k] when key k is present, else d.
// A bare infix `??` would lower to nothing sensible; the value of `??` is the
// `has`-guarded read. A non-map index has no "absent" case, so it just reads.
fn gen_qq_index(sy:*Syms, obj:Expr, idx:Expr, r:Expr) -> str {
  ot := type_of_expr(sy, obj)
  if is_map_ann(ot) {
    rt "(" + map_cty(ot) + "_has(" + gen_expr(sy, obj) + ", " + gen_expr(sy, idx) + ") ? " + gen_index(sy, obj, idx) + " : " + gen_expr(sy, r) + ")"
  }
  gen_index(sy, obj, idx)
}
// `l ?? d`. Only a map-index l-value has a defined "absent" case; every other
// shape makes `??` a no-op yielding d (arms enumerated — the subset has no `_`).
fn gen_qq(sy:*Syms, l:Expr, r:Expr) -> str {
  mt l {
    Index(obj, idx)     => gen_qq_index(sy, obj, idx, r);
    Num(v)              => gen_expr(sy, r);
    Flt(fs)             => gen_expr(sy, r);
    Str(s)              => gen_expr(sy, r);
    Var(n)              => gen_expr(sy, r);
    Bin(o,a,b)          => gen_expr(sy, r);
    Unary(o,x)          => gen_expr(sy, r);
    Call(f,a)           => gen_expr(sy, r);
    Field(o,fnm)        => gen_expr(sy, r);
    Array(es,et)        => gen_expr(sy, r);
    MapLit(mlt,mks,mvs) => gen_expr(sy, r);
    Addr(x)             => gen_expr(sy, r);
    Match(sc,vn,vb,bd)  => gen_expr(sy, r);
    IfE(c,t,e2)         => gen_expr(sy, r);
    Try(e2)             => gen_expr(sy, r);
    Lambda(ps,pts,b,id) => gen_expr(sy, r);
    Tuple(tes)          => gen_expr(sy, r);
    BlockE(bb)          => gen_expr(sy, r);
    Bad                 => gen_expr(sy, r);
  }
}

fn gen_bin(sy:*Syms, op:i64, l:Expr, r:Expr) -> str {
  if op == OP_QQ() { rt gen_qq(sy, l, r) }   // `??` — map get-or-default
  if op == OP_ADD() && expr_is_str(l, sy) && expr_is_str(r, sy) {
    rt "scat(" + gen_expr(sy, l) + ", " + gen_expr(sy, r) + ")"
  }
  if op == OP_CAT() { rt "scat(" + gen_expr(sy, l) + ", " + gen_expr(sy, r) + ")" }   // `++` string concat
  // String equality must go through strcmp — a raw C `==` compares pointers, so
  // `tok == "en"` (heap string vs literal) would be false even when equal. This
  // is the crux of self-hosting: the bootstrap's keyword dispatch is all `str ==`.
  if op == OP_EQ() && expr_is_str(l, sy) && expr_is_str(r, sy) {
    rt "(strcmp(" + gen_expr(sy, l) + ", " + gen_expr(sy, r) + ") == 0)"
  }
  if op == OP_NE() && expr_is_str(l, sy) && expr_is_str(r, sy) {
    rt "(strcmp(" + gen_expr(sy, l) + ", " + gen_expr(sy, r) + ") != 0)"
  }
  "(" + gen_expr(sy, l) + op_c(op) + gen_expr(sy, r) + ")"
}

// Emit `<cty> name = ...` (first declaration) or `name = ...` (reassignment).
// `name := expr` lowers to a plain assignment — the C declaration was already
// emitted at the function top by `hoist_decls`. (We still re-record the type so
// `xs := push(xs, …)` etc. refine an inferred element type during codegen.)
fn gen_decl(sy:*Syms, name:str, e:Expr, ind:str) -> str {
  set_ty(sy, name, type_of_expr(sy, e))
  ind + "v_" + name + " = " + gen_expr(sy, e) + ";\n"
}

// ----- tuple helpers (multi-return) -----------------------------------------
// The static type of a tuple literal: "(T1;T2;…)" from each element's type.
fn tuple_type_of(sy:*Syms, elems:[Expr]) -> str {
  mu s := "("
  mu i := 0
  lp i < len(elems) {
    if i > 0 { s = s + ";" }
    s = s + type_of_expr(sy, elems[i])
    i += 1
  }
  s + ")"
}
// A tuple literal → a C compound literal of its `tup_<suffix>` struct (fields
// positional). It only appears in `return …`, so no macro-arg-comma hazard.
fn gen_tuple_lit(sy:*Syms, elems:[Expr]) -> str {
  ty := tuple_type_of(sy, elems)
  mu out := "(" + cty(ty) + "){ "
  mu i := 0
  lp i < len(elems) {
    if i > 0 { out = out + ", " }
    out = out + gen_expr(sy, elems[i])
    i += 1
  }
  out + " }"
}
// `a, b := f()` → a block holding a temp tuple, then one assignment per name
// into the (hoisted) locals. A "_" slot is skipped. The temp is block-scoped,
// so two destructures never collide on the `__dt` name.
fn gen_destructure(sy:*Syms, names:[str], e:Expr, ind:str) -> str {
  ty := type_of_expr(sy, e)
  ets := tuple_elems(ty)
  mu out := ind + "{ " + cty(ty) + " __dt = " + gen_expr(sy, e) + ";"
  mu i := 0
  lp i < len(names) {
    if names[i] != "_" {
      ft := if i < len(ets) { ets[i] } el { "i64" }
      set_ty(sy, names[i], ft)
      out = out + " v_" + names[i] + " = __dt._" + int_to_str(i) + ";"
    }
    i += 1
  }
  out + " }\n"
}
// Hoist a destructure's bindings (one C local per non-"_" name, typed from the
// tuple's element types) — like hoist_one, so `:=` lowers to an assignment.
fn hoist_destructure(sy:*Syms, names:[str], e:Expr, ind:str) -> str {
  ty := type_of_expr(sy, e)
  ets := tuple_elems(ty)
  mu out := ""
  mu i := 0
  lp i < len(names) {
    if names[i] != "_" {
      ft := if i < len(ets) { ets[i] } el { "i64" }
      if declared(sy, names[i]) == false {
        set_ty(sy, names[i], ft)
        out = out + ind + cty(ft) + " v_" + names[i] + ";\n"
      }
    }
    i += 1
  }
  out
}
// One `tup_<suffix>` typedef for a tuple type "(T1;T2;…)".
fn gen_tuple_typedef(ty:str) -> str {
  es := tuple_elems(ty)
  mu out := "typedef struct { "
  mu i := 0
  lp i < len(es) {
    out = out + cty(es[i]) + " _" + int_to_str(i) + "; "
    i += 1
  }
  out + "} tup_" + tuple_suffix(ty) + ";\n"
}

// ----- block expressions (`{ s1; s2; …; tail }` as a value) -----------------
// Type = the tail (last stmt)'s expression type. Lowers to a GNU statement-expr
// `({ <stmts>; <tail>; })`; the block's `:=` decls are block-LOCAL (declared in
// place, naturally C-scoped — no function-top hoist), so a `_` of the same name
// in two sibling blocks never collides.
fn block_type(sy:*Syms, body:[Stmt]) -> str {
  n := len(body)
  if n == 0 rt "i64"
  last_expr_type(sy, body[n - 1])
}
// One non-tail statement inside a block: a `:=` declares a block-local (full C
// decl with its type); every other form reuses the normal statement codegen.
fn gen_blk_decl(sy:*Syms, name:str, e:Expr) -> str {
  ty := type_of_expr(sy, e)
  set_ty(sy, name, ty)
  cty(ty) + " v_" + name + " = " + gen_expr(sy, e) + "; "
}
fn gen_blk_stmt(sy:*Syms, s:Stmt) -> str {
  mt s {
    SDecl(name,e)            => gen_blk_decl(sy, name, e);
    SDestructure(names,e)    => gen_stmt(sy, s, "");
    SAssign(name,e)          => gen_stmt(sy, s, "");
    SIdxAssign(o,i,e)        => gen_stmt(sy, s, "");
    SFieldAssign(o,f,e)      => gen_stmt(sy, s, "");
    SReturn(e)               => gen_stmt(sy, s, "");
    SPrint(e)                => gen_stmt(sy, s, "");
    SIf(c,b,eb)              => gen_stmt(sy, s, "");
    SLoop(c,b)               => gen_stmt(sy, s, "");
    SLoopIn(vnm,coll,b)      => gen_stmt(sy, s, "");
    SLoopKV(kn,vn,coll,b)    => gen_stmt(sy, s, "");
    SLoopRange(v,lo,hi,b)    => gen_stmt(sy, s, "");
    SBreak                   => gen_stmt(sy, s, "");
    SContinue                => gen_stmt(sy, s, "");
    SExpr(e)                 => gen_stmt(sy, s, "");
  }
}
// The tail statement supplies the block's value: a bare expr (or `rt`) is that
// value; any other form runs as a statement and the block yields 0.
fn gen_blk_tail(sy:*Syms, s:Stmt) -> str {
  mt s {
    SExpr(e)                 => gen_expr(sy, e) + "; ";
    SReturn(e)               => gen_expr(sy, e) + "; ";
    SDecl(name,e)            => gen_blk_decl(sy, name, e) + "0; ";
    SDestructure(names,e)    => gen_stmt(sy, s, "") + "0; ";
    SAssign(name,e)          => gen_stmt(sy, s, "") + "0; ";
    SIdxAssign(o,i,e)        => gen_stmt(sy, s, "") + "0; ";
    SFieldAssign(o,f,e)      => gen_stmt(sy, s, "") + "0; ";
    SPrint(e)                => gen_stmt(sy, s, "") + "0; ";
    SIf(c,b,eb)              => gen_stmt(sy, s, "") + "0; ";
    SLoop(c,b)               => gen_stmt(sy, s, "") + "0; ";
    SLoopIn(vnm,coll,b)      => gen_stmt(sy, s, "") + "0; ";
    SLoopKV(kn,vn,coll,b)    => gen_stmt(sy, s, "") + "0; ";
    SLoopRange(v,lo,hi,b)    => gen_stmt(sy, s, "") + "0; ";
    SBreak                   => "break; 0; ";
    SContinue                => "continue; 0; ";
  }
}
fn gen_block_e(sy:*Syms, body:[Stmt]) -> str {
  n := len(body)
  if n == 0 rt "0"
  mu out := "({ "
  mu i := 0
  lp i < n - 1 { out = out + gen_blk_stmt(sy, body[i]); i += 1 }
  out + gen_blk_tail(sy, body[n - 1]) + "})"
}

// Emit `if (c) { body } [else { else_b }]`. The else block is omitted when
// empty (no `el`); a nested `el if` lands as a single SIf inside `eb`, which
// recursion renders as `else { if (...) ... }` — correct, if slightly nested.
fn gen_if(sy:*Syms, c:Expr, b:[Stmt], eb:[Stmt], ind:str) -> str {
  mu out := ind + "if (" + gen_expr(sy, c) + ") {\n" + gen_stmts(sy, b, ind + "    ") + ind + "}"
  if len(eb) > 0 {
    out = out + " else {\n" + gen_stmts(sy, eb, ind + "    ") + ind + "}"
  }
  out + "\n"
}

// Emit a [Stmt] body with the given C indentation prefix.
fn gen_stmts(sy:*Syms, body:[Stmt], ind:str) -> str {
  mu out := ""
  mu i := 0
  lp i < len(body) {
    out = out + gen_stmt(sy, body[i], ind)
    i += 1
  }
  out
}

// Hoist every local declaration to the function top. AiLang `:=` bindings are
// lexically block-scoped, but the bootstrap tracks declared names function-wide
// (declare-once); a name reused in two *sibling* blocks would otherwise be
// declared in the first C block (which then closes) and only assigned in the
// second (now undeclared). Emitting one C declaration per name up front — and
// turning every `:=` into a plain assignment (see `gen_decl`) — sidesteps C
// block scoping entirely. Types are recorded into `sy` here so codegen agrees.
fn hoist_decls(sy:*Syms, body:[Stmt], ind:str) -> str {
  mu out := ""
  mu i := 0
  lp i < len(body) {
    out = out + hoist_stmt(sy, body[i], ind)
    i += 1
  }
  out
}

fn hoist_stmt(sy:*Syms, s:Stmt, ind:str) -> str {
  mt s {
    SDecl(name,e)         => hoist_one(sy, name, e, ind);
    SDestructure(names,e) => hoist_destructure(sy, names, e, ind);
    SIf(c,b,eb)           => hoist_decls(sy, b, ind) + hoist_decls(sy, eb, ind);
    SLoop(c,b)            => hoist_decls(sy, b, ind);
    SLoopIn(vnm,coll,b)   => hoist_loopin(sy, vnm, coll, b, ind);
    SLoopKV(kn,vn,coll,b) => hoist_loopkv(sy, kn, vn, coll, b, ind);
    SLoopRange(v,lo,hi,b) => hoist_range(sy, v, b, ind);
    SAssign(name,e)       => "";
    SIdxAssign(o,i,e)     => "";
    SFieldAssign(o,f,e)   => "";
    SReturn(e)            => "";
    SPrint(e)             => "";
    SBreak                => "";
    SContinue             => "";
    SExpr(e)              => "";
  }
}

// Declare one hoisted local (skipped if it's a param or already hoisted). Sets
// its type in `sy` so a later decl's RHS — and codegen — type correctly.
fn hoist_one(sy:*Syms, name:str, e:Expr, ind:str) -> str {
  if declared(sy, name) rt ""
  ety := type_of_expr(sy, e)
  set_ty(sy, name, ety)
  ind + cty(ety) + " v_" + name + ";\n"
}

// A `lp x in coll` loop: the element var `x` is declared by `gen_loop_in` inside
// its own C block, so we only record its type (for the body's decls) and hoist
// the body's declarations.
fn hoist_loopin(sy:*Syms, vnm:str, coll:Expr, b:[Stmt], ind:str) -> str {
  set_ty(sy, vnm, coll_elem_type(sy, coll))
  hoist_decls(sy, b, ind)
}

// `lp (k, v) in map` — k/v are declared in the loop's own block by gen_loop_kv;
// record their types and hoist the body's decls.
fn hoist_loopkv(sy:*Syms, kn:str, vn:str, coll:Expr, b:[Stmt], ind:str) -> str {
  t := type_of_expr(sy, coll)
  set_ty(sy, kn, map_ktype(t))
  set_ty(sy, vn, map_vtype(t))
  hoist_decls(sy, b, ind)
}

// A function body, with AiLang's implicit tail-expression return: in a non-void
// function the last statement, if it's a bare expression, becomes `return <e>;`
// (covers `fn cty(...) -> str { … "s_" + t }` and a tail `mt`/`if` used as the
// result). Void functions and tails that are already `rt`/control-flow fall
// through to plain statement emission.
fn gen_fn_body(sy:*Syms, body:[Stmt], ret:str, ind:str) -> str {
  n := len(body)
  if n == 0 rt ""
  if len(ret) == 0 rt gen_stmts(sy, body, ind)    // void → no implicit return
  mu out := ""
  mu i := 0
  lp i < n - 1 {
    out = out + gen_stmt(sy, body[i], ind)
    i += 1
  }
  out + gen_tail_stmt(sy, body[n - 1], ret, ind)
}

// The last statement of a non-void body. A bare expression is returned; a tail
// `if` (the common `fn f() -> T { if c { a } el { b } }` shape — e.g. `under_ptr`)
// recurses so each branch returns its own tail. Other tails emit normally.
fn gen_tail_stmt(sy:*Syms, s:Stmt, ret:str, ind:str) -> str {
  mt s {
    SExpr(e)                 => ind + "return " + gen_expr(sy, e) + ";\n";
    SDecl(name,e)            => gen_decl(sy, name, e, ind);
    SDestructure(names,e)    => gen_destructure(sy, names, e, ind);
    SAssign(name,e)          => gen_assign(sy, name, e, ind);
    SIdxAssign(obj,idx,e)    => gen_idx_assign(sy, obj, idx, e, ind);
    SFieldAssign(obj,fnm,e)  => ind + gen_field(sy, obj, fnm) + " = " + gen_expr(sy, e) + ";\n";
    SReturn(e)               => ind + "return " + gen_expr(sy, e) + ";\n";
    SPrint(e)                => gen_print(sy, e, ind);
    SIf(c,b,eb)              => gen_tail_if(sy, c, b, eb, ret, ind);
    SLoop(c,b)               => ind + "while (" + gen_expr(sy, c) + ") {\n" + gen_stmts(sy, b, ind + "    ") + ind + "}\n";
    SLoopIn(vnm,coll,b)      => gen_loop_in(sy, vnm, coll, b, ind);
    SLoopKV(kn,vn,coll,b)    => gen_loop_kv(sy, kn, vn, coll, b, ind);
    SLoopRange(v,lo,hi,b)    => gen_loop_range(sy, v, lo, hi, b, ind);
    SBreak                   => ind + "break;\n";
    SContinue                => ind + "continue;\n";
  }
}

// A tail `if` in a non-void function: each branch is itself a function-body tail,
// so its last bare expression becomes a `return`. (Distinct from `gen_if`, which
// emits the if for effect, not value.)
fn gen_tail_if(sy:*Syms, c:Expr, b:[Stmt], eb:[Stmt], ret:str, ind:str) -> str {
  mu out := ind + "if (" + gen_expr(sy, c) + ") {\n" + gen_fn_body(sy, b, ret, ind + "    ") + ind + "}"
  if len(eb) > 0 {
    out = out + " else {\n" + gen_fn_body(sy, eb, ret, ind + "    ") + ind + "}"
  }
  out + "\n"
}

fn gen_print(sy:*Syms, e:Expr, ind:str) -> str {
  t := type_of_expr(sy, e)                    // compute once (str / f64 / else)
  if t == "str" {
    rt ind + "printf(\"%s\\n\", " + gen_expr(sy, e) + ");\n"
  }
  if t == "f64" {                             // %g — matches AiLang's float format
    rt ind + "printf(\"%g\\n\", (double)(" + gen_expr(sy, e) + "));\n"
  }
  if t == "bool" {                            // bool VALUE prints true/false; a raw
    if expr_is_cmp(e) {                       // comparison/logic is C int → prints 1/0 (ailangc)
      rt ind + "printf(\"%lld\\n\", (long long)(" + gen_expr(sy, e) + "));\n"
    }
    rt ind + "printf(\"%s\\n\", (" + gen_expr(sy, e) + ") ? \"true\" : \"false\");\n"
  }
  if t == "bytes" {                           // pretty-print via helper, then a newline
    rt ind + "print_bytes(" + gen_expr(sy, e) + "); putchar(10);\n"
  }
  if has(sy.ctors, t) {                       // a user struct → `Name{f: v, …}` printer
    rt ind + "print_" + t + "(" + gen_expr(sy, e) + "); putchar(10);\n"
  }
  if is_array_ann(t) {                        // `[i64]`/`[str]` → `[e, e, …]` like ailangc
    suf := arr_suffix(elem_of_ann(t))
    if suf == "i64" || suf == "str" {
      rt ind + "print_arr_" + suf + "(" + gen_expr(sy, e) + "); putchar(10);\n"
    }
  }
  if is_map_ann(t) && is_scalar_ty(map_vtype(t)) {   // `{K:scalar}` → `{"k": v, …}` like ailangc
    rt ind + map_cty(t) + "_print(" + gen_expr(sy, e) + "); putchar(10);\n"
  }
  ind + "printf(\"%lld\\n\", (long long)(" + gen_expr(sy, e) + "));\n"
}

fn gen_stmt(sy:*Syms, s:Stmt, ind:str) -> str {
  mt s {
    SDecl(name,e)            => gen_decl(sy, name, e, ind);
    SDestructure(names,e)    => gen_destructure(sy, names, e, ind);
    SAssign(name,e)          => gen_assign(sy, name, e, ind);
    SIdxAssign(obj,idx,e)    => gen_idx_assign(sy, obj, idx, e, ind);
    SFieldAssign(obj,fnm,e)  => ind + gen_field(sy, obj, fnm) + " = " + gen_expr(sy, e) + ";\n";
    SReturn(e)               => ind + "return " + gen_expr(sy, e) + ";\n";
    SPrint(e)                => gen_print(sy, e, ind);
    SIf(c,b,eb)              => gen_if(sy, c, b, eb, ind);
    SLoop(c,b)               => ind + "while (" + gen_expr(sy, c) + ") {\n" + gen_stmts(sy, b, ind + "    ") + ind + "}\n";
    SLoopIn(vnm,coll,b)      => gen_loop_in(sy, vnm, coll, b, ind);
    SLoopKV(kn,vn,coll,b)    => gen_loop_kv(sy, kn, vn, coll, b, ind);
    SLoopRange(v,lo,hi,b)    => gen_loop_range(sy, v, lo, hi, b, ind);
    SBreak                   => ind + "break;\n";
    SContinue                => ind + "continue;\n";
    SExpr(e)                 => ind + gen_expr(sy, e) + ";\n";
  }
}

// `name = expr`. Re-type the binding from the RHS so that `xs = push(xs, e)`
// refines an `xs` that started as an empty `[]` (inferred `[i64]`) to the real
// element type — mirroring how the Rust compiler back-propagates push types.
fn gen_assign(sy:*Syms, name:str, e:Expr, ind:str) -> str {
  et := type_of_expr(sy, e)
  if is_array_ann(et) { set_ty(sy, name, et) }
  ind + "v_" + name + " = " + gen_expr(sy, e) + ";\n"
}

// `obj[idx] = v`: for an array, write through the shared backing buffer in
// place (persists across value copies, like AiLang); for a map, `map_<v>_set`
// (reference-semantic, also persists).
fn gen_idx_assign(sy:*Syms, obj:Expr, idx:Expr, e:Expr, ind:str) -> str {
  ot := type_of_expr(sy, obj)
  if is_array_ann(ot) {
    rt ind + "(" + gen_expr(sy, obj) + ").data[" + gen_expr(sy, idx) + "] = " + gen_expr(sy, e) + ";\n"
  }
  if is_map_ann(ot) {
    rt ind + map_cty(ot) + "_set(" + gen_expr(sy, obj) + ", " + gen_expr(sy, idx) + ", " + gen_expr(sy, e) + ");\n"
  }
  ind + "/* unsupported index-assign */\n"
}

// Element type of an array-typed expr (its [T] stripped), or "i64".
fn coll_elem_type(sy:*Syms, coll:Expr) -> str {
  colt := type_of_expr(sy, coll)
  if is_array_ann(colt) rt elem_of_ann(colt)
  "i64"
}

// `lp x in coll { … }` over an array → a C for-loop binding `x` to each element.
fn gen_loop_in(sy:*Syms, vnm:str, coll:Expr, body:[Stmt], ind:str) -> str {
  et := coll_elem_type(sy, coll)
  suf := arr_suffix(et)
  iv := "__i_" + vnm
  cv := "__c_" + vnm
  set_ty(sy, vnm, et)
  mu out := ind + "{ arr_" + suf + " " + cv + " = " + gen_expr(sy, coll) + ";\n"
  out = out + ind + "for (int64_t " + iv + " = 0; " + iv + " < arr_" + suf + "_len(" + cv + "); " + iv + " = " + iv + " + 1) {\n"
  out = out + ind + "    " + cty(et) + " v_" + vnm + " = arr_" + suf + "_get(" + cv + ", " + iv + ");\n"
  out = out + gen_stmts(sy, body, ind + "    ")
  out = out + ind + "} }\n"
  out
}

// `lp i in lo..hi { … }` — counting for-loop over [lo, hi). The i64 counter is
// declared in the for-init (naturally scoped, so sibling range loops reusing the
// same name don't collide, and it isn't hoisted).
fn gen_loop_range(sy:*Syms, vnm:str, lo:Expr, hi:Expr, body:[Stmt], ind:str) -> str {
  set_ty(sy, vnm, "i64")
  v := "v_" + vnm
  mu out := ind + "for (int64_t " + v + " = " + gen_expr(sy, lo) + "; " + v + " < " + gen_expr(sy, hi) + "; " + v + " = " + v + " + 1) {\n"
  out = out + gen_stmts(sy, body, ind + "    ")
  out = out + ind + "}\n"
  out
}
fn hoist_range(sy:*Syms, vnm:str, b:[Stmt], ind:str) -> str {
  set_ty(sy, vnm, "i64")          // body type inference sees the counter as i64
  hoist_decls(sy, b, ind)          // counter is for-init scoped, not hoisted
}
fn collect_range_s(base:*Syms, sy:*Syms, lo:Expr, hi:Expr, b:[Stmt]) -> i64 {
  collect_lams_expr(base, sy, lo)
  collect_lams_expr(base, sy, hi)
  collect_lams(base, sy, b)
  0
}

// `lp (k, v) in map { … }` → walk the assoc-list, binding key (str) + value.
fn gen_loop_kv(sy:*Syms, kn:str, vn:str, coll:Expr, body:[Stmt], ind:str) -> str {
  mt2 := type_of_expr(sy, coll)        // "{str:V}"
  mc := map_cty(mt2)                    // map_ss / map_si
  vt := map_vtype(mt2)                  // str / i64
  nv := "__n_" + kn
  mv := "__m_" + kn
  set_ty(sy, kn, map_ktype(mt2))
  set_ty(sy, vn, vt)
  mu out := ind + "{ " + mc + " " + mv + " = " + gen_expr(sy, coll) + ";\n"
  // Iterate backing slots in order (skipping empties) — same traversal as the
  // reference's print/keys, so `lp (k,v) in m` visits entries in hash order.
  out = out + ind + "for (int64_t " + nv + " = 0; " + nv + " < " + mv + "->cap; " + nv + " += 1) {\n"
  out = out + ind + "    if (!" + mv + "->occupied[" + nv + "]) continue;\n"
  out = out + ind + "    " + cty(map_ktype(mt2)) + " v_" + kn + " = " + mv + "->keys[" + nv + "];\n"
  out = out + ind + "    " + cty(vt) + " v_" + vn + " = " + mv + "->values[" + nv + "];\n"
  out = out + gen_stmts(sy, body, ind + "    ")
  out = out + ind + "} }\n"
  out
}

// C return type: an empty inferred type (a fn with no `rt`) is `void`.
fn cty_ret(ret:str) -> str {
  if len(ret) == 0 rt "void"
  cty(ret)
}

// One C function signature: `<ret> f_<name>(<pty> v_p1, ...)`.
fn gen_sig(f:Func, ret:str) -> str {
  mu out := cty_ret(ret) + " f_" + f.name + "("
  if len(f.params) == 0 {
    out = out + "void"
  } el {
    mu i := 0
    lp i < len(f.params) {
      if i > 0 { out = out + ", " }
      out = out + cty(f.ptypes[i]) + " v_" + f.params[i]
      i += 1
    }
  }
  out + ")"
}

// ----- lifted-lambda emission (all gated on len(base.lams) > 0) --------------
// `__lam_<id>(void* __env, int64_t v_p0, ...)` — closure params default i64.
fn gen_lam_sig(lf:Func) -> str {
  mu out := "static " + cty(lf.ret) + " __lam_" + lf.name + "(void* __env"
  mu k := 0
  lp k < len(lf.params) {
    pt := if k < len(lf.ptypes) { lf.ptypes[k] } el { "i64" }
    out = out + ", " + cty(pt) + " v_" + lf.params[k]
    k += 1
  }
  out + ")"
}
// `typedef struct { <cty(capt)> v_<cap>; ... } __env_<id>;` — only for capturing
// lambdas (a non-capturing one carries env=(void*)0 and needs no struct).
fn gen_env_struct(base:*Syms, lf:Func) -> str {
  caps := split_semi(base.evar["@lamcaps." + lf.name])
  capt := split_semi(base.evar["@lamcapt." + lf.name])
  if len(caps) == 0 rt ""
  mu out := "typedef struct { "
  mu k := 0
  lp k < len(caps) { out = out + cty(capt[k]) + " v_" + caps[k] + "; "; k += 1 }
  out + "} __env_" + lf.name + ";\n"
}
// The lifted fn body: unpack captures into `v_<cap>` locals, then emit the
// lambda body (stored as [SReturn(b)], so gen_fn_body yields `return <e>;`).
// A fresh Syms seeded with params(i64)+captures(types) types the body correctly.
fn gen_lifted_body(base:*Syms, lf:Func) -> str {
  caps := split_semi(base.evar["@lamcaps." + lf.name])
  capt := split_semi(base.evar["@lamcapt." + lf.name])
  mu sy := Syms(base.vty, base.fld, base.ctors, base.frets, base.evar, base.vft, base.gfns, base.lams)
  sy.vty = {}
  mu pj := 0
  lp pj < len(lf.params) {
    pt := if pj < len(lf.ptypes) { lf.ptypes[pj] } el { "i64" }
    set_ty(&sy, lf.params[pj], pt); pj += 1
  }
  mu cj := 0
  lp cj < len(caps) { set_ty(&sy, caps[cj], capt[cj]); cj += 1 }
  mu out := gen_lam_sig(lf) + "{ "
  if len(caps) > 0 {
    out = out + "__env_" + lf.name + "* __e = (__env_" + lf.name + "*)__env; "
    mu uk := 0
    lp uk < len(caps) { out = out + cty(capt[uk]) + " v_" + caps[uk] + " = __e->v_" + caps[uk] + "; "; uk += 1 }
  } el {
    out = out + "(void)__env; "
  }
  out + gen_fn_body(&sy, lf.body, lf.ret, "") + "}\n"
}

// Emit `typedef struct { T f; ... } s_Name;` + a `mk_Name(...)` constructor.
// Emit the monomorphic dynamic-array runtime for one element type:
//   typedef struct { len; cap; E* data; } arr_<suf>;
//   arr_<suf>_new / _push (value-semantic, returns new) / _get / _len
// Array runtime split into typedef (phase 2 — only needs `et` as a pointer
// target) + helpers (phase 4 — size/copy `et` by value, so it must be complete).
fn gen_arr_typedef(suf:str, et:str) -> str {
  "typedef struct { int64_t len; int64_t cap; " + et + "* data; } arr_" + suf + ";\n"
}
fn gen_arr_helpers(suf:str, et:str) -> str {
  mu o := "static arr_" + suf + " arr_" + suf + "_new(void){ arr_" + suf + " a; a.len=0; a.cap=0; a.data=0; return a; }\n"
  o = o + "static arr_" + suf + " arr_" + suf + "_push(arr_" + suf + " a, " + et + " x){ if(a.cap<=a.len){ int64_t nc=a.cap?a.cap*2:4; " + et + "* nd=(" + et + "*)GC_MALLOC(nc*sizeof(" + et + ")); if(a.len) memcpy(nd,a.data,a.len*sizeof(" + et + ")); a.data=nd; a.cap=nc; } a.data[a.len]=x; a.len++; return a; }\n"
  o = o + "static " + et + " arr_" + suf + "_get(arr_" + suf + " a, int64_t i){ return a.data[i]; }\n"
  o = o + "static int64_t arr_" + suf + "_len(arr_" + suf + " a){ return a.len; }\n"
  // pop: value-semantic drop of the last element (returns the shortened array).
  o = o + "static arr_" + suf + " arr_" + suf + "_pop(arr_" + suf + " a){ if(a.len>0) a.len-=1; return a; }\n"
  // slice [lo, hi) end-exclusive, and reverse — both return fresh arrays.
  o = o + "static arr_" + suf + " arr_" + suf + "_slice(arr_" + suf + " a, int64_t lo, int64_t hi){ arr_" + suf + " r=arr_" + suf + "_new(); if(lo<0)lo=0; if(hi>a.len)hi=a.len; for(int64_t i=lo;i<hi;i++) r=arr_" + suf + "_push(r,a.data[i]); return r; }\n"
  o = o + "static arr_" + suf + " arr_" + suf + "_reverse(arr_" + suf + " a){ arr_" + suf + " r=arr_" + suf + "_new(); for(int64_t i=a.len-1;i>=0;i--) r=arr_" + suf + "_push(r,a.data[i]); return r; }\n"
  // `sort` only for the ordered scalar types (i64/str) — aggregates have no
  // natural comparator (no closures yet). Returns a fresh ascending-sorted copy.
  if suf == "i64" {
    o = o + "static int __cmp_i64(const void* a, const void* b){ int64_t x=*(const int64_t*)a, y=*(const int64_t*)b; return (x>y)-(x<y); }\n"
    o = o + "static arr_i64 arr_i64_sort(arr_i64 a){ arr_i64 r=arr_i64_reverse(arr_i64_reverse(a)); if(r.len>1) qsort(r.data,r.len,sizeof(int64_t),__cmp_i64); return r; }\n"
    o = o + "static int64_t arr_i64_contains(arr_i64 a, int64_t x){ for(int64_t i=0;i<a.len;i++) if(a.data[i]==x) return 1; return 0; }\n"
    o = o + "static int64_t arr_i64_index_of(arr_i64 a, int64_t x){ for(int64_t i=0;i<a.len;i++) if(a.data[i]==x) return i; return -1; }\n"
    o = o + "static const char* arr_i64_join(arr_i64 a, const char* sep){ if(!sep) sep=\"\"; size_t sl=strlen(sep); size_t cap=(size_t)a.len*22+(a.len>1?sl*(size_t)(a.len-1):0)+1; if(cap<16) cap=16; char* o=(char*)GC_MALLOC(cap); char* w=o; for(int64_t i=0;i<a.len;i++){ if(i>0&&sl){ memcpy(w,sep,sl); w+=sl; } int n=snprintf(w,cap-(size_t)(w-o),\"%lld\",(long long)a.data[i]); if(n>0) w+=n; } *w=0; return o; }\n"
  }
  if suf == "str" {
    o = o + "static int __cmp_str(const void* a, const void* b){ return strcmp(*(const char* const*)a, *(const char* const*)b); }\n"
    o = o + "static arr_str arr_str_sort(arr_str a){ arr_str r=arr_str_reverse(arr_str_reverse(a)); if(r.len>1) qsort(r.data,r.len,sizeof(const char*),__cmp_str); return r; }\n"
    o = o + "static int64_t arr_str_contains(arr_str a, const char* x){ for(int64_t i=0;i<a.len;i++) if(strcmp(a.data[i],x)==0) return 1; return 0; }\n"
    o = o + "static int64_t arr_str_index_of(arr_str a, const char* x){ for(int64_t i=0;i<a.len;i++) if(strcmp(a.data[i],x)==0) return i; return -1; }\n"
    o = o + "static const char* arr_str_join(arr_str a, const char* sep){ if(!sep) sep=\"\"; size_t sl=strlen(sep); size_t tot=0; for(int64_t i=0;i<a.len;i++) tot+=a.data[i]?strlen(a.data[i]):0; if(a.len>1) tot+=sl*(size_t)(a.len-1); char* o=(char*)GC_MALLOC(tot+1); char* w=o; for(int64_t i=0;i<a.len;i++){ if(i>0&&sl){ memcpy(w,sep,sl); w+=sl; } const char* s=a.data[i]?a.data[i]:\"\"; size_t n=strlen(s); if(n){ memcpy(w,s,n); w+=n; } } *w=0; return o; }\n"
  }
  o
}

// Map runtime (reference-semantic string-keyed assoc-list), split likewise.
// A pointer means writes through a `*Syms` field persist, like AiLang's maps.
// Forward typedefs (emitted in phase 2): the node is only forward-declared and
// `_s` holds a `node*`, so neither needs the value type complete yet — a
// struct-valued map can be *named* before the aggregate bodies are emitted. The
// node BODY (which holds the value by value) is emitted by gen_map_node, after
// the struct/enum bodies, exactly like gen_struct_fwd / gen_struct_body.
// `println(m)` for a scalar-valued map → `{"k": v, …}`, byte-for-byte the format
// ailangc emits (str keys/values quoted, i64/f64 bare). Only scalar value types
// are printable; a struct-valued map gets a no-op printer (never printed in the
// corpus). `pf_spec`/`pf_arg` pick the printf conversion + argument cast.
fn pf_spec(t:str) -> str {
  if t == "str" rt "\\\"%s\\\""
  if t == "f64" rt "%g"
  "%lld"
}
fn pf_arg(t:str, slot:str) -> str {
  if t == "str" rt "(" + slot + " ? " + slot + " : \"\")"
  if t == "f64" rt "(double)(" + slot + ")"
  "(long long)(" + slot + ")"
}
fn is_scalar_ty(t:str) -> bool { t == "str" || t == "i64" || t == "f64" }
fn gen_map_print(nm:str, kt:str, vt:str) -> str {
  if is_scalar_ty(vt) {
    fmt := pf_spec(kt) + ": " + pf_spec(vt)
    ka := pf_arg(kt, "m->keys[i]")
    va := pf_arg(vt, "m->values[i]")
    rt "static void " + nm + "_print(" + nm + " m){ printf(\"{\"); int64_t __f=1; for(int64_t i=0;i<m->cap;i++){ if(!m->occupied[i]) continue; if(!__f) printf(\", \"); __f=0; printf(\"" + fmt + "\", " + ka + ", " + va + "); } printf(\"}\"); }\n"
  }
  "static void " + nm + "_print(" + nm + " m){ (void)m; }\n"
}

// Open-addressing hash table — mirrors ailangc's prelude.c map layout (FNV-1a /
// splitmix64 hashes, cap 8, grow at load 0.7, linear probe), so slot-order
// iteration is byte-identical to the reference. Phase 2 forward-declares the
// storage tag + pointer typedef; the body lands in phase 3 (gen_map_node), the
// helpers in phase 4 — the same 3-phase split the old assoc-list used.
fn gen_map_fwd(nm:str) -> str {
  mu o := "typedef struct " + nm + "_s " + nm + "_s;\n"
  o = o + "typedef " + nm + "_s* " + nm + ";\n"
  o
}
fn gen_map_node(nm:str, kt:str, vt:str) -> str {
  // Phase-3 storage body: parallel cap-sized keys/values arrays + an occupied
  // bitmap; `len` counts live entries. Values are held by value, so the value
  // type must be complete here (as the old node body required).
  "struct " + nm + "_s { int64_t cap; int64_t len; " + cty(kt) + "* keys; " + cty(vt) + "* values; unsigned char* occupied; };\n"
}
fn gen_map_helpers(nm:str, kt:str, vt:str, dflt:str) -> str {
  ksuf := arr_suffix(kt)                                   // key's arr_<T> suffix
  vsuf := arr_suffix(vt)                                   // value's arr_<T> suffix
  kc := cty(kt)
  vc := cty(vt)
  // key equality: strcmp for string keys, == for everything else (i64 etc.).
  keyeq := if kt == "str" { "strcmp(m->keys[i],k)==0" } el { "m->keys[i]==k" }
  mu o := ""
  // hash: FNV-1a over the C string for str keys, splitmix64 for scalar keys —
  // the exact functions ailangc uses, so the slot a key lands in matches.
  if kt == "str" {
    o = o + "static uint64_t " + nm + "_hash(" + kc + " s){ uint64_t h=0xcbf29ce484222325ULL; if(!s) return h; while(*s){ h^=(uint64_t)(unsigned char)*s++; h*=0x100000001b3ULL; } return h; }\n"
  } el {
    o = o + "static uint64_t " + nm + "_hash(" + kc + " k){ uint64_t x=(uint64_t)(int64_t)k; x^=x>>30; x*=0xbf58476d1ce4e5b9ULL; x^=x>>27; x*=0x94d049bb133111ebULL; x^=x>>31; return x; }\n"
  }
  o = o + "static " + nm + " " + nm + "_new(void){ " + nm + " m=(" + nm + ")GC_MALLOC(sizeof(" + nm + "_s)); m->cap=8; m->len=0; m->keys=(" + kc + "*)GC_MALLOC(8*sizeof(" + kc + ")); m->values=(" + vc + "*)GC_MALLOC(8*sizeof(" + vc + ")); m->occupied=(unsigned char*)GC_MALLOC(8); memset(m->occupied,0,8); return m; }\n"
  o = o + "static void " + nm + "_grow(" + nm + " m){ int64_t oc=m->cap; " + kc + "* ok=m->keys; " + vc + "* ov=m->values; unsigned char* oo=m->occupied; int64_t nc=oc*2; m->cap=nc; m->keys=(" + kc + "*)GC_MALLOC(nc*sizeof(" + kc + ")); m->values=(" + vc + "*)GC_MALLOC(nc*sizeof(" + vc + ")); m->occupied=(unsigned char*)GC_MALLOC(nc); memset(m->occupied,0,nc); uint64_t mask=(uint64_t)(nc-1); for(int64_t i=0;i<oc;i++){ if(!oo[i]) continue; uint64_t h=" + nm + "_hash(ok[i])&mask; for(int64_t p=0;p<nc;p++){ int64_t j=(int64_t)((h+(uint64_t)p)&mask); if(!m->occupied[j]){ m->keys[j]=ok[i]; m->values[j]=ov[i]; m->occupied[j]=1; break; } } } }\n"
  o = o + "static void " + nm + "_set(" + nm + " m, " + kc + " k, " + vc + " val){ if(m->len*10>=m->cap*7) " + nm + "_grow(m); uint64_t mask=(uint64_t)(m->cap-1); uint64_t h=" + nm + "_hash(k)&mask; for(int64_t p=0;p<m->cap;p++){ int64_t i=(int64_t)((h+(uint64_t)p)&mask); if(!m->occupied[i]){ m->keys[i]=k; m->values[i]=val; m->occupied[i]=1; m->len++; return; } if(" + keyeq + "){ m->values[i]=val; return; } } }\n"
  o = o + "static " + vc + " " + nm + "_get(" + nm + " m, " + kc + " k){ uint64_t mask=(uint64_t)(m->cap-1); uint64_t h=" + nm + "_hash(k)&mask; for(int64_t p=0;p<m->cap;p++){ int64_t i=(int64_t)((h+(uint64_t)p)&mask); if(!m->occupied[i]) return " + dflt + "; if(" + keyeq + ") return m->values[i]; } return " + dflt + "; }\n"
  o = o + "static int64_t " + nm + "_has(" + nm + " m, " + kc + " k){ uint64_t mask=(uint64_t)(m->cap-1); uint64_t h=" + nm + "_hash(k)&mask; for(int64_t p=0;p<m->cap;p++){ int64_t i=(int64_t)((h+(uint64_t)p)&mask); if(!m->occupied[i]) return 0; if(" + keyeq + ") return 1; } return 0; }\n"
  o = o + "static arr_" + ksuf + " " + nm + "_keys(" + nm + " m){ arr_" + ksuf + " r=arr_" + ksuf + "_new(); for(int64_t i=0;i<m->cap;i++) if(m->occupied[i]) r=arr_" + ksuf + "_push(r,m->keys[i]); return r; }\n"
  o = o + "static arr_" + vsuf + " " + nm + "_values(" + nm + " m){ arr_" + vsuf + " r=arr_" + vsuf + "_new(); for(int64_t i=0;i<m->cap;i++) if(m->occupied[i]) r=arr_" + vsuf + "_push(r,m->values[i]); return r; }\n"
  o = o + "static int64_t " + nm + "_len(" + nm + " m){ return m->len; }\n"
  o = o + gen_map_print(nm, kt, vt)
  o
}

// `m[k]` / `_get` default for a missing key, by value type: 0 for numbers, "" for
// strings, a zero-initialised aggregate for struct/enum values.
fn map_dflt(vt:str) -> str {
  if vt == "str" rt "\"\""
  if vt == "i64" rt "0"
  if vt == "f64" rt "0"
  "(s_" + vt + "){0}"
}
// Emit the whole map runtime as the cross product of scalar keys × values, the
// same way arr_<T> is emitted once per element type. Keys are scalars only
// (str/i64/f64 — aggregates have no usable C `==`); values add every struct/enum.
// Split into 3 passes because the forward decls, node bodies, and helpers each
// land in a different emission phase (see compile_to_c).
fn map_nm(kt:str, vt:str) -> str { "map_" + arr_suffix(kt) + "_" + arr_suffix(vt) }
fn gen_map_fwds_all(keys:[str], vals:[str]) -> str {
  mu out := ""
  mu ki := 0
  lp ki < len(keys) {
    mu vi := 0
    lp vi < len(vals) { out = out + gen_map_fwd(map_nm(keys[ki], vals[vi])); vi += 1 }
    ki += 1
  }
  out
}
fn gen_map_nodes_all(keys:[str], vals:[str]) -> str {
  mu out := ""
  mu ki := 0
  lp ki < len(keys) {
    mu vi := 0
    lp vi < len(vals) { out = out + gen_map_node(map_nm(keys[ki], vals[vi]), keys[ki], vals[vi]); vi += 1 }
    ki += 1
  }
  out
}
fn gen_map_helpers_all(keys:[str], vals:[str]) -> str {
  mu out := ""
  mu ki := 0
  lp ki < len(keys) {
    mu vi := 0
    lp vi < len(vals) { out = out + gen_map_helpers(map_nm(keys[ki], vals[vi]), keys[ki], vals[vi], map_dflt(vals[vi])); vi += 1 }
    ki += 1
  }
  out
}

// The `!T` result runtime (monomorphic per ok-type): a tagged `{tag, ok, err}`
// with `ok`/`err` constructors. Emitted in phase 4 (holds `et` by value, so `et`
// must be complete). tag 0 = ok, 1 = err; the error payload is always a string.
fn gen_res(suf:str, et:str) -> str {
  mu o := "typedef struct { int tag; " + et + " ok; const char* err; } res_" + suf + ";\n"
  o = o + "static res_" + suf + " mk_ok_" + suf + "(" + et + " v){ res_" + suf + " r; r.tag=0; r.ok=v; r.err=\"\"; return r; }\n"
  o = o + "static res_" + suf + " mk_err_" + suf + "(const char* m){ res_" + suf + " r; r.tag=1; r.err=m; return r; }\n"
  o
}

// --- struct emission, split into the 4 phases (see compile_to_c) ---
fn gen_struct_fwd(sd:StructDef) -> str { "typedef struct s_" + sd.name + " s_" + sd.name + ";\n" }

fn gen_struct_body(sd:StructDef) -> str {
  mu out := "struct s_" + sd.name + " { "
  mu i := 0
  lp i < len(sd.fnames) {
    out = out + cty(sd.ftypes[i]) + " " + sd.fnames[i] + "; "
    i += 1
  }
  out + "};\n"
}

// `static void print_<Name>(s_Name v){ … }` — pretty-prints a struct value as
// `Name{f: v, …}`, byte-matching ailangc: str fields raw (no quotes), bool as
// true/false, i64 as the number, any aggregate/other field as `?` (ailangc does
// not recurse into nested structs either). Caller (gen_print) adds the newline.
fn gen_struct_printer(sd:StructDef) -> str {
  mu out := "static void print_" + sd.name + "(s_" + sd.name + " v){ printf(\"" + sd.name + "{\");"
  mu i := 0
  lp i < len(sd.fnames) {
    if i > 0 { out = out + " printf(\", \");" }
    out = out + " printf(\"" + sd.fnames[i] + ": \");"
    ft := sd.ftypes[i]
    if ft == "str" {
      out = out + " printf(\"%s\", v." + sd.fnames[i] + ");"
    } el if ft == "bool" {
      out = out + " printf(\"%s\", (v." + sd.fnames[i] + ") ? \"true\" : \"false\");"
    } el if ft == "i64" {
      out = out + " printf(\"%lld\", (long long)(v." + sd.fnames[i] + "));"
    } el {
      out = out + " printf(\"?\");"
    }
    i += 1
  }
  out + " printf(\"}\"); }\n"
}
fn gen_struct_ctor(sd:StructDef) -> str {
  mu out := "static s_" + sd.name + " mk_" + sd.name + "("
  mu i := 0
  lp i < len(sd.fnames) {
    if i > 0 { out = out + ", " }
    out = out + cty(sd.ftypes[i]) + " " + sd.fnames[i]
    i += 1
  }
  // Result var is `__s` (not `v`), so a struct field literally named `v` doesn't
  // collide with the ctor local (was a known bug: `mk_Box(int64_t v){ s_Box v; … }`).
  out = out + "){ s_" + sd.name + " __s; "
  i = 0
  lp i < len(sd.fnames) {
    out = out + "__s." + sd.fnames[i] + "=" + sd.fnames[i] + "; "
    i += 1
  }
  out + "return __s; }\n"
}

// --- enum emission (tagged union, boxed self-recursive fields) ---
fn gen_enum_fwd(ed:EnumDef) -> str { "typedef struct s_" + ed.name + " s_" + ed.name + ";\n" }

// `struct s_Name { int tag; union { struct { <fields> } Variant; … } u; };`
// A field of type "@self" is stored as `s_Name*` (boxed) to break the cycle.
fn gen_enum_body(ed:EnumDef) -> str {
  mu out := "struct s_" + ed.name + " { int tag; union {\n"
  mu vi := 0
  lp vi < len(ed.vnames) {
    out = out + "  struct {"
    ftypes := split_semi(ed.vftypes[vi])
    mu fi := 0
    lp fi < len(ftypes) {
      cft := if is_boxed_ft(ftypes[fi]) { "s_" + boxed_enum(ftypes[fi], ed.name) + "*" } el { cty(ftypes[fi]) }
      out = out + " " + cft + " f" + int_to_str(fi) + ";"
      fi += 1
    }
    out = out + " } " + ed.vnames[vi] + ";\n"
    vi += 1
  }
  out + "} u; };\n"
}

// One `mkv_<Variant>(args)` constructor per variant: set tag + fields; a boxed
// "@self" field is heap-copied.
fn gen_enum_ctors(ed:EnumDef) -> str {
  mu out := ""
  mu vi := 0
  lp vi < len(ed.vnames) {
    vn := ed.vnames[vi]
    ftypes := split_semi(ed.vftypes[vi])
    out = out + "static s_" + ed.name + " mkv_" + vn + "("
    mu fi := 0
    lp fi < len(ftypes) {
      if fi > 0 { out = out + ", " }
      cft := if is_boxed_ft(ftypes[fi]) { "s_" + boxed_enum(ftypes[fi], ed.name) } el { cty(ftypes[fi]) }
      out = out + cft + " f" + int_to_str(fi)
      fi += 1
    }
    out = out + "){ s_" + ed.name + " v; v.tag=" + int_to_str(vi) + "; "
    fi = 0
    lp fi < len(ftypes) {
      dst := "v.u." + vn + ".f" + int_to_str(fi)
      if is_boxed_ft(ftypes[fi]) {
        bt := boxed_enum(ftypes[fi], ed.name)
        out = out + dst + "=(s_" + bt + "*)GC_MALLOC(sizeof(s_" + bt + ")); *" + dst + "=f" + int_to_str(fi) + "; "
      } el {
        out = out + dst + "=f" + int_to_str(fi) + "; "
      }
      fi += 1
    }
    out = out + "return v; }\n"
    vi += 1
  }
  out
}

// Seed a Syms' param bindings from a function's typed params.
fn seed_params(sy:*Syms, f:Func) {
  mu pj := 0
  lp pj < len(f.params) { set_ty(sy, f.params[pj], f.ptypes[pj]); pj += 1 }
}

// Fresh per-fn Syms: a new var map, params seeded, `@ret` set for `!T` fns.
// Shared by the function-body emit loop AND the closure-collection pass so a
// lambda's captured-var types are computed exactly as the body will see them
// (the caller then runs the same `hoist_decls` to add local types). Do NOT
// hoist here — a second hoist on the same Syms re-declares nothing and would
// blank the emit loop's declaration string.
fn seed_fn(base:*Syms, f:Func) -> Syms {
  mu sy := Syms(base.vty, base.fld, base.ctors, base.frets, base.evar, base.vft, base.gfns, base.lams)
  sy.vty = {}
  seed_params(&sy, f)
  if is_result_ann(f.ret) { set_ty(&sy, "@ret", result_inner(f.ret)) }
  sy
}

// ----- closure collection pass ----------------------------------------------
// Walk a function body; on each FIRST-CLASS lambda (one NOT consumed inline by
// map/filter/reduce) compute its captures, record them on `base.evar`, and push
// a lifted `Func` onto `base.lams`. `sy` is the enclosing fn's seeded+hoisted
// Syms (so a capture's type is `ty_of(sy, name)`). All collectors return a dummy
// i64 (AiLang `mt` is expression-valued, so a side-effecting walker can't have
// bare-block arms); effects flow through the `*Syms` pointers.
fn register_lam(base:*Syms, sy:*Syms, ps:[str], pts:[str], b:Expr, id:i64) -> i64 {
  idstr := int_to_str(id)
  // Seed the lambda's params with their declared types so the body — and the
  // captured-var detection / return-type inference below — types correctly
  // (`fn(name:str) greeting + name` needs `name:str` to pick string concat).
  mu sp := 0
  lp sp < len(ps) { if sp < len(pts) { set_ty(sy, ps[sp], pts[sp]) }   sp += 1 }
  fvs := free_vars(b)
  mu cn := ""                              // ";"-joined capture NAMES
  mu cts := ""                             // ";"-joined capture TYPES (parallel) — `ct` is a reserved word
  mu k := 0
  lp k < len(fvs) {
    nm := fvs[k]
    if is_param(ps, nm) == false {         // not the lambda's own param …
      if has(sy.vty, nm) {                 // … and a real enclosing local ⇒ a capture
        if len(cn) == 0 { cn = nm; cts = ty_of(sy, nm) } el { cn = cn + ";" + nm; cts = cts + ";" + ty_of(sy, nm) }
      }
    }
    k += 1
  }
  // Two parallel keys (names / types), NOT one ":"-packed string — map/result
  // type names contain ':' (e.g. "{str:i64}", "!T") and would corrupt a split.
  base.evar["@lamcaps." + idstr] = cn
  base.evar["@lamcapt." + idstr] = cts
  rty := type_of_expr(sy, b)               // body typed with the params seeded above
  mu noTp:[str] := []
  mu lbody:[Stmt] := []
  lbody = push(lbody, SReturn(b))
  base.lams = push(base.lams, Func(idstr, ps, pts, rty, "", noTp, lbody))
  collect_lams_expr(base, sy, b)           // nested first-class lambdas inside b
  0
}
fn collect2(base:*Syms, sy:*Syms, a:Expr, b:Expr) -> i64 {
  collect_lams_expr(base, sy, a)
  collect_lams_expr(base, sy, b)
  0
}
fn collect3(base:*Syms, sy:*Syms, a:Expr, b:Expr, c:Expr) -> i64 {
  collect_lams_expr(base, sy, a)
  collect_lams_expr(base, sy, b)
  collect_lams_expr(base, sy, c)
  0
}
fn collect_args(base:*Syms, sy:*Syms, args:[Expr]) -> i64 {
  mu i := 0
  lp i < len(args) { collect_lams_expr(base, sy, args[i]); i += 1 }
  0
}
fn collect_kv(base:*Syms, sy:*Syms, keys:[Expr], vals:[Expr]) -> i64 {
  collect_args(base, sy, keys)
  collect_args(base, sy, vals)
  0
}
fn collect_match_e(base:*Syms, sy:*Syms, sc:Expr, bodies:[Expr]) -> i64 {
  collect_lams_expr(base, sy, sc)
  collect_args(base, sy, bodies)
  0
}
fn collect_if_s(base:*Syms, sy:*Syms, c:Expr, b:[Stmt], eb:[Stmt]) -> i64 {
  collect_lams_expr(base, sy, c)
  collect_lams(base, sy, b)
  collect_lams(base, sy, eb)
  0
}
fn collect_body_s(base:*Syms, sy:*Syms, c:Expr, b:[Stmt]) -> i64 {
  collect_lams_expr(base, sy, c)
  collect_lams(base, sy, b)
  0
}
fn collect_coll_s(base:*Syms, sy:*Syms, coll:Expr, b:[Stmt]) -> i64 {
  collect_lams_expr(base, sy, coll)
  collect_lams(base, sy, b)
  0
}
// KEEP map/filter/reduce inlining: do NOT collect their lambda arg (it stays
// inlined by gen_map/filter/reduce), only the array/init args.
fn collect_call(base:*Syms, sy:*Syms, fname:str, args:[Expr]) -> i64 {
  if (fname == "map" || fname == "filter") && len(args) == 2 {
    collect_lams_expr(base, sy, args[0])
    rt 0
  }
  if fname == "reduce" && len(args) == 3 {
    collect_lams_expr(base, sy, args[0])
    collect_lams_expr(base, sy, args[1])
    rt 0
  }
  collect_args(base, sy, args)
  0
}
fn collect_lams_expr(base:*Syms, sy:*Syms, e:Expr) -> i64 {
  mt e {
    Lambda(ps,pts,b,id)  => register_lam(base, sy, ps, pts, b, id);
    Call(fname,args) => collect_call(base, sy, fname, args);
    Bin(op,l,r)      => collect2(base, sy, l, r);
    Unary(op,x)      => collect_lams_expr(base, sy, x);
    Field(obj,fnm)   => collect_lams_expr(base, sy, obj);
    Index(obj,idx)   => collect2(base, sy, obj, idx);
    Array(elems,ety) => collect_args(base, sy, elems);
    Addr(x)          => collect_lams_expr(base, sy, x);
    Match(sc,vn,vb,bd) => collect_match_e(base, sy, sc, bd);
    IfE(c,t,el2)     => collect3(base, sy, c, t, el2);
    Try(x)           => collect_lams_expr(base, sy, x);
    Num(v)           => 0;
    Flt(s)           => 0;
    Str(s)           => 0;
    Var(n)           => 0;
    MapLit(m,mks,mvs) => collect_kv(base, sy, mks, mvs);
    Tuple(elems)     => collect_args(base, sy, elems);
    BlockE(bb)       => collect_lams(base, sy, bb);
    Bad              => 0;
  }
}
fn collect_lams_stmt(base:*Syms, sy:*Syms, s:Stmt) -> i64 {
  mt s {
    SDecl(name,e)         => collect_lams_expr(base, sy, e);
    SDestructure(names,e) => collect_lams_expr(base, sy, e);
    SAssign(name,e)       => collect_lams_expr(base, sy, e);
    SReturn(e)            => collect_lams_expr(base, sy, e);
    SPrint(e)             => collect_lams_expr(base, sy, e);
    SExpr(e)              => collect_lams_expr(base, sy, e);
    SIdxAssign(o,i,e)     => collect3(base, sy, o, i, e);
    SFieldAssign(o,f,e)   => collect2(base, sy, o, e);
    SIf(c,b,eb)           => collect_if_s(base, sy, c, b, eb);
    SLoop(c,b)            => collect_body_s(base, sy, c, b);
    SLoopIn(vnm,coll,b)   => collect_coll_s(base, sy, coll, b);
    SLoopKV(kn,vn,coll,b) => collect_coll_s(base, sy, coll, b);
    SLoopRange(v,lo,hi,b) => collect_range_s(base, sy, lo, hi, b);
    SBreak                => 0;
    SContinue             => 0;
  }
}
fn collect_lams(base:*Syms, sy:*Syms, body:[Stmt]) -> i64 {
  mu i := 0
  lp i < len(body) { collect_lams_stmt(base, sy, body[i]); i += 1 }
  0
}

// Infer a function's C return type from the type of its first `rt expr`
// (i64 if it has none). Uses a Syms seeded with params + the shared struct
// maps so a `rt Point(..)` / `rt p.field` is typed correctly.
fn infer_ret(f:Func, base:Syms) -> str {
  if len(f.ret) > 0 rt f.ret          // explicit `-> T` wins
  mu sy := base
  seed_params(&sy, f)
  first_return_type(&sy, f.body)
}

fn first_return_type(sy:*Syms, body:[Stmt]) -> str {
  mu i := 0
  lp i < len(body) {
    r := stmt_return_type(sy, body[i])
    if r != "" { rt r }
    i += 1
  }
  // No `rt` found: a braceless / tail-expression body returns its LAST
  // expression's type (the loop above fed every decl into `sy`). Only the tail
  // counts — mid-body bare expressions are side effects, not the return.
  if len(body) > 0 { rt last_expr_type(sy, body[len(body) - 1]) }
  ""                                  // empty body → no return
}

// A raw comparison/logic expression: its C value is `int` (1/0), so ailangc's
// _Generic prints it as an int even though its inferred type is bool. (A bool
// *variable* — typed from such an expr — prints true/false.)
fn expr_is_cmp(e:Expr) -> bool {
  mt e {
    Bin(op, l, r)         => op >= OP_LT() && op <= OP_OR();
    Unary(op, x)          => op == OP_NOT();
    Num(v)                => false;
    Flt(fs)               => false;
    Str(ss)               => false;
    Var(nm)               => false;
    Call(fnm, args)       => false;
    Field(ob, fnm2)       => false;
    Index(ob, ix)         => false;
    Array(els, ety)       => false;
    MapLit(mty, ks, vs)   => false;
    Addr(x)               => false;
    Match(sc, vn, vb, bd) => false;
    IfE(cnd, thn, el2)    => false;
    Try(x)                => false;
    Lambda(ps, pts, bd, id)    => false;
    Tuple(tes)            => false;
    BlockE(bb)            => false;
    Bad                   => false;
  }
}
fn expr_is_call(e:Expr) -> bool {
  mt e {
    Call(fnm, args)       => true;
    Tuple(tes)            => false;
    BlockE(bb)            => false;
    Num(v)                => false;
    Flt(fs)               => false;
    Str(ss)               => false;
    Var(nm)               => false;
    Bin(op, l, r)         => false;
    Unary(op, x)          => false;
    Field(ob, fnm2)       => false;
    Index(ob, ix)         => false;
    Array(els, ety)       => false;
    MapLit(mty, ks, vs)   => false;
    Addr(x)               => false;
    Match(sc, vn, vb, bd) => false;
    IfE(cnd, thn, el2)    => false;
    Try(x)                => false;
    Lambda(ps, pts, bd, id)    => false;
    Bad                   => false;
  }
}
// A tail bare-expression's contributed return type — but a tail *call* may be
// void (`type_of_expr` defaults unknown/void calls to i64), and emitting
// `return <void>` from the resulting non-void fn is invalid C. So keep call-tails
// as "" (the fn stays void, as before); only non-call value exprs infer a type.
// The called function's name, or "" if `e` isn't a Call.
fn call_fname(e:Expr) -> str {
  mt e {
    Call(fname, args)  => fname;
    Num(v)             => "";
    Flt(fs)            => "";
    Str(s)             => "";
    Var(n)             => "";
    Bin(o,a,b)         => "";
    Unary(o,x)         => "";
    Field(o,f)         => "";
    Index(o,ix)        => "";
    Array(es,et)       => "";
    MapLit(ml,mks,mvs) => "";
    Addr(x)            => "";
    Match(sc,vn,vb,bd) => "";
    IfE(c,t,el2)       => "";
    Try(e2)            => "";
    Lambda(ps,pts,b,id)    => "";
    Tuple(tes)         => "";
    BlockE(bb)         => "";
    Bad                => "";
  }
}
// The type a tail bare-expression contributes as an implicit return. A tail
// *call* is only trusted when the callee's return type is KNOWN via `frets` (a
// user fn or a declared extern): a void user-fn maps to "" (stays void); an
// unknown/builtin call also stays "" — both avoid the old `return <void>` trap
// where `type_of_expr` defaulted such calls to i64 and flipped the fn non-void.
fn tail_sexpr_type(sy:*Syms, e:Expr) -> str {
  if expr_is_call(e) {
    fnm := call_fname(e)
    if has(sy.frets, fnm) rt sy.frets[fnm]
    rt ""
  }
  type_of_expr(sy, e)
}
// The type a trailing statement contributes as an implicit tail return: a bare
// expression (or explicit `rt`) yields its expression's type; every other
// statement form yields "" (no value falls out of it).
fn last_expr_type(sy:*Syms, s:Stmt) -> str {
  mt s {
    SExpr(e)             => tail_sexpr_type(sy, e);
    SReturn(e)           => type_of_expr(sy, e);
    SDestructure(names,e)=> "";
    SDecl(name,e)        => "";
    SAssign(name,e)      => "";
    SIdxAssign(o,i,e)    => "";
    SFieldAssign(o,f,e)  => "";
    SIf(c,b,eb)          => "";
    SLoop(c,b)           => "";
    SLoopIn(vnm,coll,b)  => "";
    SLoopKV(kn,vn,coll,b)=> "";
    SLoopRange(v,lo,hi,b)=> "";
    SPrint(e)            => "";
    SBreak               => "";
    SContinue            => "";
  }
}

// If this statement (or a branch/loop it contains) has a tail `rt`, the type of
// its expression; "" otherwise. Also feeds `sy` so a decl before the `rt` types
// later field access. Returns "i64" coerced default at the call site.
fn stmt_return_type(sy:*Syms, s:Stmt) -> str {
  mt s {
    SReturn(e)            => type_of_expr(sy, e);
    SDestructure(names,e) => "";
    SDecl(name,e)         => decl_side(sy, name, e);
    SIf(c,b,eb)           => either_return(sy, b, eb);
    SLoop(c,b)            => first_return_type(sy, b);
    SLoopIn(vnm,coll,b)   => first_return_type(sy, b);
    SLoopKV(kn,vn,coll,b) => first_return_type(sy, b);
    SLoopRange(v,lo,hi,b) => first_return_type(sy, b);
    SAssign(name,e)       => "";
    SIdxAssign(o,i,e)     => "";
    SFieldAssign(o,f,e)   => "";
    SPrint(e)             => "";
    SBreak                => "";
    SContinue             => "";
    SExpr(e)              => "";
  }
}

// Record a decl's type into sy (side effect) during return inference; never a
// return itself.
fn decl_side(sy:*Syms, name:str, e:Expr) -> str {
  set_ty(sy, name, type_of_expr(sy, e))
  ""
}

fn either_return(sy:*Syms, b:[Stmt], eb:[Stmt]) -> str {
  r := first_return_type(sy, b)
  if r != "" { rt r }
  first_return_type(sy, eb)
}

// ===== driver ===============================================================
ex fn system(cmd:str) -> i32

// True if `sub` occurs anywhere in `s` — reuses the `index_of` builtin (a
// strstr-based substring search). Gates the optional native sections
// (sockets/time/regex/process) on source usage so a program that uses none
// emits byte-identical C without pulling in the heavy headers.
fn has_sub(s:str, sub:str) -> bool {
  index_of(s, sub) >= 0
}

// ----- empty `{}` usage inference -------------------------------------------
// An un-annotated `m := {}` has no (K,V) until used. Before hoist/codegen we
// scan the function body for the first `m[k]=v` and stamp the MapLit with
// `{type(k):type(v)}`, so the existing MapLit-type machinery carries it.
// (ailangc does this in sema; selfhost has no sema, hence this transform.)
fn var_name(e:Expr) -> str {
  mt e {
    Var(n)             => n;
    Num(v)             => "";
    Flt(fs)            => "";
    Str(s)             => "";
    Bin(o,a,b)         => "";
    Unary(o,x)         => "";
    Call(f,a)          => "";
    Field(o,f)         => "";
    Index(o,ix)        => "";
    Array(es,et)       => "";
    MapLit(ml,mks,mvs) => "";
    Addr(x)            => "";
    Match(sc,vn,vb,bd) => "";
    IfE(c,t,el2)       => "";
    Try(e2)            => "";
    Lambda(ps,pts,b,id)    => "";
    Bad                => "";
  }
}
fn is_empty_maplit(e:Expr) -> bool {
  mt e {
    MapLit(ml,mks,mvs) => len(mks) == 0;
    Tuple(tes)         => false;
    BlockE(bb)         => false;
    Var(n)             => false;
    Num(v)             => false;
    Flt(fs)            => false;
    Str(s)             => false;
    Bin(o,a,b)         => false;
    Unary(o,x)         => false;
    Call(f,a)          => false;
    Field(o,f)         => false;
    Index(o,ix)        => false;
    Array(es,et)       => false;
    Addr(x)            => false;
    Match(sc,vn,vb,bd) => false;
    IfE(c,t,el2)       => false;
    Try(e2)            => false;
    Lambda(ps,pts,b,id)    => false;
    Bad                => false;
  }
}
// First `m[k]=v` (recursing into nested blocks, typing loop vars en route) →
// "{type(k):type(v)}", or "" if none.
fn map_assign_type(sy:*Syms, body:[Stmt], m:str) -> str {
  mu i := 0
  lp i < len(body) {
    t := map_assign_type_s(sy, body[i], m)
    if len(t) > 0 rt t
    i += 1
  }
  ""
}
fn scan_loopin(sy:*Syms, vnm:str, coll:Expr, b:[Stmt], m:str) -> str {
  set_ty(sy, vnm, coll_elem_type(sy, coll))
  map_assign_type(sy, b, m)
}
fn scan_loopkv(sy:*Syms, kn:str, vn:str, coll:Expr, b:[Stmt], m:str) -> str {
  t := type_of_expr(sy, coll)
  set_ty(sy, kn, map_ktype(t))
  set_ty(sy, vn, map_vtype(t))
  map_assign_type(sy, b, m)
}
fn scan_range(sy:*Syms, v:str, b:[Stmt], m:str) -> str {
  set_ty(sy, v, "i64")
  map_assign_type(sy, b, m)
}
fn scan_either(sy:*Syms, b:[Stmt], eb:[Stmt], m:str) -> str {
  t := map_assign_type(sy, b, m)
  if len(t) > 0 rt t
  map_assign_type(sy, eb, m)
}
fn idx_assign_type(sy:*Syms, o:Expr, idx:Expr, e:Expr, m:str) -> str {
  if var_name(o) == m rt "{" + type_of_expr(sy, idx) + ":" + type_of_expr(sy, e) + "}"
  ""
}
fn map_assign_type_s(sy:*Syms, s:Stmt, m:str) -> str {
  mt s {
    SIdxAssign(o,idx,e)   => idx_assign_type(sy, o, idx, e, m);
    SDestructure(names,e) => "";
    SIf(c,b,eb)           => scan_either(sy, b, eb, m);
    SLoop(c,b)            => map_assign_type(sy, b, m);
    SLoopIn(vnm,coll,b)   => scan_loopin(sy, vnm, coll, b, m);
    SLoopKV(kn,vn,coll,b) => scan_loopkv(sy, kn, vn, coll, b, m);
    SLoopRange(v,lo,hi,b) => scan_range(sy, v, b, m);
    SDecl(name,e)         => "";
    SAssign(name,e)       => "";
    SFieldAssign(o,f,e)   => "";
    SReturn(e)            => "";
    SPrint(e)             => "";
    SBreak                => "";
    SContinue             => "";
    SExpr(e)              => "";
  }
}
// Top-level transform: stamp each un-annotated `m := {}` with its inferred type;
// type regular decls so later `lp x in coll` / index types resolve.
// Empty INFERRED array `mu x := []` (no annotation): pin its element type from
// the first top-level `x = push(x, E)`, mirroring the empty-`{}` map back-prop.
fn is_empty_array(e:Expr) -> bool {
  mt e {
    Array(es,et)       => len(es) == 0 && et == "";
    Tuple(tes)         => false;
    BlockE(bb)         => false;
    MapLit(ml,mks,mvs) => false;
    Var(n)             => false;
    Num(v)             => false;
    Flt(fs)            => false;
    Str(s)             => false;
    Bin(o,a,b)         => false;
    Unary(o,x)         => false;
    Call(f,a)          => false;
    Field(o,f)         => false;
    Index(o,ix)        => false;
    Addr(x)            => false;
    Match(sc,vn,vb,bd) => false;
    IfE(c,t,el2)       => false;
    Try(e2)            => false;
    Lambda(ps,pts,b,id)    => false;
    Bad                => false;
  }
}
fn push_args_elem(sy:*Syms, fname:str, args:[Expr]) -> str {
  if fname == "push" && len(args) == 2 rt type_of_expr(sy, args[1])
  ""
}
fn push_call_elem(sy:*Syms, e:Expr) -> str {
  mt e {
    Call(fname, args)  => push_args_elem(sy, fname, args);
    Tuple(tes)         => "";
    BlockE(bb)         => "";
    Array(es,et)       => "";
    MapLit(ml,mks,mvs) => "";
    Var(n)             => "";
    Num(v)             => "";
    Flt(fs)            => "";
    Str(s)             => "";
    Bin(o,a,b)         => "";
    Unary(o,x)         => "";
    Field(o,f)         => "";
    Index(o,ix)        => "";
    Addr(x)            => "";
    Match(sc,vn,vb,bd) => "";
    IfE(c,t,el2)       => "";
    Try(e2)            => "";
    Lambda(ps,pts,b,id)    => "";
    Bad                => "";
  }
}
fn same_name_push(sy:*Syms, name:str, e:Expr, a:str) -> str {
  if name != a rt ""
  push_call_elem(sy, e)
}
fn push_assign_elem(sy:*Syms, s:Stmt, a:str) -> str {
  mt s {
    SAssign(name, e)      => same_name_push(sy, name, e, a);
    SDestructure(names,e) => "";
    SDecl(name,e)         => "";
    SIdxAssign(o,ix,e)    => "";
    SFieldAssign(o,f,e)   => "";
    SReturn(e)            => "";
    SPrint(e)             => "";
    SIf(c,b,eb)           => "";
    SLoop(c,b)            => "";
    SLoopIn(vnm,coll,b)   => "";
    SLoopKV(kn,vn,coll,b) => "";
    SLoopRange(v,lo,hi,b) => "";
    SBreak                => "";
    SContinue             => "";
    SExpr(e)              => "";
  }
}
fn array_elem_from_push(sy:*Syms, body:[Stmt], a:str) -> str {
  mu i := 0
  lp i < len(body) {
    t := push_assign_elem(sy, body[i], a)
    if len(t) > 0 rt t
    i += 1
  }
  ""
}
fn stamp_decl_e(sy:*Syms, body:[Stmt], name:str, e:Expr) -> Stmt {
  if is_empty_maplit(e) {
    t := map_assign_type(sy, body, name)
    if len(t) > 0 rt SDecl(name, MapLit(t, no_exprs(), no_exprs()))   // typing handled by pass-1 + hoist
  }
  if is_empty_array(e) {
    et := array_elem_from_push(sy, body, name)
    if len(et) > 0 rt SDecl(name, Array(no_exprs(), et))              // pin elem type from first push
  }
  SDecl(name, e)
}
fn stamp_decl(sy:*Syms, body:[Stmt], s:Stmt) -> Stmt {
  mt s {
    SDecl(name,e)         => stamp_decl_e(sy, body, name, e);
    SDestructure(names,e) => s;
    SAssign(name,e)       => s;
    SIdxAssign(o,ix,e)    => s;
    SFieldAssign(o,f,e)   => s;
    SReturn(e)            => s;
    SPrint(e)             => s;
    SIf(c,b,eb)           => s;
    SLoop(c,b)            => s;
    SLoopIn(vnm,coll,b)   => s;
    SLoopKV(kn,vn,coll,b) => s;
    SLoopRange(v,lo,hi,b) => s;
    SBreak                => s;
    SContinue             => s;
    SExpr(e)              => s;
  }
}
// pass 1: type every top-level decl so inference resolves feed-arrays regardless
// of decl order (e.g. `counts := {}` declared BEFORE `words := split(...)`).
fn seed_one(sy:*Syms, name:str, e:Expr) -> i64 { set_ty(sy, name, type_of_expr(sy, e)); 0 }
fn seed_decl_s(sy:*Syms, s:Stmt) -> i64 {
  mt s {
    SDecl(name,e)         => seed_one(sy, name, e);
    SDestructure(names,e) => 0;
    SAssign(name,e)       => 0;
    SIdxAssign(o,ix,e)    => 0;
    SFieldAssign(o,f,e)   => 0;
    SReturn(e)            => 0;
    SPrint(e)             => 0;
    SIf(c,b,eb)           => 0;
    SLoop(c,b)            => 0;
    SLoopIn(vnm,coll,b)   => 0;
    SLoopKV(kn,vn,coll,b) => 0;
    SLoopRange(v,lo,hi,b) => 0;
    SBreak                => 0;
    SContinue             => 0;
    SExpr(e)              => 0;
  }
}
fn stamp_empty_maps(sy:*Syms, body:[Stmt]) -> [Stmt] {
  mu si := 0
  lp si < len(body) { seed_decl_s(sy, body[si]); si += 1 }   // pass 1: type decls
  mu out:[Stmt] := []
  mu i := 0
  lp i < len(body) {                                          // pass 2: stamp `{}`
    out = push(out, stamp_decl(sy, body, body[i]))
    i += 1
  }
  out
}

fn compile_to_c(src:str) -> str {
  toks := lex(src)
  mu p := P(toks, 0, src)

  mu structs:[StructDef] := []
  mu enums:[EnumDef] := []
  mu funcs:[Func] := []
  mu externs:[Func] := []
  mu cincs:[str] := []
  mu mains:[Stmt] := []

  lp ckind(&p) != TK_EOF() {
    if ckind(&p) == TK_SEMI() { adv(&p); ct }   // skip stray `;` separators
    if ckind(&p) == TK_IDENT() && ctext(&p) == "st" {
      structs = push(structs, parse_struct(&p))
    } el if ckind(&p) == TK_IDENT() && ctext(&p) == "en" {
      enums = push(enums, parse_enum(&p))
    } el if ckind(&p) == TK_IDENT() && ctext(&p) == "cinc" {
      adv(&p); cincs = push(cincs, ctext(&p)); adv(&p)   // cinc "header.h"
    } el if ckind(&p) == TK_IDENT() && ctext(&p) == "ex" {
      externs = push(externs, parse_extern(&p))
    } el if ckind(&p) == TK_IDENT() && ctext(&p) == "fn" {
      funcs = push(funcs, parse_func(&p))
    } el {
      mains = push(mains, parse_stmt(&p))
    }
  }

  // Split generic functions (`fn id<T>(…)`) out — inlined at call sites, not
  // emitted as C functions. Regular fns emit normally.
  mu gfuncs:[Func] := []
  mu rfuncs:[Func] := []
  mu gi := 0
  lp gi < len(funcs) {
    if len(funcs[gi].tparams) > 0 { gfuncs = push(gfuncs, funcs[gi]) } el { rfuncs = push(rfuncs, funcs[gi]) }
    gi += 1
  }
  funcs = rfuncs

  // Build the shared type context: struct ctors + field-type map + enum tables.
  mu nolams:[Func] := []
  mu base := Syms({}, {}, {}, {}, {}, {}, gfuncs, nolams)
  mu si := 0
  lp si < len(structs) {
    sd := structs[si]
    base.ctors[sd.name] = "1"
    mu fi := 0
    lp fi < len(sd.fnames) { base.fld[fkey(sd.name, sd.fnames[fi])] = sd.ftypes[fi]; fi += 1 }
    si += 1
  }
  // Box bare cross-enum fields now that ALL enums are known (mutual recursion),
  // BEFORE the registry/codegen read their field types.
  enums = box_cross_enums(enums)
  // Mark extern return types that name a C-header type (`-> div_t`) so they spell
  // raw, now that all user structs/enums are known.
  externs = mark_extern_ctypes(externs, structs, enums)
  // Enum registry: each variant → its enum + ";"-joined field types; plus a
  // per-enum "@order.<Enum>" → ";"-joined variant list (for tag indices).
  mu ei := 0
  lp ei < len(enums) {
    ed := enums[ei]
    mu order := ""
    mu vi := 0
    lp vi < len(ed.vnames) {
      vn := ed.vnames[vi]
      base.evar[vn] = ed.name
      base.vft[vn] = ed.vftypes[vi]
      if vi == 0 { order = vn } el { order = order + ";" + vn }
      vi += 1
    }
    base.evar["@order." + ed.name] = order
    ei += 1
  }
  // Externs FIRST: register each declared return type before fn inference, so a
  // fn whose tail is an extern call (`fn parse_int(s) { atoi(s) }`) infers that
  // extern's return type instead of defaulting to void. (i32/i64 both lower to
  // int64_t via cty, so this is fixpoint-stable.)
  mu xi := 0
  lp xi < len(externs) {
    if len(externs[xi].ret) > 0 { base.frets[externs[xi].name] = externs[xi].ret }
    xi += 1
  }
  // Infer + record each fn's return type (so calls type their results).
  mu fi2 := 0
  lp fi2 < len(funcs) {
    f := funcs[fi2]
    base.frets[f.name] = infer_ret(f, base)
    fi2 += 1
  }
  // Mark generic fn names so calls are recognized + inlined (see gen_call).
  mu gj := 0
  lp gj < len(gfuncs) {
    base.evar["@generic." + gfuncs[gj].name] = "1"
    gj += 1
  }

  // Closure collection pass: discover every first-class lambda (each user fn's
  // body, then `main`), recording its captures + a lifted Func on `base`. Seeds
  // each Syms exactly as the body-emit loop does (seed_fn / fresh-vty + hoist),
  // so capture types match. `main.ail` itself has no first-class lambdas ⇒
  // `base.lams` stays empty ⇒ the gated emission below is skipped ⇒ fixpoint safe.
  mu cf := 0
  lp cf < len(funcs) {
    mu csy := seed_fn(&base, funcs[cf])
    cdecls := hoist_decls(&csy, funcs[cf].body, "    ")
    collect_lams(&base, &csy, funcs[cf].body)
    cf += 1
  }
  mu csm := Syms(base.vty, base.fld, base.ctors, base.frets, base.evar, base.vft, base.gfns, base.lams)
  csm.vty = {}
  cmdecls := hoist_decls(&csm, mains, "    ")
  collect_lams(&base, &csm, mains)

  // Link-flag marker: one comment line listing the libs from `ex "lib"` decls,
  // read back by the driver to append `-l<lib>` to clang. Absent when nothing
  // needs linking (e.g. main.ail itself), so its own emitted C is unchanged.
  mu out := ""
  mu lk := 0
  mu libline := ""
  lp lk < len(externs) {
    if len(externs[lk].lib) > 0 { libline = libline + " " + externs[lk].lib }
    lk += 1
  }
  if len(libline) > 0 { out = "// @links:" + libline + "\n" }

  // C prelude: headers (system, then `cinc` headers) + string/runtime helpers.
  // Runtime allocates via Boehm GC (`GC_MALLOC` + `<gc.h>`, linked `-lgc`) to
  // match the Rust reference — there is no `free`; the collector reclaims, so
  // long-running programs (servers) no longer leak.
  // Optional native sections, gated on source usage. main.ail mentions every
  // name (in codegen strings) so it pulls them all — harmless (libc-only, no
  // link flags; unused statics are stripped) and fixpoint-safe (stage2==stage3).
  needs_time := has_sub(src, "now_ms") || has_sub(src, "now_us") || has_sub(src, "mono_ms") || has_sub(src, "sleep_ms") || has_sub(src, "time_iso")
  needs_sock := has_sub(src, "tcp_listen") || has_sub(src, "tcp_connect") || has_sub(src, "tcp_accept") || has_sub(src, "sock_send") || has_sub(src, "sock_recv") || has_sub(src, "sock_close")
  needs_proc := has_sub(src, "proc_fork") || has_sub(src, "proc_getpid") || has_sub(src, "proc_no_zombies") || has_sub(src, "proc_reap")
  needs_regex := has_sub(src, "regex_match") || has_sub(src, "regex_find")
  // TLS (OpenSSL) + Postgres (libpq) — unlike the libc sections above these need
  // external libs, so the clang cmd in main() adds -lssl/-lcrypto / -lpq when the
  // emitted C uses them. main.ail mentions these names so its self-compile pulls
  // them in (needs both libs installed — fixpoint-safe: stage2==stage3).
  needs_tls := has_sub(src, "tls_") || has_sub(src, "sha1")
  needs_pg := has_sub(src, "pg_")
  out = out + "#include <stdio.h>\n#include <stdint.h>\n#include <stdlib.h>\n#include <string.h>\n#include <stdarg.h>\n#include <gc.h>\n"
  if needs_time { out = out + "#include <time.h>\n" }
  if needs_sock { out = out + "#include <sys/socket.h>\n#include <netinet/in.h>\n#include <arpa/inet.h>\n#include <netdb.h>\n#include <unistd.h>\n" }
  if needs_proc { out = out + "#include <unistd.h>\n#include <signal.h>\n#include <sys/wait.h>\n" }
  if needs_regex { out = out + "#include <regex.h>\n" }
  if needs_tls { out = out + "#include <openssl/ssl.h>\n#include <openssl/err.h>\n#include <openssl/sha.h>\n" }
  if needs_pg { out = out + "#include <libpq-fe.h>\n" }
  mu ci := 0
  lp ci < len(cincs) { out = out + "#include \"" + cincs[ci] + "\"\n"; ci += 1 }
  out = out + "static const char* scat(const char* a, const char* b){ size_t la=strlen(a), lb=strlen(b); char* r=(char*)GC_MALLOC(la+lb+1); memcpy(r,a,la); memcpy(r+la,b,lb); r[la+lb]=0; return r; }\n"
  out = out + "static const char* i2s(long long v){ char* r=(char*)GC_MALLOC(24); snprintf(r,24,\"%lld\",v); return r; }\n"
  // substring is [a, b) end-exclusive (matches AiLang); str_to_int via strtoll.
  out = out + "static const char* substr(const char* s, int64_t a, int64_t b){ int64_t n=(int64_t)strlen(s); if(a<0)a=0; if(b>n)b=n; if(b<a)b=a; int64_t L=b-a; char* r=(char*)GC_MALLOC(L+1); memcpy(r,s+a,L); r[L]=0; return r; }\n"
  out = out + "static int64_t s2i(const char* s){ return (int64_t)strtoll(s,0,10); }\n"
  // f64 <-> str: %g formatting (matches AiLang's float print) / strtod parse.
  out = out + "static const char* f2s(double v){ char* r=(char*)GC_MALLOC(32); snprintf(r,32,\"%g\",v); return r; }\n"
  out = out + "static double s2f(const char* s){ return strtod(s,0); }\n"
  out = out + "static const char* read_file_c(const char* path){ FILE* f=fopen(path,\"rb\"); if(!f) return \"\"; fseek(f,0,SEEK_END); long n=ftell(f); fseek(f,0,SEEK_SET); char* b=(char*)GC_MALLOC(n+1); if(n>0) fread(b,1,n,f); b[n]=0; fclose(f); return b; }\n"
  out = out + "static int64_t write_file_c(const char* path, const char* content){ FILE* f=fopen(path,\"wb\"); if(!f) return 0; fwrite(content,1,strlen(content),f); fclose(f); return 1; }\n"
  // bytes — a binary buffer {len, data} distinct from str (may hold embedded \0).
  out = out + "typedef struct { int64_t len; const uint8_t* data; } ailang_bytes;\n"
  out = out + "static ailang_bytes str_to_bytes(const char* s){ ailang_bytes r; if(!s){ r.len=0; r.data=(const uint8_t*)\"\"; return r; } size_t n=strlen(s); r.len=(int64_t)n; r.data=(const uint8_t*)s; return r; }\n"
  out = out + "static const char* bytes_to_str(ailang_bytes b){ char* buf=(char*)GC_MALLOC((size_t)b.len+1); if(b.len>0) memcpy(buf,b.data,(size_t)b.len); buf[b.len]=0; return buf; }\n"
  out = out + "static int64_t bytes_at(ailang_bytes b, int64_t i){ if(i<0||i>=b.len) return 0; return (int64_t)b.data[i]; }\n"
  out = out + "static ailang_bytes bytes_slice(ailang_bytes b, int64_t lo, int64_t hi){ if(lo<0) lo=0; if(hi>b.len) hi=b.len; if(lo>hi) lo=hi; int64_t n=hi-lo; ailang_bytes r; r.len=n; uint8_t* buf=(uint8_t*)GC_MALLOC((size_t)(n>0?n:1)); if(n>0) memcpy(buf,b.data+lo,(size_t)n); r.data=buf; return r; }\n"
  out = out + "static ailang_bytes read_file_bytes(const char* path){ ailang_bytes r; r.len=0; r.data=(const uint8_t*)\"\"; FILE* f=fopen(path,\"rb\"); if(!f) return r; if(fseek(f,0,SEEK_END)!=0){ fclose(f); return r; } long sz=ftell(f); if(sz<0){ fclose(f); return r; } fseek(f,0,SEEK_SET); uint8_t* buf=(uint8_t*)GC_MALLOC((size_t)(sz>0?sz:1)); size_t got=fread(buf,1,(size_t)sz,f); fclose(f); r.len=(int64_t)got; r.data=buf; return r; }\n"
  out = out + "static int64_t write_file_bytes(const char* path, ailang_bytes b){ FILE* f=fopen(path,\"wb\"); if(!f) return 0; size_t want=(size_t)b.len; size_t got=b.len>0?fwrite(b.data,1,want,f):0; int closed=fclose(f); return (closed==0 && got==want)?1:0; }\n"
  out = out + "static void print_bytes(ailang_bytes b){ putchar(98); putchar(34); for(int64_t i=0;i<b.len;i++){ unsigned c=b.data[i]; if(c==34){ putchar(92); putchar(34); } else if(c==92){ putchar(92); putchar(92); } else if(c==10){ putchar(92); putchar(110); } else if(c==13){ putchar(92); putchar(114); } else if(c==9){ putchar(92); putchar(116); } else if(c>=32 && c<127){ putchar((int)c); } else { putchar(92); putchar(120); printf(\"%02x\", c); } } putchar(34); }\n"
  // ===== Phase 1 builtins: string / numeric / io (ported from the Rust =======
  // prelude; behaviour matches `ailangc` so sample output is identical). Bool
  // is i64 (0/1) per AiLang's model; `=0` terminates (no `'\0'` escaping).
  out = out + "static int64_t str_contains(const char* h, const char* n){ if(!h||!n) return 0; return strstr(h,n)!=0; }\n"
  out = out + "static int64_t starts_with(const char* s, const char* p){ if(!s||!p) return 0; size_t lp=strlen(p); return strncmp(s,p,lp)==0; }\n"
  out = out + "static int64_t ends_with(const char* s, const char* su){ if(!s||!su) return 0; size_t ls=strlen(s),lu=strlen(su); if(lu>ls) return 0; return memcmp(s+ls-lu,su,lu)==0; }\n"
  out = out + "static int64_t str_index_of(const char* h, const char* n){ if(!h||!n) return -1; const char* p=strstr(h,n); return p?(int64_t)(p-h):(int64_t)-1; }\n"
  out = out + "static const char* to_upper(const char* s){ if(!s) return \"\"; size_t n=strlen(s); char* o=(char*)GC_MALLOC(n+1); for(size_t i=0;i<n;i++){ unsigned char c=(unsigned char)s[i]; o[i]=(c>=97&&c<=122)?(char)(c-32):(char)c; } o[n]=0; return o; }\n"
  out = out + "static const char* to_lower(const char* s){ if(!s) return \"\"; size_t n=strlen(s); char* o=(char*)GC_MALLOC(n+1); for(size_t i=0;i<n;i++){ unsigned char c=(unsigned char)s[i]; o[i]=(c>=65&&c<=90)?(char)(c+32):(char)c; } o[n]=0; return o; }\n"
  out = out + "static const char* trim(const char* s){ if(!s) return \"\"; const char* p=s; while(*p==32||*p==9||*p==10||*p==13) p++; const char* e=s+strlen(s); while(e>p){ char c=e[-1]; if(c!=32&&c!=9&&c!=10&&c!=13) break; e--; } size_t n=(size_t)(e-p); char* o=(char*)GC_MALLOC(n+1); memcpy(o,p,n); o[n]=0; return o; }\n"
  out = out + "static const char* str_replace(const char* s, const char* a, const char* b){ if(!s||!a||!*a) return s?s:\"\"; if(!b) b=\"\"; size_t la=strlen(a),lb=strlen(b); size_t cnt=0; const char* p=s; while((p=strstr(p,a))!=0){ cnt++; p+=la; } size_t ls=strlen(s); size_t ol=ls+cnt*(lb>=la?lb-la:0)-cnt*(la>lb?la-lb:0); char* o=(char*)GC_MALLOC(ol+1); char* w=o; const char* r=s; while((p=strstr(r,a))!=0){ size_t bf=(size_t)(p-r); memcpy(w,r,bf); w+=bf; memcpy(w,b,lb); w+=lb; r=p+la; } size_t tl=strlen(r); memcpy(w,r,tl); w+=tl; *w=0; return o; }\n"
  out = out + "static const char* repeat(const char* s, int64_t n){ if(!s||n<=0) return \"\"; size_t one=strlen(s); size_t tot=one*(size_t)n; char* o=(char*)GC_MALLOC(tot+1); for(int64_t i=0;i<n;i++) memcpy(o+(size_t)i*one,s,one); o[tot]=0; return o; }\n"
  out = out + "static const char* pad_left(const char* s, int64_t w, const char* pad){ if(!s) s=\"\"; if(!pad||!*pad) pad=\" \"; size_t sl=strlen(s); if((int64_t)sl>=w){ char* o=(char*)GC_MALLOC(sl+1); memcpy(o,s,sl+1); return o; } size_t pl=strlen(pad); size_t need=(size_t)w-sl; char* o=(char*)GC_MALLOC((size_t)w+1); size_t i=0; while(i<need){ o[i]=pad[i%pl]; i++; } memcpy(o+need,s,sl); o[w]=0; return o; }\n"
  out = out + "static const char* pad_right(const char* s, int64_t w, const char* pad){ if(!s) s=\"\"; if(!pad||!*pad) pad=\" \"; size_t sl=strlen(s); if((int64_t)sl>=w){ char* o=(char*)GC_MALLOC(sl+1); memcpy(o,s,sl+1); return o; } size_t pl=strlen(pad); char* o=(char*)GC_MALLOC((size_t)w+1); memcpy(o,s,sl); size_t i=sl; while(i<(size_t)w){ o[i]=pad[(i-sl)%pl]; i++; } o[w]=0; return o; }\n"
  out = out + "static const char* chr(int64_t i){ char* o=(char*)GC_MALLOC(2); o[0]=(char)(i&255); o[1]=0; return o; }\n"
  out = out + "static int64_t ord(const char* s){ return (s&&*s)?(int64_t)(unsigned char)s[0]:0; }\n"
  out = out + "static int64_t str_to_bool(const char* s){ if(!s) return 0; if(strcmp(s,\"true\")==0) return 1; if(strcmp(s,\"True\")==0) return 1; if(strcmp(s,\"TRUE\")==0) return 1; if(strcmp(s,\"1\")==0) return 1; if(strcmp(s,\"yes\")==0) return 1; return 0; }\n"
  out = out + "static int64_t abs_i64(int64_t n){ return n<0?-n:n; }\n"
  out = out + "static double abs_f64(double x){ return x<0?-x:x; }\n"
  out = out + "static int64_t sign(int64_t n){ return (n>0)-(n<0); }\n"
  out = out + "static int64_t clamp(int64_t n, int64_t lo, int64_t hi){ if(n<lo) return lo; if(n>hi) return hi; return n; }\n"
  out = out + "static const char* read_line(void){ size_t cap=128,len=0; char* b=(char*)GC_MALLOC(cap); int c; while((c=fgetc(stdin))!=EOF&&c!=10){ if(len+1>=cap){ size_t nc=cap*2; char* nb=(char*)GC_MALLOC(nc); memcpy(nb,b,len); b=nb; cap=nc; } b[len++]=(char)c; } b[len]=0; if(len==0&&c==EOF) return \"\"; return b; }\n"
  out = out + "static const char* get_env(const char* name){ const char* v=name?getenv(name):0; return v?v:\"\"; }\n"
  out = out + "static const char* format(const char* fmt, ...){ char b[1024]; va_list ap; va_start(ap,fmt); int n=vsnprintf(b,sizeof b,fmt?fmt:\"\",ap); va_end(ap); if(n<0) n=0; if(n>=(int)sizeof b) n=(int)sizeof b-1; char* o=(char*)GC_MALLOC((size_t)n+1); memcpy(o,b,(size_t)n+1); return o; }\n"
  // ===== Phase 2 optional native sections (gated; ported from prelude.c) =====
  if needs_time {
    out = out + "static int64_t now_ms(void){ struct timespec ts; if(clock_gettime(CLOCK_REALTIME,&ts)!=0) return 0; return (int64_t)ts.tv_sec*1000+(int64_t)(ts.tv_nsec/1000000); }\n"
    out = out + "static int64_t now_us(void){ struct timespec ts; if(clock_gettime(CLOCK_REALTIME,&ts)!=0) return 0; return (int64_t)ts.tv_sec*1000000+(int64_t)(ts.tv_nsec/1000); }\n"
    out = out + "static int64_t mono_ms(void){ struct timespec ts; if(clock_gettime(CLOCK_MONOTONIC,&ts)!=0) return 0; return (int64_t)ts.tv_sec*1000+(int64_t)(ts.tv_nsec/1000000); }\n"
    out = out + "static void sleep_ms(int64_t ms){ if(ms<=0) return; struct timespec ts; ts.tv_sec=(time_t)(ms/1000); ts.tv_nsec=(long)((ms%1000)*1000000); while(nanosleep(&ts,&ts)==-1){} }\n"
    out = out + "static const char* time_iso(int64_t ms){ time_t sec=(time_t)(ms/1000); struct tm tmv; if(!gmtime_r(&sec,&tmv)) return \"\"; char* buf=(char*)GC_MALLOC(32); size_t n=strftime(buf,32,\"%Y-%m-%dT%H:%M:%SZ\",&tmv); if(n==0){ buf[0]=0; } return buf; }\n"
  }
  if needs_sock {
    out = out + "static int64_t tcp_listen(const char* host, int64_t port){ if(!host||port<=0||port>65535) return -1; int fd=socket(AF_INET,SOCK_STREAM,0); if(fd<0) return -1; int yes=1; setsockopt(fd,SOL_SOCKET,SO_REUSEADDR,&yes,sizeof(yes)); struct sockaddr_in addr; memset(&addr,0,sizeof(addr)); addr.sin_family=AF_INET; addr.sin_port=htons((uint16_t)port); if(host[0]==0||strcmp(host,\"0.0.0.0\")==0){ addr.sin_addr.s_addr=htonl(INADDR_ANY); } else if(inet_pton(AF_INET,host,&addr.sin_addr)!=1){ close(fd); return -1; } if(bind(fd,(struct sockaddr*)&addr,sizeof(addr))<0){ close(fd); return -1; } if(listen(fd,128)<0){ close(fd); return -1; } return (int64_t)fd; }\n"
    out = out + "static int64_t tcp_accept(int64_t fd){ struct sockaddr_in addr; socklen_t len=sizeof(addr); int client=accept((int)fd,(struct sockaddr*)&addr,&len); if(client<0) return -1; return (int64_t)client; }\n"
    out = out + "static int64_t tcp_connect(const char* host, int64_t port){ if(!host||port<=0||port>65535) return -1; int fd=socket(AF_INET,SOCK_STREAM,0); if(fd<0) return -1; struct sockaddr_in addr; memset(&addr,0,sizeof(addr)); addr.sin_family=AF_INET; addr.sin_port=htons((uint16_t)port); if(inet_pton(AF_INET,host,&addr.sin_addr)!=1){ struct addrinfo hints; memset(&hints,0,sizeof(hints)); hints.ai_family=AF_INET; hints.ai_socktype=SOCK_STREAM; struct addrinfo* res=0; if(getaddrinfo(host,0,&hints,&res)!=0||!res){ close(fd); return -1; } addr.sin_addr=((struct sockaddr_in*)res->ai_addr)->sin_addr; freeaddrinfo(res); } if(connect(fd,(struct sockaddr*)&addr,sizeof(addr))<0){ close(fd); return -1; } return (int64_t)fd; }\n"
    out = out + "static int64_t sock_send(int64_t fd, ailang_bytes b){ if(fd<0) return -1; if(b.len==0) return 0; ssize_t n=send((int)fd,b.data,(size_t)b.len,0); return (int64_t)n; }\n"
    out = out + "static int64_t sock_send_str(int64_t fd, const char* s){ if(fd<0||!s) return -1; size_t len=strlen(s); if(len==0) return 0; ssize_t n=send((int)fd,s,len,0); return (int64_t)n; }\n"
    out = out + "static ailang_bytes sock_recv(int64_t fd, int64_t max){ ailang_bytes r; r.len=0; r.data=(const uint8_t*)\"\"; if(fd<0||max<=0) return r; uint8_t* buf=(uint8_t*)GC_MALLOC((size_t)max); ssize_t n=recv((int)fd,buf,(size_t)max,0); if(n<=0) return r; r.len=(int64_t)n; r.data=buf; return r; }\n"
    out = out + "static int64_t sock_close(int64_t fd){ if(fd<0) return 0; return (int64_t)close((int)fd); }\n"
  }
  if needs_proc {
    out = out + "static int64_t proc_fork(void){ pid_t p=fork(); return (int64_t)p; }\n"
    out = out + "static int64_t proc_getpid(void){ return (int64_t)getpid(); }\n"
    out = out + "static void proc_no_zombies(void){ struct sigaction sa; memset(&sa,0,sizeof(sa)); sa.sa_handler=SIG_IGN; sigemptyset(&sa.sa_mask); sa.sa_flags=SA_NOCLDWAIT; sigaction(SIGCHLD,&sa,0); }\n"
    out = out + "static int64_t proc_reap(void){ int64_t n=0; while(waitpid(-1,0,WNOHANG)>0) n++; return n; }\n"
  }
  if needs_regex {
    out = out + "static int64_t regex_match(const char* pat, const char* text){ if(!pat||!text) return 0; regex_t re; if(regcomp(&re,pat,REG_EXTENDED|REG_NOSUB)!=0) return 0; int rc=regexec(&re,text,0,0,0); regfree(&re); return rc==0; }\n"
    out = out + "static const char* regex_find(const char* pat, const char* text){ if(!pat||!text) return \"\"; regex_t re; if(regcomp(&re,pat,REG_EXTENDED)!=0) return \"\"; regmatch_t m; int rc=regexec(&re,text,1,&m,0); regfree(&re); if(rc!=0||m.rm_so<0) return \"\"; size_t len=(size_t)(m.rm_eo-m.rm_so); char* o=(char*)GC_MALLOC(len+1); memcpy(o,text+m.rm_so,len); o[len]=0; return o; }\n"
  }
  // ===== Phase 3 optional native sections: TLS (OpenSSL) + Postgres (libpq) =====
  if needs_tls {
    out = out + "static int ailang_tls_init_done_=0;\n"
    out = out + "static void ailang_tls_init_(void){ if(ailang_tls_init_done_) return; SSL_library_init(); SSL_load_error_strings(); OpenSSL_add_ssl_algorithms(); ailang_tls_init_done_=1; }\n"
    out = out + "static int64_t tls_server_ctx(const char* cert, const char* key){ ailang_tls_init_(); SSL_CTX* ctx=SSL_CTX_new(TLS_server_method()); if(!ctx) return -1; if(!cert||SSL_CTX_use_certificate_file(ctx,cert,SSL_FILETYPE_PEM)<=0){ SSL_CTX_free(ctx); return -1; } if(!key||SSL_CTX_use_PrivateKey_file(ctx,key,SSL_FILETYPE_PEM)<=0){ SSL_CTX_free(ctx); return -1; } return (int64_t)(intptr_t)ctx; }\n"
    out = out + "static int64_t tls_client_ctx(void){ ailang_tls_init_(); SSL_CTX* ctx=SSL_CTX_new(TLS_client_method()); if(!ctx) return -1; return (int64_t)(intptr_t)ctx; }\n"
    out = out + "static void tls_free_ctx(int64_t ctx){ if(ctx>0) SSL_CTX_free((SSL_CTX*)(intptr_t)ctx); }\n"
    out = out + "static int64_t tls_accept(int64_t ctx, int64_t fd){ if(ctx<=0||fd<0) return -1; SSL* ssl=SSL_new((SSL_CTX*)(intptr_t)ctx); if(!ssl) return -1; SSL_set_fd(ssl,(int)fd); if(SSL_accept(ssl)<=0){ SSL_free(ssl); return -1; } return (int64_t)(intptr_t)ssl; }\n"
    out = out + "static int64_t tls_connect_fd(int64_t ctx, int64_t fd){ if(ctx<=0||fd<0) return -1; SSL* ssl=SSL_new((SSL_CTX*)(intptr_t)ctx); if(!ssl) return -1; SSL_set_fd(ssl,(int)fd); if(SSL_connect(ssl)<=0){ SSL_free(ssl); return -1; } return (int64_t)(intptr_t)ssl; }\n"
    out = out + "static int64_t tls_send(int64_t ssl, ailang_bytes b){ if(ssl<=0) return -1; if(b.len==0) return 0; int n=SSL_write((SSL*)(intptr_t)ssl,b.data,(int)b.len); return (int64_t)n; }\n"
    out = out + "static int64_t tls_send_str(int64_t ssl, const char* s){ if(ssl<=0||!s) return -1; size_t len=strlen(s); if(len==0) return 0; int n=SSL_write((SSL*)(intptr_t)ssl,s,(int)len); return (int64_t)n; }\n"
    out = out + "static ailang_bytes tls_recv(int64_t ssl, int64_t max){ ailang_bytes r; r.len=0; r.data=(const uint8_t*)\"\"; if(ssl<=0||max<=0) return r; uint8_t* buf=(uint8_t*)GC_MALLOC((size_t)max); int n=SSL_read((SSL*)(intptr_t)ssl,buf,(int)max); if(n<=0) return r; r.len=(int64_t)n; r.data=buf; return r; }\n"
    out = out + "static void tls_close(int64_t ssl){ if(ssl>0){ SSL_shutdown((SSL*)(intptr_t)ssl); SSL_free((SSL*)(intptr_t)ssl); } }\n"
    out = out + "static const char* tls_error(void){ unsigned long e=ERR_peek_error(); if(e==0) return \"\"; char* buf=(char*)GC_MALLOC(256); ERR_error_string_n(e,buf,256); return buf; }\n"
    out = out + "static ailang_bytes sha1(const char* s){ ailang_bytes r; uint8_t* buf=(uint8_t*)GC_MALLOC(20); SHA1((const unsigned char*)(s?s:\"\"), s?strlen(s):0, buf); r.len=20; r.data=buf; return r; }\n"
  }
  if needs_pg {
    out = out + "static int64_t pg_connect(const char* conninfo){ PGconn* c=PQconnectdb(conninfo?conninfo:\"\"); return (int64_t)(intptr_t)c; }\n"
    out = out + "static int64_t pg_status(int64_t conn){ if(conn==0) return -1; return (int64_t)PQstatus((PGconn*)(intptr_t)conn); }\n"
    out = out + "static const char* pg_error(int64_t conn){ if(conn==0) return \"(null connection)\"; const char* msg=PQerrorMessage((PGconn*)(intptr_t)conn); return msg?msg:\"\"; }\n"
    out = out + "static void pg_close(int64_t conn){ if(conn!=0) PQfinish((PGconn*)(intptr_t)conn); }\n"
    out = out + "static int64_t pg_exec(int64_t conn, const char* sql){ if(conn==0||!sql) return 0; PGresult* r=PQexec((PGconn*)(intptr_t)conn,sql); return (int64_t)(intptr_t)r; }\n"
    out = out + "static int64_t pg_ok(int64_t res){ if(res==0) return 0; int s=PQresultStatus((PGresult*)(intptr_t)res); return s==PGRES_COMMAND_OK||s==PGRES_TUPLES_OK; }\n"
    out = out + "static const char* pg_result_error(int64_t res){ if(res==0) return \"(null result)\"; const char* m=PQresultErrorMessage((PGresult*)(intptr_t)res); return m?m:\"\"; }\n"
    out = out + "static void pg_clear(int64_t res){ if(res!=0) PQclear((PGresult*)(intptr_t)res); }\n"
    out = out + "static int64_t pg_nrows(int64_t res){ if(res==0) return 0; return (int64_t)PQntuples((PGresult*)(intptr_t)res); }\n"
    out = out + "static int64_t pg_ncols(int64_t res){ if(res==0) return 0; return (int64_t)PQnfields((PGresult*)(intptr_t)res); }\n"
    out = out + "static const char* pg_value(int64_t res, int64_t row, int64_t col){ if(res==0) return \"\"; const char* v=PQgetvalue((PGresult*)(intptr_t)res,(int)row,(int)col); if(!v) return \"\"; size_t n=strlen(v); char* o=(char*)GC_MALLOC(n+1); memcpy(o,v,n+1); return o; }\n"
    out = out + "static int64_t pg_isnull(int64_t res, int64_t row, int64_t col){ if(res==0) return 0; return PQgetisnull((PGresult*)(intptr_t)res,(int)row,(int)col)!=0; }\n"
    out = out + "static const char* pg_col_name(int64_t res, int64_t col){ if(res==0) return \"\"; const char* nm=PQfname((PGresult*)(intptr_t)res,(int)col); if(!nm) return \"\"; size_t l=strlen(nm); char* o=(char*)GC_MALLOC(l+1); memcpy(o,nm,l+1); return o; }\n"
    out = out + "static int64_t pg_affected(int64_t res){ if(res==0) return 0; const char* s=PQcmdTuples((PGresult*)(intptr_t)res); if(!s||!*s) return 0; return (int64_t)atoll(s); }\n"
    out = out + "static const char* pg_escape(int64_t conn, const char* s){ if(conn==0||!s) return \"''\"; char* esc=PQescapeLiteral((PGconn*)(intptr_t)conn,s,strlen(s)); if(!esc) return \"''\"; size_t n=strlen(esc); char* o=(char*)GC_MALLOC(n+1); memcpy(o,esc,n+1); PQfreemem(esc); return o; }\n"
  }
  out = out + "static int g_argc=0; static char** g_argv=0;\n"
  // Closure value type — only when the program actually has first-class lambdas,
  // so the existing samples + main.ail emit byte-identical C (fixpoint safe).
  if len(base.lams) > 0 { out = out + "typedef struct { void* fn; void* env; } closure_t;\n" }
  out = out + "\n"

  // ===== 4-phase aggregate emission (order matters for incomplete types) =====
  // Phase 1: forward declarations of every aggregate (struct + enum), so an
  // array/map typedef below can hold a pointer to any of them.
  si = 0
  lp si < len(structs) { out = out + gen_struct_fwd(structs[si]); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_enum_fwd(enums[ei]); ei += 1 }
  out = out + "\n"

  // Phase 2: array/map typedefs (they hold `T*`, so a fwd decl suffices). One
  // array runtime per element type: i64, str, each struct, each enum.
  out = out + gen_arr_typedef("i64", "int64_t")
  out = out + gen_arr_typedef("str", "const char*")
  out = out + gen_arr_typedef("f64", "double")
  si = 0
  lp si < len(structs) { out = out + gen_arr_typedef(structs[si].name, "s_" + structs[si].name); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_arr_typedef(enums[ei].name, "s_" + enums[ei].name); ei += 1 }
  // Map runtime universe: scalar keys × (scalar ∪ struct ∪ enum) values, mirroring
  // arr_<T>'s per-type emission. Built once here, reused in phases 3 and 4.
  mu mapkeys:[str] := ["str", "i64", "f64"]
  mu mapvals:[str] := ["i64", "str", "f64"]
  mu mvs := 0
  lp mvs < len(structs) { mapvals = push(mapvals, structs[mvs].name); mvs += 1 }
  mu mve := 0
  lp mve < len(enums) { mapvals = push(mapvals, enums[mve].name); mve += 1 }
  out = out + gen_map_fwds_all(mapkeys, mapvals)
  out = out + "\n"

  // Phase 3: aggregate bodies (now an enum/struct body may embed `arr_<T>` by
  // value and box self-references).
  si = 0
  lp si < len(structs) { out = out + gen_struct_body(structs[si]); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_enum_body(enums[ei]); ei += 1 }
  // map node bodies (hold the value by value, so they need the aggregates above).
  out = out + gen_map_nodes_all(mapkeys, mapvals)
  out = out + "\n"

  // Phase 4: array/map helpers (need complete element types) + aggregate ctors.
  out = out + gen_arr_helpers("i64", "int64_t")
  out = out + gen_arr_helpers("str", "const char*")
  out = out + gen_arr_helpers("f64", "double")
  // array pretty-printers (match ailangc: i64 raw, str quoted via putchar(34) to
  // dodge AiLang→C quote-escaping; `, ` separator; empty → `[]`).
  out = out + "static void print_arr_i64(arr_i64 a){ printf(\"[\"); for(int64_t i=0;i<a.len;i++){ if(i>0) printf(\", \"); printf(\"%lld\",(long long)a.data[i]); } printf(\"]\"); }\n"
  out = out + "static void print_arr_str(arr_str a){ printf(\"[\"); for(int64_t i=0;i<a.len;i++){ if(i>0) printf(\", \"); putchar(34); printf(\"%s\", a.data[i] ? a.data[i] : \"\"); putchar(34); } printf(\"]\"); }\n"
  // `args()` → argv[1..] as [str] (depends on arr_str helpers just emitted).
  out = out + "static arr_str ailang_args(void){ arr_str a = arr_str_new(); for(int i=1;i<g_argc;i++) a = arr_str_push(a, g_argv[i]); return a; }\n"
  // split(s, sep) → [str]; empty sep → [s]; uses arr_str runtime just emitted.
  out = out + "static arr_str split(const char* s, const char* sep){ arr_str a=arr_str_new(); if(!s) s=\"\"; if(!sep||!*sep){ return arr_str_push(a,s); } size_t ls=strlen(sep); const char* r=s; const char* p; while((p=strstr(r,sep))!=0){ size_t n=(size_t)(p-r); char* pc=(char*)GC_MALLOC(n+1); memcpy(pc,r,n); pc[n]=0; a=arr_str_push(a,pc); r=p+ls; } size_t n=strlen(r); char* pc=(char*)GC_MALLOC(n+1); memcpy(pc,r,n+1); a=arr_str_push(a,pc); return a; }\n"
  si = 0
  lp si < len(structs) { out = out + gen_arr_helpers(structs[si].name, "s_" + structs[si].name); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_arr_helpers(enums[ei].name, "s_" + enums[ei].name); ei += 1 }
  out = out + gen_map_helpers_all(mapkeys, mapvals)
  // `!T` result runtimes: scalar `res_i64`/`res_str` + one per struct.
  out = out + gen_res("i64", "int64_t")
  out = out + gen_res("str", "const char*")
  si = 0
  lp si < len(structs) { out = out + gen_res(structs[si].name, "s_" + structs[si].name); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_res(enums[ei].name, "s_" + enums[ei].name); ei += 1 }   // !Enum too
  si = 0
  lp si < len(structs) { out = out + gen_struct_ctor(structs[si]); si += 1 }
  si = 0
  lp si < len(structs) { out = out + gen_struct_printer(structs[si]); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_enum_ctors(enums[ei]); ei += 1 }
  out = out + "\n"

  // On-demand tuple structs: one `tup_<suffix>` per distinct tuple-typed fn
  // return — the MVP producer (a `-> (T,U)` fn, consumed by `a, b := f()`).
  // Emitted before fn signatures (which reference `tup_*` by value). main.ail
  // itself returns no tuples, so nothing is emitted → fixpoint-safe.
  mu tup_seen:[str] := []
  mu ti := 0
  lp ti < len(funcs) {
    rt2 := base.frets[funcs[ti].name]
    if is_tuple_ann(rt2) {
      suf := tuple_suffix(rt2)
      mu found := false
      mu tk := 0
      lp tk < len(tup_seen) { if tup_seen[tk] == suf { found = true } tk += 1 }
      if found == false {
        tup_seen = push(tup_seen, suf)
        out = out + gen_tuple_typedef(rt2)
      }
    }
    ti += 1
  }

  // extern wrappers (libc passthrough), then fn forward declarations.
  mu xj := 0
  lp xj < len(externs) { out = out + gen_extern(externs[xj]); xj += 1 }
  if len(externs) > 0 { out = out + "\n" }
  mu i := 0
  lp i < len(funcs) { out = out + gen_sig(funcs[i], base.frets[funcs[i].name]) + ";\n"; i += 1 }
  out = out + "\n"

  // Lifted lambdas (gated): env structs (fields use fully-defined phase-4
  // aggregates), then `__lam_<id>` fwd decls, then bodies. Driven by the ordered
  // `base.lams` so emission is deterministic (no map iteration).
  if len(base.lams) > 0 {
    mu lm := 0
    lp lm < len(base.lams) { out = out + gen_env_struct(&base, base.lams[lm]); lm += 1 }
    lm = 0
    lp lm < len(base.lams) { out = out + gen_lam_sig(base.lams[lm]) + ";\n"; lm += 1 }
    lm = 0
    lp lm < len(base.lams) { out = out + gen_lifted_body(&base, base.lams[lm]); lm += 1 }
    out = out + "\n"
  }

  // function bodies — each gets a fresh Syms sharing the base struct/ctor/fret
  // maps, then its own params seeded.
  i = 0
  lp i < len(funcs) {
    f := funcs[i]
    // seed_fn: fresh per-fn var map + params + `@ret`. Shared with the closure
    // collection pass so a lambda's capture types match what the body emits.
    mu sy := seed_fn(&base, f)
    fb := stamp_empty_maps(&sy, f.body)          // infer un-annotated `m := {}`
    sy = seed_fn(&base, f)                        // discard inference's scratch typing
    decls := hoist_decls(&sy, fb, "    ")
    out = out + gen_sig(f, base.frets[f.name]) + " {\n" + decls + gen_fn_body(&sy, fb, base.frets[f.name], "    ") + "}\n\n"
    i += 1
  }

  // main() — capture argv so `args()` can return argv[1..].
  mu msy := Syms({}, base.fld, base.ctors, base.frets, base.evar, base.vft, base.gfns, base.lams)
  mmains := stamp_empty_maps(&msy, mains)        // infer un-annotated `m := {}`
  msy = Syms({}, base.fld, base.ctors, base.frets, base.evar, base.vft, base.gfns, base.lams)
  mdecls := hoist_decls(&msy, mmains, "    ")
  // A user `fn main()` is a normal function (emitted `f_main`), not a top-level
  // stmt, so it'd never run. Call it after any top-level stmts. Nullary only;
  // main.ail uses top-level stmts (no `fn main`) so this stays "" → fixpoint-safe.
  mu maincall := ""
  mu mk := 0
  lp mk < len(funcs) { if funcs[mk].name == "main" && len(funcs[mk].params) == 0 { maincall = "    f_main();\n" } mk += 1 }
  out = out + "int main(int argc, char** argv){\n    GC_INIT();\n    g_argc=argc; g_argv=argv;\n" + mdecls + gen_stmts(&msy, mmains, "    ") + maincall + "    return 0;\n}\n"
  out
}

// Read the `// @links:` marker (if any) from the head of the generated C and
// turn its space-separated lib list into clang `-l<lib>` flags. "" when absent.
fn link_flags(cprog:str) -> str {
  pre := "// @links:"
  np := len(pre)
  if len(cprog) < np rt ""
  if substring(cprog, 0, np) != pre rt ""
  mu e := np
  lp e < len(cprog) { if cprog[e] == 10 { br } e += 1 }   // first line ends here
  libs := substring(cprog, np, e)                          // " z m"
  mu out := ""
  mu start := 0 - 1
  mu i := 0
  lp i < len(libs) {
    if libs[i] == 32 {
      if start >= 0 { out = out + " -l" + substring(libs, start, i); start = 0 - 1 }
    } el {
      if start < 0 { start = i }
    }
    i += 1
  }
  if start >= 0 { out = out + " -l" + substring(libs, start, len(libs)) }
  out
}

// The directory prefix of a path (through the last '/'), or "" if none — used
// to resolve `im` paths relative to the importing file.
fn dirname(path:str) -> str {
  mu last := 0 - 1
  mu i := 0
  lp i < len(path) { if path[i] == 47 { last = i } i += 1 }   // '/'
  if last < 0 rt ""
  substring(path, 0, last + 1)
}

// If `line` is `im "path"` (leading spaces allowed), return the path; else "".
fn import_path(line:str) -> str {
  mu i := 0
  lp i < len(line) { if line[i] != 32 { br } i += 1 }   // skip spaces
  if i + 3 > len(line) rt ""
  if line[i] != 105 rt ""              // 'i'
  if line[i + 1] != 109 rt ""          // 'm'
  if line[i + 2] != 32 rt ""           // ' '
  mu j := i + 3
  lp j < len(line) { if line[j] == 34 { br } j += 1 }   // opening '"'
  if j >= len(line) rt ""
  mu k := j + 1
  lp k < len(line) { if line[k] == 34 { br } k += 1 }   // closing '"'
  if k >= len(line) rt ""
  substring(line, j + 1, k)
}

// True if any line of `src` is an `im "..."` import. Allocation-free (a plain
// char scan, no substring) so the no-import fast path adds zero heap pressure.
fn has_import(src:str) -> bool {
  mu i := 0
  mu atstart := true
  lp i < len(src) {
    c := src[i]
    if c == 10 { atstart = true; i += 1; ct }
    if atstart && c == 32 { i += 1; ct }     // leading spaces stay at line start
    if atstart {
      if c == 105 && i + 2 < len(src) && src[i + 1] == 109 && src[i + 2] == 32 { rt true }
      atstart = false
    }
    i += 1
  }
  false
}

// Inline every `im "path"` by splicing the (recursively import-resolved) source
// of the imported file in its place, so imported decls precede their uses. A
// `seen` set blocks re-imports and cycles. Paths resolve relative to `dir`.
// Fast path: a source with no imports is returned verbatim (no reconstruction),
// so the overwhelmingly common single-file case is byte-for-byte unchanged.
fn is_math_export(nm:str) -> bool {
  if nm == "sqrt" || nm == "pow" || nm == "sin" || nm == "cos" || nm == "tan" rt true
  if nm == "log" || nm == "log2" || nm == "log10" || nm == "exp" rt true
  if nm == "floor" || nm == "ceil" || nm == "rand" || nm == "srand" rt true
  if nm == "min" || nm == "max" || nm == "ipow" || nm == "gcd" rt true
  false
}
// Auto-import: prepend `im "std/…"` for std exports referenced-but-not-defined
// (mirrors ailangc's driver, scaled to math+sock — the only modules the corpus
// auto-imports). Token-based, so names inside strings/comments don't trigger
// (main.ail mentions `max`/`sqrt` only in C-string literals → no IDENT match →
// returns "" → fixpoint-safe).
fn auto_imports(src:str) -> str {
  toks := lex(src)
  mu defined:{str:str} := {}
  mu i := 0
  lp i + 1 < len(toks) {
    if toks[i].kind == TK_IDENT() && toks[i].text == "fn" && toks[i + 1].kind == TK_IDENT() { defined[toks[i + 1].text] = "1" }
    i += 1
  }
  mu need_math := false
  mu need_sock := false
  i = 0
  lp i < len(toks) {
    if toks[i].kind == TK_IDENT() && has(defined, toks[i].text) == false {
      nm := toks[i].text
      if is_math_export(nm) { need_math = true }
      if nm == "env_int" { need_sock = true }
    }
    i += 1
  }
  mu out := ""
  if need_math { out = out + "im \"std/math.ail\"\n" }
  if need_sock { out = out + "im \"std/sock.ail\"\n" }
  out
}
fn resolve_imports(src:str, dir:str, seen:{str:str}) -> str {
  if has_import(src) == false rt src
  mu out := ""
  mu i := 0
  mu lstart := 0
  lp i <= len(src) {
    if i == len(src) || src[i] == 10 {     // end of a line
      line := substring(src, lstart, i)
      imp := import_path(line)
      if len(imp) > 0 {
        full := dir + imp
        if has(seen, full) == false {
          seen[full] = "1"
          out = out + resolve_imports(read_file(full), dirname(full), seen) + "\n"
        }
      } el {
        out = out + line + "\n"
      }
      lstart = i + 1
    }
    i += 1
  }
  out
}

av := args()
if len(av) < 2 {
  println("usage: ailc0 <input.ail> <output-binary>")
  exit(1)
}
input := av[0]
outbin := av[1]

mu src := read_file(input)
src = auto_imports(src) + src        // inject `im "std/…"` for referenced std exports
if has_import(src) {
  mu seen:{str:str} := {}
  src = resolve_imports(src, dirname(input), seen)
}
cprog := compile_to_c(src)

cpath := outbin + ".c"
write_file(cpath, cprog)

// GC flags via pkg-config (mirrors the driver's bdw-gc discovery); fallback -lgc.
mu cmd := "clang -O2 " + cpath + " $(pkg-config --cflags --libs bdw-gc 2>/dev/null || echo -lgc)"
// OpenSSL / libpq when the emitted C references them (mirrors the driver's symbol
// scan + env/pkg-config/brew discovery; libpq is keg-only so pkg-config misses it
// → brew fallback).
if has_sub(cprog, "SSL_") || has_sub(cprog, "SHA1(") { cmd = cmd + " $(pkg-config --cflags --libs openssl 2>/dev/null || echo -I$(brew --prefix openssl@3)/include -L$(brew --prefix openssl@3)/lib -lssl -lcrypto)" }
if has_sub(cprog, "PQconnectdb") || has_sub(cprog, "PQexec") { cmd = cmd + " $(pkg-config --cflags --libs libpq 2>/dev/null || echo -I$(brew --prefix libpq)/include -L$(brew --prefix libpq)/lib -lpq)" }
cmd = cmd + link_flags(cprog) + " -lm -o " + outbin
rc := system(cmd)
if rc != 0 {
  println("clang failed")
  exit(1)
}
println("compiled " + input + " -> " + outbin)
