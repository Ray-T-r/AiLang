// ===== driver ===============================================================
ex fn system(cmd:str) -> i32

// True if `sub` occurs anywhere in `s` — reuses the `index_of` builtin (a
// strstr-based substring search). Gates the optional native sections
// (sockets/time/regex/process) on source usage so a program that uses none
// emits byte-identical C without pulling in the heavy headers.
fn has_sub(s:str, sub:str) -> bool {
  index_of(s, sub) >= 0
}

// Split a "name:bound" tparam (from `<T: Bound>`): the part before / after the
// first ':' (the whole string / "" when there's no ':'). 58 == ':'.
fn before_colon(s:str) -> str {
  mu i := 0
  lp i < len(s) { if s[i] == 58 rt substring(s, 0, i)   i += 1 }
  s
}
fn after_colon(s:str) -> str {
  mu i := 0
  lp i < len(s) { if s[i] == 58 rt substring(s, i + 1, len(s))   i += 1 }
  ""
}
// Join with ';' — inverse of split_semi; used to store a trait's method list.
fn join_semi(xs:[str]) -> str {
  mu s := ""
  mu i := 0
  lp i < len(xs) { if i > 0 { s = s + ";" }   s = s + xs[i]   i += 1 }
  s
}

// ----- generic data types: instantiation name mangling ----------------------
// A generic-struct instantiation is carried as the type string "Box<i64>"
// (parse_type keeps the brackets). These helpers mangle it to the concrete C
// struct name "Box_i64" and recover its parts. 60 == '<'.
fn inst_head(ty:str) -> str {                       // "Box<i64>" → "Box"
  mu i := 0
  lp i < len(ty) { if ty[i] == 60 rt substring(ty, 0, i)   i += 1 }
  ty
}
fn inst_args(ty:str) -> [str] {                     // "Box<i64>" → ["i64"]; "Pair<i64,str>" → ["i64","str"]
  mu lt := 0
  lp lt < len(ty) { if ty[lt] == 60 { br } lt += 1 }
  split(substring(ty, lt + 1, len(ty) - 1), ",")    // strip `<` … `>`, split on ','
}
fn mono_of(head:str, args:[str]) -> str {           // ("Box", ["i64"]) → "Box_i64"
  mu nm := head
  mu i := 0
  lp i < len(args) { nm = nm + "_" + args[i]; i += 1 }
  nm
}
// A direct generic-struct annotation ("Box<i64>") → its mono name; pass-through
// for anything else (no '<', or a container/ptr wrapper — out of scope).
fn mono_name(ty:str) -> str {
  if has_sub(ty, "<") == false rt ty                // not a generic instantiation → unchanged
  mono_of(inst_head(ty), inst_args(ty))
}
// Substitute a generic struct's type params in a field type: T→arg, [T]→[arg].
fn subst_struct_ty(tparams:[str], args:[str], ty:str) -> str {
  mu i := 0
  lp i < len(tparams) {
    if i < len(args) {
      if ty == tparams[i] rt args[i]
      if ty == "[" + tparams[i] + "]" rt "[" + args[i] + "]"
    }
    i += 1
  }
  ty
}
fn mk1(s:str) -> [str] { mu xs:[str] := []   xs = push(xs, s)   xs }
fn mk2(a:str, b:str) -> [str] { mu xs:[str] := []   xs = push(xs, a)   xs = push(xs, b)   xs }
// True if a struct named `nm` is already in `xs` (dedup of generated instances).
fn has_struct(xs:[StructDef], nm:str) -> bool {
  mu i := 0
  lp i < len(xs) { if xs[i].name == nm rt true   i += 1 }
  false
}
// One concrete StructDef from a generic template + concrete args (T substituted).
fn gen_instance(gt:StructDef, args:[str]) -> StructDef {
  mu fts:[str] := []
  mu i := 0
  lp i < len(gt.fnames) { fts = push(fts, subst_struct_ty(gt.tparams, args, gt.ftypes[i])); i += 1 }
  mu notp:[str] := []
  StructDef(mono_of(gt.name, args), gt.fnames, fts, notp)
}
// The generic template named `nm`, or an empty StructDef (name "") if none.
fn find_gstruct(gstructs:[StructDef], nm:str) -> StructDef {
  mu i := 0
  lp i < len(gstructs) { if gstructs[i].name == nm rt gstructs[i]   i += 1 }
  mu e:[str] := []
  StructDef("", e, e, e)
}
// Rewrite a Func's param/return type strings, mangling any "Box<i64>" → "Box_i64".
fn norm_func(f:Func) -> Func {
  mu pts:[str] := []
  mu i := 0
  lp i < len(f.ptypes) { pts = push(pts, mono_name(f.ptypes[i])); i += 1 }
  Func(f.name, f.params, pts, mono_name(f.ret), f.lib, f.tparams, f.body)
}
// Rewrite a StructDef's field type strings likewise.
fn norm_struct(sd:StructDef) -> StructDef {
  mu fts:[str] := []
  mu i := 0
  lp i < len(sd.fnames) { fts = push(fts, mono_name(sd.ftypes[i])); i += 1 }
  StructDef(sd.name, sd.fnames, fts, sd.tparams)
}
// If `ty` is a generic-struct instantiation not yet generated, append its concrete
// StructDef; return the (possibly extended) struct list.
fn collect_struct_inst(structs:[StructDef], gstructs:[StructDef], ty:str) -> [StructDef] {
  if has_sub(ty, "<") == false rt structs
  gt := find_gstruct(gstructs, inst_head(ty))
  if len(gt.name) == 0 rt structs
  nm := mono_name(ty)
  if has_struct(structs, nm) rt structs
  push(structs, gen_instance(gt, inst_args(ty)))
}

// ----- generic FUNCTIONS: monomorphize each instantiation into a real C function
// (so bodies may early-return, declare locals, be multi-statement — impossible when
// inlined). lower_generic_funcs collects instances from call sites (with the same
// seeded type context codegen uses → same mangle), monomorphizes each, and appends
// it to `funcs`; the existing proto+body assembly then emits it. gen_call emits the
// matching `f_<name>__<targs>(…)` call. Inert when no generic fns exist (main.ail). -
fn subst_ty_full(tps:[str], targs:[str], ty:str) -> str {
  mu i := 0
  lp i < len(tps) { if i < len(targs) && ty == tps[i] rt targs[i]   i += 1 }
  if is_array_ann(ty) rt "[" + subst_ty_full(tps, targs, elem_of_ann(ty)) + "]"
  if is_fn_ann(ty) {
    pp := fn_params_of(ty)
    mu sp:[str] := []
    mu k := 0
    lp k < len(pp) { sp = push(sp, subst_ty_full(tps, targs, pp[k])); k += 1 }
    rt fn_type_of_pts(sp, subst_ty_full(tps, targs, fn_ret_of(ty)))
  }
  if is_map_ann(ty) rt "{" + subst_ty_full(tps, targs, map_ktype(ty)) + ":" + subst_ty_full(tps, targs, map_vtype(ty)) + "}"
  ty
}
// Rewrite a generic body for one instantiation: substitute type params in the only
// AST fields that carry them — Array element-type (`mu out:[U] := []`), Lambda param
// types, and MapLit annotation. Every other node is rebuilt unchanged. (Identity on
// a body with no tparam annotations, e.g. any/sort_by — they ride through verbatim.)
fn subst_ptypes(tps:[str], targs:[str], pts:[str]) -> [str] {
  mu out:[str] := []
  mu i := 0
  lp i < len(pts) { out = push(out, subst_ty_full(tps, targs, pts[i])); i += 1 }
  out
}
fn subst_exprs(tps:[str], targs:[str], es:[Expr]) -> [Expr] {
  mu out:[Expr] := []
  mu i := 0
  lp i < len(es) { out = push(out, subst_expr(tps, targs, es[i])); i += 1 }
  out
}
fn subst_expr(tps:[str], targs:[str], e:Expr) -> Expr {
  mt e {
    Num(v)              => Num(v);
    Flt(s)              => Flt(s);
    Str(s)              => Str(s);
    Var(name)           => Var(name);
    Bad                 => Bad;
    Bin(op,l,r)         => Bin(op, subst_expr(tps, targs, l), subst_expr(tps, targs, r));
    Unary(op,x)         => Unary(op, subst_expr(tps, targs, x));
    Call(cn,args)       => Call(cn, subst_exprs(tps, targs, args));
    Field(obj,fnm)      => Field(subst_expr(tps, targs, obj), fnm);
    Index(obj,idx)      => Index(subst_expr(tps, targs, obj), subst_expr(tps, targs, idx));
    Array(elems,ety)    => Array(subst_exprs(tps, targs, elems), subst_ty_full(tps, targs, ety));
    MapLit(mty,ks,vs)   => MapLit(subst_ty_full(tps, targs, mty), subst_exprs(tps, targs, ks), subst_exprs(tps, targs, vs));
    Addr(x)             => Addr(subst_expr(tps, targs, x));
    Match(sc,vn,vb,bd,gd) => Match(subst_expr(tps, targs, sc), vn, vb, subst_exprs(tps, targs, bd), subst_exprs(tps, targs, gd));
    IfE(c,t,el2)        => IfE(subst_expr(tps, targs, c), subst_expr(tps, targs, t), subst_expr(tps, targs, el2));
    Try(x)              => Try(subst_expr(tps, targs, x));
    Lambda(ps,pts,b,id) => Lambda(ps, subst_ptypes(tps, targs, pts), subst_expr(tps, targs, b), id);
    Tuple(tes)          => Tuple(subst_exprs(tps, targs, tes));
    BlockE(bb)          => BlockE(subst_stmts(tps, targs, bb));
  }
}
fn subst_stmts(tps:[str], targs:[str], body:[Stmt]) -> [Stmt] {
  mu out:[Stmt] := []
  mu i := 0
  lp i < len(body) { out = push(out, subst_stmt(tps, targs, body[i])); i += 1 }
  out
}
fn subst_stmt(tps:[str], targs:[str], s:Stmt) -> Stmt {
  mt s {
    SDecl(name,e,pos)       => SDecl(name, subst_expr(tps, targs, e), pos);
    SDestructure(names,e)   => SDestructure(names, subst_expr(tps, targs, e));
    SAssign(name,e,pos)     => SAssign(name, subst_expr(tps, targs, e), pos);
    SIdxAssign(o,ix,e,pos)  => SIdxAssign(subst_expr(tps, targs, o), subst_expr(tps, targs, ix), subst_expr(tps, targs, e), pos);
    SFieldAssign(o,f,e,pos) => SFieldAssign(subst_expr(tps, targs, o), f, subst_expr(tps, targs, e), pos);
    SReturn(e,pos)          => SReturn(subst_expr(tps, targs, e), pos);
    SPrint(e,pos)           => SPrint(subst_expr(tps, targs, e), pos);
    SIf(c,b,eb)             => SIf(subst_expr(tps, targs, c), subst_stmts(tps, targs, b), subst_stmts(tps, targs, eb));
    SLoop(c,b)              => SLoop(subst_expr(tps, targs, c), subst_stmts(tps, targs, b));
    SLoopIn(vnm,coll,b)     => SLoopIn(vnm, subst_expr(tps, targs, coll), subst_stmts(tps, targs, b));
    SLoopKV(kn,vn,coll,b)   => SLoopKV(kn, vn, subst_expr(tps, targs, coll), subst_stmts(tps, targs, b));
    SLoopRange(v,lo,hi,b)   => SLoopRange(v, subst_expr(tps, targs, lo), subst_expr(tps, targs, hi), subst_stmts(tps, targs, b));
    SBreak                  => SBreak;
    SContinue               => SContinue;
    SExpr(e,pos)            => SExpr(subst_expr(tps, targs, e), pos);
  }
}
fn monomorphize_fn(gt:Func, targs:[str]) -> Func {
  mu pts:[str] := []
  mu i := 0
  lp i < len(gt.ptypes) { pts = push(pts, subst_ty_full(gt.tparams, targs, gt.ptypes[i])); i += 1 }
  ret := subst_ty_full(gt.tparams, targs, gt.ret)
  mu notp:[str] := []
  Func(mono_fn_name(gt.name, targs), gt.params, pts, ret, gt.lib, notp, subst_stmts(gt.tparams, targs, gt.body))
}
// Recursive walk recording every generic call (record_gi is a no-op for non-generics).
// Seeds map/filter/reduce inlined-lambda params (mirrors gen_map/…) so generic calls
// inside those lambdas infer the same types codegen will.
fn cgi2(sy:*Syms, a:Expr, b:Expr) -> i64 { collect_gi_expr(sy, a)   collect_gi_expr(sy, b)   0 }
fn cgi3(sy:*Syms, a:Expr, b:Expr, c:Expr) -> i64 { collect_gi_expr(sy, a)   collect_gi_expr(sy, b)   collect_gi_expr(sy, c)   0 }
fn collect_gi_args(sy:*Syms, args:[Expr]) -> i64 {
  mu i := 0
  lp i < len(args) { collect_gi_expr(sy, args[i]); i += 1 }
  0
}
fn cgi_kv(sy:*Syms, ks:[Expr], vs:[Expr]) -> i64 { collect_gi_args(sy, ks)   collect_gi_args(sy, vs)   0 }
fn cgi_match(sy:*Syms, sc:Expr, bd:[Expr], gd:[Expr]) -> i64 { collect_gi_expr(sy, sc)   collect_gi_args(sy, bd)   collect_gi_args(sy, gd)   0 }
fn cgi_seed1(sy:*Syms, lam:Expr, t:str) -> i64 {
  ps := lam_params(lam)
  if len(ps) > 0 { set_ty(sy, ps[0], t) }
  collect_gi_expr(sy, lam_body(lam))
  0
}
fn cgi_seed2(sy:*Syms, lam:Expr, t0:str, t1:str) -> i64 {
  ps := lam_params(lam)
  if len(ps) > 0 { set_ty(sy, ps[0], t0) }
  if len(ps) > 1 { set_ty(sy, ps[1], t1) }
  collect_gi_expr(sy, lam_body(lam))
  0
}
fn cgi_call(sy:*Syms, fname:str, args:[Expr]) -> i64 {
  record_gi(sy, fname, args)
  if (fname == "map" || fname == "filter") && len(args) == 2 {
    collect_gi_expr(sy, args[0])
    cgi_seed1(sy, args[1], elem_of_ann(type_of_expr(sy, args[0])))
    rt 0
  }
  if fname == "reduce" && len(args) == 3 {
    collect_gi_expr(sy, args[0])
    collect_gi_expr(sy, args[1])
    cgi_seed2(sy, args[2], type_of_expr(sy, args[1]), elem_of_ann(type_of_expr(sy, args[0])))
    rt 0
  }
  collect_gi_args(sy, args)
  0
}
fn collect_gi_expr(sy:*Syms, e:Expr) -> i64 {
  mt e {
    Num(v)           => 0;
    Flt(s)           => 0;
    Str(s)           => 0;
    Var(n)           => 0;
    Bad              => 0;
    Bin(op,l,r)      => cgi2(sy, l, r);
    Unary(op,x)      => collect_gi_expr(sy, x);
    Call(fname,args) => cgi_call(sy, fname, args);
    Field(obj,fnm)   => collect_gi_expr(sy, obj);
    Index(obj,idx)   => cgi2(sy, obj, idx);
    Array(elems,ety) => collect_gi_args(sy, elems);
    MapLit(m,mks,mvs) => cgi_kv(sy, mks, mvs);
    Addr(x)          => collect_gi_expr(sy, x);
    Match(sc,vn,vb,bd,gd) => cgi_match(sy, sc, bd, gd);
    IfE(c,t,el2)     => cgi3(sy, c, t, el2);
    Try(x)           => collect_gi_expr(sy, x);
    Lambda(ps,pts,b,id) => collect_gi_expr(sy, b);
    Tuple(tes)       => collect_gi_args(sy, tes);
    BlockE(bb)       => collect_gi_body(sy, bb);
  }
}
fn cgi_if(sy:*Syms, c:Expr, b:[Stmt], eb:[Stmt]) -> i64 { collect_gi_expr(sy, c)   collect_gi_body(sy, b)   collect_gi_body(sy, eb)   0 }
fn cgi_cb(sy:*Syms, c:Expr, b:[Stmt]) -> i64 { collect_gi_expr(sy, c)   collect_gi_body(sy, b)   0 }
fn cgi_range(sy:*Syms, lo:Expr, hi:Expr, b:[Stmt]) -> i64 { collect_gi_expr(sy, lo)   collect_gi_expr(sy, hi)   collect_gi_body(sy, b)   0 }
fn collect_gi_stmt(sy:*Syms, s:Stmt) -> i64 {
  mt s {
    SDecl(name,e)         => collect_gi_expr(sy, e);
    SDestructure(names,e) => collect_gi_expr(sy, e);
    SAssign(name,e)       => collect_gi_expr(sy, e);
    SIdxAssign(o,ix,e)    => cgi3(sy, o, ix, e);
    SFieldAssign(o,f,e)   => cgi2(sy, o, e);
    SReturn(e)            => collect_gi_expr(sy, e);
    SPrint(e)             => collect_gi_expr(sy, e);
    SExpr(e)              => collect_gi_expr(sy, e);
    SIf(c,b,eb)           => cgi_if(sy, c, b, eb);
    SLoop(c,b)            => cgi_cb(sy, c, b);
    SLoopIn(vnm,coll,b)   => cgi_cb(sy, coll, b);
    SLoopKV(kn,vn,coll,b) => cgi_cb(sy, coll, b);
    SLoopRange(v,lo,hi,b) => cgi_range(sy, lo, hi, b);
    SBreak                => 0;
    SContinue             => 0;
  }
}
fn collect_gi_body(sy:*Syms, body:[Stmt]) -> i64 {
  mu i := 0
  lp i < len(body) { collect_gi_stmt(sy, body[i]); i += 1 }
  0
}
fn gi_count(base:*Syms) -> i64 {
  if has(base.evar, "@gilist") == false rt 0
  if len(base.evar["@gilist"]) == 0 rt 0
  len(split_semi(base.evar["@gilist"]))
}
fn gi_at(base:*Syms, idx:i64) -> str {
  list := split_semi(base.evar["@gilist"])
  if idx < len(list) rt list[idx]
  ""
}
fn lower_generic_funcs(base:*Syms, funcs:[Func], mains:[Stmt]) -> [Func] {
  if len(base.gfns) == 0 rt funcs
  base.evar["@gilist"] = ""
  mu i := 0
  lp i < len(funcs) {
    mu sy := seed_fn(base, funcs[i])
    hoist_decls(&sy, funcs[i].body, "")
    collect_gi_body(&sy, funcs[i].body)
    i += 1
  }
  mu msy := Syms(base.vty, base.fld, base.ctors, base.frets, base.evar, base.vft, base.gfns, base.lams, base.errc)
  msy.vty = {}
  hoist_decls(&msy, mains, "")
  collect_gi_body(&msy, mains)
  mu result := funcs
  mu idx := 0
  lp idx < gi_count(base) {
    mangle := gi_at(base, idx)
    payload := if len(mangle) > 0 { base.evar["@gi." + mangle] } el { "" }
    parts := split_semi(payload)
    if len(parts) > 0 {
      tname := parts[0]
      mu targs:[str] := []
      mu pi := 1
      lp pi < len(parts) { targs = push(targs, parts[pi]); pi += 1 }
      gt := find_gfn(base, tname)
      if len(gt.name) > 0 {
        cf := monomorphize_fn(gt, targs)
        base.frets[cf.name] = cf.ret
        result = push(result, cf)
        mu sy2 := seed_fn(base, cf)
        hoist_decls(&sy2, cf.body, "")
        collect_gi_body(&sy2, cf.body)
      }
    }
    idx += 1
  }
  result
}

// ----- generic enums: monomorphize instantiations (variants mangled per-instance) -
// `mono_variant("Option_i64", "Some")` → "Option_i64_Some" — a per-instance variant
// name so the existing enum machinery (evar/@order/@vfld/mkv_/union) handles each
// instance with NO collision; bare `Some`/`None` map to it at ctor + match sites.
fn mono_variant(inst:str, bareV:str) -> str { inst + "_" + bareV }
fn has_enum(xs:[EnumDef], nm:str) -> bool {
  mu i := 0
  lp i < len(xs) { if xs[i].name == nm rt true   i += 1 }
  false
}
fn find_genum(genums:[EnumDef], nm:str) -> EnumDef {
  mu i := 0
  lp i < len(genums) { if genums[i].name == nm rt genums[i]   i += 1 }
  mu e:[str] := []
  EnumDef("", e, e, e)
}
// One concrete EnumDef from a generic template + concrete args: name mangled
// (Option_i64), variants mangled (Option_i64_Some), T substituted in each field.
fn gen_enum_instance(gt:EnumDef, args:[str]) -> EnumDef {
  inst := mono_of(gt.name, args)
  mu vns:[str] := []
  mu vfts:[str] := []
  mu i := 0
  lp i < len(gt.vnames) {
    vns = push(vns, mono_variant(inst, gt.vnames[i]))
    raw := gt.vftypes[i]
    if len(raw) == 0 { vfts = push(vfts, "") } el {
      parts := split_semi(raw)
      mu nf := ""
      mu fj := 0
      lp fj < len(parts) {
        sft := subst_struct_ty(gt.tparams, args, parts[fj])
        if fj == 0 { nf = sft } el { nf = nf + ";" + sft }
        fj += 1
      }
      vfts = push(vfts, nf)
    }
    i += 1
  }
  mu notp:[str] := []
  EnumDef(inst, vns, vfts, notp)
}
// If `ty` is a generic-enum instantiation not yet generated, append it.
fn collect_enum_inst(enums:[EnumDef], genums:[EnumDef], ty:str) -> [EnumDef] {
  if has_sub(ty, "<") == false rt enums
  gt := find_genum(genums, inst_head(ty))
  if len(gt.name) == 0 rt enums
  nm := mono_name(ty)
  if has_enum(enums, nm) rt enums
  push(enums, gen_enum_instance(gt, inst_args(ty)))
}

// ----- empty `{}` usage inference -------------------------------------------
// An un-annotated `m := {}` has no (K,V) until used. Before hoist/codegen we
// scan the function body for the first `m[k]=v` and stamp the MapLit with
// `{type(k):type(v)}`, so the existing MapLit-type machinery carries it.
// (ailangc does this in sema; selfhost has no sema, hence this transform.)
fn var_name(e:Expr) -> str {
  mt e {
    Var(n)             => n;
    Tuple(tes)         => "";
    BlockE(bb)         => "";
    Num(v)             => "";
    Flt(fs)            => "";
    Str(s)             => "";
    Bin(o,a,b)         => "";
    Unary(o,x)         => "";
    Call(f,a)          => "";
    Field(o,f)         => "";
    Index(o,ix)        => "";
    Array(es,et)       => "";
    MapLit(ml,mks,mvs) => "";
    Addr(x)            => "";
    Match(sc,vn,vb,bd) => "";
    IfE(c,t,el2)       => "";
    Try(e2)            => "";
    Lambda(ps,pts,b,id)    => "";
    Bad                => "";
  }
}
fn is_empty_maplit(e:Expr) -> bool {
  mt e {
    MapLit(ml,mks,mvs) => len(mks) == 0;
    Tuple(tes)         => false;
    BlockE(bb)         => false;
    Var(n)             => false;
    Num(v)             => false;
    Flt(fs)            => false;
    Str(s)             => false;
    Bin(o,a,b)         => false;
    Unary(o,x)         => false;
    Call(f,a)          => false;
    Field(o,f)         => false;
    Index(o,ix)        => false;
    Array(es,et)       => false;
    Addr(x)            => false;
    Match(sc,vn,vb,bd) => false;
    IfE(c,t,el2)       => false;
    Try(e2)            => false;
    Lambda(ps,pts,b,id)    => false;
    Bad                => false;
  }
}
// The map annotation already stamped on a literal ("" when absent) — an
// annotated empty `{}` must keep its type, not be re-inferred (the inference
// can't see e.g. a generic instance's key var and would fall back to i64).
fn maplit_ann(e:Expr) -> str {
  mt e {
    MapLit(ml,mks,mvs) => ml;
    Tuple(tes)         => "";
    BlockE(bb)         => "";
    Var(n)             => "";
    Num(v)             => "";
    Flt(fs)            => "";
    Str(s)             => "";
    Bin(o,a,b)         => "";
    Unary(o,x)         => "";
    Call(f,a)          => "";
    Field(o,f)         => "";
    Index(o,ix)        => "";
    Array(es,et)       => "";
    Addr(x)            => "";
    Match(sc,vn,vb,bd) => "";
    IfE(c,t,el2)       => "";
    Try(e2)            => "";
    Lambda(ps,pts,b,id)    => "";
    Bad                => "";
  }
}
// First `m[k]=v` (recursing into nested blocks, typing loop vars en route) →
// "{type(k):type(v)}", or "" if none.
fn map_assign_type(sy:*Syms, body:[Stmt], m:str) -> str {
  mu i := 0
  lp i < len(body) {
    t := map_assign_type_s(sy, body[i], m)
    if len(t) > 0 rt t
    i += 1
  }
  ""
}
fn scan_loopin(sy:*Syms, vnm:str, coll:Expr, b:[Stmt], m:str) -> str {
  set_ty(sy, vnm, coll_elem_type(sy, coll))
  map_assign_type(sy, b, m)
}
fn scan_loopkv(sy:*Syms, kn:str, vn:str, coll:Expr, b:[Stmt], m:str) -> str {
  t := type_of_expr(sy, coll)
  set_ty(sy, kn, map_ktype(t))
  set_ty(sy, vn, map_vtype(t))
  map_assign_type(sy, b, m)
}
fn scan_range(sy:*Syms, v:str, b:[Stmt], m:str) -> str {
  set_ty(sy, v, "i64")
  map_assign_type(sy, b, m)
}
fn scan_either(sy:*Syms, b:[Stmt], eb:[Stmt], m:str) -> str {
  t := map_assign_type(sy, b, m)
  if len(t) > 0 rt t
  map_assign_type(sy, eb, m)
}
fn idx_assign_type(sy:*Syms, o:Expr, idx:Expr, e:Expr, m:str) -> str {
  if var_name(o) == m rt "{" + type_of_expr(sy, idx) + ":" + type_of_expr(sy, e) + "}"
  ""
}
fn map_assign_type_s(sy:*Syms, s:Stmt, m:str) -> str {
  mt s {
    SIdxAssign(o,idx,e)   => idx_assign_type(sy, o, idx, e, m);
    SDestructure(names,e) => "";
    SIf(c,b,eb)           => scan_either(sy, b, eb, m);
    SLoop(c,b)            => map_assign_type(sy, b, m);
    SLoopIn(vnm,coll,b)   => scan_loopin(sy, vnm, coll, b, m);
    SLoopKV(kn,vn,coll,b) => scan_loopkv(sy, kn, vn, coll, b, m);
    SLoopRange(v,lo,hi,b) => scan_range(sy, v, b, m);
    SDecl(name,e)         => "";
    SAssign(name,e)       => "";
    SFieldAssign(o,f,e)   => "";
    SReturn(e)            => "";
    SPrint(e)             => "";
    SBreak                => "";
    SContinue             => "";
    SExpr(e)              => "";
  }
}
// Top-level transform: stamp each un-annotated `m := {}` with its inferred type;
// type regular decls so later `lp x in coll` / index types resolve.
// Empty INFERRED array `mu x := []` (no annotation): pin its element type from
// the first top-level `x = push(x, E)`, mirroring the empty-`{}` map back-prop.
fn is_empty_array(e:Expr) -> bool {
  mt e {
    Array(es,et)       => len(es) == 0 && et == "";
    Tuple(tes)         => false;
    BlockE(bb)         => false;
    MapLit(ml,mks,mvs) => false;
    Var(n)             => false;
    Num(v)             => false;
    Flt(fs)            => false;
    Str(s)             => false;
    Bin(o,a,b)         => false;
    Unary(o,x)         => false;
    Call(f,a)          => false;
    Field(o,f)         => false;
    Index(o,ix)        => false;
    Addr(x)            => false;
    Match(sc,vn,vb,bd) => false;
    IfE(c,t,el2)       => false;
    Try(e2)            => false;
    Lambda(ps,pts,b,id)    => false;
    Bad                => false;
  }
}
fn push_args_elem(sy:*Syms, fname:str, args:[Expr]) -> str {
  if fname == "push" && len(args) == 2 rt type_of_expr(sy, args[1])
  ""
}
fn push_call_elem(sy:*Syms, e:Expr) -> str {
  mt e {
    Call(fname, args)  => push_args_elem(sy, fname, args);
    Tuple(tes)         => "";
    BlockE(bb)         => "";
    Array(es,et)       => "";
    MapLit(ml,mks,mvs) => "";
    Var(n)             => "";
    Num(v)             => "";
    Flt(fs)            => "";
    Str(s)             => "";
    Bin(o,a,b)         => "";
    Unary(o,x)         => "";
    Field(o,f)         => "";
    Index(o,ix)        => "";
    Addr(x)            => "";
    Match(sc,vn,vb,bd) => "";
    IfE(c,t,el2)       => "";
    Try(e2)            => "";
    Lambda(ps,pts,b,id)    => "";
    Bad                => "";
  }
}
fn same_name_push(sy:*Syms, name:str, e:Expr, a:str) -> str {
  if name != a rt ""
  push_call_elem(sy, e)
}
fn push_assign_elem(sy:*Syms, s:Stmt, a:str) -> str {
  mt s {
    SAssign(name, e)      => same_name_push(sy, name, e, a);
    SDestructure(names,e) => "";
    SDecl(name,e)         => "";
    SIdxAssign(o,ix,e)    => "";
    SFieldAssign(o,f,e)   => "";
    SReturn(e)            => "";
    SPrint(e)             => "";
    SIf(c,b,eb)           => "";
    SLoop(c,b)            => "";
    SLoopIn(vnm,coll,b)   => "";
    SLoopKV(kn,vn,coll,b) => "";
    SLoopRange(v,lo,hi,b) => "";
    SBreak                => "";
    SContinue             => "";
    SExpr(e)              => "";
  }
}
fn array_elem_from_push(sy:*Syms, body:[Stmt], a:str) -> str {
  mu i := 0
  lp i < len(body) {
    t := push_assign_elem(sy, body[i], a)
    if len(t) > 0 rt t
    i += 1
  }
  ""
}
fn stamp_decl_e(sy:*Syms, body:[Stmt], name:str, e:Expr, pos:i64) -> Stmt {
  if is_empty_maplit(e) && len(maplit_ann(e)) == 0 {   // unannotated only — an annotation wins over inference
    t := map_assign_type(sy, body, name)
    if len(t) > 0 rt SDecl(name, MapLit(t, no_exprs(), no_exprs()), pos)   // preserve source pos (codegen ignores it; the checker walks stamped bodies and needs it)
  }
  if is_empty_array(e) {
    et := array_elem_from_push(sy, body, name)
    if len(et) > 0 rt SDecl(name, Array(no_exprs(), et), pos)             // pin elem type from first push
  }
  SDecl(name, e, pos)
}
fn stamp_decl(sy:*Syms, body:[Stmt], s:Stmt) -> Stmt {
  mt s {
    SDecl(name,e,pos)     => stamp_decl_e(sy, body, name, e, pos);
    SDestructure(names,e) => s;
    SAssign(name,e)       => s;
    SIdxAssign(o,ix,e)    => s;
    SFieldAssign(o,f,e)   => s;
    SReturn(e)            => s;
    SPrint(e)             => s;
    SIf(c,b,eb)           => s;
    SLoop(c,b)            => s;
    SLoopIn(vnm,coll,b)   => s;
    SLoopKV(kn,vn,coll,b) => s;
    SLoopRange(v,lo,hi,b) => s;
    SBreak                => s;
    SContinue             => s;
    SExpr(e)              => s;
  }
}
// pass 1: type every top-level decl so inference resolves feed-arrays regardless
// of decl order (e.g. `counts := {}` declared BEFORE `words := split(...)`).
fn seed_one(sy:*Syms, name:str, e:Expr) -> i64 { set_ty(sy, name, type_of_expr(sy, e)); 0 }
fn seed_decl_s(sy:*Syms, s:Stmt) -> i64 {
  mt s {
    SDecl(name,e)         => seed_one(sy, name, e);
    SDestructure(names,e) => 0;
    SAssign(name,e)       => 0;
    SIdxAssign(o,ix,e)    => 0;
    SFieldAssign(o,f,e)   => 0;
    SReturn(e)            => 0;
    SPrint(e)             => 0;
    SIf(c,b,eb)           => 0;
    SLoop(c,b)            => 0;
    SLoopIn(vnm,coll,b)   => 0;
    SLoopKV(kn,vn,coll,b) => 0;
    SLoopRange(v,lo,hi,b) => 0;
    SBreak                => 0;
    SContinue             => 0;
    SExpr(e)              => 0;
  }
}
fn stamp_empty_maps(sy:*Syms, body:[Stmt]) -> [Stmt] {
  mu si := 0
  lp si < len(body) { seed_decl_s(sy, body[si]); si += 1 }   // pass 1: type decls
  mu out:[Stmt] := []
  mu i := 0
  lp i < len(body) {                                          // pass 2: stamp `{}`
    out = push(out, stamp_decl(sy, body, body[i]))
    i += 1
  }
  out
}

// Is method m already a slot in the ";"-joined vtable slot list?
fn slot_has(slots:str, m:str) -> bool {
  parts := split(slots, ";")
  mu i := 0
  lp i < len(parts) { if parts[i] == m rt true; i += 1 }
  false
}

// ===== conservative type checker =============================================
// A read-only pass (mutates nothing observable by codegen) that walks every
// function body + the implicit main, and reports CONFIDENT type mismatches at
// the originating .ail line via report_chk (which prints `error L:C:` + caret but
// does NOT exit — it records the error in sy.errc so the walk continues and
// EVERY confident error surfaces in one run; the driver bails after the pass).
// It runs AFTER the symbol tables are fully populated and BEFORE emission, so it
// can't change the generated C. Every check fires only when the types involved
// are confidently known and clearly incompatible (see type_confident /
// incompatible) — never on an unknown — so it cannot reject any program that
// compiles today. Walkers mirror the collect_lams family: each returns a dummy
// i64 (AiLang `mt` is expression-valued), effects via report_chk.

// Accumulating diagnostic: print the error, but instead of exiting, flag+count it
// in the SHARED sy.errc map (same object across every per-fn `sy` and `base`, see
// seed_fn / st Syms). The driver inspects base.errc after the pass and exits if any
// error fired — so the whole program is checked before we give up.
fn report_chk(sy:*Syms, src:str, pos:i64, msg:str) -> i64 {
  print_diag(src, pos, msg)
  sy.errc["bad"] = "1"
  mu n := 0
  if has(sy.errc, "n") { n = str_to_int(sy.errc["n"]) }
  sy.errc["n"] = int_to_str(n + 1)
  0
}

// ----- "did you mean?" spelling suggestions -------------------------------------
// Levenshtein edit distance (two-row DP) over byte values, used to suggest the
// nearest known name when an unknown variant/field is referenced.
fn min2(a:i64, b:i64) -> i64 { if a < b { a } el { b } }
fn min3(a:i64, b:i64, c:i64) -> i64 { min2(min2(a, b), c) }
fn edit_dist(a:str, b:str) -> i64 {
  la := len(a)
  lb := len(b)
  if la == 0 rt lb
  if lb == 0 rt la
  mu prev:[i64] := []
  mu j := 0
  lp j <= lb { prev = push(prev, j); j += 1 }
  mu i := 0
  lp i < la {
    mu cur:[i64] := []
    cur = push(cur, i + 1)
    mu k := 0
    lp k < lb {
      cost := if a[i] == b[k] { 0 } el { 1 }
      cur = push(cur, min3(prev[k + 1] + 1, cur[k] + 1, prev[k] + cost))
      k += 1
    }
    prev = cur
    i += 1
  }
  prev[lb]
}
// The closest candidate to `target`, or "" if none is close enough. Threshold
// scales gently with name length (1 + len/4) so a typo suggests but an unrelated
// name does not.
fn nearest(target:str, cands:[str]) -> str {
  mu best := ""
  mu bestd := 1000000
  mu i := 0
  lp i < len(cands) {
    if len(cands[i]) > 0 {
      d := edit_dist(target, cands[i])
      if d < bestd { bestd = d; best = cands[i] }
    }
    i += 1
  }
  thresh := 1 + len(target) / 4
  if best != "" && bestd <= thresh { rt best }
  ""
}
// `" — did you mean 'X'?"` for the nearest of `cands`, or "" if nothing is close.
fn suggest(target:str, cands:[str]) -> str {
  s := nearest(target, cands)
  if s == "" rt ""
  " — did you mean '" + s + "'?"
}
// Field names declared on struct `sty` (keys "sty.field" in sy.fld), for suggest().
fn struct_fields(sy:*Syms, sty:str) -> [str] {
  mu out:[str] := []
  pfx := sty + "."
  lp (k, v) in sy.fld {
    if len(k) >= len(pfx) && substring(k, 0, len(pfx)) == pfx {
      out = push(out, substring(k, len(pfx), len(k)))
    }
  }
  out
}

// A user function's index by name, or -1. Built-ins / externs / ctors / generics
// are NOT in `funcs`, so a hit here means "a non-generic user function".
fn find_func_i(funcs:[Func], name:str) -> i64 {
  mu i := 0
  lp i < len(funcs) { if funcs[i].name == name { rt i } i += 1 }
  -1
}
// A str / array / map / struct / enum operand makes arithmetic & bitwise ops bogus.
fn bad_in_arith(t:str) -> bool {
  c := ty_cat(t)
  c == "str" || c == "arr" || c == "map" || c == "agg" || c == "bytes"
}
fn arith_or_bit_nonadd(op:i64) -> bool {
  op == OP_SUB() || op == OP_MUL() || op == OP_DIV() || op == OP_MOD() || op == OP_SHL() || op == OP_SHR() || op == OP_BAND() || op == OP_BXOR() || op == OP_BOR()
}
// Relational operators compare two operands that must be the same kind. `&&`/`||`
// are excluded — they combine truthy values, not compare them.
fn is_cmp_op(op:i64) -> bool {
  op == OP_EQ() || op == OP_NE() || op == OP_LT() || op == OP_GT() || op == OP_LE() || op == OP_GE()
}
fn binop_check(sy:*Syms, op:i64, l:Expr, r:Expr, pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  if len(overload_class(sy, op, l)) > 0 rt 0        // operator overloaded on a class → valid, skip operand checks
  lt := type_confident(sy, l)
  rr := type_confident(sy, r)
  if confident(lt) == false || confident(rr) == false rt 0
  if is_cmp_op(op) {
    if incompatible(sy, lt, rr) { report_chk(sy, src, pos, "type mismatch: comparing " + lt + " and " + rr) }
    rt 0
  }
  if op == OP_ADD() {
    bothstr := lt == "str" && rr == "str"           // str + str is concat — fine
    if bothstr == false && (bad_in_arith(lt) || bad_in_arith(rr)) {
      report_chk(sy, src, pos, "type mismatch: operator" + op_c(op) + "on " + lt + " and " + rr)
    }
    rt 0
  }
  if arith_or_bit_nonadd(op) {
    if bad_in_arith(lt) || bad_in_arith(rr) {
      report_chk(sy, src, pos, "type mismatch: operator" + op_c(op) + "on " + lt + " and " + rr)
    }
  }
  0
}
fn callarg_check(funcs:[Func], sy:*Syms, fname:str, args:[Expr], pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  fi := find_func_i(funcs, fname)
  if fi < 0 rt 0                                     // not a non-generic user fn → skip
  if len(funcs[fi].tparams) > 0 rt 0                 // belt-and-braces: never a generic
  np := len(funcs[fi].params)                        // params is authoritative (untyped params still counted)
  if len(args) != np {
    report_chk(sy, src, pos, "function '" + fname + "' expects " + int_to_str(np) + " arguments, got " + int_to_str(len(args)))
    rt 0
  }
  pts := funcs[fi].ptypes
  mu i := 0
  lp i < len(args) {
    if i < len(pts) {
      at := type_confident(sy, args[i])
      if confident(at) && incompatible(sy, pts[i], at) {
        report_chk(sy, src, pos, "type mismatch: argument " + int_to_str(i + 1) + " to '" + fname + "' expects " + pts[i] + ", got " + at)
      }
    }
    i += 1
  }
  0
}
fn field_check(sy:*Syms, obj:Expr, fname:str, pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  ot := type_confident(sy, obj)
  if ot == "?" rt 0
  sty := under_ptr(ot)
  if is_ctor(sy, sty) {                              // a known struct/class (incl. flattened inherited fields)
    if has(sy.fld, fkey(sty, fname)) == false {
      fsug := nearest(fname, struct_fields(sy, sty))
      fhint := if fsug == "" { "" } el { " — did you mean '." + fsug + "'?" }   // dotted, matching field syntax
      report_chk(sy, src, pos, "unknown field '." + fname + "' on " + sty + fhint)
    }
    rt 0
  }
  report_chk(sy, src, pos, "type error: field '." + fname + "' on non-struct value of type " + ot)
  0
}
fn index_check(sy:*Syms, obj:Expr, pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  t := type_confident(sy, obj)
  if t == "?" rt 0
  if is_array_ann(t) rt 0
  if is_map_ann(t) rt 0
  if t == "str" rt 0
  if t == "bytes" rt 0
  report_chk(sy, src, pos, "type error: cannot index value of type " + t)
  0
}

fn chk2(funcs:[Func], sy:*Syms, a:Expr, b:Expr, pos:i64, src:str) -> i64 {
  check_expr(funcs, sy, a, pos, src); check_expr(funcs, sy, b, pos, src); 0
}
fn chk3(funcs:[Func], sy:*Syms, a:Expr, b:Expr, c:Expr, pos:i64, src:str) -> i64 {
  check_expr(funcs, sy, a, pos, src); check_expr(funcs, sy, b, pos, src); check_expr(funcs, sy, c, pos, src); 0
}
fn chk_args(funcs:[Func], sy:*Syms, args:[Expr], pos:i64, src:str) -> i64 {
  mu i := 0
  lp i < len(args) { check_expr(funcs, sy, args[i], pos, src); i += 1 }
  0
}
fn chk_kv(funcs:[Func], sy:*Syms, ks:[Expr], vs:[Expr], pos:i64, src:str) -> i64 {
  chk_args(funcs, sy, ks, pos, src); chk_args(funcs, sy, vs, pos, src); 0
}
// `e?` is only valid inside a function whose return type is `!T` — seed_fn sets
// @ret exactly for those, so its absence means `?` is misplaced (e.g. in plain
// fns or the implicit main). Valid `?` code always has @ret, so no false positive.
fn chk_try(funcs:[Func], sy:*Syms, x:Expr, pos:i64, src:str) -> i64 {
  if pos >= 0 && has(sy.vty, "@ret") == false {
    report_chk(sy, src, pos, "'?' used outside a function returning !T")
  }
  check_expr(funcs, sy, x, pos, src)
  0
}
// A literal's confidently-known elements must all share one category — AiLang
// arrays/maps are monomorphic. Numerics (i64/f64/bool) count as one category
// (matches codegen tolerance), and any "?" element is ignored.
fn homog_check(sy:*Syms, elems:[Expr], msg:str, pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  mu base := "?"
  mu i := 0
  lp i < len(elems) {
    t := type_confident(sy, elems[i])
    if confident(t) {
      if base == "?" { base = t } el if cat_incompatible(base, t) { report_chk(sy, src, pos, msg + " " + base + " and " + t) }
    }
    i += 1
  }
  0
}
fn chk_array(funcs:[Func], sy:*Syms, elems:[Expr], pos:i64, src:str) -> i64 {
  homog_check(sy, elems, "array literal mixes", pos, src)
  chk_args(funcs, sy, elems, pos, src)
  0
}
// Reject (K,V) combos the map runtime universe never emits: map values, nested
// array values, and array values with a non-str/i64 key (f64 keys have no
// grouping use; only str/i64 key × [T] runtimes exist).
fn map_combo_check(sy:*Syms, t:str, pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  if is_map_ann(t) == false rt 0
  kt := map_ktype(t)
  vt := map_vtype(t)
  if is_map_ann(vt) { report_chk(sy, src, pos, "unsupported map value type " + vt) rt 0 }
  if is_array_ann(vt) {
    ev := elem_of_ann(vt)
    if is_array_ann(ev) || is_map_ann(ev) { report_chk(sy, src, pos, "unsupported map value type " + vt) rt 0 }
    if kt != "str" && kt != "i64" && kt != "bool" { report_chk(sy, src, pos, "a map with array values requires a str or i64 key, got " + kt) rt 0 }
  }
  if is_array_ann(kt) || is_map_ann(kt) { report_chk(sy, src, pos, "unsupported map key type " + kt) }
  0
}
fn chk_maplit(funcs:[Func], sy:*Syms, mty:str, ks:[Expr], vs:[Expr], pos:i64, src:str) -> i64 {
  homog_check(sy, ks, "map literal mixes key types", pos, src)
  homog_check(sy, vs, "map literal mixes value types", pos, src)
  map_combo_check(sy, maplit_type(sy, mty, ks, vs), pos, src)
  chk_args(funcs, sy, ks, pos, src)
  chk_args(funcs, sy, vs, pos, src)
  0
}
// Is `v` one of the match's arm names?
fn vn_has(vnames:[str], v:str) -> bool {
  mu i := 0
  lp i < len(vnames) { if vnames[i] == v rt true; i += 1 }
  false
}
// Like vn_has, but only counts an UNGUARDED arm (a guarded arm may not fire at
// runtime, so it can't cover a variant for exhaustiveness). `is_bad(guards[i])`
// == this arm has no guard. Also used with v=="_" to detect a plain catch-all.
fn vn_has_ug(vnames:[str], guards:[Expr], v:str) -> bool {
  mu i := 0
  lp i < len(vnames) { if vnames[i] == v && is_bad(guards[i]) rt true; i += 1 }
  false
}
// `mt scrut { V(b…) => … }` — match type-safety. The parser only emits a `Match`
// AST node for capitalized-Variant arms (literal/`_`/tuple matches desugar to an
// if-chain upstream), and the corpus has NO catch-all arms — so a Match is a
// COMPLETE variant enumeration. gen_match lowers it to a bare if/else-if on the
// tag with no default branch, so a stray arm silently aliases tag 0 and a missing
// variant leaves the result uninitialized — both real bugs. Two confident checks,
// each a no-op when the scrutinee type is "?" (so today's programs all still pass):
//   (1) every arm names a real variant OF the scrutinee's enum;
//   (2) exhaustiveness — every variant of that enum appears as an arm.
fn match_check(sy:*Syms, scrut:Expr, vnames:[str], vbinds:[str], guards:[Expr], pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  ty := type_confident(sy, scrut)
  if confident(ty) == false rt 0                       // unknown scrutinee → skip
  if has(sy.evar, "@order." + ty) == false {           // confident, but not an enum
    report_chk(sy, src, pos, "type error: match on non-enum value of type " + ty)
    rt 0
  }
  // (1) per arm: a `_` catch-all is always valid; otherwise the arm must be a
  // variant of enum `ty`, binding no more vars than the variant has fields.
  // Binding fewer ignores trailing fields (legal); binding more would read a
  // nonexistent union member. @vfldn is registered only for tuple/fn-free
  // variants, so subtler variants degrade to no-op (has → false).
  // Map bare generic-enum patterns (`Some`) to the scrutinee instance's mangled
  // variant (`Option_i64_Some`) so the registered variant tables resolve; normal
  // enums + `_` are unchanged.
  mu mv:[str] := []
  mu mk := 0
  lp mk < len(vnames) { mv = push(mv, eff_variant(sy, ty, vnames[mk])); mk += 1 }
  mu i := 0
  lp i < len(vnames) {
    nm := vnames[i]
    emn := mv[i]
    if nm != "_" {
      if is_variant(sy, emn) == false || sy.evar[emn] != ty {
        report_chk(sy, src, pos, "unknown variant '" + nm + "' in match on " + ty + suggest(nm, split_semi(sy.evar["@order." + ty])))
      }
      nb := len(split_semi(vbinds[i]))
      if has(sy.evar, "@vfldn." + emn) {
        nf := str_to_int(sy.evar["@vfldn." + emn])
        if nb > nf {
          report_chk(sy, src, pos, "variant '" + nm + "' binds " + int_to_str(nb) + " but has " + int_to_str(nf) + " field(s)")
        }
      }
    }
    i += 1
  }
  // (2) exhaustiveness — every variant of enum `ty` must have an UNGUARDED arm
  // (a guarded arm may not fire at runtime). An unguarded `_` catch-all covers
  // everything, so it satisfies exhaustiveness outright.
  if vn_has_ug(mv, guards, "_") rt 0
  all := split_semi(sy.evar["@order." + ty])
  mu j := 0
  lp j < len(all) {
    if vn_has_ug(mv, guards, all[j]) == false {
      mu miss := all[j]
      if has_sub(miss, ty + "_") { miss = substring(miss, len(ty) + 1, len(miss)) }   // de-mangle Option_i64_Some → Some for the message
      report_chk(sy, src, pos, "non-exhaustive match: enum " + ty + " missing variant '" + miss + "'")
    }
    j += 1
  }
  0
}
// The nested-pattern desugar binds a `__nest*` temp to a variant field, then
// matches on it in an inner (synthetic) match. Type those temps to their field's
// enum so the inner match's exhaustiveness IS checked — a refutable nested
// pattern (the inner enum has variants the pattern doesn't cover) then reports
// "non-exhaustive", and destructuring a non-enum field reports "match on
// non-enum". Scoped to `__nest*`, so non-nested code (incl. the compiler itself)
// is untouched and the fixpoint is unaffected.
fn type_nest_temps(sy:*Syms, vnames:[str], vbinds:[str], pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  mu i := 0
  lp i < len(vnames) {
    nm := vnames[i]
    bs := split_semi(vbinds[i])
    mu j := 0
    lp j < len(bs) {
      if has_sub(bs[j], "__nest") {
        k := "@vfld." + nm + "." + int_to_str(j)
        if has(sy.evar, k) {
          ft := sy.evar[k]                          // a sub-enum field is stored boxed
          ty := if is_boxed_ft(ft) { boxed_enum(ft, sy.evar[nm]) } el { ft }
          if has(sy.evar, "@order." + ty) {
            set_ty(sy, bs[j], ty)                    // known enum → type the temp so the inner match checks
          } el {
            report_chk(sy, src, pos, "cannot destructure non-enum field of type " + ty + " with a nested pattern")
          }
        }
      }
      j += 1
    }
    i += 1
  }
  0
}
fn chk_match(funcs:[Func], sy:*Syms, sc:Expr, vnames:[str], vbinds:[str], bd:[Expr], guards:[Expr], pos:i64, src:str) -> i64 {
  match_check(sy, sc, vnames, vbinds, guards, pos, src)
  type_nest_temps(sy, vnames, vbinds, pos, src)
  check_expr(funcs, sy, sc, pos, src); chk_args(funcs, sy, bd, pos, src); chk_args(funcs, sy, guards, pos, src); 0
}
fn chk_bin(funcs:[Func], sy:*Syms, op:i64, l:Expr, r:Expr, pos:i64, src:str) -> i64 {
  binop_check(sy, op, l, r, pos, src)
  check_expr(funcs, sy, l, pos, src); check_expr(funcs, sy, r, pos, src); 0
}
// The parameter count of a lambda-literal arg, or -1 if it isn't a lambda.
// (lam_params can't tell a 0-param lambda from a non-lambda; this can, so the
// collection/init args of a HOF are never mistaken for a 0-param callback.)
fn lambda_arity(e:Expr) -> i64 {
  mt e {
    Lambda(ps,pts,b,id) => len(ps);
    Num(v)             => -1;
    Flt(fs)            => -1;
    Str(s)             => -1;
    Var(n)             => -1;
    Bin(o,a,b2)        => -1;
    Unary(o,x)         => -1;
    Call(f,a)          => -1;
    Field(o,f)         => -1;
    Index(o,ix)        => -1;
    Array(es,et)       => -1;
    MapLit(ml,mks,mvs) => -1;
    Addr(x)            => -1;
    Match(sc,vn,vb,bd) => -1;
    IfE(c,t,el2)       => -1;
    Try(e2)            => -1;
    Tuple(tes)         => -1;
    BlockE(bb)         => -1;
    Bad                => -1;
  }
}
// `map`/`filter` take a 1-param callback, `reduce` a 2-param one. Fires only when
// an arg is confidently a lambda literal of the wrong arity, so it never touches
// the collection/init args or a callback passed by name (those stay "?").
fn hof_arity_check(sy:*Syms, fname:str, args:[Expr], pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  mu want := -1
  mu cbidx := -1
  if fname == "map" || fname == "filter" { want = 1; cbidx = 1 }
  if fname == "reduce" { want = 2; cbidx = 2 }
  if want < 0 rt 0
  // The builtin map/filter/reduce INLINE their callback at codegen time, so it
  // must be a lambda literal right here — a stored or named function in the
  // callback slot silently miscompiles (the #1 LLM gotcha). Turn that into a
  // clear, actionable error. lambda_arity returns >=0 only for a lambda literal.
  if cbidx >= 0 && cbidx < len(args) && lambda_arity(args[cbidx]) < 0 {
    report_chk(sy, src, pos, "the function argument to '" + fname + "' must be an inline lambda (fn(x) …); a stored or named function isn't supported here — use std/seq.ail (keep/map_to/fold) for that")
  }
  mu i := 0
  lp i < len(args) {
    np := lambda_arity(args[i])
    if np >= 0 && np != want {
      report_chk(sy, src, pos, "'" + fname + "' callback takes " + int_to_str(want) + " parameter(s), got " + int_to_str(np))
    }
    i += 1
  }
  0
}
// A call to a user generic fn (`fn id<T>(…)`) — inlined at its call sites, so it
// is NOT in `funcs` and escapes callarg_check. Its T-polymorphic params can't be
// type-checked, but arity is exact: count the registered generic's params (sy.gfns
// is the [Func] of generics, carried through every seed_fn).
fn generic_arity_check(sy:*Syms, fname:str, args:[Expr], pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  mu gi := 0
  lp gi < len(sy.gfns) {
    if sy.gfns[gi].name == fname {
      np := len(sy.gfns[gi].params)
      if len(args) != np {
        report_chk(sy, src, pos, "generic function '" + fname + "' expects " + int_to_str(np) + " arguments, got " + int_to_str(len(args)))
      }
      rt 0
    }
    gi += 1
  }
  0
}
// ----- constrained generics / traits ----------------------------------------
// The concrete type bound to type-param `tp` at a call: the type of the arg whose
// generic param is exactly `tp` (or the element type for a `[tp]` param). "?" when
// none/unknown. Mirrors generic_T (codegen) but for a specific named param.
fn concrete_of_tparam(sy:*Syms, f:Func, tp:str, args:[Expr]) -> str {
  mu i := 0
  lp i < len(f.ptypes) {
    if i < len(args) {
      if f.ptypes[i] == tp rt type_of_expr(sy, args[i])
      if f.ptypes[i] == "[" + tp + "]" rt elem_of_ann(type_of_expr(sy, args[i]))
    }
    i += 1
  }
  "?"
}
// Method names a class (or an ancestor) defines — for "did you mean?" on a missing
// trait method. Scans "@class.defines.<cls>.<m>" up the inheritance chain.
fn class_methods(sy:*Syms, cls:str) -> [str] {
  mu out:[str] := []
  mu c := cls
  lp len(c) > 0 {
    pfx := "@class.defines." + c + "."
    lp (k, v) in sy.evar {
      if len(k) >= len(pfx) && substring(k, 0, len(pfx)) == pfx { out = push(out, substring(k, len(pfx), len(k))) }
    }
    c = class_parent(sy, c)
  }
  out
}
// When a generic call's `<T: Trait>` bound applies, the concrete T must be a class
// (or ancestor) defining every method the trait requires (structural satisfaction,
// via is_class_method). Conservative: skips unknown T and unregistered traits, so
// it never rejects code that compiles today. The bound is erased at codegen — the
// inline-monomorphization already dispatches each method per concrete class.
fn generic_bound_check(sy:*Syms, fname:str, args:[Expr], pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  if has(sy.evar, "@generic." + fname) == false rt 0
  f := find_gfn(sy, fname)
  mu ti := 0
  lp ti < len(f.tparams) {
    tp := f.tparams[ti]
    bkey := "@bound." + fname + "." + tp
    if has(sy.evar, bkey) {
      trait := sy.evar[bkey]
      conc := concrete_of_tparam(sy, f, tp, args)
      if confident(conc) && has(sy.evar, "@trait." + trait) {
        cls := under_ptr(conc)
        ms := split_semi(sy.evar["@trait." + trait])
        mu mi := 0
        lp mi < len(ms) {
          if len(ms[mi]) > 0 && is_class_method(sy, cls, ms[mi]) == false {
            report_chk(sy, src, pos, "type '" + cls + "' does not satisfy bound '" + trait + "': missing method '" + ms[mi] + "'" + suggest(ms[mi], class_methods(sy, cls)))
          }
          mi += 1
        }
      }
    }
    ti += 1
  }
  0
}
// `ok(x)` is monomorphic on the ENCLOSING fn's result type — it builds a
// `res_<T>` where T is that fn's ok type, stashed as @ret by seed_fn for every
// `-> !T` fn. So x must be compatible with T. (incompatible() treats `!T` itself
// as "skip", so a result fn's returns are otherwise unchecked — this closes that.)
// Conservative: no @ret (not a result fn) or unknown x → skip.
fn ok_ret_check(sy:*Syms, fname:str, args:[Expr], pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  if fname != "ok" rt 0
  if len(args) != 1 rt 0
  if has(sy.vty, "@ret") == false rt 0
  want := sy.vty["@ret"]
  got := type_confident(sy, args[0])
  if confident(want) && confident(got) && incompatible(sy, want, got) {
    report_chk(sy, src, pos, "type mismatch: ok(" + got + ") but function returns !" + want)
  }
  0
}
// `values(m)` has no runtime for array-valued maps (would need arr_arr_*).
fn map_values_check(sy:*Syms, fname:str, args:[Expr], pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  if fname == "values" && len(args) == 1 {
    t := type_confident(sy, args[0])
    if is_map_ann(t) && is_array_ann(map_vtype(t)) {
      report_chk(sy, src, pos, "values() on a map with array values is not supported (iterate keys() instead)")
    }
  }
  0
}
fn chk_call(funcs:[Func], sy:*Syms, fname:str, args:[Expr], pos:i64, src:str) -> i64 {
  map_values_check(sy, fname, args, pos, src)
  callarg_check(funcs, sy, fname, args, pos, src)
  ctor_arg_check(sy, fname, args, pos, src)
  variant_arg_check(sy, fname, args, pos, src)
  hof_arity_check(sy, fname, args, pos, src)
  generic_arity_check(sy, fname, args, pos, src)
  generic_bound_check(sy, fname, args, pos, src)
  ok_ret_check(sy, fname, args, pos, src)
  chk_args(funcs, sy, args, pos, src); 0
}
fn chk_field(funcs:[Func], sy:*Syms, obj:Expr, fname:str, pos:i64, src:str) -> i64 {
  field_check(sy, obj, fname, pos, src)
  check_expr(funcs, sy, obj, pos, src); 0
}
fn chk_index(funcs:[Func], sy:*Syms, obj:Expr, idx:Expr, pos:i64, src:str) -> i64 {
  index_check(sy, obj, pos, src)
  check_expr(funcs, sy, obj, pos, src); check_expr(funcs, sy, idx, pos, src); 0
}
fn check_expr(funcs:[Func], sy:*Syms, e:Expr, pos:i64, src:str) -> i64 {
  mt e {
    Bin(op,l,r)         => chk_bin(funcs, sy, op, l, r, pos, src);
    Call(fname,args)    => chk_call(funcs, sy, fname, args, pos, src);
    Field(obj,fnm)      => chk_field(funcs, sy, obj, fnm, pos, src);
    Index(obj,idx)      => chk_index(funcs, sy, obj, idx, pos, src);
    Unary(op,x)         => check_expr(funcs, sy, x, pos, src);
    Addr(x)             => check_expr(funcs, sy, x, pos, src);
    Array(elems,ety)    => chk_array(funcs, sy, elems, pos, src);
    MapLit(mty,mks,mvs) => chk_maplit(funcs, sy, mty, mks, mvs, pos, src);
    Match(sc,vn,vb,bd,gd)  => chk_match(funcs, sy, sc, vn, vb, bd, gd, pos, src);
    IfE(c,t,el2)        => chk3(funcs, sy, c, t, el2, pos, src);
    Try(x)              => chk_try(funcs, sy, x, pos, src);
    Tuple(elems)        => chk_args(funcs, sy, elems, pos, src);
    BlockE(bb)          => check_stmts(funcs, sy, bb, src);
    Lambda(ps,pts,b,id) => check_expr(funcs, sy, b, pos, src);
    Num(v)              => 0;
    Flt(s)              => 0;
    Str(s)              => 0;
    Var(n)              => 0;
    Bad                 => 0;
  }
}
fn chk_assign(funcs:[Func], sy:*Syms, name:str, e:Expr, pos:i64, src:str) -> i64 {
  if pos >= 0 {
    lt := tcon_var(sy, name)
    rr := type_confident(sy, e)
    if confident(lt) && confident(rr) && incompatible(sy, lt, rr) {
      report_chk(sy, src, pos, "type mismatch: cannot assign " + rr + " to '" + name + "' of type " + lt)
    }
  }
  check_expr(funcs, sy, e, pos, src)
  0
}
// `rt expr` — when the enclosing fn has an EXPLICIT `-> T` (stashed as @chkret by
// check_fn), flag a confidently-incompatible returned value. Implicit-return fns
// (no annotation) have no @chkret, so they're skipped (their type IS the return).
fn chk_return(funcs:[Func], sy:*Syms, e:Expr, pos:i64, src:str) -> i64 {
  if pos >= 0 {
    if has(sy.vty, "@chkret") {
      want := sy.vty["@chkret"]
      got := type_confident(sy, e)
      if confident(got) && incompatible(sy, want, got) {
        report_chk(sy, src, pos, "type mismatch: returning " + got + " but function returns " + want)
      }
    }
  }
  check_expr(funcs, sy, e, pos, src)
  0
}
// `obj.fnm = e` — the field must exist on a struct (field_check, fail-fast) and the
// value's confident type must be compatible with the field's slot type.
fn chk_field_assign(funcs:[Func], sy:*Syms, obj:Expr, fnm:str, e:Expr, pos:i64, src:str) -> i64 {
  field_check(sy, obj, fnm, pos, src)
  if pos >= 0 {
    slot := tcon_field(sy, obj, fnm)
    val := type_confident(sy, e)
    if confident(slot) && confident(val) && incompatible(sy, slot, val) {
      report_chk(sy, src, pos, "type mismatch: cannot assign " + val + " to field '." + fnm + "' of type " + slot)
    }
  }
  check_expr(funcs, sy, obj, pos, src)
  check_expr(funcs, sy, e, pos, src)
  0
}
// `obj[idx] = e` — obj must be indexable (index_check, fail-fast) and the value's
// confident type must be compatible with the array elem / map value type.
fn idx_slot_type(sy:*Syms, obj:Expr) -> str {
  t := type_confident(sy, obj)
  if is_array_ann(t) rt elem_of_ann(t)
  if is_map_ann(t) rt map_vtype(t)
  "?"
}
fn chk_idx_assign(funcs:[Func], sy:*Syms, obj:Expr, idx:Expr, e:Expr, pos:i64, src:str) -> i64 {
  index_check(sy, obj, pos, src)
  if pos >= 0 {
    slot := idx_slot_type(sy, obj)
    val := type_confident(sy, e)
    if confident(slot) && confident(val) && incompatible(sy, slot, val) {
      report_chk(sy, src, pos, "type mismatch: cannot assign " + val + " to element of type " + slot)
    }
  }
  check_expr(funcs, sy, obj, pos, src)
  check_expr(funcs, sy, idx, pos, src)
  check_expr(funcs, sy, e, pos, src)
  0
}
// `Name(a, b, …)` for a struct/class ctor — positional field types are registered
// as @fld.<Name>.<i> (user fields only, __vt skipped) with arity @fldn.<Name>.
// Skips entirely unless the arg count matches the registered arity, so any
// vtable/lowering surprise degrades to no-op rather than a wrong report.
fn ctor_arg_check(sy:*Syms, fname:str, args:[Expr], pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  if has(sy.evar, "@fldn." + fname) == false rt 0
  n := str_to_int(sy.evar["@fldn." + fname])
  if len(args) != n {
    report_chk(sy, src, pos, "constructor '" + fname + "' expects " + int_to_str(n) + " fields, got " + int_to_str(len(args)))
    rt 0
  }
  mu i := 0
  lp i < len(args) {
    k := "@fld." + fname + "." + int_to_str(i)
    if has(sy.evar, k) {
      want := sy.evar[k]
      got := type_confident(sy, args[i])
      if confident(want) && confident(got) && incompatible(sy, want, got) {
        report_chk(sy, src, pos, "type mismatch: field " + int_to_str(i + 1) + " of '" + fname + "' expects " + want + ", got " + got)
      }
    }
    i += 1
  }
  0
}
// `Variant(a, b, …)` for an enum variant — like ctor_arg_check but registered
// only for tuple/fn-free variants (@vfldn/@vfld). Uses cat_incompatible (NOT the
// nominal one) so boxed recursive fields (@box:/@self) and any struct/enum field
// are tolerated; only scalar/str/container category mismatches are flagged.
fn variant_arg_check(sy:*Syms, fname:str, args:[Expr], pos:i64, src:str) -> i64 {
  if pos < 0 rt 0
  if has(sy.evar, "@vfldn." + fname) == false rt 0
  n := str_to_int(sy.evar["@vfldn." + fname])
  if len(args) != n {
    report_chk(sy, src, pos, "variant '" + fname + "' expects " + int_to_str(n) + " fields, got " + int_to_str(len(args)))
    rt 0
  }
  mu i := 0
  lp i < len(args) {
    k := "@vfld." + fname + "." + int_to_str(i)
    if has(sy.evar, k) {
      want := sy.evar[k]
      got := type_confident(sy, args[i])
      if confident(want) && confident(got) && cat_incompatible(want, got) {
        report_chk(sy, src, pos, "type mismatch: field " + int_to_str(i + 1) + " of variant '" + fname + "' expects " + want + ", got " + got)
      }
    }
    i += 1
  }
  0
}
// Tail-expression return check: the last statement of a body is the implicit
// return when there's no `rt`. Mirrors last_expr_type/either_return — an SExpr
// tail is the return value; a tail SIf returns through BOTH branches.
fn check_tail_expr(sy:*Syms, e:Expr, pos:i64, want:str, src:str) -> i64 {
  if pos < 0 rt 0
  got := type_confident(sy, e)
  if confident(got) && incompatible(sy, want, got) {
    report_chk(sy, src, pos, "type mismatch: returning " + got + " but function returns " + want)
  }
  0
}
fn check_tail_if(sy:*Syms, b:[Stmt], eb:[Stmt], want:str, src:str) -> i64 {
  check_tail_return(sy, b, want, src)
  check_tail_return(sy, eb, want, src)
  0
}
fn check_tail_stmt(sy:*Syms, s:Stmt, want:str, src:str) -> i64 {
  mt s {
    SExpr(e,pos)             => check_tail_expr(sy, e, pos, want, src);
    SIf(c,b,eb)              => check_tail_if(sy, b, eb, want, src);
    SDecl(name,e,pos)        => 0;
    SDestructure(names,e)    => 0;
    SAssign(name,e,pos)      => 0;
    SIdxAssign(o,i,e,pos)    => 0;
    SFieldAssign(o,f,e,pos)  => 0;
    SReturn(e,pos)           => 0;
    SPrint(e,pos)            => 0;
    SLoop(c,b)               => 0;
    SLoopIn(vnm,coll,b)      => 0;
    SLoopKV(kn,vn,coll,b)    => 0;
    SLoopRange(v,lo,hi,b)    => 0;
    SBreak                   => 0;
    SContinue                => 0;
  }
}
fn check_tail_return(sy:*Syms, body:[Stmt], want:str, src:str) -> i64 {
  if len(body) == 0 rt 0
  check_tail_stmt(sy, body[len(body) - 1], want, src)
  0
}
fn chk_if(funcs:[Func], sy:*Syms, c:Expr, b:[Stmt], eb:[Stmt], src:str) -> i64 {
  check_expr(funcs, sy, c, -1, src); check_stmts(funcs, sy, b, src); check_stmts(funcs, sy, eb, src); 0
}
fn chk_body(funcs:[Func], sy:*Syms, c:Expr, b:[Stmt], src:str) -> i64 {
  check_expr(funcs, sy, c, -1, src); check_stmts(funcs, sy, b, src); 0
}
fn chk_coll(funcs:[Func], sy:*Syms, coll:Expr, b:[Stmt], src:str) -> i64 {
  check_expr(funcs, sy, coll, -1, src); check_stmts(funcs, sy, b, src); 0
}
fn chk_range(funcs:[Func], sy:*Syms, lo:Expr, hi:Expr, b:[Stmt], src:str) -> i64 {
  check_expr(funcs, sy, lo, -1, src); check_expr(funcs, sy, hi, -1, src); check_stmts(funcs, sy, b, src); 0
}
fn check_stmt(funcs:[Func], sy:*Syms, s:Stmt, src:str) -> i64 {
  mt s {
    SDecl(name,e,pos)        => check_expr(funcs, sy, e, pos, src);
    SDestructure(names,e)    => check_expr(funcs, sy, e, -1, src);
    SAssign(name,e,pos)      => chk_assign(funcs, sy, name, e, pos, src);
    SIdxAssign(obj,idx,e,pos)    => chk_idx_assign(funcs, sy, obj, idx, e, pos, src);
    SFieldAssign(obj,fnm,e,pos)  => chk_field_assign(funcs, sy, obj, fnm, e, pos, src);
    SReturn(e,pos)           => chk_return(funcs, sy, e, pos, src);
    SPrint(e,pos)            => check_expr(funcs, sy, e, pos, src);
    SIf(c,b,eb)              => chk_if(funcs, sy, c, b, eb, src);
    SLoop(c,b)               => chk_body(funcs, sy, c, b, src);
    SLoopIn(vnm,coll,b)      => chk_coll(funcs, sy, coll, b, src);
    SLoopKV(kn,vn,coll,b)    => chk_coll(funcs, sy, coll, b, src);
    SLoopRange(v,lo,hi,b)    => chk_range(funcs, sy, lo, hi, b, src);
    SBreak                   => 0;
    SContinue                => 0;
    SExpr(e,pos)             => check_expr(funcs, sy, e, pos, src);
  }
}
fn check_stmts(funcs:[Func], sy:*Syms, body:[Stmt], src:str) -> i64 {
  mu i := 0
  lp i < len(body) { check_stmt(funcs, sy, body[i], src); i += 1 }
  0
}
fn check_fn(funcs:[Func], base:*Syms, f:Func, src:str) -> i64 {
  mu sy := seed_fn(base, f)
  fb := stamp_empty_maps(&sy, f.body)               // infer un-annotated `m := {}` / `xs := []` (mirror codegen 1144)
  sy = seed_fn(base, f)                              // discard inference's scratch typing (mirror codegen 1145)
  hd := hoist_decls(&sy, fb, "    ")                 // populate sy.vty for locals from the STAMPED body
  if len(f.ret) > 0 { set_ty(&sy, "@chkret", f.ret) }   // explicit `-> T` → enable the return-type check
  check_stmts(funcs, &sy, fb, src)
  if len(f.ret) > 0 { check_tail_return(&sy, fb, f.ret, src) }   // implicit tail-expr return vs declared
  0
}
fn check_program(funcs:[Func], base:*Syms, mains:[Stmt], src:str) -> i64 {
  mu i := 0
  lp i < len(funcs) { check_fn(funcs, base, funcs[i], src); i += 1 }
  mu msy := Syms({}, base.fld, base.ctors, base.frets, base.evar, base.vft, base.gfns, base.lams, base.errc)
  mm := stamp_empty_maps(&msy, mains)               // infer un-annotated `m := {}` (mirror codegen 1159)
  msy = Syms({}, base.fld, base.ctors, base.frets, base.evar, base.vft, base.gfns, base.lams, base.errc)   // re-seed fresh — discard inference scratch (codegen 1160)
  mhd := hoist_decls(&msy, mm, "    ")
  check_stmts(funcs, &msy, mm, src)
  0
}

// `libmode` = compile as a shared library: no `main`, a load-time constructor
// inits Boehm GC, and each name in `exports` (the root file's top-level `fn`s)
// with a C-friendly signature gets an unmangled wrapper + a header proto. When
// libmode==false this is byte-identical to the executable path (`exports` unused).
fn compile_to_c(src:str, dir:str, libmode:bool, exports:[str]) -> str {
  toks := lex(src)
  mu p := P(toks, 0, src)

  mu structs:[StructDef] := []
  mu enums:[EnumDef] := []
  mu funcs:[Func] := []
  mu externs:[Func] := []
  mu cincs:[str] := []
  mu csrcs:[str] := []
  mu classes:[ClassDef] := []
  mu traits:[TraitDef] := []
  mu mains:[Stmt] := []

  lp ckind(&p) != TK_EOF() {
    if ckind(&p) == TK_SEMI() { adv(&p); ct }   // skip stray `;` separators
    if ckind(&p) == TK_IDENT() && ctext(&p) == "st" {
      structs = push(structs, parse_struct(&p))
    } el if ckind(&p) == TK_IDENT() && ctext(&p) == "en" {
      enums = push(enums, parse_enum(&p))
    } el if ckind(&p) == TK_IDENT() && ctext(&p) == "cl" {
      classes = push(classes, parse_class(&p))
    } el if ckind(&p) == TK_IDENT() && ctext(&p) == "tr" {
      traits = push(traits, parse_trait(&p))
    } el if ckind(&p) == TK_IDENT() && ctext(&p) == "cinc" {
      adv(&p); cincs = push(cincs, ctext(&p)); adv(&p)   // cinc "header.h"
    } el if ckind(&p) == TK_IDENT() && ctext(&p) == "csrc" {
      adv(&p)
      if ckind(&p) == TK_RAWSTR() {                       // csrc `…inline C++…` → write a temp .cpp beside the input
        fname := "__ailinline_" + int_to_str(len(csrcs)) + ".cpp"
        write_file(dir + fname, ctext(&p)); adv(&p)
        csrcs = push(csrcs, fname)                        // same one-file UX as csrc "shim.cpp"
      } el {                                              // csrc "shim.cpp" → external file path
        csrcs = push(csrcs, ctext(&p)); adv(&p)
      }
    } el if ckind(&p) == TK_IDENT() && ctext(&p) == "ex" {
      externs = push(externs, parse_extern(&p))
    } el if ckind(&p) == TK_IDENT() && ctext(&p) == "fn" {
      funcs = push(funcs, parse_func(&p))
    } el {
      mains = push(mains, parse_stmt(&p))
    }
  }

  // Split generic functions (`fn id<T>(…)`) out — inlined at call sites, not
  // emitted as C functions. Regular fns emit normally.
  mu gfuncs:[Func] := []
  mu rfuncs:[Func] := []
  mu bkeys:[str] := []                                // parallel: "@bound.<fn>.<T>" keys + trait names, applied to base.evar below
  mu bvals:[str] := []
  mu gi := 0
  lp gi < len(funcs) {
    if len(funcs[gi].tparams) > 0 {
      f := funcs[gi]
      // tparams may carry a bound from `<T: Bound>` encoded "T:Bound". Strip it to a
      // clean name (so codegen's is_tparam/subst_tparam match the `T` annotation) and
      // record the bound for the checker.
      mu cleantp:[str] := []
      mu ti := 0
      lp ti < len(f.tparams) {
        nm := before_colon(f.tparams[ti])
        bd := after_colon(f.tparams[ti])
        if len(bd) > 0 { bkeys = push(bkeys, "@bound." + f.name + "." + nm); bvals = push(bvals, bd) }
        cleantp = push(cleantp, nm)
        ti += 1
      }
      gfuncs = push(gfuncs, Func(f.name, f.params, f.ptypes, f.ret, f.lib, cleantp, f.body))
    } el { rfuncs = push(rfuncs, funcs[gi]) }
    gi += 1
  }
  funcs = rfuncs

  // Build the shared type context: struct ctors + field-type map + enum tables.
  mu nolams:[Func] := []
  mu base := Syms({}, {}, {}, {}, {}, {}, gfuncs, nolams, {})
  // Trait metadata for the generic-bound checker (codegen never reads these):
  // "@trait.<Name>" → ";"-joined required method names; "@bound.<fn>.<T>" → trait.
  mu tri := 0
  lp tri < len(traits) { base.evar["@trait." + traits[tri].name] = join_semi(traits[tri].methods); tri += 1 }
  mu bi := 0
  lp bi < len(bkeys) { base.evar[bkeys[bi]] = bvals[bi]; bi += 1 }
  // Lower classes (B1: data struct + statically-dispatched methods). Each class
  // → a StructDef (so the struct registration below + all the struct codegen —
  // ctor, printer, arr_/map_/res_ — handle it for free) plus one top-level Func
  // per method, mangled `<Class>_<method>` with `self:*Class` as params[0]. The
  // `@class.*` evar keys let gen_call route `obj.m(args)` → `f_<Class>_m`. Pushed
  // BEFORE the struct loop (so fields register) and the fn return-inference loop
  // (so method returns infer). Additive: classes==[] (e.g. main.ail) ⇒ no-op.
  mu notp:[str] := []                         // lowered classes are never generic structs
  mu lci := 0
  lp lci < len(classes) {
    cd := classes[lci]
    // Does this class (or an ancestor) have any virtual method? Drives the hidden
    // __vt field and the vtable emission.
    parent_hasvt := len(cd.parent) > 0 && has(base.evar, "@class.hasvt." + cd.parent)
    mu own_virt := false
    mu vci := 0
    lp vci < len(cd.vflags) { if cd.vflags[vci] == "1" { own_virt = true } vci += 1 }
    hasvt := own_virt || parent_hasvt

    // Flatten fields: [__vt?] + parent (flattened) + own — so s_<Derived> begins
    // with s_<Base>'s layout (a Derived* upcasts to Base*, cfront/GObject style).
    // __vt is prepended only at the ROOT of a virtual hierarchy; a derived class
    // inherits the parent's. Base must precede the derived class in source order.
    mu allf:[str] := []
    mu allt:[str] := []
    if hasvt && (parent_hasvt == false) { allf = push(allf, "__vt"); allt = push(allt, "@vtp") }
    if len(cd.parent) > 0 {
      mu k := 0
      lp k < len(structs) {
        if structs[k].name == cd.parent {
          mu pj := 0
          lp pj < len(structs[k].fnames) { allf = push(allf, structs[k].fnames[pj]); allt = push(allt, structs[k].ftypes[pj]); pj += 1 }
        }
        k += 1
      }
    }
    mu fi := 0
    lp fi < len(cd.fnames) { allf = push(allf, cd.fnames[fi]); allt = push(allt, cd.ftypes[fi]); fi += 1 }
    structs = push(structs, StructDef(cd.name, allf, allt, notp))

    base.evar["@class." + cd.name] = "1"
    base.evar["@class.parent." + cd.name] = cd.parent
    if hasvt { base.evar["@class.hasvt." + cd.name] = "1" }

    // Methods → top-level Funcs; record defines, owning class, and (for virtuals)
    // the slot signature (return C type + arg C types after the `void*` self).
    mu mi := 0
    lp mi < len(cd.methods) {
      m := cd.methods[mi]
      funcs = push(funcs, Func(cd.name + "_" + m.name, m.params, m.ptypes, m.ret, "", m.tparams, m.body))
      base.evar["@class.defines." + cd.name + "." + m.name] = "1"
      base.evar["@mclass." + cd.name + "_" + m.name] = cd.name
      if cd.vflags[mi] == "1" {
        mu vr := "void"
        if len(m.ret) > 0 { vr = cty(m.ret) }
        base.evar["@class.vret." + cd.name + "." + m.name] = vr
        mu va := ""
        mu ai := 1
        lp ai < len(m.ptypes) { va = va + ", " + cty(m.ptypes[ai]); ai += 1 }
        base.evar["@class.vargs." + cd.name + "." + m.name] = va
      }
      mi += 1
    }

    // vslots: the parent's slot list, then this class's NEW virtuals (an override
    // reuses the inherited slot). Then mark each slot virtual-for-this-class.
    mu slots := ""
    if parent_hasvt { slots = base.evar["@class.vslots." + cd.parent] }
    mu vm := 0
    lp vm < len(cd.methods) {
      if cd.vflags[vm] == "1" {
        mn := cd.methods[vm].name
        if slot_has(slots, mn) == false {
          if len(slots) == 0 { slots = mn } el { slots = slots + ";" + mn }
        }
      }
      vm += 1
    }
    base.evar["@class.vslots." + cd.name] = slots
    mu sp := split(slots, ";")
    mu spi := 0
    lp spi < len(sp) { if len(sp[spi]) > 0 { base.evar["@class.virt." + cd.name + "." + sp[spi]] = "1" } spi += 1 }
    lci += 1
  }

  // Lower generic structs (`st Box<T>{…}`) → concrete monomorphic StructDefs, the
  // same way lower_classes lowers a class: the registration + struct codegen below
  // (ctor/printer/arr_/map_/res_) then handle each instance for free. Templates are
  // split out of `structs` (not emitted); instances come from (a) the 3 scalar
  // types — covering ctor-inferred `Box(5)`/`Box("x")` — and (b) any `G<Struct>`
  // named in a fn param/return or struct field. Finally all decl type strings are
  // mangled `Box<i64>`→`Box_i64` so the rest of the pipeline sees plain names.
  // Additive: no generic structs (e.g. main.ail) ⇒ gstructs==[] ⇒ pure no-op.
  mu gstructs:[StructDef] := []
  mu cstructs:[StructDef] := []
  mu gsi := 0
  lp gsi < len(structs) {
    if len(structs[gsi].tparams) > 0 {
      gstructs = push(gstructs, structs[gsi])
      base.evar["@gstruct." + structs[gsi].name] = join_semi(structs[gsi].tparams)
      base.evar["@gstruct.fields." + structs[gsi].name] = join_semi(structs[gsi].ftypes)   // template field types (with T) → ctor-arg T inference
    } el { cstructs = push(cstructs, structs[gsi]) }
    gsi += 1
  }
  structs = cstructs
  // (a) scalar instantiations for each single-param template
  mu gscal:[str] := ["i64", "str", "f64"]
  mu gti := 0
  lp gti < len(gstructs) {
    if len(gstructs[gti].tparams) == 1 {
      mu sk := 0
      lp sk < len(gscal) {
        inst := gen_instance(gstructs[gti], mk1(gscal[sk]))
        if has_struct(structs, inst.name) == false { structs = push(structs, inst) }
        sk += 1
      }
    } el if len(gstructs[gti].tparams) == 2 {
      mu sa := 0                                  // 2-param: scalar Cartesian (covers ctor-inferred Pair(1,"x"))
      lp sa < len(gscal) {
        mu sb := 0
        lp sb < len(gscal) {
          inst := gen_instance(gstructs[gti], mk2(gscal[sa], gscal[sb]))
          if has_struct(structs, inst.name) == false { structs = push(structs, inst) }
          sb += 1
        }
        sa += 1
      }
    }
    gti += 1
  }
  // (b) instantiations named explicitly in fn signatures / struct fields
  mu afi := 0
  lp afi < len(funcs) {
    mu pj := 0
    lp pj < len(funcs[afi].ptypes) { structs = collect_struct_inst(structs, gstructs, funcs[afi].ptypes[pj]); pj += 1 }
    structs = collect_struct_inst(structs, gstructs, funcs[afi].ret)
    afi += 1
  }
  mu asi := 0
  lp asi < len(structs) {                       // note: only scans the structs present before this loop grows it; fields-of-generics are out of scope
    mu fj := 0
    lp fj < len(structs[asi].ftypes) { structs = collect_struct_inst(structs, gstructs, structs[asi].ftypes[fj]); fj += 1 }
    asi += 1
  }
  // Lower generic enums (`en Option<T>{…}`) → concrete monomorphic EnumDefs with
  // per-instance-mangled variants (Option_i64_Some), the same way generic structs
  // lower. Bare `Some`/`None` route to the mangled variant at the ctor + match sites
  // (via @gvariant). Instances: the 3 scalars (covers ctor-inferred `Some(5)`) + any
  // `Option<X>` in a fn sig / struct field. Templates are split out (not emitted).
  // Must run BEFORE the normalize below so annotations still carry `<…>` to collect.
  mu genums:[EnumDef] := []
  mu cenums:[EnumDef] := []
  mu gnei := 0
  lp gnei < len(enums) {
    if len(enums[gnei].tparams) > 0 {
      genums = push(genums, enums[gnei])
      base.evar["@genum." + enums[gnei].name] = join_semi(enums[gnei].tparams)
      mu evk := 0
      lp evk < len(enums[gnei].vnames) {
        base.evar["@gvariant." + enums[gnei].vnames[evk]] = enums[gnei].name                                  // bare variant → template enum
        base.evar["@gvar.fields." + enums[gnei].name + "." + enums[gnei].vnames[evk]] = enums[gnei].vftypes[evk]  // its template field types → T inference
        evk += 1
      }
    } el { cenums = push(cenums, enums[gnei]) }
    gnei += 1
  }
  enums = cenums
  mu gnti := 0
  lp gnti < len(genums) {
    if len(genums[gnti].tparams) == 1 {
      mu esk := 0
      lp esk < len(gscal) {
        einst := gen_enum_instance(genums[gnti], mk1(gscal[esk]))
        if has_enum(enums, einst.name) == false { enums = push(enums, einst) }
        esk += 1
      }
    } el if len(genums[gnti].tparams) == 2 {
      mu ea := 0                                  // 2-param: scalar Cartesian
      lp ea < len(gscal) {
        mu eb := 0
        lp eb < len(gscal) {
          einst := gen_enum_instance(genums[gnti], mk2(gscal[ea], gscal[eb]))
          if has_enum(enums, einst.name) == false { enums = push(enums, einst) }
          eb += 1
        }
        ea += 1
      }
    }
    gnti += 1
  }
  mu aei := 0
  lp aei < len(funcs) {
    mu epj := 0
    lp epj < len(funcs[aei].ptypes) { enums = collect_enum_inst(enums, genums, funcs[aei].ptypes[epj]); epj += 1 }
    enums = collect_enum_inst(enums, genums, funcs[aei].ret)
    aei += 1
  }
  mu aesi := 0
  lp aesi < len(structs) {
    mu efj := 0
    lp efj < len(structs[aesi].ftypes) { enums = collect_enum_inst(enums, genums, structs[aesi].ftypes[efj]); efj += 1 }
    aesi += 1
  }
  // normalize: mangle every `G<…>` annotation (struct OR enum) in fn sigs + struct fields
  mu nfi := 0
  lp nfi < len(funcs) { funcs[nfi] = norm_func(funcs[nfi]); nfi += 1 }
  mu nsi := 0
  lp nsi < len(structs) { structs[nsi] = norm_struct(structs[nsi]); nsi += 1 }

  mu si := 0
  lp si < len(structs) {
    sd := structs[si]
    base.ctors[sd.name] = "1"
    mu fi := 0
    mu uidx := 0
    lp fi < len(sd.fnames) {
      base.fld[fkey(sd.name, sd.fnames[fi])] = sd.ftypes[fi]
      if sd.fnames[fi] != "__vt" {                                   // skip the hidden vtable ptr — ctors don't take it
        base.evar["@fld." + sd.name + "." + int_to_str(uidx)] = sd.ftypes[fi]   // positional user-field type (ctor-arg checks)
        uidx = uidx + 1
      }
      fi += 1
    }
    base.evar["@fldn." + sd.name] = int_to_str(uidx)                 // ctor arity (user fields only)
    si += 1
  }
  // Box bare cross-enum fields now that ALL enums are known (mutual recursion),
  // BEFORE the registry/codegen read their field types.
  enums = box_cross_enums(enums)
  // Mark extern return types that name a C-header type (`-> div_t`) so they spell
  // raw, now that all user structs/enums are known.
  externs = mark_extern_ctypes(externs, structs, enums)
  // Enum registry: each variant → its enum + ";"-joined field types; plus a
  // per-enum "@order.<Enum>" → ";"-joined variant list (for tag indices).
  mu ei := 0
  lp ei < len(enums) {
    ed := enums[ei]
    mu order := ""
    mu vi := 0
    lp vi < len(ed.vnames) {
      vn := ed.vnames[vi]
      base.evar[vn] = ed.name
      base.vft[vn] = ed.vftypes[vi]
      // variant-arg checks: register positional field types + arity — but ONLY
      // when no field is a tuple/fn type (a '(' means an inner ';'/',' that would
      // corrupt the ;-split); such variants are simply left un-arg-checked.
      vfs := ed.vftypes[vi]
      if contains(vfs, "(") == false {
        if len(vfs) == 0 {
          base.evar["@vfldn." + vn] = "0"
        } el {
          vparts := split_semi(vfs)
          mu vpj := 0
          lp vpj < len(vparts) { base.evar["@vfld." + vn + "." + int_to_str(vpj)] = vparts[vpj]; vpj += 1 }
          base.evar["@vfldn." + vn] = int_to_str(len(vparts))
        }
      }
      if vi == 0 { order = vn } el { order = order + ";" + vn }
      vi += 1
    }
    base.evar["@order." + ed.name] = order
    ei += 1
  }
  // Externs FIRST: register each declared return type before fn inference, so a
  // fn whose tail is an extern call (`fn parse_int(s) { atoi(s) }`) infers that
  // extern's return type instead of defaulting to void. (i32/i64 both lower to
  // int64_t via cty, so this is fixpoint-stable.)
  mu xi := 0
  lp xi < len(externs) {
    if len(externs[xi].ret) > 0 { base.frets[externs[xi].name] = externs[xi].ret }
    xi += 1
  }
  // Infer + record each fn's return type (so calls type their results).
  mu fi2 := 0
  lp fi2 < len(funcs) {
    f := funcs[fi2]
    base.frets[f.name] = infer_ret(f, base)
    fi2 += 1
  }
  // Mark generic fn names so calls are recognized + inlined (see gen_call).
  mu gj := 0
  lp gj < len(gfuncs) {
    base.evar["@generic." + gfuncs[gj].name] = "1"
    gj += 1
  }

  // Closure collection pass: discover every first-class lambda (each user fn's
  // body, then `main`), recording its captures + a lifted Func on `base`. Seeds
  // each Syms exactly as the body-emit loop does (seed_fn / fresh-vty + hoist),
  // so capture types match. `main.ail` itself has no first-class lambdas ⇒
  // `base.lams` stays empty ⇒ the gated emission below is skipped ⇒ fixpoint safe.
  mu cf := 0
  lp cf < len(funcs) {
    mu csy := seed_fn(&base, funcs[cf])
    cdecls := hoist_decls(&csy, funcs[cf].body, "    ")
    collect_lams(&base, &csy, funcs[cf].body)
    cf += 1
  }
  mu csm := Syms(base.vty, base.fld, base.ctors, base.frets, base.evar, base.vft, base.gfns, base.lams, base.errc)
  csm.vty = {}
  cmdecls := hoist_decls(&csm, mains, "    ")
  collect_lams(&base, &csm, mains)

  // Type-check pass: report confident type mismatches at the .ail source line,
  // BEFORE any C is emitted. base is fully populated above; conservative + additive
  // (see type_confident/incompatible), so it never rejects code that compiles today
  // and leaves the generated C byte-identical (fixpoint-safe). report_chk records
  // every error into base.errc (shared map) without exiting, so the whole program
  // is checked in one run; we bail here if any fired (gating codegen, same as the
  // old exit-on-first-error — just deferred so all errors print first).
  check_program(funcs, &base, mains, src)
  if has(base.errc, "bad") {
    n := str_to_int(base.errc["n"])
    if n > 1 {
      // summary only for multi-error; single-error output stays byte-identical.
      // --json must stay valid JSONL, so emit a summary object instead of prose.
      if want_json() { println("{\"severity\":\"summary\",\"errors\":" + int_to_str(n) + "}") } el { println("found " + int_to_str(n) + " errors") }
    }
    exit(1)
  }

  // Monomorphize generic functions into real C functions (one per instantiation),
  // appended to `funcs` so the proto+body assembly below emits them. No-op for
  // main.ail (uses no generic fns) → emitted C unchanged → fixpoint safe.
  funcs = lower_generic_funcs(&base, funcs, mains)

  // Link-flag marker: one comment line listing the libs from `ex "lib"` decls,
  // read back by the driver to append `-l<lib>` to clang. Absent when nothing
  // needs linking (e.g. main.ail itself), so its own emitted C is unchanged.
  mu out := ""
  mu lk := 0
  mu libline := ""
  lp lk < len(externs) {
    if len(externs[lk].lib) > 0 { libline = libline + " " + externs[lk].lib }
    lk += 1
  }
  // The `// @links:` marker is prepended AFTER body codegen (see end of this fn),
  // so @uses-driven libs (mysqlclient — recorded only on a real myq_ call) can join
  // it. Prepending at offset 0 keeps it byte-identical for programs with no @uses.

  // C++ shim marker: one comment line listing the `csrc "..."` .cpp paths, read
  // back by main()'s driver to compile each with clang++ and link with clang++.
  // Absent when no `csrc` is used (e.g. main.ail itself), so the emitted C — and
  // the link command main() picks — are unchanged (fixpoint-safe, same mold as
  // the `// @links:` marker above).
  mu cline := ""
  mu cs := 0
  lp cs < len(csrcs) { cline = cline + " " + csrcs[cs]; cs += 1 }
  if len(cline) > 0 { out = out + "// @csrc:" + cline + "\n" }

  // C prelude: headers (system, then `cinc` headers) + string/runtime helpers.
  // Runtime allocates via Boehm GC (`GC_MALLOC` + `<gc.h>`, linked `-lgc`) to
  // match the Rust reference — there is no `free`; the collector reclaims, so
  // long-running programs (servers) no longer leak.
  // Optional native sections, gated on source usage. main.ail mentions every
  // name (in codegen strings) so it pulls them all — harmless (libc-only, no
  // link flags; unused statics are stripped) and fixpoint-safe (stage2==stage3).
  needs_time := has_sub(src, "now_ms") || has_sub(src, "now_us") || has_sub(src, "mono_ms") || has_sub(src, "sleep_ms") || has_sub(src, "time_iso")
  needs_sock := has_sub(src, "tcp_listen") || has_sub(src, "tcp_connect") || has_sub(src, "tcp_accept") || has_sub(src, "sock_send") || has_sub(src, "sock_recv") || has_sub(src, "sock_close")
  needs_proc := has_sub(src, "proc_fork") || has_sub(src, "proc_getpid") || has_sub(src, "proc_no_zombies") || has_sub(src, "proc_reap")
  // Filesystem ops (libc/POSIX, no link flag). Full names, not a bare "fs_",
  // so unrelated identifiers can't pull the section in.
  needs_fs := has_sub(src, "fs_mkdir") || has_sub(src, "fs_rmdir") || has_sub(src, "fs_unlink") || has_sub(src, "fs_rename") || has_sub(src, "fs_exists") || has_sub(src, "fs_is_dir") || has_sub(src, "fs_size") || has_sub(src, "fs_mtime") || has_sub(src, "fs_list_dir")
  // OS threads + mutex (pthread). Like sockets/proc this is POSIX-only (#ifndef
  // _WIN32), but unlike them it needs the threaded Boehm GC (`#define GC_THREADS`
  // before <gc.h>, so pthread_create→GC_pthread_create scans the new thread's
  // stack) and the -lpthread link flag (added in main() when "pthread_" shows up
  // in the C). main.ail mentions these names so its self-compile pulls the
  // section in — harmless (the compiler stays single-threaded) and fixpoint-safe.
  needs_thread := has_sub(src, "thread_spawn") || has_sub(src, "thread_join") || has_sub(src, "mutex_new") || has_sub(src, "mutex_lock") || has_sub(src, "mutex_unlock") || has_sub(src, "chan_new") || has_sub(src, "chan_send") || has_sub(src, "chan_recv") || has_sub(src, "chan_close")
  needs_regex := has_sub(src, "regex_match") || has_sub(src, "regex_find")
  // TLS (OpenSSL) + Postgres (libpq) — unlike the libc sections above these need
  // external libs, so the clang cmd in main() adds -lssl/-lcrypto / -lpq when the
  // emitted C uses them. main.ail mentions these names so its self-compile pulls
  // them in (needs both libs installed — fixpoint-safe: stage2==stage3).
  needs_tls := has_sub(src, "tls_") || has_sub(src, "sha1")
  needs_hmac := has_sub(src, "hmac_sha256")
  needs_pg := has_sub(src, "pg_")
  // exe_dir() — the compiler uses it (in resolve_imports) to find the std/ that
  // ships beside the ailc binary; gated, so user programs that never call it
  // (and main.ail's self-compile DOES, via the string below) decide on their own.
  needs_exedir := has_sub(src, "exe_dir")
  // assert(cond,msg): abort with the message on a false condition (libc only, no
  // header/link). Gate on the SPLIT token so the compiler's own source — which
  // never contains a contiguous "assert(" — doesn't pull the helper; programs
  // that don't assert emit byte-identical C. (Same split-placeholder discipline
  // as the mysql/sqlite link markers.)
  needs_assert := has_sub(src, "assert" + "(")
  // Threaded GC must be requested before <gc.h> so it pulls in <pthread.h> and
  // redirects pthread_create→GC_pthread_create. Prepended (no header reorder) so
  // non-thread programs emit byte-identical C; POSIX-only so Windows stays plain.
  if needs_thread { out = out + "#ifndef _WIN32\n#define GC_THREADS\n#endif\n" }
  out = out + "#include <stdio.h>\n#include <stdint.h>\n#include <stdlib.h>\n#include <string.h>\n#include <stdarg.h>\n#include <gc.h>\n"
  if needs_time { out = out + "#include <time.h>\n" }
  if needs_sock { out = out + "#ifndef _WIN32\n#include <sys/socket.h>\n#include <netinet/in.h>\n#include <arpa/inet.h>\n#include <netdb.h>\n#include <unistd.h>\n#endif\n" }
  if needs_proc { out = out + "#ifndef _WIN32\n#include <unistd.h>\n#include <signal.h>\n#include <sys/wait.h>\n#endif\n" }
  if needs_fs { out = out + "#ifndef _WIN32\n#include <sys/stat.h>\n#include <sys/types.h>\n#include <dirent.h>\n#include <unistd.h>\n#endif\n" }
  if needs_regex { out = out + "#ifndef _WIN32\n#include <regex.h>\n#endif\n" }
  if needs_tls { out = out + "#ifndef _WIN32\n#include <openssl/ssl.h>\n#include <openssl/err.h>\n#include <openssl/sha.h>\n#endif\n" }
  if needs_hmac { out = out + "#ifndef _WIN32\n#include <openssl/hmac.h>\n#include <openssl/evp.h>\n#endif\n" }
  if needs_pg { out = out + "#ifndef _WIN32\n#include <libpq-fe.h>\n#endif\n" }
  if needs_exedir { out = out + "#ifdef _WIN32\nunsigned long GetModuleFileNameA(void*, char*, unsigned long);\n#elif defined(__APPLE__)\n#include <mach-o/dyld.h>\n#else\n#include <unistd.h>\n#endif\n" }
  mu ci := 0
  lp ci < len(cincs) { out = out + "#include \"" + cincs[ci] + "\"\n"; ci += 1 }
  out = out + "static const char* scat(const char* a, const char* b){ size_t la=strlen(a), lb=strlen(b); char* r=(char*)GC_MALLOC(la+lb+1); memcpy(r,a,la); memcpy(r+la,b,lb); r[la+lb]=0; return r; }\n"
  out = out + "static const char* i2s(long long v){ char* r=(char*)GC_MALLOC(24); snprintf(r,24,\"%lld\",v); return r; }\n"
  // substring is [a, b) end-exclusive (matches AiLang); str_to_int via strtoll.
  out = out + "static const char* substr(const char* s, int64_t a, int64_t b){ int64_t n=(int64_t)strlen(s); if(a<0)a=0; if(b>n)b=n; if(b<a)b=a; int64_t L=b-a; char* r=(char*)GC_MALLOC(L+1); memcpy(r,s+a,L); r[L]=0; return r; }\n"
  out = out + "static int64_t s2i(const char* s){ return (int64_t)strtoll(s,0,10); }\n"
  // f64 <-> str: %g formatting (matches AiLang's float print) / strtod parse.
  out = out + "static const char* f2s(double v){ char* r=(char*)GC_MALLOC(32); snprintf(r,32,\"%g\",v); return r; }\n"
  out = out + "static double s2f(const char* s){ return strtod(s,0); }\n"
  // Source files created on Windows often carry a BOM (PowerShell `>` writes
  // UTF-16 LE) — transcode UTF-16→UTF-8 and strip a UTF-8 BOM so any editor/shell
  // works. Plain UTF-8 (no BOM, e.g. all in-repo .ail) is returned untouched, so
  // the self-compile is byte-identical and the fixpoint is unaffected.
  out = out + "static const char* ail_u16to8(const unsigned char* p, long n, int be){ char* o=(char*)GC_MALLOC((size_t)(n*2+4)); size_t k=0; long i=0; while(i+1<n){ unsigned cu=be?((unsigned)p[i]<<8|p[i+1]):((unsigned)p[i]|(unsigned)p[i+1]<<8); i+=2; unsigned cp=cu; if(cu>=0xD800&&cu<=0xDBFF&&i+1<n){ unsigned lo=be?((unsigned)p[i]<<8|p[i+1]):((unsigned)p[i]|(unsigned)p[i+1]<<8); if(lo>=0xDC00&&lo<=0xDFFF){ cp=0x10000u+((cu-0xD800u)<<10)+(lo-0xDC00u); i+=2; } } if(cp<0x80){ o[k++]=(char)cp; } else if(cp<0x800){ o[k++]=(char)(0xC0|(cp>>6)); o[k++]=(char)(0x80|(cp&0x3F)); } else if(cp<0x10000){ o[k++]=(char)(0xE0|(cp>>12)); o[k++]=(char)(0x80|((cp>>6)&0x3F)); o[k++]=(char)(0x80|(cp&0x3F)); } else { o[k++]=(char)(0xF0|(cp>>18)); o[k++]=(char)(0x80|((cp>>12)&0x3F)); o[k++]=(char)(0x80|((cp>>6)&0x3F)); o[k++]=(char)(0x80|(cp&0x3F)); } } o[k]=0; return o; }\n"
  out = out + "static const char* read_file_c(const char* path){ FILE* f=fopen(path,\"rb\"); if(!f) return \"\"; fseek(f,0,SEEK_END); long n=ftell(f); fseek(f,0,SEEK_SET); unsigned char* b=(unsigned char*)GC_MALLOC(n+1); if(n>0) fread(b,1,n,f); b[n]=0; fclose(f); if(n>=3&&b[0]==0xEF&&b[1]==0xBB&&b[2]==0xBF){ memmove(b,b+3,(size_t)(n-3)+1); return (const char*)b; } if(n>=2&&b[0]==0xFF&&b[1]==0xFE){ return ail_u16to8(b+2,n-2,0); } if(n>=2&&b[0]==0xFE&&b[1]==0xFF){ return ail_u16to8(b+2,n-2,1); } return (const char*)b; }\n"
  out = out + "static int64_t write_file_c(const char* path, const char* content){ FILE* f=fopen(path,\"wb\"); if(!f) return 0; fwrite(content,1,strlen(content),f); fclose(f); return 1; }\n"
  // bytes — a binary buffer {len, data} distinct from str (may hold embedded \0).
  out = out + "typedef struct { int64_t len; const uint8_t* data; } ailang_bytes;\n"
  out = out + "static ailang_bytes str_to_bytes(const char* s){ ailang_bytes r; if(!s){ r.len=0; r.data=(const uint8_t*)\"\"; return r; } size_t n=strlen(s); r.len=(int64_t)n; r.data=(const uint8_t*)s; return r; }\n"
  out = out + "static const char* bytes_to_str(ailang_bytes b){ char* buf=(char*)GC_MALLOC((size_t)b.len+1); if(b.len>0) memcpy(buf,b.data,(size_t)b.len); buf[b.len]=0; return buf; }\n"
  out = out + "static int64_t bytes_at(ailang_bytes b, int64_t i){ if(i<0||i>=b.len) return 0; return (int64_t)b.data[i]; }\n"
  out = out + "static ailang_bytes bytes_slice(ailang_bytes b, int64_t lo, int64_t hi){ if(lo<0) lo=0; if(hi>b.len) hi=b.len; if(lo>hi) lo=hi; int64_t n=hi-lo; ailang_bytes r; r.len=n; uint8_t* buf=(uint8_t*)GC_MALLOC((size_t)(n>0?n:1)); if(n>0) memcpy(buf,b.data+lo,(size_t)n); r.data=buf; return r; }\n"
  out = out + "static ailang_bytes read_file_bytes(const char* path){ ailang_bytes r; r.len=0; r.data=(const uint8_t*)\"\"; FILE* f=fopen(path,\"rb\"); if(!f) return r; if(fseek(f,0,SEEK_END)!=0){ fclose(f); return r; } long sz=ftell(f); if(sz<0){ fclose(f); return r; } fseek(f,0,SEEK_SET); uint8_t* buf=(uint8_t*)GC_MALLOC((size_t)(sz>0?sz:1)); size_t got=fread(buf,1,(size_t)sz,f); fclose(f); r.len=(int64_t)got; r.data=buf; return r; }\n"
  out = out + "static int64_t write_file_bytes(const char* path, ailang_bytes b){ FILE* f=fopen(path,\"wb\"); if(!f) return 0; size_t want=(size_t)b.len; size_t got=b.len>0?fwrite(b.data,1,want,f):0; int closed=fclose(f); return (closed==0 && got==want)?1:0; }\n"
  out = out + "static void print_bytes(ailang_bytes b){ putchar(98); putchar(34); for(int64_t i=0;i<b.len;i++){ unsigned c=b.data[i]; if(c==34){ putchar(92); putchar(34); } else if(c==92){ putchar(92); putchar(92); } else if(c==10){ putchar(92); putchar(110); } else if(c==13){ putchar(92); putchar(114); } else if(c==9){ putchar(92); putchar(116); } else if(c>=32 && c<127){ putchar((int)c); } else { putchar(92); putchar(120); printf(\"%02x\", c); } } putchar(34); }\n"
  // ===== Phase 1 builtins: string / numeric / io (ported from the Rust =======
  // prelude; behaviour matches `ailangc` so sample output is identical). Bool
  // is i64 (0/1) per AiLang's model; `=0` terminates (no `'\0'` escaping).
  out = out + "static int64_t str_contains(const char* h, const char* n){ if(!h||!n) return 0; return strstr(h,n)!=0; }\n"
  out = out + "static int64_t starts_with(const char* s, const char* p){ if(!s||!p) return 0; size_t lp=strlen(p); return strncmp(s,p,lp)==0; }\n"
  out = out + "static int64_t ends_with(const char* s, const char* su){ if(!s||!su) return 0; size_t ls=strlen(s),lu=strlen(su); if(lu>ls) return 0; return memcmp(s+ls-lu,su,lu)==0; }\n"
  out = out + "static int64_t str_index_of(const char* h, const char* n){ if(!h||!n) return -1; const char* p=strstr(h,n); return p?(int64_t)(p-h):(int64_t)-1; }\n"
  out = out + "static const char* to_upper(const char* s){ if(!s) return \"\"; size_t n=strlen(s); char* o=(char*)GC_MALLOC(n+1); for(size_t i=0;i<n;i++){ unsigned char c=(unsigned char)s[i]; o[i]=(c>=97&&c<=122)?(char)(c-32):(char)c; } o[n]=0; return o; }\n"
  out = out + "static const char* to_lower(const char* s){ if(!s) return \"\"; size_t n=strlen(s); char* o=(char*)GC_MALLOC(n+1); for(size_t i=0;i<n;i++){ unsigned char c=(unsigned char)s[i]; o[i]=(c>=65&&c<=90)?(char)(c+32):(char)c; } o[n]=0; return o; }\n"
  out = out + "static const char* trim(const char* s){ if(!s) return \"\"; const char* p=s; while(*p==32||*p==9||*p==10||*p==13) p++; const char* e=s+strlen(s); while(e>p){ char c=e[-1]; if(c!=32&&c!=9&&c!=10&&c!=13) break; e--; } size_t n=(size_t)(e-p); char* o=(char*)GC_MALLOC(n+1); memcpy(o,p,n); o[n]=0; return o; }\n"
  out = out + "static const char* str_replace(const char* s, const char* a, const char* b){ if(!s||!a||!*a) return s?s:\"\"; if(!b) b=\"\"; size_t la=strlen(a),lb=strlen(b); size_t cnt=0; const char* p=s; while((p=strstr(p,a))!=0){ cnt++; p+=la; } size_t ls=strlen(s); size_t ol=ls+cnt*(lb>=la?lb-la:0)-cnt*(la>lb?la-lb:0); char* o=(char*)GC_MALLOC(ol+1); char* w=o; const char* r=s; while((p=strstr(r,a))!=0){ size_t bf=(size_t)(p-r); memcpy(w,r,bf); w+=bf; memcpy(w,b,lb); w+=lb; r=p+la; } size_t tl=strlen(r); memcpy(w,r,tl); w+=tl; *w=0; return o; }\n"
  out = out + "static const char* repeat(const char* s, int64_t n){ if(!s||n<=0) return \"\"; size_t one=strlen(s); size_t tot=one*(size_t)n; char* o=(char*)GC_MALLOC(tot+1); for(int64_t i=0;i<n;i++) memcpy(o+(size_t)i*one,s,one); o[tot]=0; return o; }\n"
  out = out + "static const char* pad_left(const char* s, int64_t w, const char* pad){ if(!s) s=\"\"; if(!pad||!*pad) pad=\" \"; size_t sl=strlen(s); if((int64_t)sl>=w){ char* o=(char*)GC_MALLOC(sl+1); memcpy(o,s,sl+1); return o; } size_t pl=strlen(pad); size_t need=(size_t)w-sl; char* o=(char*)GC_MALLOC((size_t)w+1); size_t i=0; while(i<need){ o[i]=pad[i%pl]; i++; } memcpy(o+need,s,sl); o[w]=0; return o; }\n"
  out = out + "static const char* pad_right(const char* s, int64_t w, const char* pad){ if(!s) s=\"\"; if(!pad||!*pad) pad=\" \"; size_t sl=strlen(s); if((int64_t)sl>=w){ char* o=(char*)GC_MALLOC(sl+1); memcpy(o,s,sl+1); return o; } size_t pl=strlen(pad); char* o=(char*)GC_MALLOC((size_t)w+1); memcpy(o,s,sl); size_t i=sl; while(i<(size_t)w){ o[i]=pad[(i-sl)%pl]; i++; } o[w]=0; return o; }\n"
  out = out + "static const char* chr(int64_t i){ char* o=(char*)GC_MALLOC(2); o[0]=(char)(i&255); o[1]=0; return o; }\n"
  out = out + "static int64_t ord(const char* s){ return (s&&*s)?(int64_t)(unsigned char)s[0]:0; }\n"
  out = out + "static int64_t str_to_bool(const char* s){ if(!s) return 0; if(strcmp(s,\"true\")==0) return 1; if(strcmp(s,\"True\")==0) return 1; if(strcmp(s,\"TRUE\")==0) return 1; if(strcmp(s,\"1\")==0) return 1; if(strcmp(s,\"yes\")==0) return 1; return 0; }\n"
  out = out + "static int64_t abs_i64(int64_t n){ return n<0?-n:n; }\n"
  out = out + "static double abs_f64(double x){ return x<0?-x:x; }\n"
  out = out + "static int64_t sign(int64_t n){ return (n>0)-(n<0); }\n"
  out = out + "static int64_t clamp(int64_t n, int64_t lo, int64_t hi){ if(n<lo) return lo; if(n>hi) return hi; return n; }\n"
  out = out + "static const char* read_line(void){ size_t cap=128,len=0; char* b=(char*)GC_MALLOC(cap); int c; while((c=fgetc(stdin))!=EOF&&c!=10){ if(len+1>=cap){ size_t nc=cap*2; char* nb=(char*)GC_MALLOC(nc); memcpy(nb,b,len); b=nb; cap=nc; } b[len++]=(char)c; } b[len]=0; if(len==0&&c==EOF) return \"\"; return b; }\n"
  out = out + "static const char* read_stdin(void){ size_t cap=1024,len=0; char* b=(char*)GC_MALLOC(cap); int c; while((c=fgetc(stdin))!=EOF){ if(len+1>=cap){ size_t nc=cap*2; char* nb=(char*)GC_MALLOC(nc); memcpy(nb,b,len); b=nb; cap=nc; } b[len++]=(char)c; } b[len]=0; return b; }\n"
  out = out + "static const char* get_env(const char* name){ const char* v=name?getenv(name):0; return v?v:\"\"; }\n"
  out = out + "static const char* format(const char* fmt, ...){ char b[1024]; va_list ap; va_start(ap,fmt); int n=vsnprintf(b,sizeof b,fmt?fmt:\"\",ap); va_end(ap); if(n<0) n=0; if(n>=(int)sizeof b) n=(int)sizeof b-1; char* o=(char*)GC_MALLOC((size_t)n+1); memcpy(o,b,(size_t)n+1); return o; }\n"
  // assert(cond,msg) → ail_assert_check: print to stderr + exit(1) when cond is
  // falsy, else return 0 (so it type-resolves as i64 in any position). The helper
  // name has no contiguous "assert(" substring, so the gate above stays clean.
  if needs_assert { out = out + "static int64_t ail_assert_check(int64_t c, const char* m){ if(!c){ fprintf(stderr, \"assertion failed: %s\\n\", m?m:\"\"); exit(1); } return 0; }\n" }
  // exe_dir() — directory of the running compiler, so `im "std/…"` finds the
  // bundled std with no env var (the path stripped to its dir; "" if unknown).
  if needs_exedir { out = out + "static const char* exe_dir(void){ char buf[4096]; buf[0]=0;\n#ifdef _WIN32\n unsigned long wn=GetModuleFileNameA(0,buf,(unsigned long)sizeof buf); if(wn==0||wn>=sizeof buf) return \"\";\n#elif defined(__APPLE__)\n unsigned int sz=(unsigned int)sizeof buf; if(_NSGetExecutablePath(buf,&sz)!=0) return \"\";\n#else\n long rn=readlink(\"/proc/self/exe\",buf,sizeof buf-1); if(rn<=0) return \"\"; buf[(size_t)rn]=0;\n#endif\n int i=(int)strlen(buf)-1; while(i>=0 && buf[i]!='/' && buf[i]!=92) i--; if(i<0) return \"\"; char* d=(char*)GC_MALLOC((size_t)i+1); memcpy(d,buf,(size_t)i); d[i]=0; return d; }\n" }
  // ===== Phase 2 optional native sections (gated; ported from prelude.c) =====
  if needs_time {
    out = out + "static int64_t now_ms(void){ struct timespec ts; if(clock_gettime(CLOCK_REALTIME,&ts)!=0) return 0; return (int64_t)ts.tv_sec*1000+(int64_t)(ts.tv_nsec/1000000); }\n"
    out = out + "static int64_t now_us(void){ struct timespec ts; if(clock_gettime(CLOCK_REALTIME,&ts)!=0) return 0; return (int64_t)ts.tv_sec*1000000+(int64_t)(ts.tv_nsec/1000); }\n"
    out = out + "static int64_t mono_ms(void){ struct timespec ts; if(clock_gettime(CLOCK_MONOTONIC,&ts)!=0) return 0; return (int64_t)ts.tv_sec*1000+(int64_t)(ts.tv_nsec/1000000); }\n"
    out = out + "static void sleep_ms(int64_t ms){ if(ms<=0) return; struct timespec ts; ts.tv_sec=(time_t)(ms/1000); ts.tv_nsec=(long)((ms%1000)*1000000); while(nanosleep(&ts,&ts)==-1){} }\n"
    out = out + "static const char* time_iso(int64_t ms){ time_t sec=(time_t)(ms/1000); struct tm tmv;\n#ifdef _WIN32\n if(gmtime_s(&tmv,&sec)!=0) return \"\";\n#else\n if(!gmtime_r(&sec,&tmv)) return \"\";\n#endif\n char* buf=(char*)GC_MALLOC(32); size_t n=strftime(buf,32,\"%Y-%m-%dT%H:%M:%SZ\",&tmv); if(n==0){ buf[0]=0; } return buf; }\n"
  }
  if needs_sock {
    out = out + "#ifndef _WIN32\n"
    out = out + "static int64_t tcp_listen(const char* host, int64_t port){ if(!host||port<=0||port>65535) return -1; int fd=socket(AF_INET,SOCK_STREAM,0); if(fd<0) return -1; int yes=1; setsockopt(fd,SOL_SOCKET,SO_REUSEADDR,&yes,sizeof(yes)); struct sockaddr_in addr; memset(&addr,0,sizeof(addr)); addr.sin_family=AF_INET; addr.sin_port=htons((uint16_t)port); if(host[0]==0||strcmp(host,\"0.0.0.0\")==0){ addr.sin_addr.s_addr=htonl(INADDR_ANY); } else if(inet_pton(AF_INET,host,&addr.sin_addr)!=1){ close(fd); return -1; } if(bind(fd,(struct sockaddr*)&addr,sizeof(addr))<0){ close(fd); return -1; } if(listen(fd,128)<0){ close(fd); return -1; } return (int64_t)fd; }\n"
    out = out + "static int64_t tcp_accept(int64_t fd){ struct sockaddr_in addr; socklen_t len=sizeof(addr); int client=accept((int)fd,(struct sockaddr*)&addr,&len); if(client<0) return -1; return (int64_t)client; }\n"
    out = out + "static int64_t tcp_connect(const char* host, int64_t port){ if(!host||port<=0||port>65535) return -1; int fd=socket(AF_INET,SOCK_STREAM,0); if(fd<0) return -1; struct sockaddr_in addr; memset(&addr,0,sizeof(addr)); addr.sin_family=AF_INET; addr.sin_port=htons((uint16_t)port); if(inet_pton(AF_INET,host,&addr.sin_addr)!=1){ struct addrinfo hints; memset(&hints,0,sizeof(hints)); hints.ai_family=AF_INET; hints.ai_socktype=SOCK_STREAM; struct addrinfo* res=0; if(getaddrinfo(host,0,&hints,&res)!=0||!res){ close(fd); return -1; } addr.sin_addr=((struct sockaddr_in*)res->ai_addr)->sin_addr; freeaddrinfo(res); } if(connect(fd,(struct sockaddr*)&addr,sizeof(addr))<0){ close(fd); return -1; } return (int64_t)fd; }\n"
    out = out + "static int64_t sock_send(int64_t fd, ailang_bytes b){ if(fd<0) return -1; if(b.len==0) return 0; ssize_t n=send((int)fd,b.data,(size_t)b.len,0); return (int64_t)n; }\n"
    out = out + "static int64_t sock_send_str(int64_t fd, const char* s){ if(fd<0||!s) return -1; size_t len=strlen(s); if(len==0) return 0; ssize_t n=send((int)fd,s,len,0); return (int64_t)n; }\n"
    out = out + "static ailang_bytes sock_recv(int64_t fd, int64_t max){ ailang_bytes r; r.len=0; r.data=(const uint8_t*)\"\"; if(fd<0||max<=0) return r; uint8_t* buf=(uint8_t*)GC_MALLOC((size_t)max); ssize_t n=recv((int)fd,buf,(size_t)max,0); if(n<=0) return r; r.len=(int64_t)n; r.data=buf; return r; }\n"
    out = out + "static int64_t sock_close(int64_t fd){ if(fd<0) return 0; return (int64_t)close((int)fd); }\n"
    out = out + "#endif\n"
  }
  if needs_proc {
    out = out + "#ifndef _WIN32\n"
    out = out + "static int64_t proc_fork(void){ pid_t p=fork(); return (int64_t)p; }\n"
    out = out + "static int64_t proc_getpid(void){ return (int64_t)getpid(); }\n"
    out = out + "static void proc_no_zombies(void){ struct sigaction sa; memset(&sa,0,sizeof(sa)); sa.sa_handler=SIG_IGN; sigemptyset(&sa.sa_mask); sa.sa_flags=SA_NOCLDWAIT; sigaction(SIGCHLD,&sa,0); }\n"
    out = out + "static int64_t proc_reap(void){ int64_t n=0; while(waitpid(-1,0,WNOHANG)>0) n++; return n; }\n"
    out = out + "#endif\n"
  }
  if needs_regex {
    out = out + "#ifndef _WIN32\n"
    out = out + "static int64_t regex_match(const char* pat, const char* text){ if(!pat||!text) return 0; regex_t re; if(regcomp(&re,pat,REG_EXTENDED|REG_NOSUB)!=0) return 0; int rc=regexec(&re,text,0,0,0); regfree(&re); return rc==0; }\n"
    out = out + "static const char* regex_find(const char* pat, const char* text){ if(!pat||!text) return \"\"; regex_t re; if(regcomp(&re,pat,REG_EXTENDED)!=0) return \"\"; regmatch_t m; int rc=regexec(&re,text,1,&m,0); regfree(&re); if(rc!=0||m.rm_so<0) return \"\"; size_t len=(size_t)(m.rm_eo-m.rm_so); char* o=(char*)GC_MALLOC(len+1); memcpy(o,text+m.rm_so,len); o[len]=0; return o; }\n"
    out = out + "#endif\n"
  }
  // ===== Phase 3 optional native sections: TLS (OpenSSL) + Postgres (libpq) =====
  if needs_tls {
    out = out + "#ifndef _WIN32\n"
    out = out + "static int ailang_tls_init_done_=0;\n"
    out = out + "static void ailang_tls_init_(void){ if(ailang_tls_init_done_) return; SSL_library_init(); SSL_load_error_strings(); OpenSSL_add_ssl_algorithms(); ailang_tls_init_done_=1; }\n"
    out = out + "static int64_t tls_server_ctx(const char* cert, const char* key){ ailang_tls_init_(); SSL_CTX* ctx=SSL_CTX_new(TLS_server_method()); if(!ctx) return -1; if(!cert||SSL_CTX_use_certificate_file(ctx,cert,SSL_FILETYPE_PEM)<=0){ SSL_CTX_free(ctx); return -1; } if(!key||SSL_CTX_use_PrivateKey_file(ctx,key,SSL_FILETYPE_PEM)<=0){ SSL_CTX_free(ctx); return -1; } return (int64_t)(intptr_t)ctx; }\n"
    out = out + "static int64_t tls_client_ctx(void){ ailang_tls_init_(); SSL_CTX* ctx=SSL_CTX_new(TLS_client_method()); if(!ctx) return -1; return (int64_t)(intptr_t)ctx; }\n"
    out = out + "static void tls_free_ctx(int64_t ctx){ if(ctx>0) SSL_CTX_free((SSL_CTX*)(intptr_t)ctx); }\n"
    out = out + "static int64_t tls_accept(int64_t ctx, int64_t fd){ if(ctx<=0||fd<0) return -1; SSL* ssl=SSL_new((SSL_CTX*)(intptr_t)ctx); if(!ssl) return -1; SSL_set_fd(ssl,(int)fd); if(SSL_accept(ssl)<=0){ SSL_free(ssl); return -1; } return (int64_t)(intptr_t)ssl; }\n"
    out = out + "static int64_t tls_connect_fd(int64_t ctx, int64_t fd){ if(ctx<=0||fd<0) return -1; SSL* ssl=SSL_new((SSL_CTX*)(intptr_t)ctx); if(!ssl) return -1; SSL_set_fd(ssl,(int)fd); if(SSL_connect(ssl)<=0){ SSL_free(ssl); return -1; } return (int64_t)(intptr_t)ssl; }\n"
    out = out + "static int64_t tls_connect_host(int64_t ctx, int64_t fd, const char* host){ if(ctx<=0||fd<0) return -1; SSL* ssl=SSL_new((SSL_CTX*)(intptr_t)ctx); if(!ssl) return -1; SSL_set_fd(ssl,(int)fd); if(host&&*host) SSL_set_tlsext_host_name(ssl,host); if(SSL_connect(ssl)<=0){ SSL_free(ssl); return -1; } return (int64_t)(intptr_t)ssl; }\n"
    out = out + "static int64_t tls_send(int64_t ssl, ailang_bytes b){ if(ssl<=0) return -1; if(b.len==0) return 0; int n=SSL_write((SSL*)(intptr_t)ssl,b.data,(int)b.len); return (int64_t)n; }\n"
    out = out + "static int64_t tls_send_str(int64_t ssl, const char* s){ if(ssl<=0||!s) return -1; size_t len=strlen(s); if(len==0) return 0; int n=SSL_write((SSL*)(intptr_t)ssl,s,(int)len); return (int64_t)n; }\n"
    out = out + "static ailang_bytes tls_recv(int64_t ssl, int64_t max){ ailang_bytes r; r.len=0; r.data=(const uint8_t*)\"\"; if(ssl<=0||max<=0) return r; uint8_t* buf=(uint8_t*)GC_MALLOC((size_t)max); int n=SSL_read((SSL*)(intptr_t)ssl,buf,(int)max); if(n<=0) return r; r.len=(int64_t)n; r.data=buf; return r; }\n"
    out = out + "static void tls_close(int64_t ssl){ if(ssl>0){ SSL_shutdown((SSL*)(intptr_t)ssl); SSL_free((SSL*)(intptr_t)ssl); } }\n"
    out = out + "static const char* tls_error(void){ unsigned long e=ERR_peek_error(); if(e==0) return \"\"; char* buf=(char*)GC_MALLOC(256); ERR_error_string_n(e,buf,256); return buf; }\n"
    out = out + "static ailang_bytes sha1(const char* s){ ailang_bytes r; uint8_t* buf=(uint8_t*)GC_MALLOC(20); SHA1((const unsigned char*)(s?s:\"\"), s?strlen(s):0, buf); r.len=20; r.data=buf; return r; }\n"
    out = out + "#endif\n"
  }
  if needs_hmac {
    out = out + "#ifndef _WIN32\n"
    out = out + "static ailang_bytes hmac_sha256(ailang_bytes key, ailang_bytes msg){ unsigned char* b=(unsigned char*)GC_MALLOC(32); unsigned int n=32; HMAC(EVP_sha256(), key.data, (int)key.len, msg.data, (size_t)msg.len, b, &n); ailang_bytes r; r.len=32; r.data=b; return r; }\n"
    out = out + "#endif\n"
  }
  if needs_pg {
    out = out + "#ifndef _WIN32\n"
    out = out + "static int64_t pg_connect(const char* conninfo){ PGconn* c=PQconnectdb(conninfo?conninfo:\"\"); return (int64_t)(intptr_t)c; }\n"
    out = out + "static int64_t pg_status(int64_t conn){ if(conn==0) return -1; return (int64_t)PQstatus((PGconn*)(intptr_t)conn); }\n"
    out = out + "static const char* pg_error(int64_t conn){ if(conn==0) return \"(null connection)\"; const char* msg=PQerrorMessage((PGconn*)(intptr_t)conn); return msg?msg:\"\"; }\n"
    out = out + "static void pg_close(int64_t conn){ if(conn!=0) PQfinish((PGconn*)(intptr_t)conn); }\n"
    out = out + "static int64_t pg_exec(int64_t conn, const char* sql){ if(conn==0||!sql) return 0; PGresult* r=PQexec((PGconn*)(intptr_t)conn,sql); return (int64_t)(intptr_t)r; }\n"
    out = out + "static int64_t pg_ok(int64_t res){ if(res==0) return 0; int s=PQresultStatus((PGresult*)(intptr_t)res); return s==PGRES_COMMAND_OK||s==PGRES_TUPLES_OK; }\n"
    out = out + "static const char* pg_result_error(int64_t res){ if(res==0) return \"(null result)\"; const char* m=PQresultErrorMessage((PGresult*)(intptr_t)res); return m?m:\"\"; }\n"
    out = out + "static void pg_clear(int64_t res){ if(res!=0) PQclear((PGresult*)(intptr_t)res); }\n"
    out = out + "static int64_t pg_nrows(int64_t res){ if(res==0) return 0; return (int64_t)PQntuples((PGresult*)(intptr_t)res); }\n"
    out = out + "static int64_t pg_ncols(int64_t res){ if(res==0) return 0; return (int64_t)PQnfields((PGresult*)(intptr_t)res); }\n"
    out = out + "static const char* pg_value(int64_t res, int64_t row, int64_t col){ if(res==0) return \"\"; const char* v=PQgetvalue((PGresult*)(intptr_t)res,(int)row,(int)col); if(!v) return \"\"; size_t n=strlen(v); char* o=(char*)GC_MALLOC(n+1); memcpy(o,v,n+1); return o; }\n"
    out = out + "static int64_t pg_isnull(int64_t res, int64_t row, int64_t col){ if(res==0) return 0; return PQgetisnull((PGresult*)(intptr_t)res,(int)row,(int)col)!=0; }\n"
    out = out + "static const char* pg_col_name(int64_t res, int64_t col){ if(res==0) return \"\"; const char* nm=PQfname((PGresult*)(intptr_t)res,(int)col); if(!nm) return \"\"; size_t l=strlen(nm); char* o=(char*)GC_MALLOC(l+1); memcpy(o,nm,l+1); return o; }\n"
    out = out + "static int64_t pg_affected(int64_t res){ if(res==0) return 0; const char* s=PQcmdTuples((PGresult*)(intptr_t)res); if(!s||!*s) return 0; return (int64_t)atoll(s); }\n"
    out = out + "static const char* pg_escape(int64_t conn, const char* s){ if(conn==0||!s) return \"''\"; char* esc=PQescapeLiteral((PGconn*)(intptr_t)conn,s,strlen(s)); if(!esc) return \"''\"; size_t n=strlen(esc); char* o=(char*)GC_MALLOC(n+1); memcpy(o,esc,n+1); PQfreemem(esc); return o; }\n"
    out = out + "#endif\n"
  }
  // MySQL prelude slot — filled below ONLY when a real myq_ call was emitted. The
  // marker is split ("/*@MY"+"SQL@*/") so the contiguous token never appears in the
  // compiler's own string data (else the replace below would corrupt it).
  out = out + "/*@MY" + "SQL@*/"
  // SQLite prelude slot — same opt-in mold as mysql (split marker, filled below).
  out = out + "/*@SQ" + "LITE@*/"
  out = out + "static int g_argc=0; static char** g_argv=0;\n"
  // Closure value type — only when the program actually has first-class lambdas,
  // so the existing samples + main.ail emit byte-identical C (fixpoint safe).
  // Also forced on for threads: thread_spawn takes a closure_t by value.
  if len(base.lams) > 0 || needs_thread { out = out + "typedef struct { void* fn; void* env; } closure_t;\n" }
  // OS threads + mutex (pthread, POSIX-only). A thread handle is a GC-allocated
  // {pthread_t, closure_t} block returned as an i64 — the handle keeps the
  // closure (fn+env) reachable for the GC while the thread runs, so no extra
  // root bookkeeping is needed. A `fn()->i64` lambda already lowers to
  // __lam_<id>(void* env, …), exactly a pthread start-routine, so the trampoline
  // just calls clo.fn(clo.env); thread_join returns the thread's i64 result.
  // Mutexes are pthread_mutex_t* behind an i64 handle (Boehm retains it
  // conservatively, like the TLS/PG handles above).
  if needs_thread {
    out = out + "#ifndef _WIN32\n"
    out = out + "typedef struct { pthread_t th; closure_t clo; } ail_thread_t;\n"
    out = out + "static void* ail_thread_tramp(void* p){ closure_t* c=(closure_t*)p; return (void*)(intptr_t)((int64_t(*)(void*))c->fn)(c->env); }\n"
    out = out + "static int64_t thread_spawn(closure_t clo){ ail_thread_t* t=(ail_thread_t*)GC_MALLOC(sizeof(ail_thread_t)); t->clo=clo; if(pthread_create(&t->th,0,ail_thread_tramp,&t->clo)!=0) return 0; return (int64_t)(intptr_t)t; }\n"
    out = out + "static int64_t thread_join(int64_t h){ if(h==0) return 0; ail_thread_t* t=(ail_thread_t*)(intptr_t)h; void* rv=0; pthread_join(t->th,&rv); return (int64_t)(intptr_t)rv; }\n"
    out = out + "static int64_t mutex_new(void){ pthread_mutex_t* m=(pthread_mutex_t*)GC_MALLOC(sizeof(pthread_mutex_t)); pthread_mutex_init(m,0); return (int64_t)(intptr_t)m; }\n"
    out = out + "static int64_t mutex_lock(int64_t h){ if(h) pthread_mutex_lock((pthread_mutex_t*)(intptr_t)h); return 0; }\n"
    out = out + "static int64_t mutex_unlock(int64_t h){ if(h) pthread_mutex_unlock((pthread_mutex_t*)(intptr_t)h); return 0; }\n"
    // Bounded blocking channel — a ring buffer of i64 words (which hold ints or
    // any pointer-sized value: str/struct payloads ride as pointers, and the
    // buffer is a GC object so Boehm scans those payloads). Two condvars give
    // backpressure: senders block when full, receivers block when empty.
    // chan_recv returns 0 on a closed+drained channel (the i64-channel sentinel).
    out = out + "typedef struct { pthread_mutex_t m; pthread_cond_t ne, nf; int64_t* buf; int64_t cap, head, tail, cnt; int closed; } ail_chan_t;\n"
    out = out + "static int64_t chan_new(int64_t cap){ if(cap<1) cap=1; ail_chan_t* c=(ail_chan_t*)GC_MALLOC(sizeof(ail_chan_t)); pthread_mutex_init(&c->m,0); pthread_cond_init(&c->ne,0); pthread_cond_init(&c->nf,0); c->buf=(int64_t*)GC_MALLOC(sizeof(int64_t)*(size_t)cap); c->cap=cap; c->head=0; c->tail=0; c->cnt=0; c->closed=0; return (int64_t)(intptr_t)c; }\n"
    out = out + "static int64_t chan_send(int64_t h, int64_t v){ ail_chan_t* c=(ail_chan_t*)(intptr_t)h; if(!c) return 0; pthread_mutex_lock(&c->m); while(c->cnt==c->cap && !c->closed) pthread_cond_wait(&c->nf,&c->m); if(c->closed){ pthread_mutex_unlock(&c->m); return 0; } c->buf[c->tail]=v; c->tail=(c->tail+1)%c->cap; c->cnt++; pthread_cond_signal(&c->ne); pthread_mutex_unlock(&c->m); return 1; }\n"
    out = out + "static int64_t chan_recv(int64_t h){ ail_chan_t* c=(ail_chan_t*)(intptr_t)h; if(!c) return 0; pthread_mutex_lock(&c->m); while(c->cnt==0 && !c->closed) pthread_cond_wait(&c->ne,&c->m); if(c->cnt==0 && c->closed){ pthread_mutex_unlock(&c->m); return 0; } int64_t v=c->buf[c->head]; c->head=(c->head+1)%c->cap; c->cnt--; pthread_cond_signal(&c->nf); pthread_mutex_unlock(&c->m); return v; }\n"
    out = out + "static int64_t chan_close(int64_t h){ ail_chan_t* c=(ail_chan_t*)(intptr_t)h; if(!c) return 0; pthread_mutex_lock(&c->m); c->closed=1; pthread_cond_broadcast(&c->ne); pthread_cond_broadcast(&c->nf); pthread_mutex_unlock(&c->m); return 0; }\n"
    out = out + "#endif\n"
  }
  out = out + "\n"

  // ===== 4-phase aggregate emission (order matters for incomplete types) =====
  // Phase 1: forward declarations of every aggregate (struct + enum), so an
  // array/map typedef below can hold a pointer to any of them.
  si = 0
  lp si < len(structs) { out = out + gen_struct_fwd(structs[si]); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_enum_fwd(enums[ei]); ei += 1 }
  out = out + "\n"

  // Phase 2: array/map typedefs (they hold `T*`, so a fwd decl suffices). One
  // array runtime per element type: i64, str, each struct, each enum.
  out = out + gen_arr_typedef("i64", "int64_t")
  out = out + gen_arr_typedef("str", "const char*")
  out = out + gen_arr_typedef("f64", "double")
  si = 0
  lp si < len(structs) { out = out + gen_arr_typedef(structs[si].name, "s_" + structs[si].name); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_arr_typedef(enums[ei].name, "s_" + enums[ei].name); ei += 1 }
  // Map runtime universe: scalar keys × (scalar ∪ struct ∪ enum) values, mirroring
  // arr_<T>'s per-type emission. Built once here, reused in phases 3 and 4.
  mu mapkeys:[str] := ["str", "i64", "f64"]
  mu mapvals:[str] := ["i64", "str", "f64"]
  mu mvs := 0
  lp mvs < len(structs) { mapvals = push(mapvals, structs[mvs].name); mvs += 1 }
  mu mve := 0
  lp mve < len(enums) { mapvals = push(mapvals, enums[mve].name); mve += 1 }
  // Map-of-array universe ({str:[T]}/{i64:[T]} — group_by et al.): str/i64 keys
  // only (f64 keys have no grouping use), array values over every arr_<T>.
  mu arrkeys:[str] := ["str", "i64"]
  mu arrvals:[str] := ["[i64]", "[str]", "[f64]"]
  mu avs := 0
  lp avs < len(structs) { arrvals = push(arrvals, "[" + structs[avs].name + "]"); avs += 1 }
  mu ave := 0
  lp ave < len(enums) { arrvals = push(arrvals, "[" + enums[ave].name + "]"); ave += 1 }
  out = out + gen_map_fwds_all(mapkeys, mapvals)
  out = out + gen_map_fwds_all(arrkeys, arrvals)
  out = out + "\n"

  // Phase 3: aggregate bodies (now an enum/struct body may embed `arr_<T>` by
  // value and box self-references).
  si = 0
  lp si < len(structs) { out = out + gen_struct_body(structs[si]); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_enum_body(enums[ei]); ei += 1 }
  // map node bodies (hold the value by value, so they need the aggregates above).
  out = out + gen_map_nodes_all(mapkeys, mapvals)
  out = out + gen_map_nodes_all(arrkeys, arrvals)
  out = out + "\n"

  // vtable types + forward decls for classes with virtual methods (B3). The
  // `extern` decl lets the ctor (phase 4) reference &__vtbl_<C> before the
  // instance is defined (after the fn prototypes — it points at f_<impl>_<m>).
  mu vt1 := 0
  lp vt1 < len(classes) {
    if has(base.evar, "@class.hasvt." + classes[vt1].name) {
      out = out + gen_vtable_typedef(&base, classes[vt1].name)
      out = out + "extern const vt_" + classes[vt1].name + " __vtbl_" + classes[vt1].name + ";\n"
    }
    vt1 += 1
  }

  // Phase 4: array/map helpers (need complete element types) + aggregate ctors.
  out = out + gen_arr_helpers("i64", "int64_t")
  out = out + gen_arr_helpers("str", "const char*")
  out = out + gen_arr_helpers("f64", "double")
  // array pretty-printers (match ailangc: i64 raw, str quoted via putchar(34) to
  // dodge AiLang→C quote-escaping; `, ` separator; empty → `[]`).
  out = out + "static void print_arr_i64(arr_i64 a){ printf(\"[\"); for(int64_t i=0;i<a.len;i++){ if(i>0) printf(\", \"); printf(\"%lld\",(long long)a.data[i]); } printf(\"]\"); }\n"
  out = out + "static void print_arr_str(arr_str a){ printf(\"[\"); for(int64_t i=0;i<a.len;i++){ if(i>0) printf(\", \"); putchar(34); printf(\"%s\", a.data[i] ? a.data[i] : \"\"); putchar(34); } printf(\"]\"); }\n"
  // `args()` → argv[1..] as [str] (depends on arr_str helpers just emitted).
  out = out + "static arr_str ailang_args(void){ arr_str a = arr_str_new(); for(int i=1;i<g_argc;i++) a = arr_str_push(a, g_argv[i]); return a; }\n"
  // split(s, sep) → [str]; empty sep → [s]; uses arr_str runtime just emitted.
  out = out + "static arr_str split(const char* s, const char* sep){ arr_str a=arr_str_new(); if(!s) s=\"\"; if(!sep||!*sep){ return arr_str_push(a,s); } size_t ls=strlen(sep); const char* r=s; const char* p; while((p=strstr(r,sep))!=0){ size_t n=(size_t)(p-r); char* pc=(char*)GC_MALLOC(n+1); memcpy(pc,r,n); pc[n]=0; a=arr_str_push(a,pc); r=p+ls; } size_t n=strlen(r); char* pc=(char*)GC_MALLOC(n+1); memcpy(pc,r,n+1); a=arr_str_push(a,pc); return a; }\n"
  // Filesystem helpers live HERE (phase 4), not in the phase-2 prelude:
  // fs_list_dir returns arr_str, whose typedef + push only exist from phase 4 on.
  if needs_fs {
    out = out + "#ifndef _WIN32\n"
    out = out + "static int64_t fs_mkdir(const char* p){ if(!p||!*p) return 0; return mkdir(p,0777)==0; }\n"
    out = out + "static int64_t fs_rmdir(const char* p){ if(!p||!*p) return 0; return rmdir(p)==0; }\n"
    out = out + "static int64_t fs_unlink(const char* p){ if(!p||!*p) return 0; return unlink(p)==0; }\n"
    out = out + "static int64_t fs_rename(const char* a, const char* b){ if(!a||!b) return 0; return rename(a,b)==0; }\n"
    out = out + "static int64_t fs_exists(const char* p){ struct stat st; if(!p) return 0; return stat(p,&st)==0; }\n"
    out = out + "static int64_t fs_is_dir(const char* p){ struct stat st; if(!p||stat(p,&st)!=0) return 0; return S_ISDIR(st.st_mode)!=0; }\n"
    out = out + "static int64_t fs_size(const char* p){ struct stat st; if(!p||stat(p,&st)!=0) return -1; return (int64_t)st.st_size; }\n"
    out = out + "static int64_t fs_mtime(const char* p){ struct stat st; if(!p||stat(p,&st)!=0) return -1; return (int64_t)st.st_mtime; }\n"
    out = out + "static arr_str fs_list_dir(const char* p){ arr_str a=arr_str_new(); DIR* d=opendir(p?p:\"\"); if(!d) return a; struct dirent* e; while((e=readdir(d))!=0){ if(strcmp(e->d_name,\".\")==0||strcmp(e->d_name,\"..\")==0) continue; size_t n=strlen(e->d_name); char* o=(char*)GC_MALLOC(n+1); memcpy(o,e->d_name,n+1); a=arr_str_push(a,o); } closedir(d); return a; }\n"
    out = out + "#endif\n"
  }
  // pg_exec_params — Postgres prepared-statement exec (PQexecParams). Lives HERE
  // (phase 4), not in the phase-3 pg block, because it takes an arr_str of values
  // and the array runtime only exists from here on (same reason as fs_list_dir).
  // Values are passed as text params ($1,$2,…) → bound, never interpolated.
  if needs_pg {
    out = out + "#ifndef _WIN32\n"
    out = out + "static int64_t pg_exec_params(int64_t conn, const char* sql, arr_str params){ if(conn==0||!sql) return 0; int n=(int)params.len; const char** vals=(const char**)GC_MALLOC(sizeof(char*)*(n>0?n:1)); for(int i=0;i<n;i++) vals[i]=params.data[i]?params.data[i]:\"\"; PGresult* r=PQexecParams((PGconn*)(intptr_t)conn,sql,n,0,vals,0,0,0); return (int64_t)(intptr_t)r; }\n"
    out = out + "#endif\n"
  }
  // MySQL prepared-statement helpers (myq_exec_params/myq_query_one_params) take an
  // arr_str, so — like pg_exec_params — they belong in phase 4 (after the array
  // runtime), NOT in the phase-2 @uses.mysql slot (which lands before arr_str). A
  // SECOND split placeholder here is filled post-body in the same @uses.mysql gate.
  out = out + "/*@MY" + "PARAMS@*/"
  si = 0
  lp si < len(structs) { out = out + gen_arr_helpers(structs[si].name, "s_" + structs[si].name); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_arr_helpers(enums[ei].name, "s_" + enums[ei].name); ei += 1 }
  out = out + gen_map_helpers_all(mapkeys, mapvals)
  out = out + gen_map_helpers_all(arrkeys, arrvals)   // after print_arr_* (their printers call them)
  // `!T` result runtimes: scalar `res_i64`/`res_str` + one per struct.
  out = out + gen_res("i64", "int64_t")
  out = out + gen_res("str", "const char*")
  si = 0
  lp si < len(structs) { out = out + gen_res(structs[si].name, "s_" + structs[si].name); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_res(enums[ei].name, "s_" + enums[ei].name); ei += 1 }   // !Enum too
  si = 0
  lp si < len(structs) { out = out + gen_struct_ctor(structs[si]); si += 1 }
  si = 0
  lp si < len(structs) { out = out + gen_struct_printer(structs[si]); si += 1 }
  ei = 0
  lp ei < len(enums) { out = out + gen_enum_ctors(enums[ei]); ei += 1 }
  out = out + "\n"

  // On-demand tuple structs: one `tup_<suffix>` per distinct tuple-typed fn
  // return — the MVP producer (a `-> (T,U)` fn, consumed by `a, b := f()`).
  // Emitted before fn signatures (which reference `tup_*` by value). main.ail
  // itself returns no tuples, so nothing is emitted → fixpoint-safe.
  mu tup_seen:[str] := []
  mu ti := 0
  lp ti < len(funcs) {
    rt2 := base.frets[funcs[ti].name]
    if is_tuple_ann(rt2) {
      suf := tuple_suffix(rt2)
      mu found := false
      mu tk := 0
      lp tk < len(tup_seen) { if tup_seen[tk] == suf { found = true } tk += 1 }
      if found == false {
        tup_seen = push(tup_seen, suf)
        out = out + gen_tuple_typedef(rt2)
      }
    }
    ti += 1
  }

  // extern wrappers (libc passthrough), then fn forward declarations.
  mu xj := 0
  lp xj < len(externs) { out = out + gen_extern(externs[xj]); xj += 1 }
  if len(externs) > 0 { out = out + "\n" }
  mu i := 0
  lp i < len(funcs) { out = out + gen_sig(funcs[i], base.frets[funcs[i].name]) + ";\n"; i += 1 }
  out = out + "\n"

  // vtable instances (B3) — emitted after the fn prototypes they point at.
  mu vt2 := 0
  lp vt2 < len(classes) {
    if has(base.evar, "@class.hasvt." + classes[vt2].name) { out = out + gen_vtable_instance(&base, classes[vt2].name) }
    vt2 += 1
  }
  if len(classes) > 0 { out = out + "\n" }

  // Lifted lambdas (gated): env structs (fields use fully-defined phase-4
  // aggregates), then `__lam_<id>` fwd decls, then bodies. Driven by the ordered
  // `base.lams` so emission is deterministic (no map iteration).
  if len(base.lams) > 0 {
    mu lm := 0
    lp lm < len(base.lams) { out = out + gen_env_struct(&base, base.lams[lm]); lm += 1 }
    lm = 0
    lp lm < len(base.lams) { out = out + gen_lam_sig(base.lams[lm]) + ";\n"; lm += 1 }
    lm = 0
    lp lm < len(base.lams) { out = out + gen_lifted_body(&base, base.lams[lm]); lm += 1 }
    out = out + "\n"
  }

  // function bodies — each gets a fresh Syms sharing the base struct/ctor/fret
  // maps, then its own params seeded.
  i = 0
  lp i < len(funcs) {
    f := funcs[i]
    // seed_fn: fresh per-fn var map + params + `@ret`. Shared with the closure
    // collection pass so a lambda's capture types match what the body emits.
    mu sy := seed_fn(&base, f)
    fb := stamp_empty_maps(&sy, f.body)          // infer un-annotated `m := {}`
    sy = seed_fn(&base, f)                        // discard inference's scratch typing
    decls := hoist_decls(&sy, fb, "    ")
    // mark the enclosing class (if f is a method) so `super.m()` in the body
    // resolves to the parent impl; cleared otherwise.
    if has(sy.evar, "@mclass." + f.name) { sy.evar["@curclass"] = sy.evar["@mclass." + f.name] } el { sy.evar["@curclass"] = "" }
    out = out + gen_sig(f, base.frets[f.name]) + " {\n" + decls + gen_fn_body(&sy, fb, base.frets[f.name], "    ") + "}\n\n"
    i += 1
  }

  // main() — capture argv so `args()` can return argv[1..].
  mu msy := Syms({}, base.fld, base.ctors, base.frets, base.evar, base.vft, base.gfns, base.lams, base.errc)
  mmains := stamp_empty_maps(&msy, mains)        // infer un-annotated `m := {}`
  msy = Syms({}, base.fld, base.ctors, base.frets, base.evar, base.vft, base.gfns, base.lams, base.errc)
  mdecls := hoist_decls(&msy, mmains, "    ")
  // A user `fn main()` is a normal function (emitted `f_main`), not a top-level
  // stmt, so it'd never run. Call it after any top-level stmts. Nullary only;
  // main.ail uses top-level stmts (no `fn main`) so this stays "" → fixpoint-safe.
  mu maincall := ""
  mu mk := 0
  lp mk < len(funcs) { if funcs[mk].name == "main" && len(funcs[mk].params) == 0 { maincall = "    f_main();\n" } mk += 1 }
  if libmode {
    // A shared library has no `main`. A load-time constructor inits Boehm GC so
    // the host needs no GC_INIT. Top-level statements are dropped: a top-level
    // `mu` binding is main-local and unobservable to any exported fn, so nothing
    // persistent is lost — we just note if the file had any (likely a demo/CLI).
    if len(mains) > 0 { println("note: " + int_to_str(len(mains)) + " top-level statement(s) ignored in lib mode (only functions are compiled into a library)") }
    out = out + "__attribute__((constructor)) static void __ail_lib_init(void){ GC_INIT(); }\n"
  } el {
    out = out + "int main(int argc, char** argv){\n    GC_INIT();\n    g_argc=argc; g_argv=argv;\n" + mdecls + gen_stmts(&msy, mmains, "    ") + maincall + "    return 0;\n}\n"
  }

  // MySQL is opt-in: fill the slot with the libmysqlclient wrappers (+ header) only
  // when a real myq_ call set @uses.mysql, and add "mysqlclient" to the link marker.
  // The compiler itself never calls myq_, so its self-compile stays mysql-free and
  // builds with NO libmysqlclient. (pat is split so it doesn't match string data.)
  pat := "/*@MY" + "SQL@*/"
  ppat := "/*@MY" + "PARAMS@*/"        // phase-4 slot for the arr_str-taking prepared-stmt helpers
  mu mlib := libline
  if has(base.evar, "@uses.mysql") {
    mu mp := "#ifndef _WIN32\n#include <mysql/mysql.h>\n"
    mp = mp + "static int64_t myq_conn(const char* host, const char* user, const char* pass, const char* db, int64_t port){ MYSQL* m=mysql_init(NULL); if(!m) return 0; if(!mysql_real_connect(m,host,user,pass,db,(unsigned int)port,NULL,0)){ mysql_close(m); return 0; } return (int64_t)(intptr_t)m; }\n"
    mp = mp + "static int64_t myq_query(int64_t c, const char* sql){ if(c==0||!sql) return -1; return (int64_t)mysql_query((MYSQL*)(intptr_t)c, sql); }\n"
    mp = mp + "static int64_t myq_store(int64_t c){ if(c==0) return 0; MYSQL_RES* r=mysql_store_result((MYSQL*)(intptr_t)c); return (int64_t)(intptr_t)r; }\n"
    mp = mp + "static int64_t myq_nrows(int64_t res){ if(res==0) return 0; return (int64_t)mysql_num_rows((MYSQL_RES*)(intptr_t)res); }\n"
    mp = mp + "static int64_t myq_nfields(int64_t res){ if(res==0) return 0; return (int64_t)mysql_num_fields((MYSQL_RES*)(intptr_t)res); }\n"
    mp = mp + "static int64_t myq_fetch(int64_t res){ if(res==0) return 0; MYSQL_ROW row=mysql_fetch_row((MYSQL_RES*)(intptr_t)res); return (int64_t)(intptr_t)row; }\n"
    mp = mp + "static const char* myq_field(int64_t row, int64_t i){ if(row==0) return \"\"; char** r=(char**)(intptr_t)row; const char* v=r[i]; if(!v) return \"\"; size_t n=strlen(v); char* o=(char*)GC_MALLOC(n+1); memcpy(o,v,n+1); return o; }\n"
    mp = mp + "static const char* myq_err(int64_t c){ if(c==0) return \"(null)\"; const char* e=mysql_error((MYSQL*)(intptr_t)c); return e?e:\"\"; }\n"
    mp = mp + "static int64_t myq_free(int64_t res){ if(res!=0) mysql_free_result((MYSQL_RES*)(intptr_t)res); return 0; }\n"
    mp = mp + "static int64_t myq_close(int64_t c){ if(c!=0) mysql_close((MYSQL*)(intptr_t)c); return 0; }\n"
    mp = mp + "static const char* myq_escape(int64_t c, const char* s){ if(c==0||!s) return \"\"; size_t n=strlen(s); char* o=(char*)GC_MALLOC(n*2+1); mysql_real_escape_string((MYSQL*)(intptr_t)c, o, s, (unsigned long)n); return o; }\n"
    mp = mp + "#endif\n"
    out = replace(out, pat, mp)
    // Prepared-statement helpers (phase 4 — they take arr_str). All params bind as
    // MYSQL_TYPE_STRING. We deliberately do NOT set MYSQL_BIND.is_null/.error (whose
    // type flipped my_bool→bool across MySQL/MariaDB versions) — a zeroed bind +
    // a generous output buffer keeps it portable. Values are bound, never interpolated.
    mu mpp := "#ifndef _WIN32\n"
    mpp = mpp + "static int64_t myq_exec_params(int64_t c, const char* sql, arr_str params){ if(c==0||!sql) return -1; MYSQL_STMT* st=mysql_stmt_init((MYSQL*)(intptr_t)c); if(!st) return -1; if(mysql_stmt_prepare(st,sql,(unsigned long)strlen(sql))){ mysql_stmt_close(st); return -1; } int n=(int)params.len; MYSQL_BIND* b=(MYSQL_BIND*)GC_MALLOC(sizeof(MYSQL_BIND)*(n>0?n:1)); memset(b,0,sizeof(MYSQL_BIND)*(n>0?n:1)); unsigned long* L=(unsigned long*)GC_MALLOC(sizeof(unsigned long)*(n>0?n:1)); for(int i=0;i<n;i++){ const char* v=params.data[i]?params.data[i]:\"\"; L[i]=(unsigned long)strlen(v); b[i].buffer_type=MYSQL_TYPE_STRING; b[i].buffer=(void*)v; b[i].buffer_length=L[i]; b[i].length=&L[i]; } if(n>0 && mysql_stmt_bind_param(st,b)){ mysql_stmt_close(st); return -1; } if(mysql_stmt_execute(st)){ mysql_stmt_close(st); return -1; } long long aff=(long long)mysql_stmt_affected_rows(st); mysql_stmt_close(st); return (int64_t)aff; }\n"
    mpp = mpp + "static const char* myq_query_one_params(int64_t c, const char* sql, arr_str params){ if(c==0||!sql) return \"\"; MYSQL_STMT* st=mysql_stmt_init((MYSQL*)(intptr_t)c); if(!st) return \"\"; if(mysql_stmt_prepare(st,sql,(unsigned long)strlen(sql))){ mysql_stmt_close(st); return \"\"; } int n=(int)params.len; MYSQL_BIND* b=(MYSQL_BIND*)GC_MALLOC(sizeof(MYSQL_BIND)*(n>0?n:1)); memset(b,0,sizeof(MYSQL_BIND)*(n>0?n:1)); unsigned long* L=(unsigned long*)GC_MALLOC(sizeof(unsigned long)*(n>0?n:1)); for(int i=0;i<n;i++){ const char* v=params.data[i]?params.data[i]:\"\"; L[i]=(unsigned long)strlen(v); b[i].buffer_type=MYSQL_TYPE_STRING; b[i].buffer=(void*)v; b[i].buffer_length=L[i]; b[i].length=&L[i]; } if(n>0 && mysql_stmt_bind_param(st,b)){ mysql_stmt_close(st); return \"\"; } if(mysql_stmt_execute(st)){ mysql_stmt_close(st); return \"\"; } char* buf=(char*)GC_MALLOC(65536); unsigned long olen=0; MYSQL_BIND ob; memset(&ob,0,sizeof(ob)); ob.buffer_type=MYSQL_TYPE_STRING; ob.buffer=buf; ob.buffer_length=65535; ob.length=&olen; if(mysql_stmt_bind_result(st,&ob)){ mysql_stmt_close(st); return \"\"; } const char* outv=\"\"; if(mysql_stmt_fetch(st)==0){ unsigned long m=olen<65535?olen:65535; char* o=(char*)GC_MALLOC(m+1); memcpy(o,buf,m); o[m]=0; outv=o; } mysql_stmt_free_result(st); mysql_stmt_close(st); return outv; }\n"
    mpp = mpp + "#endif\n"
    out = replace(out, ppat, mpp)
    mlib = mlib + " mysqlclient"
  } el {
    out = replace(out, pat, "")
    out = replace(out, ppat, "")
  }
  // SQLite is opt-in exactly like mysql: fill the slot only when a real sq_ call
  // set @uses.sqlite. The compiler never calls sq_, so its self-compile stays
  // sqlite-free and builds with NO libsqlite3.
  spat := "/*@SQ" + "LITE@*/"
  if has(base.evar, "@uses.sqlite") {
    mu sqp := "#ifndef _WIN32\n#include <sqlite3.h>\n"
    sqp = sqp + "static int64_t sq_open(const char* path){ sqlite3* db=0; if(sqlite3_open(path?path:\":memory:\",&db)!=SQLITE_OK){ if(db) sqlite3_close(db); return 0; } return (int64_t)(intptr_t)db; }\n"
    sqp = sqp + "static int64_t sq_close(int64_t c){ if(c!=0) sqlite3_close((sqlite3*)(intptr_t)c); return 0; }\n"
    sqp = sqp + "static const char* sq_err(int64_t c){ if(c==0) return \"(null)\"; const char* e=sqlite3_errmsg((sqlite3*)(intptr_t)c); if(!e) return \"\"; size_t n=strlen(e); char* o=(char*)GC_MALLOC(n+1); memcpy(o,e,n+1); return o; }\n"
    sqp = sqp + "static int64_t sq_exec(int64_t c, const char* sql){ if(c==0||!sql) return -1; return (int64_t)sqlite3_exec((sqlite3*)(intptr_t)c,sql,0,0,0); }\n"
    sqp = sqp + "static int64_t sq_prepare(int64_t c, const char* sql){ if(c==0||!sql) return 0; sqlite3_stmt* st=0; if(sqlite3_prepare_v2((sqlite3*)(intptr_t)c,sql,-1,&st,0)!=SQLITE_OK) return 0; return (int64_t)(intptr_t)st; }\n"
    sqp = sqp + "static int64_t sq_step(int64_t st){ if(st==0) return -1; int rc=sqlite3_step((sqlite3_stmt*)(intptr_t)st); if(rc==SQLITE_ROW) return 1; if(rc==SQLITE_DONE) return 0; return -1; }\n"
    sqp = sqp + "static int64_t sq_ncols(int64_t st){ if(st==0) return 0; return (int64_t)sqlite3_column_count((sqlite3_stmt*)(intptr_t)st); }\n"
    sqp = sqp + "static const char* sq_col(int64_t st, int64_t i){ if(st==0) return \"\"; const unsigned char* v=sqlite3_column_text((sqlite3_stmt*)(intptr_t)st,(int)i); if(!v) return \"\"; size_t n=strlen((const char*)v); char* o=(char*)GC_MALLOC(n+1); memcpy(o,(const char*)v,n+1); return o; }\n"
    sqp = sqp + "static const char* sq_col_name(int64_t st, int64_t i){ if(st==0) return \"\"; const char* v=sqlite3_column_name((sqlite3_stmt*)(intptr_t)st,(int)i); if(!v) return \"\"; size_t n=strlen(v); char* o=(char*)GC_MALLOC(n+1); memcpy(o,v,n+1); return o; }\n"
    sqp = sqp + "static int64_t sq_finalize(int64_t st){ if(st!=0) sqlite3_finalize((sqlite3_stmt*)(intptr_t)st); return 0; }\n"
    sqp = sqp + "static int64_t sq_changes(int64_t c){ if(c==0) return 0; return (int64_t)sqlite3_changes((sqlite3*)(intptr_t)c); }\n"
    sqp = sqp + "static int64_t sq_last_id(int64_t c){ if(c==0) return 0; return (int64_t)sqlite3_last_insert_rowid((sqlite3*)(intptr_t)c); }\n"
    // Parameter binding (1-based index) for prepared statements — the safe path
    // that defeats SQL injection: values never touch the SQL text. SQLITE_TRANSIENT
    // makes sqlite copy the string, so the AiLang str can be GC'd freely.
    sqp = sqp + "static int64_t sq_bind_text(int64_t st, int64_t i, const char* v){ if(st==0) return -1; return (int64_t)sqlite3_bind_text((sqlite3_stmt*)(intptr_t)st,(int)i,v?v:\"\",-1,SQLITE_TRANSIENT); }\n"
    sqp = sqp + "static int64_t sq_bind_int(int64_t st, int64_t i, int64_t v){ if(st==0) return -1; return (int64_t)sqlite3_bind_int64((sqlite3_stmt*)(intptr_t)st,(int)i,(sqlite3_int64)v); }\n"
    sqp = sqp + "static int64_t sq_bind_null(int64_t st, int64_t i){ if(st==0) return -1; return (int64_t)sqlite3_bind_null((sqlite3_stmt*)(intptr_t)st,(int)i); }\n"
    sqp = sqp + "static int64_t sq_reset(int64_t st){ if(st==0) return -1; sqlite3_clear_bindings((sqlite3_stmt*)(intptr_t)st); return (int64_t)sqlite3_reset((sqlite3_stmt*)(intptr_t)st); }\n"
    sqp = sqp + "#endif\n"
    out = replace(out, spat, sqp)
    mlib = mlib + " sqlite3"
  } el {
    out = replace(out, spat, "")
  }
  // ── shared-library exports ──────────────────────────────────────────────────
  // For each root-file top-level `fn` with a C-friendly signature (i64/i32/u32/
  // bool/f64/str/bytes params & return), emit an unmangled wrapper delegating to
  // its `f_<name>` body, so a host program calls it by its plain name; collect a
  // matching header. Aggregate signatures (arrays/maps/structs/…) use AiLang's
  // internal ABI and are skipped with a note. The wrappers reference `f_<name>`
  // functions already emitted above, so appending them here is safe.
  mu libhdr := ""
  if libmode {
    mu need_bytes := false
    // Portable export marker: dllexport on Windows, default visibility elsewhere.
    mu wrap := "#if defined(_WIN32)\n#define AIL_EXPORT __declspec(dllexport)\n#else\n#define AIL_EXPORT __attribute__((visibility(\"default\")))\n#endif\n"
    mu protos := ""
    mu ei := 0
    lp ei < len(funcs) {
      f := funcs[ei]
      if str_in(exports, f.name) && f.name != "main" {
        if cabi_sig_ok(f) {
          if f.ret == "bytes" { need_bytes = true }
          mu plist := ""
          mu alist := ""
          mu pi := 0
          lp pi < len(f.params) {
            if f.ptypes[pi] == "bytes" { need_bytes = true }
            if pi > 0 { plist = plist + ", "; alist = alist + ", " }
            plist = plist + cty(f.ptypes[pi]) + " " + f.params[pi]
            alist = alist + f.params[pi]
            pi += 1
          }
          if len(f.params) == 0 { plist = "void" }
          sig := cty_ret(f.ret) + " " + f.name + "(" + plist + ")"
          mu call := "return f_" + f.name + "(" + alist + ");"
          if len(f.ret) == 0 { call = "f_" + f.name + "(" + alist + ");" }
          // AIL_EXPORT (defined at the top of the wrapper block) marks only these
          // wrappers for export — `__declspec(dllexport)` on Windows, default ELF
          // visibility elsewhere (built -fvisibility=hidden). Internal `f_*` bodies
          // + runtime globals stay private, so the DLL/.so exports just the API.
          wrap = wrap + "AIL_EXPORT " + sig + " { " + call + " }\n"
          protos = protos + sig + ";\n"
        } el {
          println("note: '" + f.name + "' not exported — its signature uses a non-C-ABI type (array/map/struct/etc.)")
        }
      }
      ei += 1
    }
    out = out + "\n/* ── exported C-ABI wrappers ── */\n" + wrap
    libhdr = "#ifndef AILLIB_H\n#define AILLIB_H\n#include <stdint.h>\n"
    if need_bytes { libhdr = libhdr + "typedef struct { int64_t len; const uint8_t* data; } ailang_bytes;\n" }
    libhdr = libhdr + "#ifdef __cplusplus\nextern \"C\" {\n#endif\n" + protos + "#ifdef __cplusplus\n}\n#endif\n#endif\n"
  }
  if len(mlib) > 0 { out = "// @links:" + mlib + "\n" + out }
  if libmode { out = out + "\n//@@AILHDR@@\n" + libhdr }
  out
}

// Read the `// @links:` marker (if any) from the head of the generated C and
// turn its space-separated lib list into clang `-l<lib>` flags. "" when absent.
fn link_flags(cprog:str) -> str {
  pre := "// @links:"
  np := len(pre)
  if len(cprog) < np rt ""
  if substring(cprog, 0, np) != pre rt ""
  mu e := np
  lp e < len(cprog) { if cprog[e] == 10 { br } e += 1 }   // first line ends here
  libs := substring(cprog, np, e)                          // " z m"
  mu out := ""
  mu start := 0 - 1
  mu i := 0
  lp i < len(libs) {
    if libs[i] == 32 {
      if start >= 0 { out = out + " -l" + substring(libs, start, i); start = 0 - 1 }
    } el {
      if start < 0 { start = i }
    }
    i += 1
  }
  if start >= 0 { out = out + " -l" + substring(libs, start, len(libs)) }
  out
}

// Read the `// @csrc:` marker — the .cpp shim paths from `csrc "..."` decls.
// Line-scanned (NOT offset-0 like link_flags) because `// @links:`, when present,
// occupies the first line and pushes `// @csrc:` to the second. Returns [] when
// absent (the common case → main() takes the unchanged single-clang link path).
fn csrc_list(cprog:str) -> [str] {
  pre := "// @csrc:"
  np := len(pre)
  mu out:[str] := []
  mu ls := 0
  mu i := 0
  lp i < len(cprog) {
    if cprog[i] == 10 {
      if (i - ls >= np) && (substring(cprog, ls, ls + np) == pre) {
        seg := substring(cprog, ls + np, i)        // the " path1 path2" tail
        mu start := 0 - 1
        mu j := 0
        lp j < len(seg) {
          if seg[j] == 32 {
            if start >= 0 { out = push(out, substring(seg, start, j)); start = 0 - 1 }
          } el {
            if start < 0 { start = j }
          }
          j += 1
        }
        if start >= 0 { out = push(out, substring(seg, start, len(seg))) }
        rt out
      }
      ls = i + 1
    }
    i += 1
  }
  out
}

// The directory prefix of a path (through the last separator), or "" if none —
// used to resolve `im` paths relative to the importing file. Splits on both '/'
// and '\' so a Windows-style path (e.g. `ailc src\app.ail`, or a tab-completed
// `.\sub\app.ail`) still resolves its sibling imports; otherwise dirname would
// return "" and imports would be looked up against the cwd instead.
fn dirname(path:str) -> str {
  mu last := 0 - 1
  mu i := 0
  lp i < len(path) { if path[i] == 47 || path[i] == 92 { last = i } i += 1 }   // '/' or '\' (Windows)
  if last < 0 rt ""
  substring(path, 0, last + 1)
}

// If `line` is `im "path"` (leading spaces allowed), return the path; else "".
fn import_path(line:str) -> str {
  mu i := 0
  lp i < len(line) { if line[i] != 32 { br } i += 1 }   // skip spaces
  if i + 3 > len(line) rt ""
  if line[i] != 105 rt ""              // 'i'
  if line[i + 1] != 109 rt ""          // 'm'
  if line[i + 2] != 32 rt ""           // ' '
  mu j := i + 3
  lp j < len(line) { if line[j] == 34 { br } j += 1 }   // opening '"'
  if j >= len(line) rt ""
  mu k := j + 1
  lp k < len(line) { if line[k] == 34 { br } k += 1 }   // closing '"'
  if k >= len(line) rt ""
  substring(line, j + 1, k)
}

// True if any line of `src` is an `im "..."` import. Allocation-free (a plain
// char scan, no substring) so the no-import fast path adds zero heap pressure.
fn has_import(src:str) -> bool {
  mu i := 0
  mu atstart := true
  lp i < len(src) {
    c := src[i]
    if c == 10 { atstart = true; i += 1; ct }
    if atstart && c == 32 { i += 1; ct }     // leading spaces stay at line start
    if atstart {
      if c == 105 && i + 2 < len(src) && src[i + 1] == 109 && src[i + 2] == 32 { rt true }
      atstart = false
    }
    i += 1
  }
  false
}

// Inline every `im "path"` by splicing the (recursively import-resolved) source
// of the imported file in its place, so imported decls precede their uses. A
// `seen` set blocks re-imports and cycles. Paths resolve relative to `dir`.
// Fast path: a source with no imports is returned verbatim (no reconstruction),
// so the overwhelmingly common single-file case is byte-for-byte unchanged.
fn is_math_export(nm:str) -> bool {
  if nm == "sqrt" || nm == "pow" || nm == "sin" || nm == "cos" || nm == "tan" rt true
  if nm == "log" || nm == "log2" || nm == "log10" || nm == "exp" rt true
  if nm == "floor" || nm == "ceil" || nm == "rand" || nm == "srand" rt true
  if nm == "min" || nm == "max" || nm == "ipow" || nm == "gcd" rt true
  false
}
// Auto-import: prepend `im "std/…"` for std exports referenced-but-not-defined
// (mirrors ailangc's driver, scaled to math+sock — the only modules the corpus
// auto-imports). Token-based, so names inside strings/comments don't trigger
// (main.ail mentions `max`/`sqrt` only in C-string literals → no IDENT match →
// returns "" → fixpoint-safe).
fn auto_imports(src:str) -> str {
  toks := lex(src)
  mu defined:{str:str} := {}
  mu i := 0
  lp i + 1 < len(toks) {
    if toks[i].kind == TK_IDENT() && toks[i].text == "fn" && toks[i + 1].kind == TK_IDENT() { defined[toks[i + 1].text] = "1" }
    i += 1
  }
  mu need_math := false
  mu need_sock := false
  i = 0
  lp i < len(toks) {
    if toks[i].kind == TK_IDENT() && has(defined, toks[i].text) == false {
      nm := toks[i].text
      if is_math_export(nm) { need_math = true }
      if nm == "env_int" { need_sock = true }
    }
    i += 1
  }
  mu out := ""
  if need_math { out = out + "im \"std/math.ail\"\n" }
  if need_sock { out = out + "im \"std/sock.ail\"\n" }
  out
}
// ----- module namespacing: `im "path" as m` + qualified `m.fn()` ---------------
// The alias in `im "path" as NAME` (else ""). Mirrors import_path's quote scan, then
// looks for `as <ident>` after the closing quote.
fn import_alias(line:str) -> str {
  mu i := 0
  lp i < len(line) { if line[i] != 32 { br } i += 1 }
  if i + 3 > len(line) rt ""
  if line[i] != 105 rt ""                 // 'i'
  if line[i + 1] != 109 rt ""             // 'm'
  mu j := i + 3
  lp j < len(line) { if line[j] == 34 { br } j += 1 }   // opening '"'
  mu k := j + 1
  lp k < len(line) { if line[k] == 34 { br } k += 1 }   // closing '"'
  if k >= len(line) rt ""
  mu p := k + 1
  lp p < len(line) { if line[p] != 32 { br } p += 1 }   // spaces
  if p + 2 > len(line) rt ""
  if line[p] != 97 rt ""                  // 'a'
  if line[p + 1] != 115 rt ""             // 's'
  p = p + 2
  lp p < len(line) { if line[p] != 32 { br } p += 1 }
  mu q := p
  lp q < len(line) {
    c := line[q]
    if (c >= 97 && c <= 122) || (c >= 65 && c <= 90) || (c >= 48 && c <= 57) || c == 95 { q += 1 } el { br }
  }
  substring(line, p, q)
}
fn name_in(names:[str], n:str) -> bool {
  mu i := 0
  lp i < len(names) { if names[i] == n rt true   i += 1 }
  false
}
// The top-level (non-extern) function names defined in `body`: `fn NAME`, but not
// `ex fn NAME` (renaming an extern would break its C symbol).
fn module_fn_names(body:str) -> [str] {
  toks := lex(body)
  mu out:[str] := []
  mu i := 0
  lp i + 1 < len(toks) {
    if toks[i].kind == TK_IDENT() && toks[i].text == "fn" && toks[i + 1].kind == TK_IDENT() {
      if i == 0 || toks[i - 1].text != "ex" { out = push(out, toks[i + 1].text) }
    }
    i += 1
  }
  out
}
// Prefix every IDENT token in `src` whose text is in `names` with `pfx` — a
// position-based edit (insert before the token start), so strings/comments/spacing
// are preserved verbatim. Renames a module's own `fn` defs + their internal calls.
fn prefix_idents(src:str, names:[str], pfx:str) -> str {
  toks := lex(src)
  mu out := ""
  mu cur := 0
  mu i := 0
  lp i < len(toks) {
    if toks[i].kind == TK_IDENT() && name_in(names, toks[i].text) {
      p := toks[i].pos
      if p >= cur { out = out + substring(src, cur, p) + pfx; cur = p }
    }
    i += 1
  }
  out + substring(src, cur, len(src))
}
// Rewrite qualified accesses `alias.name` → `alias_name` for each known alias.
// Fast path: no aliases → returns `src` byte-identical (so the no-`as` self-compile
// is unchanged → fixpoint-safe).
fn rewrite_qualified(src:str, aliases:[str]) -> str {
  if len(aliases) == 0 rt src
  toks := lex(src)
  mu out := ""
  mu cur := 0
  mu i := 0
  lp i < len(toks) {
    if i + 2 < len(toks) && toks[i].kind == TK_IDENT() && name_in(aliases, toks[i].text) && toks[i + 1].kind == TK_DOT() && toks[i + 2].kind == TK_IDENT() {
      mp := toks[i].pos
      nend := toks[i + 2].pos + len(toks[i + 2].text)
      if mp >= cur { out = out + substring(src, cur, mp) + toks[i].text + "_" + toks[i + 2].text; cur = nend }
      i += 3
      ct
    }
    i += 1
  }
  out + substring(src, cur, len(src))
}
fn resolve_imports(src:str, dir:str, seen:{str:str}) -> str {
  if has_import(src) == false rt src
  mu out := ""
  mu aliases:[str] := []                  // `im "…" as m` aliases declared in THIS source
  mu i := 0
  mu lstart := 0
  lp i <= len(src) {
    if i == len(src) || src[i] == 10 {     // end of a line
      line := substring(src, lstart, i)
      imp := import_path(line)
      if len(imp) > 0 {
        alias := import_alias(line)
        if len(alias) > 0 { aliases = push(aliases, alias) }
        full := dir + imp
        if has(seen, full) == false {
          seen[full] = "1"
          mu body := read_file(full)
          mu bdir := dirname(full)
          mu rfull := full                     // the path that actually resolves (dedup key)
          if len(body) == 0 {
            // Not found next to the source — fall back to the global library dir
            // ($AILANG_STD, set by the installer) so `im "std/…"` works anywhere,
            // not just when std/ happens to sit beside the source file.
            root := get_env("AILANG_STD")
            if len(root) > 0 {
              gfull := root + "/" + imp
              gbody := read_file(gfull)
              if len(gbody) > 0 { body = gbody; bdir = dirname(gfull); rfull = gfull }
            }
          }
          if len(body) == 0 {
            // Still nothing — look beside the compiler executable itself. The
            // std/ library ships next to ailc, so `im "std/…"` resolves even when
            // AILANG_STD is unset (e.g. a terminal opened before the installer ran).
            ed := exe_dir()
            if len(ed) > 0 {
              efull := ed + "/" + imp
              ebody := read_file(efull)
              if len(ebody) > 0 { body = ebody; bdir = dirname(efull); rfull = efull }
            }
          }
          if len(body) == 0 {
            // Found nowhere — fail loudly instead of dropping the import (which
            // left the importer's calls undefined and surfaced as a cryptic
            // clang `f_<fn> undeclared`). main.ail's own imports always resolve
            // via path (1), so this is dead code for the self-compile → fixpoint-safe.
            println("error: cannot resolve import \"" + imp + "\" — not found beside the source, in AILANG_STD, or next to ailc")
            exit(1)
          }
          // Dedup on the RESOLVED path too: the same file reached from different
          // importer dirs (e.g. auto_imports injecting "std/sock.ail" at the root
          // while std/http_client.ail imports it via $AILANG_STD) must splice once.
          // (full itself is already marked above; only a DIFFERENT resolved path
          // needs the extra check, else every importer-relative hit would skip.)
          mu fresh := true
          if rfull != full {
            if has(seen, rfull) { fresh = false } el { seen[rfull] = "1" }
          }
          if fresh {
            mu rb := resolve_imports(body, bdir, seen)
            if len(alias) > 0 { rb = prefix_idents(rb, module_fn_names(body), alias + "_") }   // namespace: rename the module's own fns
            out = out + rb + "\n"
          }
        }
      } el {
        out = out + line + "\n"
      }
      lstart = i + 1
    }
    i += 1
  }
  rewrite_qualified(out, aliases)        // `m.fn` → `m_fn`; no aliases → byte-identical (fixpoint-safe)
}

// Compile `input` to a native binary at `outbin` (clang appends ".exe" on
// Windows). When link==false this is `check` mode — run lex/parse/type-check
// only (compile_to_c reports + exit(1)s on any error), write no C, invoke no
// clang. Returns 0 on success, 1 on a read or clang failure. The single shared
// build path behind the build / run / check / test CLI modes in main.ail; the
// clang command strings are byte-identical to the former inline ones.
fn build_one(input:str, outbin:str, keepc:bool, link:bool, asan:bool) -> i64 {
  mu src := read_file(input)
  if len(src) == 0 { println("error: cannot read input file (missing or empty): " + input); rt 1 }
  src = auto_imports(src) + src
  if has_import(src) {
    mu seen:{str:str} := {}
    src = resolve_imports(src, dirname(input), seen)
  }
  mu noexp:[str] := []
  cprog := compile_to_c(src, dirname(input), false, noexp)
  if link == false { rt 0 }
  cpath := outbin + ".c"
  write_file(cpath, cprog)
  win := get_env("OS") == "Windows_NT"
  shims0 := csrc_list(cprog)
  mu shims:[str] := []
  mu ri := 0
  lp ri < len(shims0) { shims = push(shims, dirname(input) + shims0[ri]); ri += 1 }
  mu rc := 0
  if win {
    if len(shims) == 0 {
      cmd := "clang -O2 -DGC_NOT_DLL \"" + cpath + "\"" + link_flags(cprog) + " -static -lgc -lm -o \"" + outbin + ".exe\""
      rc = system(cmd)
    } el {
      println("error: C++ interop (csrc) is not supported on Windows in this release; build on macOS/Linux")
      rt 1
    }
  } el {
    extra := unix_link_extra(cprog)
    mu asanflag := ""
    if asan { asanflag = " -fsanitize=address -g" }
    if len(shims) == 0 {
      cmd := "clang -O2" + asanflag + " " + cpath + extra + " -o " + outbin
      rc = system(cmd)
    } el {
      mu shimline := ""
      mu si := 0
      lp si < len(shims) { shimline = shimline + " " + shims[si]; si += 1 }
      cmd := "clang++ -O2" + asanflag + " -x c " + cpath + " -x c++" + shimline + extra + " -o " + outbin
      rc = system(cmd)
    }
  }
  if rc != 0 { println("clang failed"); rt 1 }
  if keepc == false {
    if win { system("del /f /q \"" + cpath + "\"") } el { system("rm -f " + cpath) }
    mu ci2 := 0
    lp ci2 < len(shims) {
      if has_sub(shims[ci2], "__ailinline_") { system("rm -f " + shims[ci2]) }
      ci2 += 1
    }
  }
  0
}

// The POSIX clang tail: bdw-gc plus usage-gated openssl / libpq / pthread /
// mysqlclient / sqlite3 discovery, then the `// @links:` flags and -lm. Shared
// by build_one (executables) and build_lib (shared libraries) so both link the
// same optional libs. (Windows uses its own -static tail; this is #ifndef there.)
fn unix_link_extra(cprog:str) -> str {
  mu extra := " $(pkg-config --cflags --libs bdw-gc 2>/dev/null || echo -lgc)"
  if has_sub(cprog, "SSL_") || has_sub(cprog, "SHA1(") || has_sub(cprog, "HMAC(") { extra = extra + " $(pkg-config --cflags --libs openssl 2>/dev/null || echo -I$(brew --prefix openssl@3)/include -L$(brew --prefix openssl@3)/lib -lssl -lcrypto)" }
  if has_sub(cprog, "PQconnectdb") || has_sub(cprog, "PQexec") { extra = extra + " $(pkg-config --cflags --libs libpq 2>/dev/null || echo -I$(brew --prefix libpq)/include -L$(brew --prefix libpq)/lib -lpq)" }
  if has_sub(cprog, "pthread_") { extra = extra + " -lpthread" }
  mu lf := link_flags(cprog)
  if has_sub(lf, "lmysqlclient") { extra = extra + " $(pkg-config --cflags --libs mysqlclient 2>/dev/null || pkg-config --cflags --libs libmariadb 2>/dev/null || echo -I$(brew --prefix mysql-client)/include -L$(brew --prefix mysql-client)/lib)" }
  if has_sub(lf, "lsqlite3") { extra = extra + " $(pkg-config --cflags --libs sqlite3 2>/dev/null || echo)" }
  extra = extra + lf + " -lm"
  extra
}

// Is `s` in `xs`? (small linear membership over the export-name list)
fn str_in(xs:[str], s:str) -> bool {
  mu i := 0
  lp i < len(xs) { if xs[i] == s rt true   i += 1 }
  false
}

// A type usable across a plain C ABI from a host program: the scalars + str +
// bytes, each of which `cty` lowers to a self-describing C type (int64_t/double/
// const char*/ailang_bytes). Aggregates (arrays/maps/structs/tuples/results/
// closures) use AiLang's internal runtime layout and are NOT exportable.
fn is_cabi_type(t:str) -> bool {
  t == "i64" || t == "i32" || t == "u32" || t == "bool" || t == "f64" || t == "str" || t == "bytes"
}
// True when every param type and the return type (empty == void) are C-ABI-safe.
fn cabi_sig_ok(f:Func) -> bool {
  if len(f.ret) > 0 && is_cabi_type(f.ret) == false { rt false }
  mu i := 0
  lp i < len(f.params) {
    if is_cabi_type(f.ptypes[i]) == false { rt false }
    i += 1
  }
  true
}

// The header path for a library output: `libfoo.dylib`/`.so`/`.dll` → `libfoo.h`
// (else just append `.h`).
fn lib_header_path(outbin:str) -> str {
  n := len(outbin)
  if n >= 6 && substring(outbin, n - 6, n) == ".dylib" { rt substring(outbin, 0, n - 6) + ".h" }
  if n >= 3 && substring(outbin, n - 3, n) == ".so" { rt substring(outbin, 0, n - 3) + ".h" }
  if n >= 4 && substring(outbin, n - 4, n) == ".dll" { rt substring(outbin, 0, n - 4) + ".h" }
  outbin + ".h"
}

// Compile `input` to a shared library at `outbin` (.dylib on macOS, .so on
// Linux; POSIX-only — callers guard Windows out) plus a C header next to it. The
// exported surface is the root file's own top-level `fn`s with C-ABI signatures.
// Returns 0 on success, 1 on a read or clang failure.
fn build_lib(input:str, outbin:str, keepc:bool) -> i64 {
  mu rawsrc := read_file(input)
  if len(rawsrc) == 0 { println("error: cannot read input file (missing or empty): " + input); rt 1 }
  exports := module_fn_names(rawsrc)              // the root file's own top-level fn names
  mu src := auto_imports(rawsrc) + rawsrc
  if has_import(src) {
    mu seen:{str:str} := {}
    src = resolve_imports(src, dirname(input), seen)
  }
  full := compile_to_c(src, dirname(input), true, exports)
  // The header content is appended after a sentinel line; split it back out.
  sen := "\n//@@AILHDR@@\n"
  mu cprog := full
  mu hdr := ""
  sp := index_of(full, sen)
  if sp >= 0 {
    cprog = substring(full, 0, sp)
    hdr = substring(full, sp + len(sen), len(full))
  }
  cpath := outbin + ".c"
  hpath := lib_header_path(outbin)
  write_file(cpath, cprog)
  write_file(hpath, hdr)
  win := get_env("OS") == "Windows_NT"
  mu rc := 0
  if win {
    // Windows DLL: only the __declspec(dllexport) wrappers are exported (adding any
    // dllexport disables MinGW auto-export). Boehm GC is linked statically into the
    // DLL (-DGC_NOT_DLL, matching the -static exe path); GC_INIT runs in the load
    // constructor. --out-implib emits a `<dll>.a` import library for the linker.
    cmd := "clang -O2 -shared -DGC_NOT_DLL \"" + cpath + "\"" + link_flags(cprog) + " -lgc -lm -o \"" + outbin + "\" -Wl,--out-implib,\"" + outbin + ".a\""
    rc = system(cmd)
  } el {
    extra := unix_link_extra(cprog)
    cmd := "clang -O2 -shared -fPIC -fvisibility=hidden " + cpath + extra + " -o " + outbin
    rc = system(cmd)
  }
  if rc != 0 { println("clang failed"); rt 1 }
  if keepc == false {
    if win { system("del /f /q \"" + cpath + "\"") } el { system("rm -f " + cpath) }
  }
  0
}

