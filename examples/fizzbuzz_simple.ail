// FizzBuzz without `match`.
// Demonstrates: nested if/el, range loop, modulo, logical &&, println polymorphism.

lp i in 1..16 {
  if i % 3 == 0 && i % 5 == 0 println("FizzBuzz")
  el if i % 3 == 0           println("Fizz")
  el if i % 5 == 0           println("Buzz")
  el                          println(i)
}
