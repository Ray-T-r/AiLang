// Struct decl + literal + field access.

st Point { x: i64; y: i64 }
st Person { name: str; age: i64 }

fn dist_sq(p:Point) p.x * p.x + p.y * p.y

p := Point { x: 3, y: 4 }
println(p.x)
println(p.y)
println(dist_sq(p))         // 25

alice := Person { name: "alice", age: 30 }
println(alice.name)
println(alice.age)
