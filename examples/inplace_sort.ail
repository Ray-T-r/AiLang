fn swap(arr:[i64], i:i64, j:i64) {
  t := arr[i]
  arr[i] = arr[j]
  arr[j] = t
}

fn quicksort(arr:[i64], lo:i64, hi:i64) {
  if lo < hi {
    pivot := arr[hi]
    mu i := lo - 1
    lp j in lo..hi {
      if arr[j] < pivot {
        i += 1
        swap(arr, i, j)
      }
    }
    swap(arr, i + 1, hi)
    p := i + 1
    quicksort(arr, lo, p - 1)
    quicksort(arr, p + 1, hi)
  }
}

mu arr := [9, 3, 7, 1, 8, 2, 6, 5, 4, 0]
quicksort(arr, 0, len(arr) - 1)
println(arr)
