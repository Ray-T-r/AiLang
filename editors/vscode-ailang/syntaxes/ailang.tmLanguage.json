{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "AiLang",
  "scopeName": "source.ailang",
  "fileTypes": ["ail"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#fn-declaration" },
    { "include": "#extern-declaration" },
    { "include": "#struct-declaration" },
    { "include": "#enum-declaration" },
    { "include": "#import" },
    { "include": "#cinclude" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#type-name" },
    { "include": "#wildcard" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.ailang",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.ailang",
          "match": "//[^\\n]*"
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.ailang",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "meta.interpolation.ailang",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.ailang" } },
          "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.ailang" } },
          "patterns": [ { "include": "$self" } ]
        },
        {
          "name": "constant.character.escape.ailang",
          "match": "\\\\."
        }
      ]
    },

    "chars": {
      "name": "string.quoted.single.ailang",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.ailang",
          "match": "\\\\."
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.ailang",
          "match": "\\b[0-9]+\\.[0-9]+(?:_f(?:32|64))?\\b"
        },
        {
          "name": "constant.numeric.integer.ailang",
          "match": "\\b[0-9]+(?:_[iu](?:8|16|32|64))?\\b"
        }
      ]
    },

    "fn-declaration": {
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.function.ailang keyword.declaration.function.ailang" },
        "2": { "name": "entity.name.function.ailang" }
      }
    },

    "extern-declaration": {
      "match": "\\b(ex)\\b(?:\\s+(\"[^\"]*\"))?\\s+(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.other.extern.ailang" },
        "2": { "name": "string.quoted.double.ailang" },
        "3": { "name": "storage.type.function.ailang" },
        "4": { "name": "entity.name.function.ailang" }
      }
    },

    "struct-declaration": {
      "match": "\\b(st)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.struct.ailang storage.type.struct.ailang" },
        "2": { "name": "entity.name.type.struct.ailang" }
      }
    },

    "enum-declaration": {
      "match": "\\b(en)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.enum.ailang storage.type.enum.ailang" },
        "2": { "name": "entity.name.type.enum.ailang" }
      }
    },

    "import": {
      "match": "\\b(im)\\b(?:\\s+(\"[^\"]*\"))?(?:\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*))?",
      "captures": {
        "1": { "name": "keyword.control.import.ailang" },
        "2": { "name": "string.quoted.double.ailang" },
        "3": { "name": "keyword.control.import.as.ailang" },
        "4": { "name": "entity.name.namespace.ailang" }
      }
    },

    "cinclude": {
      "match": "\\b(cinc)\\b(?:\\s+(\"[^\"]*\"))?",
      "captures": {
        "1": { "name": "keyword.control.import.ailang" },
        "2": { "name": "string.quoted.double.ailang" }
      }
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ailang",
          "match": "\\b(if|el|lp|rt|mt|br|ct|in)\\b"
        },
        {
          "name": "keyword.other.ailang",
          "match": "\\b(fn|st|en|tr|im|ex|mu|as|cinc)\\b"
        }
      ]
    },

    "constants": {
      "name": "constant.language.ailang",
      "match": "\\b(true|false|nil)\\b"
    },

    "types": {
      "name": "storage.type.primitive.ailang",
      "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|str|bytes)\\b"
    },

    "builtins": {
      "name": "support.function.builtin.ailang",
      "match": "\\b(print|println|read_file|write_file|read_line|args|exit|get_env|int_to_str|str_to_int|float_to_str|str_to_float|str_to_bool|to_str|format|contains|starts_with|ends_with|index_of|to_upper|to_lower|trim|substring|replace|split|repeat|pad_left|pad_right|chr|ord|len|has|push|pop|sort|reverse|slice|join|keys|values|map|filter|reduce|regex_match|regex_find|abs_i64|abs_f64|sign|clamp|ok|err_i64|err_str|err_bool|err_f64|unwrap|is_ok|is_err|err_msg|str_to_bytes|bytes_to_str|bytes_at|bytes_slice|tcp_listen|tcp_accept|tcp_connect|sock_send|sock_send_str|sock_recv|sock_close|now_ms|now_us|mono_ms|time_iso|sleep_ms|sqrt|pow|sin|cos|tan|log|log2|log10|exp|floor|ceil|min|max|ipow|gcd|abs|rand|srand|parse_int|eq|strcmp|atoi)\\b(?=\\s*\\()"
    },

    "type-name": {
      "name": "entity.name.type.ailang",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    },

    "wildcard": {
      "name": "variable.language.wildcard.ailang",
      "match": "(?<![a-zA-Z0-9_])_(?![a-zA-Z0-9_])"
    },

    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.ailang" }
      }
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.range.ailang",
          "match": "\\.{3}|\\.\\.=|\\.\\."
        },
        {
          "name": "keyword.operator.pipe.ailang",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.ailang",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.assignment.compound.ailang",
          "match": ":=|\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.coalesce.ailang",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.concat.ailang",
          "match": "\\+\\+"
        },
        {
          "name": "keyword.operator.bitwise.shift.ailang",
          "match": "<<|>>"
        },
        {
          "name": "keyword.operator.comparison.ailang",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.ailang",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.ailang",
          "match": "&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.assignment.ailang",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.ailang",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.other.ailang",
          "match": "\\?|:"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.ailang",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.ailang",
          "match": ","
        },
        {
          "name": "punctuation.accessor.dot.ailang",
          "match": "\\."
        },
        {
          "name": "punctuation.section.brackets.ailang",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.parens.ailang",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.braces.ailang",
          "match": "[{}]"
        }
      ]
    }
  }
}
