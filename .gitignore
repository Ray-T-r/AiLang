# ---- Rust / build ----
/target
**/*.rs.bk
*.pdb
# Cargo.lock is committed — this is a binary crate (`ailangc`), so locking
# dependency versions for contributors and CI is the right default.

# ---- Local-only (not shared via git) ----
CLAUDE.md

# ---- Editor / OS junk ----
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# ---- Generic build output ----
*.o
*.ll
*.bc
/build
/dist

# ---- Cargo registry mirror ----
# Keep .cargo/config.toml tracked — it holds the China mirror config.

# ---- ailangc-generated artifacts (next to .ail sources) ----
# Whitelist style: ignore everything in the dir, re-include the sources
# we want tracked. New generated files get ignored automatically.

# examples/: only .ail sources + the std/ subdir
/examples/*
!/examples/*.ail
!/examples/std/

# std/ and examples/std/: only .ail sources (codegen artifacts from the
# VS Code diagnostics provider — or from `ailangc compile` on a library
# file — would otherwise pile up here).
/std/*
!/std/*.ail
/examples/std/*
!/examples/std/*.ail

# bench/ailang_v2/ and bench/perf/ailang/: only .ail sources
/bench/ailang_v2/*
!/bench/ailang_v2/*.ail
/bench/perf/ailang/*
!/bench/perf/ailang/*.ail

# bench/perf/{c,go,rust,java}/: keep hand-written sources, drop binaries / .class
/bench/perf/c/*
!/bench/perf/c/*.c
/bench/perf/go/*
!/bench/perf/go/*.go
/bench/perf/rust/*
!/bench/perf/rust/*.rs
/bench/perf/java/*
!/bench/perf/java/*.java

# selfhost bootstrap build artifacts (binaries + generated C land next to source)
/selfhost/lexer
/selfhost/parser
/selfhost/main
/selfhost/*.c
/examples-selfhost/*
!/examples-selfhost/*.ail
