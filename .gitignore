# ---- Local-only (not shared via git) ----
CLAUDE.md
.vscode

# ---- Editor / OS junk ----
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# ---- Generic build output ----
/target
*.o
*.ll
*.bc

# release staging — built by scripts/package-release.sh, uploaded to GitHub
# Releases, never committed
/dist

# ---- compiler-generated artifacts (next to .ail sources) ----
# Whitelist style: ignore everything in the dir, re-include the sources/fixtures
# we track. New generated files (binaries, .c) get ignored automatically.

# std/: only the .ail stdlib modules
/std/*
!/std/*.ail

# examples-selfhost/: .ail sources + the expected/ output fixtures, not binaries
/examples-selfhost/*
!/examples-selfhost/*.ail
!/examples-selfhost/expected/
!/examples-selfhost/expected/*
# the imports sample's dependency lives in a subdir — re-include it too, or a
# fresh clone can't compile imports.ail (verify.sh would fail on a clean checkout)
!/examples-selfhost/lib/
!/examples-selfhost/lib/*.ail
# the cppinterop sample ships a C++ shim (csrc "shim.cpp"); re-include shim
# sources/headers so a fresh clone can compile it (else verify.sh fails on CI)
!/examples-selfhost/*.cpp
!/examples-selfhost/*.h
# stdin fixtures (verify.sh feeds <name>.in to the matching sample); re-include
# so the stdin samples are reproducible on a clean checkout / CI
!/examples-selfhost/*.in

# selfhost/ bootstrap build outputs are covered by selfhost/.gitignore

# ---- root scratch (not part of the compiler) ----
/test
/test.ail
/selfhost/bar1.sh
/*.c
/*.ail.c
